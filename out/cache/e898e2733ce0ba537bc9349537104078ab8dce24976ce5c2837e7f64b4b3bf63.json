{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_core_src_shell","nodes":[{"id":"packages_core_src_shell","label":"shell.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L1"}]},{"id":"packages_core_src_shell_killtree","label":"killTree()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L31-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L31"}],"snippet":"export async function killTree(proc: ChildProcess, opts?: { exited?: () => boolean }): Promise<void> {\n  const pid = proc.pid\n  if (!pid || opts?.exited?.()) return\n\n  if (process.platform === \"win32\") {\n    await new Promise<void>((resolve) => {\n      const killer = spawn(\"taskkill\", [\"/pid\", String(pid), \"/f\", \"/t\"], {\n        stdio: \"ignore\",\n        windowsHide: true,\n      })\n      killer.once(\"exit\", () => resolve())\n      killer.once(\"error\", () => resolve())\n    })\n    return\n  }\n\n  try {\n    process.kill(-pid, \"SIGTERM\")\n    await sleep(SIGKILL_TIMEOUT_MS)\n    if (!opts?.exited?.()) {\n      process.kill(-pid, \"SIGKILL\")\n    }\n  } catch {\n    proc.kill(\"SIGTERM\")\n    await sleep(SIGKILL_TIMEOUT_MS)"},{"id":"packages_core_src_shell_stat","label":"stat()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L62-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L62"}],"snippet":"function stat(file: string) {\n  return statSync(file, { throwIfNoEntry: false }) ?? undefined\n}"},{"id":"packages_core_src_shell_full","label":"full()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L66-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L66"}],"snippet":"function full(file: string) {\n  if (process.platform !== \"win32\") return file\n  const shell = FSUtil.windowsPath(file)\n  if (path.win32.dirname(shell) !== \".\") {\n    if (shell.startsWith(\"/\") && name(shell) === \"bash\") return gitbash() || shell\n    return shell\n  }\n  if (name(shell) === \"bash\") return gitbash() || which(shell) || shell\n  return which(shell) || shell\n}"},{"id":"packages_core_src_shell_meta","label":"meta()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L77-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L77"}],"snippet":"function meta(file: string) {\n  return META[name(file)]\n}"},{"id":"packages_core_src_shell_ok","label":"ok()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L81-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L81"}],"snippet":"function ok(file: string) {\n  return meta(file)?.deny !== true\n}"},{"id":"packages_core_src_shell_rooted","label":"rooted()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L85-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L85"}],"snippet":"function rooted(file: string) {\n  return path.isAbsolute(FSUtil.windowsPath(file))\n}"},{"id":"packages_core_src_shell_resolve","label":"resolve()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L89-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L89"}],"snippet":"function resolve(file: string) {\n  const shell = full(file)\n  if (rooted(shell)) {\n    if (stat(shell)?.isFile()) return shell\n    return\n  }\n  return which(shell) ?? undefined\n}"},{"id":"packages_core_src_shell_win","label":"win()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L98-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L98"}],"snippet":"function win() {\n  return Array.from(\n    new Set(\n      [which(\"pwsh\"), which(\"powershell\"), gitbash(), process.env.COMSPEC || \"cmd.exe\"]\n        .filter((item): item is string => Boolean(item))\n        .map(full),\n    ),\n  )\n}"},{"id":"packages_core_src_shell_unix","label":"unix()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L108-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L108"}],"snippet":"async function unix() {\n  const text = await readFile(\"/etc/shells\", \"utf8\").catch(() => \"\")\n  if (text) return Array.from(new Set(text.split(\"\\n\").filter((line) => line.trim() && !line.startsWith(\"#\"))))\n  return [\"/bin/bash\", \"/bin/zsh\", \"/bin/sh\"]\n}"},{"id":"packages_core_src_shell_select","label":"select()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L114-L121","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L114"}],"snippet":"function select(file: string | undefined, opts?: { acceptable?: boolean }) {\n  if (file && (!opts?.acceptable || ok(file))) {\n    const shell = resolve(file)\n    if (shell) return shell\n  }\n  if (process.platform === \"win32\") return win()[0]\n  return fallback()\n}"},{"id":"packages_core_src_shell_gitbash","label":"gitbash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L123-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L123"}],"snippet":"export function gitbash() {\n  if (process.platform !== \"win32\") return\n  if (Flag.OPENCODE_GIT_BASH_PATH) return Flag.OPENCODE_GIT_BASH_PATH\n  const git = which(\"git\")\n  if (!git) return\n  const file = path.join(git, \"..\", \"..\", \"bin\", \"bash.exe\")\n  if (stat(file)?.size) return file\n}"},{"id":"packages_core_src_shell_fallback","label":"fallback()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L132-L137","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L132"}],"snippet":"function fallback() {\n  if (process.platform === \"darwin\") return \"/bin/zsh\"\n  const bash = which(\"bash\")\n  if (bash) return bash\n  return \"/bin/sh\"\n}"},{"id":"packages_core_src_shell_name","label":"name()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L139-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L139"}],"snippet":"export function name(file: string) {\n  if (process.platform === \"win32\") return path.win32.parse(FSUtil.windowsPath(file)).name.toLowerCase()\n  return path.basename(file).toLowerCase()\n}"},{"id":"packages_core_src_shell_login","label":"login()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L144-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L144"}],"snippet":"export function login(file: string) {\n  return meta(file)?.login === true\n}"},{"id":"packages_core_src_shell_posix","label":"posix()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L148-L150","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L148"}],"snippet":"export function posix(file: string) {\n  return meta(file)?.posix === true\n}"},{"id":"packages_core_src_shell_ps","label":"ps()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L152-L154","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L152"}],"snippet":"export function ps(file: string) {\n  return meta(file)?.ps === true\n}"},{"id":"packages_core_src_shell_info","label":"info()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L156-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L156"}],"snippet":"function info(file: string): Item {\n  const item = full(file)\n  const n = name(item)\n  return {\n    path: item,\n    name: resolve(n) ? n : item,\n    acceptable: ok(item),\n  }\n}"},{"id":"packages_core_src_shell_args","label":"args()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L166-L200","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L166"}],"snippet":"export function args(file: string, command: string, cwd: string) {\n  const n = name(file)\n  if (n === \"nu\" || n === \"fish\") return [\"-c\", command]\n  if (n === \"zsh\") {\n    return [\n      \"-l\",\n      \"-c\",\n      `\n        [[ -f ~/.zshenv ]] && source ~/.zshenv >/dev/null 2>&1 || true\n        [[ -f \"\\${ZDOTDIR:-$HOME}/.zshrc\" ]] && source \"\\${ZDOTDIR:-$HOME}/.zshrc\" >/dev/null 2>&1 || true\n        cd -- \"$1\"\n        eval ${JSON.stringify(command)}\n      `,\n      \"rimuru-ai\",\n      cwd,\n    ]\n  }\n  if (n === \"bash\") {\n    return [\n      \"-l\",\n      \"-c\",\n      `\n        shopt -s expand_aliases\n        [[ -f ~/.bashrc ]] && source ~/.bashrc >/dev/null 2>&1 || true\n        cd -- \"$1\""},{"id":"packages_core_src_shell_preferred","label":"preferred()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L205-L209","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L205"}],"snippet":"export function preferred(configShell?: string) {\n  if (configShell) return select(configShell)\n  defaultPreferred ??= select(process.env.SHELL)\n  return defaultPreferred\n}"},{"id":"packages_core_src_shell_acceptable","label":"acceptable()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L214-L218","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L214"}],"snippet":"export function acceptable(configShell?: string) {\n  if (configShell) return select(configShell, { acceptable: true })\n  defaultAcceptable ??= select(process.env.SHELL, { acceptable: true })\n  return defaultAcceptable\n}"},{"id":"packages_core_src_shell_list","label":"list()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L223-L226","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/shell.ts","source_location":"L223"}],"snippet":"export async function list(): Promise<Item[]> {\n  const shells = process.platform === \"win32\" ? win() : await unix()\n  return shells.filter((s) => resolve(s)).map(info)\n}"}],"edges":[{"source":"packages_core_src_shell","target":"shell","relation":"imports_from","confidence"