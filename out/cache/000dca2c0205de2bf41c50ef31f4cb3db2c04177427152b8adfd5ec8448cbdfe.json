{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_enterprise_src_core_storage","nodes":[{"id":"packages_enterprise_src_core_storage","label":"storage.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L1"}]},{"id":"packages_enterprise_src_core_storage_adapter","label":"Adapter","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L5-L10","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L5"}],"snippet":"export interface Adapter {\n    read(path: string): Promise<string | undefined>\n    write(path: string, value: string): Promise<void>\n    remove(path: string): Promise<void>\n    list(options?: { prefix?: string; limit?: number; after?: string; before?: string }): Promise<string[]>\n  }"},{"id":"packages_enterprise_src_core_storage_createadapter","label":"createAdapter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L12-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L12"}],"snippet":"function createAdapter(client: AwsClient, endpoint: string, bucket: string): Adapter {\n    const base = `${endpoint}/${bucket}`\n    return {\n      async read(path: string): Promise<string | undefined> {\n        const response = await client.fetch(`${base}/${path}`)\n        if (response.status === 404) return undefined\n        if (!response.ok) throw new Error(`Failed to read ${path}: ${response.status}`)\n        return response.text()\n      },\n\n      async write(path: string, value: string): Promise<void> {\n        const response = await client.fetch(`${base}/${path}`, {\n          method: \"PUT\",\n          body: value,\n          headers: {\n            \"Content-Type\": \"application/json\",\n          },\n        })\n        if (!response.ok) throw new Error(`Failed to write ${path}: ${response.status}`)\n      },\n\n      async remove(path: string): Promise<void> {\n        const response = await client.fetch(`${base}/${path}`, {\n          method: \"DELETE\",\n        })"},{"id":"packages_enterprise_src_core_storage_s3","label":"s3()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L66-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L66"}],"snippet":"function s3(): Adapter {\n    const bucket = process.env.OPENCODE_STORAGE_BUCKET!\n    const region = process.env.OPENCODE_STORAGE_REGION || \"us-east-1\"\n    const client = new AwsClient({\n      region,\n      accessKeyId: process.env.OPENCODE_STORAGE_ACCESS_KEY_ID!,\n      secretAccessKey: process.env.OPENCODE_STORAGE_SECRET_ACCESS_KEY!,\n    })\n    return createAdapter(client, `https://s3.${region}.amazonaws.com`, bucket)\n  }"},{"id":"packages_enterprise_src_core_storage_r2","label":"r2()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L77-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L77"}],"snippet":"function r2() {\n    const accountId = process.env.OPENCODE_STORAGE_ACCOUNT_ID!\n    const client = new AwsClient({\n      accessKeyId: process.env.OPENCODE_STORAGE_ACCESS_KEY_ID!,\n      secretAccessKey: process.env.OPENCODE_STORAGE_SECRET_ACCESS_KEY!,\n    })\n    return createAdapter(client, `https://${accountId}.r2.cloudflarestorage.com`, process.env.OPENCODE_STORAGE_BUCKET!)\n  }"},{"id":"packages_enterprise_src_core_storage_resolve","label":"resolve()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L93-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L93"}],"snippet":"function resolve(key: string[]) {\n    return key.join(\"/\") + \".json\"\n  }"},{"id":"packages_enterprise_src_core_storage_read","label":"read()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L97-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L97"}],"snippet":"export async function read<T>(key: string[]) {\n    const result = await adapter().read(resolve(key))\n    if (!result) return undefined\n    return JSON.parse(result) as T\n  }"},{"id":"packages_enterprise_src_core_storage_write","label":"write()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L103-L105","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L103"}],"snippet":"export function write<T>(key: string[], value: T) {\n    return adapter().write(resolve(key), JSON.stringify(value))\n  }"},{"id":"packages_enterprise_src_core_storage_remove","label":"remove()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L107-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L107"}],"snippet":"export function remove(key: string[]) {\n    return adapter().remove(resolve(key))\n  }"},{"id":"packages_enterprise_src_core_storage_list","label":"list()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L111-L120","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L111"}],"snippet":"export async function list(options?: { prefix?: string[]; limit?: number; after?: string; before?: string }) {\n    const p = options?.prefix ? options.prefix.join(\"/\") + (options.prefix.length ? \"/\" : \"\") : \"\"\n    const result = await adapter().list({\n      prefix: p,\n      limit: options?.limit,\n      after: options?.after,\n      before: options?.before,\n    })\n    return result.map((x) => x.replace(/\\.json$/, \"\").split(\"/\"))\n  }"},{"id":"packages_enterprise_src_core_storage_update","label":"update()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L122-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L122"}],"snippet":"export async function update<T>(key: string[], fn: (draft: T) => void) {\n    const val = await read<T>(key)\n    if (!val) throw new Error(\"Not found\")\n    fn(val)\n    await write(key, val)\n    return val\n  }"}],"edges":[{"source":"packages_enterprise_src_core_storage","target":"aws4fetch","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L1"}],"weight":1},{"source":"packages_enterprise_src_core_storage","target":"lazy","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L2"}],"weight":1},{"source":"packages_enterprise_src_core_storage","target":"packages_enterprise_src_core_storage_adapter","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L5","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L5"}],"weight":1},{"source":"packages_enterprise_src_core_storage","target":"packages_enterprise_src_core_storage_createadapter","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/core/storage.ts","source_location":"L12","lay