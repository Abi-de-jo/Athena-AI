{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_stats_core_src_domain_inference","nodes":[{"id":"packages_stats_core_src_domain_inference","label":"inference.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L1"}]},{"id":"packages_stats_core_src_domain_inference_buildstatsquery","label":"buildStatsQuery()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L17-L158","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L17"}],"snippet":"export function buildStatsQuery(periodStart: Date, periodEnd: Date, dimension: StatDimension) {\n  const periodStartValue = sqlString(periodStart.toISOString())\n  const periodEndValue = sqlString(periodEnd.toISOString())\n  const sourceTable = [Resource.InferenceEvent.catalog, Resource.InferenceEvent.database, Resource.InferenceEvent.table]\n    .map(sqlIdentifier)\n    .join(\".\")\n  const dimensionSql = (() => {\n    if (dimension === \"model\")\n      return {\n        select: \"provider, model, COALESCE(MAX(NULLIF(provider_model, '')), '') AS provider_model\",\n        groupBy: \"provider, model\",\n      }\n    if (dimension === \"provider\") return { select: \"provider\", groupBy: \"provider\" }\n    if (dimension === \"geo_model\")\n      return {\n        select: \"provider, model, country, COALESCE(MAX(NULLIF(continent, '')), '') AS continent\",\n        groupBy: \"provider, model, country\",\n      }\n    return {\n      select: \"'all' AS provider, 'all' AS model, country, COALESCE(MAX(NULLIF(continent, '')), '') AS continent\",\n      groupBy: \"country\",\n    }\n  })()\n  const aggregateColumns = `\n    COUNT(DISTINCT session) AS sessions,"},{"id":"packages_stats_core_src_domain_inference_tomodelaggregate","label":"toModelAggregate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L160-L168","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L160"}],"snippet":"export function toModelAggregate(data: AthenaData): ModelStatAggregate[] {\n  const model = statModel(data.model, data.provider_model)\n  const provider = statProvider(model, data.provider_model, data.provider)\n  if (!provider) return []\n\n  return toStatBaseAggregate(data).flatMap((base) => [\n    { ...base, provider, model, provider_model: data.provider_model || \"\" },\n  ])\n}"},{"id":"packages_stats_core_src_domain_inference_toprovideraggregate","label":"toProviderAggregate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L170-L174","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L170"}],"snippet":"export function toProviderAggregate(data: AthenaData): ProviderStatAggregate[] {\n  return toStatBaseAggregate(data).flatMap((base) => [\n    { ...base, provider: statProvider(data.model, data.provider_model, data.provider) || \"unknown\" },\n  ])\n}"},{"id":"packages_stats_core_src_domain_inference_togeoaggregate","label":"toGeoAggregate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L176-L186","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L176"}],"snippet":"export function toGeoAggregate(data: AthenaData): GeoStatAggregate[] {\n  return toStatBaseAggregate(data).flatMap((base) => [\n    {\n      ...base,\n      provider: statProvider(data.model, data.provider_model, data.provider) || \"all\",\n      model: statModel(data.model || \"all\", data.provider_model),\n      country: normalizeCountry(data.country),\n      continent: data.continent || \"\",\n    },\n  ])\n}"},{"id":"packages_stats_core_src_domain_inference_tostatbaseaggregate","label":"toStatBaseAggregate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L188-L220","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L188"}],"snippet":"function toStatBaseAggregate(data: AthenaData): StatBaseAggregate[] {\n  const grain = data.grain === \"day\" || data.grain === \"week\" ? data.grain : undefined\n  if (!grain || !data.period_key) return []\n\n  return [\n    {\n      grain,\n      period_key: data.period_key,\n      dataset: data.dataset || Resource.StatsSyncConfig.dataset,\n      tier: normalizeTier(data.tier || \"unknown\"),\n      sessions: integer(data, \"sessions\"),\n      requests: integer(data, \"requests\"),\n      input_tokens: integer(data, \"input_tokens\"),\n      output_tokens: integer(data, \"output_tokens\"),\n      reasoning_tokens: integer(data, \"reasoning_tokens\"),\n      cache_read_tokens: integer(data, \"cache_read_tokens\"),\n      total_tokens: integer(data, \"total_tokens\"),\n      input_cost_microcents: integer(data, \"input_cost_microcents\"),\n      output_cost_microcents: integer(data, \"output_cost_microcents\"),\n      total_cost_microcents: integer(data, \"total_cost_microcents\"),\n      avg_duration_ms: nullableNumber(data, \"avg_duration_ms\"),\n      p50_duration_ms: nullableInteger(data, \"p50_duration_ms\"),\n      p95_duration_ms: nullableInteger(data, \"p95_duration_ms\"),\n      avg_ttfb_ms: nullableNumber(data, \"avg_ttfb_ms\"),\n      p50_ttfb_ms: nullableInteger(data, \"p50_ttfb_ms\"),"},{"id":"packages_stats_core_src_domain_inference_integer","label":"integer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L222-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L222"}],"snippet":"function integer(data: AthenaData, key: string) {\n  return Math.round(number(data, key))\n}"},{"id":"packages_stats_core_src_domain_inference_nullablenumber","label":"nullableNumber()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L226-L229","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L226"}],"snippet":"function nullableNumber(data: AthenaData, key: string) {\n  if (data[key] === undefined || data[key] === \"\") return null\n  return Number(number(data, key).toFixed(2))\n}"},{"id":"packages_stats_core_src_domain_inference_nullableinteger","label":"nullableInteger()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L231-L234","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L231"}],"snippet":"function nullableInteger(data: AthenaData, key: string) {\n  if (data[key] === undefined || data[key] === \"\") return null\n  return Math.round(number(data, key))\n}"},{"id":"packages_stats_core_src_domain_inference_number","label":"number()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L236-L239","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L236"}],"snippet":"function number(data: AthenaData, key: string) {\n  const value = Number(data[key])\n  return Number.isFinite(value) ? value : 0\n}"},{"id":"packages_stats_core_src_domain_inference_sqlidentifier","label":"sqlIdentifier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L241-L243","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L241"}],"snippet":"function sqlIdentifier(value: string) {\n  return `\"${value.replace(/\"/g, '\"\"')}\"`\n}"},{"id":"packages_stats_core_src_domain_inference_sqlstring","label":"sqlString()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L245-L247","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L245"}],"snippet":"function sqlString(value: string) {\n  return `'${value.replace(/'/g, \"''\")}'`\n}"},{"id":"packages_stats_core_src_domain_inference_statmodelsql","label":"statModelSql()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L249-L254","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L249"}],"snippet":"function statModelSql(model: string, providerModel: string) {\n  return `COALESCE(NULLIF(regexp_replace(CASE\n      WHEN lower(${model}) = 'big-pickle' THEN NULLIF(${providerModel}, '')\n      ELSE ${model}\n    END, '(-free|:global)+$', ''), ''), 'unknown')`\n}"},{"id":"packages_stats_core_src_domain_inference_statprovidersql","label":"statProviderSql()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L256-L263","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/inference.ts","source_location":"L256"}],"snippet":"function statProviderSql(model: string, providerModel: string, provider: string) {\n  return `CASE\n${MODEL_AUTHOR_RULES.map((item) => `      WHEN strpos(lower(${providerModel}), ${sqlString(item.match)}) > 0 THEN ${sqlString(item.author)}`).join(\"\\n\")}\n${MODEL_AUTHOR_RULES.map((item) => `      WHEN strpos(lower(${model}), ${sqlString(item.match)}) > 0 THEN ${sqlString(item.author)}`).join(\"\\n\")}\n      WHEN ${provider} <> '' AND lower(${provider}) NOT IN (${RETIRED_STAT_PROVIDERS.map(sqlString).join(\", \")}) THEN ${provider}\n      ELSE 'unknown'\n    END`\n}"}],"edges":[{"source":"packages_stats_core_src_domain_inference","target":"resource","relation":"imports_from","confidence":"EX