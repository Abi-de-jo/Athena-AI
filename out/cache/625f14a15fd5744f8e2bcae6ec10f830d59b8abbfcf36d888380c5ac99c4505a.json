otocols/utils/tool-stream.ts","source_location":"L81-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L81"}],"snippet":"appendTool = <K extends StreamKey>(\n  tools: State<K>,\n  key: K,\n  tool: PendingTool,\n  text: string,\n): AppendOutcome<K> => {\n  const events: LLMEvent[] = []\n  if (!tools[key]) events.push(inputStart(tool))\n  if (text.length > 0) events.push(inputDelta(tool, text))\n  return {\n    tools: withTool(tools, key, tool),\n    tool,\n    events,\n  }\n}"},{"id":"tool_stream_iserror","label":"isError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L97-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L97"}],"snippet":"isError = <K extends StreamKey>(result: AppendOutcome<K> | LLMError): result is LLMError =>\n  result instanceof LLMError"},{"id":"tool_stream_start","label":"start()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L105-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L105"}],"snippet":"start = <K extends StreamKey>(\n  tools: State<K>,\n  key: K,\n  tool: Omit<PendingTool, \"input\"> & { readonly input?: string },\n) => withTool(tools, key, { ...tool, input: tool.input ?? \"\" })"},{"id":"tool_stream_appendorstart","label":"appendOrStart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L117-L139","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L117"}],"snippet":"appendOrStart = <K extends StreamKey>(\n  route: string,\n  tools: State<K>,\n  key: K,\n  delta: { readonly id?: string; readonly name?: string; readonly text: string },\n  missingToolMessage: string,\n): AppendOutcome<K> | LLMError => {\n  const current = tools[key]\n  const id = delta.id ?? current?.id\n  const name = delta.name ?? current?.name\n  if (!id || !name) return eventError(route, missingToolMessage)\n\n  const tool = {\n    id,\n    name,\n    input: `${current?.input ?? \"\"}${delta.text}`,\n    providerExecuted: current?.providerExecuted,\n    providerMetadata: current?.providerMetadata,\n  }\n  if (current && delta.text.length === 0 && current.id === id && current.name === name)\n    return { tools, tool: current, events: [] }\n  return appendTool(tools, key, tool, delta.text)\n}"},{"id":"tool_stream_appendexisting","label":"appendExisting()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L146-L157","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L146"}],"snippet":"appendExisting = <K extends StreamKey>(\n  route: string,\n  tools: State<K>,\n  key: K,\n  text: string,\n  missingToolMessage: string,\n): AppendOutcome<K> | LLMError => {\n  const current = tools[key]\n  if (!current) return eventError(route, missingToolMessage)\n  if (text.length === 0) return { tools, tool: current, events: [] }\n  return appendTool(tools, key, { ...current, input: `${current.input}${text}` }, text)\n}"},{"id":"tool_stream_finish","label":"finish()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L164-L175","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L164"}],"snippet":"finish = <K extends StreamKey>(route: string, tools: State<K>, key: K) =>\n  Effect.gen(function* () {\n    const tool = tools[key]\n    if (!tool) return { tools }\n    return {\n      tools: withoutTool(tools, key),\n      events: [\n        LLMEvent.toolInputEnd({ id: tool.id, name: tool.name, providerMetadata: tool.providerMetadata }),\n        yield* toolCall(route, tool),\n      ],\n    }\n  })"},{"id":"tool_stream_finishwithinput","label":"finishWithInput()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L182-L193","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L182"}],"snippet":"finishWithInput = <K extends StreamKey>(route: string, tools: State<K>, key: K, input: string) =>\n  Effect.gen(function* () {\n    const tool = tools[key]\n    if (!tool) return { tools }\n    return {\n      tools: withoutTool(tools, key),\n      events: [\n        LLMEvent.toolInputEnd({ id: tool.id, name: tool.name, providerMetadata: tool.providerMetadata }),\n        yield* toolCall(route, tool, input),\n      ],\n    }\n  })"},{"id":"tool_stream_finishall","label":"finishAll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L200-L216","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L200"}],"snippet":"finishAll = <K extends StreamKey>(route: string, tools: State<K>) =>\n  Effect.gen(function* () {\n    const pending = Object.values<PendingTool | undefined>(tools).filter(\n      (tool): tool is PendingTool => tool !== undefined,\n    )\n    return {\n      tools: empty<K>(),\n      events: yield* Effect.forEach(pending, (tool) =>\n        toolCall(route, tool).pipe(\n          Effect.map((call) => [\n            LLMEvent.toolInputEnd({ id: tool.id, name: tool.name, providerMetadata: tool.providerMetadata }),\n            call,\n          ]),\n        ),\n      ).pipe(Effect.map((events) => events.flat())),\n    }\n  })"}],"edges":[{"source":"tool_stream","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L1"}],"weight":1},{"source":"tool_stream","target":"schema","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L2"}],"weight":1},{"source":"tool_stream","target":"shared","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/tool-stream.ts","source_location":"L3","layer":"base","proven