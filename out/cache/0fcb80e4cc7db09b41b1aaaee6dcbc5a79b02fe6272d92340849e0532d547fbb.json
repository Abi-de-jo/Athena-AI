l","label":"isPartEqual()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L66-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L66"}],"snippet":"function isPartEqual(partA: ContentPart, partB: ContentPart) {\n  switch (partA.type) {\n    case \"text\":\n      return partB.type === \"text\" && partA.content === partB.content\n    case \"file\":\n      return partB.type === \"file\" && partA.path === partB.path && isSelectionEqual(partA.selection, partB.selection)\n    case \"agent\":\n      return partB.type === \"agent\" && partA.name === partB.name\n    case \"image\":\n      return partB.type === \"image\" && partA.id === partB.id\n  }\n}"},{"id":"packages_app_src_context_prompt_ispromptequal","label":"isPromptEqual()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L79-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L79"}],"snippet":"export function isPromptEqual(promptA: Prompt, promptB: Prompt): boolean {\n  if (promptA.length !== promptB.length) return false\n  for (let i = 0; i < promptA.length; i++) {\n    if (!isPartEqual(promptA[i], promptB[i])) return false\n  }\n  return true\n}"},{"id":"packages_app_src_context_prompt_cloneselection","label":"cloneSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L87-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L87"}],"snippet":"function cloneSelection(selection?: FileSelection) {\n  if (!selection) return undefined\n  return { ...selection }\n}"},{"id":"packages_app_src_context_prompt_clonepart","label":"clonePart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L92-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L92"}],"snippet":"function clonePart(part: ContentPart): ContentPart {\n  if (part.type === \"text\") return { ...part }\n  if (part.type === \"image\") return { ...part }\n  if (part.type === \"agent\") return { ...part }\n  return {\n    ...part,\n    selection: cloneSelection(part.selection),\n  }\n}"},{"id":"packages_app_src_context_prompt_cloneprompt","label":"clonePrompt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L102-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L102"}],"snippet":"function clonePrompt(prompt: Prompt): Prompt {\n  return prompt.map(clonePart)\n}"},{"id":"packages_app_src_context_prompt_contextitemkey","label":"contextItemKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L106-L120","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/prompt.tsx","source_location":"L106"}],"snippet":"function contextItemKey(item: ContextItem) {\n  if (item.type !== \"file\") return item.type\n  const start = i