hare/common.tsx","source_location":"L47-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/web-astro.bak/src/components/share/common.tsx","source_location":"L47"}],"snippet":"export function AnchorIcon(props: AnchorProps) {\n  const [local, rest] = splitProps(props, [\"id\", \"children\"])\n  const [copied, setCopied] = createSignal(false)\n  const messages = useShareMessages()\n\n  return (\n    <div {...rest} data-element-anchor title={messages.link_to_message} data-status={copied() ? \"copied\" : \"\"}>\n      <a\n        href={`#${local.id}`}\n        onClick={(e) => {\n          e.preventDefault()\n\n          const anchor = e.currentTarget\n          const hash = anchor.getAttribute(\"href\") || \"\"\n          const { origin, pathname, search } = window.location\n\n          navigator.clipboard\n            .writeText(`${origin}${pathname}${search}${hash}`)\n            .catch((err) => console.error(\"Copy failed\", err))\n\n          setCopied(true)\n          setTimeout(() => setCopied(false), 3000)\n        }}\n      >\n        {local.children}","node_kind":"component"},{"id":"packages_web_astro_bak_src_components_share_common_createoverflow","label":"createOverflow()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/web-astro.bak/src/components/share/common.tsx","source_location":"L80-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/web-astro.bak/src/components/share/common.tsx","source_location":"L80"}],"snippet":"export function createOverflow() {\n  const [overflow, setOverflow] = createSignal(false)\n  return {\n    get status() {\n      return overflow()\n    },\n    ref(el: HTMLElement) {\n      const sync = () => {\n        setOverflow(el.scrollHeight > el.clientHeight + 1)\n      }\n\n