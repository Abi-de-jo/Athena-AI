{"__madarTsExtractorVersion":67,"__madarFileStem":"openai-chat","nodes":[{"id":"openai_chat","label":"openai-chat.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L1"}]},{"id":"openai_chat_parserstate","label":"ParserState","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L161-L167","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L161"}],"snippet":"interface ParserState {\n  readonly tools: ToolStream.State<number>\n  readonly toolCallEvents: ReadonlyArray<LLMEvent>\n  readonly usage?: Usage\n  readonly finishReason?: FinishReason\n  readonly lifecycle: Lifecycle.State\n}"},{"id":"openai_chat_lowertool","label":"lowerTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L177-L184","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L177"}],"snippet":"lowerTool = (tool: ToolDefinition): OpenAIChatTool => ({\n  type: \"function\",\n  function: {\n    name: tool.name,\n    description: tool.description,\n    parameters: ProviderShared.openAiToolInputSchema(tool.inputSchema),\n  },\n})"},{"id":"openai_chat_lowertoolchoice","label":"lowerToolChoice()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L186-L192","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L186"}],"snippet":"lowerToolChoice = (toolChoice: NonNullable<LLMRequest[\"toolChoice\"]>) =>\n  ProviderShared.matchToolChoice(\"OpenAI Chat\", toolChoice, {\n    auto: () => \"auto\" as const,\n    none: () => \"none\" as const,\n    required: () => \"required\" as const,\n    tool: (name) => ({ type: \"function\" as const, function: { name } }),\n  })"},{"id":"openai_chat_lowertoolcall","label":"lowerToolCall()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L194-L201","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L194"}],"snippet":"lowerToolCall = (part: ToolCallPart): OpenAIChatAssistantToolCall => ({\n  id: part.id,\n  type: \"function\",\n  function: {\n    name: part.name,\n    arguments: ProviderShared.encodeJson(part.input),\n  },\n})"},{"id":"openai_chat_openaicompatiblereasoningcontent","label":"openAICompatibleReasoningContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L208-L209","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L208"}],"snippet":"openAICompatibleReasoningContent = (native: unknown) =>\n  isRecord(native) && typeof native.reasoning_content === \"string\" ? native.reasoning_content : undefined"},{"id":"openai_chat_mapfinishreason","label":"mapFinishReason()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L370-L376","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L370"}],"snippet":"mapFinishReason = (reason: string | null | undefined): FinishReason => {\n  if (reason === \"stop\") return \"stop\"\n  if (reason === \"length\") return \"length\"\n  if (reason === \"content_filter\") return \"content-filter\"\n  if (reason === \"function_call\" || reason === \"tool_calls\") return \"tool-calls\"\n  return \"unknown\"\n}"},{"id":"openai_chat_mapusage","label":"mapUsage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L383-L397","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L383"}],"snippet":"mapUsage = (usage: OpenAIChatEvent[\"usage\"]): Usage | undefined => {\n  if (!usage) return undefined\n  const cached = usage.prompt_tokens_details?.cached_tokens\n  const reasoning = usage.completion_tokens_details?.reasoning_tokens\n  const nonCached = ProviderShared.subtractTokens(usage.prompt_tokens, cached)\n  return new Usage({\n    inputTokens: usage.prompt_tokens,\n    outputTokens: usage.completion_tokens,\n    nonCachedInputTokens: nonCached,\n    cacheReadInputTokens: cached,\n    reasoningTokens: reasoning,\n    totalTokens: ProviderShared.totalTokens(usage.prompt_tokens, usage.completion_tokens, usage.total_tokens),\n    providerMetadata: { openai: usage },\n  })\n}"},{"id":"openai_chat_step","label":"step()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L399-L447","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L399"}],"snippet":"step = (state: ParserState, event: OpenAIChatEvent) =>\n  Effect.gen(function* () {\n    const events: LLMEvent[] = []\n    const usage = mapUsage(event.usage) ?? state.usage\n    const choice = event.choices[0]\n    const finishReason = choice?.finish_reason ? mapFinishReason(choice.finish_reason) : state.finishReason\n    const delta = choice?.delta\n    const toolDeltas = delta?.tool_calls ?? []\n    let tools = state.tools\n\n    let lifecycle = state.lifecycle\n\n    if (delta?.reasoning_content)\n      lifecycle = Lifecycle.reasoningDelta(lifecycle, events, \"reasoning-0\", delta.reasoning_content)\n\n    if (delta?.content) lifecycle = Lifecycle.textDelta(lifecycle, events, \"text-0\", delta.content)\n\n    for (const tool of toolDeltas) {\n      const result = ToolStream.appendOrStart(\n        ADAPTER,\n        tools,\n        tool.index,\n        { id: tool.id ?? undefined, name: tool.function?.name ?? undefined, text: tool.function?.arguments ?? \"\" },\n        \"OpenAI Chat tool call delta is missing id or name\",\n      )"},{"id":"openai_chat_finishevents","label":"finishEvents()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L449-L457","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L449"}],"snippet":"finishEvents = (state: ParserState): ReadonlyArray<LLMEvent> => {\n  const events: LLMEvent[] = []\n  const hasToolCalls = state.toolCallEvents.length > 0\n  const reason = state.finishReason === \"stop\" && hasToolCalls ? \"tool-calls\" : state.finishReason\n  const lifecycle = state.toolCallEvents.length ? Lifecycle.stepStart(state.lifecycle, events) : state.lifecycle\n  events.push(...state.toolCallEvents)\n  if (reason) Lifecycle.finish(lifecycle, events, { reason, usage: state.usage })\n  return events\n}"}],"edges":[{"source":"openai_chat","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L1"}],"weight":1},{"source":"openai_chat","target":"client","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L2"}],"weight":1},{"source":"openai_chat","target":"auth","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L3"}],"weight":1},{"source":"openai_chat","target":"endpoint","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/openai-chat.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/pro