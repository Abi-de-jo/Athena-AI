muru-ai/packages/llm/src/providers/azure.ts","source_location":"L65-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/azure.ts","source_location":"L65"}],"snippet":"auth = (input: Config) => {\n  if (\"auth\" in input && input.auth) return input.auth\n  return Auth.remove(\"authorization\").andThen(\n    Auth.optional(\"apiKey\" in input ? input.apiKey : undefined, \"apiKey\")\n      .orElse(Auth.config(\"AZURE_OPENAI_API_KEY\"))\n      .pipe(Auth.header(\"api-key\")),\n  )\n}"},{"id":"packages_llm_src_providers_azure_configuredroute","label":"configuredRoute()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/azure.ts","source_location":"L74-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/azure.ts","source_location":"L74"}],"snippet":"configuredRoute = <Body, Prepared>(route: RouteDef<Body, Prepared>, input: Config) =>\n  route.with({\n    auth: auth(input),\n    endpoint: {\n      // AtLeastOne guarantees at least one is set; baseURL wins if both are.\n      baseURL: input.baseURL ?? resourceBaseURL(input.resourceName!),\n      query: {\n        ...(input.apiVersion ? { \"api-version\": input.apiVersion } : {}),\n        ...input.queryParams,\n      },\n    },\n  })"},{"id":"packages_llm_src_providers_azure_configure","label":"configure()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/azure.ts","source_location":"L87-L105","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/azure.ts","source_location":"L87"}],"snippet":"configure = (input: Config) => {\n  const configuredResponsesRoute = configuredRoute(responsesRoute, input)\n  const configuredChatRoute = configuredRoute(chatRoute, input)\n  const modelDefaults = defaults(input)\n\n  const responses = (modelID: string | ModelID) =>\n    configuredResponsesRoute.with(withOpenAIOptions(modelID, modelDefaults)).model({ id: modelID })\n\n  const chat = (modelID: string | ModelID) =>\n    configuredChatRoute.with(withOpenAIOptions(modelID, modelDefaults)).model({ id: modelID })\n\n  return {\n    id,\n    model: (modelID: string | ModelID) => (input.useCompletionUrls === true ? chat(modelID) : responses(modelID)),\n    responses,\n    chat,\n    configure,\n  }\n}"},{"id":"packages_llm_src_providers_azure_configure_responses","label":"responses()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/azure.ts","source_location":"L92-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/azure.ts","source_location":"L92"}],"snippet":"responses = (modelID: string | ModelID) =>\n    configuredResponsesRoute.with(withOpenAIOptions(modelID, modelDefaults)).model({ id: modelID })"},{"id":"packages_llm_src_providers_azure_configure_chat","label":"chat()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/azure.ts","source_location":"L95-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/azure.ts","source_location":"L95"}],"snippet":"chat = (modelID: string | ModelID) =>\n    configuredChatRoute.with(withOpenAIOptions(modelID, modelDefaults)).model({ id: modelID })"}],"edges":[{"source":"packages_llm_src_providers_azure","target":"auth","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal