{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_desktop_src_main_migrate","nodes":[{"id":"packages_desktop_src_main_migrate","label":"migrate.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L1"}]},{"id":"packages_desktop_src_main_migrate_tauridir","label":"tauriDir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L13-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L13"}],"snippet":"function tauriDir(id: string) {\n  switch (process.platform) {\n    case \"darwin\":\n      return join(homedir(), \"Library\", \"Application Support\", id)\n    case \"win32\":\n      return join(process.env.APPDATA ?? join(homedir(), \"AppData\", \"Roaming\"), id)\n    default:\n      return join(process.env.XDG_DATA_HOME ?? join(homedir(), \".local\", \"share\"), id)\n  }\n}"},{"id":"packages_desktop_src_main_migrate_tauriappid","label":"tauriAppId()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L30-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L30"}],"snippet":"function tauriAppId() {\n  return app.isPackaged ? TAURI_APP_IDS[CHANNEL] : \"ai.opencode.desktop.dev\"\n}"},{"id":"packages_desktop_src_main_migrate_migratefile","label":"migrateFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L39-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L39"}],"snippet":"function migrateFile(datPath: string, filename: string) {\n  let data: Record<string, unknown>\n  try {\n    data = JSON.parse(readFileSync(datPath, \"utf-8\"))\n  } catch (err) {\n    log.warn(\"tauri migration: failed to parse\", filename, err)\n    return\n  }\n\n  // opencode.settings.dat → the electron settings store (\"opencode.settings\").\n  // All other .dat files keep their full filename as the store name so they match\n  // what the renderer passes via IPC (e.g. \"default.dat\", \"opencode.global.dat\").\n  const storeName = filename === \"opencode.settings.dat\" ? \"opencode.settings\" : filename\n  const target = getStore(storeName)\n  const migrated: string[] = []\n  const skipped: string[] = []\n\n  for (const [key, value] of Object.entries(data)) {\n    // Don't overwrite values the user has already set in the Electron app.\n    if (target.has(key)) {\n      skipped.push(key)\n      continue\n    }\n    target.set(key, value)\n    migrated.push(key)"},{"id":"packages_desktop_src_main_migrate_migrate","label":"migrate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L69-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L69"}],"snippet":"export function migrate() {\n  if (getStore().get(TAURI_MIGRATED_KEY)) {\n    log.log(\"tauri migration: already done, skipping\")\n    return\n  }\n\n  const dir = tauriDir(tauriAppId())\n  log.log(\"tauri migration: starting\", { dir })\n\n  if (!existsSync(dir)) {\n    log.log(\"tauri migration: no tauri data directory found, nothing to migrate\")\n    getStore().set(TAURI_MIGRATED_KEY, true)\n    return\n  }\n\n  for (const filename of readdirSync(dir)) {\n    if (!filename.endsWith(\".dat\")) continue\n    migrateFile(join(dir, filename), filename)\n  }\n\n  log.log(\"tauri migration: complete\")\n  getStore().set(TAURI_MIGRATED_KEY, true)\n}"}],"edges":[{"source":"packages_desktop_src_main_migrate","target":"electron","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L1"}],"weight":1},{"source":"packages_desktop_src_main_migrate","target":"main","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L2"}],"weight":1},{"source":"packages_desktop_src_main_migrate","target":"fs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migrate.ts","source_location":"L3"}],"weight":1},{"source":"packages_desktop_src_main_migrate","target":"os","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/migr