Permit(effect).pipe(\n          Effect.ensuring(\n            Effect.sync(() => {\n              entry.users--\n              if (entry.users === 0) locks.delete(key)\n            }),\n          ),\n        )\n      })\n\n  return { size: Effect.sync(() => locks.size), withLock }\n}"},{"id":"keyed_mutex_makeunsafe_withlock","label":"withLock()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/keyed-mutex.ts","source_location":"L23-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/keyed-mutex.ts","source_location":"L23"}],"snippet":"withLock =\n    (key: Key) =>\n    <A, E, R>(effect: Effect.Effect<A, E, R>) =>\n      Effect.suspend(() => {\n        const current = locks.get(key)\n        const entry = current ?? { semaphore: Semaphore.makeUnsafe(1), users: 0 }\n        if (!current) locks.set(key, entry)\n        entry.users++\n        return entry.semaphore.withPermit(effect).pipe(\n          Effect.ensuring(\n            Effect.sync(() => {\n              entry.users--\n              if (entry.users === 0) locks.delete(key)\n            }),\n          ),\n        )\n      })"},{"id":"keyed_mutex_make","label":"make()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/keyed-mutex.ts","source_location":"L45","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/keyed-mutex.ts","source_location":"L45"}],"snippet":"make = <Key>(): Effect.Effect<KeyedMutex<Key>> => Effect.sync(makeUnsafe<Key>)"}],"edges":[{"source":"keyed_mutex","target":"keyed_mutex","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/keyed-mutex.ts","source_location":"