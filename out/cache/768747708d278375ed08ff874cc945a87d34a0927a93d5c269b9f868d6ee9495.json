cation":"L7"}],"snippet":"export function isMedia(mime: string) {\n  return mime.startsWith(\"image/\") || isPdfAttachment(mime)\n}"},{"id":"packages_opencode_src_util_media_isimageattachment","label":"isImageAttachment()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/media.ts","source_location":"L11-L13","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/media.ts","source_location":"L11"}],"snippet":"export function isImageAttachment(mime: string) {\n  return mime.startsWith(\"image/\") && mime !== \"image/svg+xml\" && mime !== \"image/vnd.fastbidsheet\"\n}"},{"id":"packages_opencode_src_util_media_sniffattachmentmime","label":"sniffAttachmentMime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/media.ts","source_location":"L15-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/media.ts","source_location":"L15"}],"snippet":"export function sniffAttachmentMime(bytes: Uint8Array, fallback: string) {\n  if (startsWith(bytes, [0x89, 0x50, 0x4e, 0x47, 0x0d, 0x0a, 0x1a, 0x0a])) return \"image/png\"\n  if (startsWith(bytes, [0xff, 0xd8, 0xff])) return \"image/jpeg\"\n  if (startsWith(bytes, [0x47, 0x49, 0x46, 0x38])) return \"image/gif\"\n  if (startsWith(bytes, [0x42, 0x4d])) return \"image/bmp\"\n  if (startsWith(bytes, [0x25, 0x50, 0x44, 0x46, 0x2d])) return \"application/pdf\"\n  if (startsWith(bytes, [0x52, 0x49, 0x46, 0x46]) && startsWith(bytes.subarray(8), [0x57, 0x45, 0x42, 0x50])) {\n    return \"image/webp\"\n  }\n\n  return fallback\n}"}],"edges":[{"source":"packages_opencode_src_util_media","target":"packages_opencode_src_util_media_startswith","relation":"contains","confidence":"EXTRACTED","