og_select_dialogselect_move","label":"move()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L227-L234","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L227"}],"snippet":"function move(direction: number) {\n    if (props.locked) return\n    if (flat().length === 0) return\n    let next = store.selected + direction\n    if (next < 0) next = flat().length - 1\n    if (next >= flat().length) next = 0\n    moveTo(next, true)\n  }"},{"id":"dialog_select_dialogselect_moveto","label":"moveTo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L236-L271","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L236"}],"snippet":"function moveTo(next: number, center = false) {\n    setFocusedAction(undefined)\n    setStore(\"selected\", next)\n    const option = selected()\n    if (option) props.onMove?.(option)\n    if (!scroll) return\n    let remaining = store.selected\n    let index = 0\n    // Locate the row by position because a unique renderable ID cannot currently be ensured.\n    for (const [category, options] of grouped()) {\n      if (category) index++\n      if (remaining < options.length) {\n        index += remaining\n        break\n      }\n      index += options.length\n      remaining -= options.length\n    }\n    const target = scroll.getChildren()[index]\n    if (!target) return\n    const y = target.y - scroll.y\n    if (center) {\n      const centerOffset = Math.floor(scroll.height / 2)\n      scroll.scrollBy(y - centerOffset)\n    } else {"},{"id":"dialog_select_dialogselect_submit","label":"submit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L273-L285","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L273"}],"snippet":"function submit() {\n    if (props.locked) return\n    setStore(\"input\", \"keyboard\")\n    const index = focusedAction()\n    if (index !== undefined) {\n      triggerAction(actionItems()[index])\n      return\n    }\n    const option = selected()\n    if (!option) return\n    option.onSelect?.(dialog)\n    props.onSelect?.(option)\n  }"},{"id":"dialog_select_dialogselect_moveaction","label":"moveAction()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L287-L296","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L287"}],"snippet":"function moveAction(direction: 1 | -1) {\n    if (props.locked) return\n    const total = actionItems().length\n    if (total === 0) return\n    setFocusedAction((index) => {\n      if (index === undefined) return direction === 1 ? 0 : total - 1\n      const next = index + direction\n      return next < 0 || next >= total ? undefined : next\n    })\n  }"},{"id":"dialog_select_dialogselect_triggeraction","label":"triggerAction()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L432-L439","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L432"}],"snippet":"function triggerAction(item: VisibleAction | undefined) {\n    if (props.locked) return\n    if (!item || !isActionItem(item) || isActionDisabled(item)) return\n    setStore(\"input\", \"keyboard\")\n    const option = selected()\n    if (!option) return\n    item.onTrigger(option)\n  }"},{"id":"dialog_select_dialogselect_isactionitem","label":"isActionItem()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L441-L443","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L441"}],"snippet":"function isActionItem(item: VisibleAction): item is Action & { label: string } {\n    return \"onTrigger\" in item\n  }"},{"id":"dialog_select_dialogselect_isactiondisabled","label":"isActionDisabled()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L445-L447","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L445"}],"snippet":"function isActionDisabled(item: Action) {\n    return typeof item.disabled === \"function\" ? item.disabled(selected()) : item.disabled\n  }"},{"id":"dialog_select_dialogselect_isactionfocused","label":"isActionFocused()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L449-L453","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L449"}],"snippet":"function isActionFocused(item: VisibleAction) {\n    if (props.locked) return false\n    if (!isActionItem(item)) return false\n    return actionItems().indexOf(item) === focusedAction()\n  }"},{"id":"dialog_select_dialogselect_footeraction","label":"FooterAction()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L455-L484","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L455"}],"snippet":"function FooterAction(action: { item: VisibleAction }) {\n    if (!isActionItem(action.item))\n      return (\n        <text>\n          <span style={{ fg: theme.text }}>\n            <b>{action.item.title}</b>{\" \"}\n          </span>\n          <span style={{ fg: theme.textMuted }}>{action.item.label}</span>\n        </text>\n      )\n    const item = action.item\n    const active = createMemo(() => isActionFocused(item))\n    const disabled = createMemo(() => isActionDisabled(item))\n    const fg = selectedForeground(theme)\n    return (\n      <box\n        flexDirection=\"row\"\n        backgroundColor={active() ? theme.primary : RGBA.fromInts(0, 0, 0, 0)}\n        onMouseUp={() => triggerAction(item)}\n      >\n        <text\n          fg={disabled() ? theme.textMuted : active() ? fg : theme.text}\n          attributes={active() ? TextAttributes.BOLD : undefined}\n        >\n          {item.title}"},{"id":"dialog_select_option","label":"Option()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L660-L719","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L660"}],"snippet":"function Option(props: {\n  title: string\n  titleView?: JSX.Element\n  description?: string\n  active?: boolean\n  current?: boolean\n  muted?: boolean\n  footer?: JSX.Element | string\n  titleWidth?: number\n  truncateTitle?: boolean | \"left\"\n  gutter?: () => JSX.Element\n  onMouseOver?: () => void\n}) {\n  const { theme } = useTheme()\n  const fg = selectedForeground(theme)\n  const text = createMemo(() => {\n    if (props.active && !props.muted) return fg\n    if (props.muted && (props.active || props.current)) return theme.textMuted\n    if (props.current) return theme.primary\n    return theme.text\n  })\n\n  return (\n    <>\n      <Show when={props.current && !props.gutter}>","node_kind":"component"}],"edges":[{"source":"dialog_select","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L1"}],"weight":1},{"source":"dialog_select","target":"keymap","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L9","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L9"}],"weight":1},{"source":"dialog_select","target":"theme","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L10","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/ui/dialog-select.tsx","source_location":"L10"}],"weight":1},{"source":"dialog_select","target":"remeda","relation":"