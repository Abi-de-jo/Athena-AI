{"__madarTsExtractorVersion":67,"__madarFileStem":"server-sdk","nodes":[{"id":"server_sdk","label":"server-sdk.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L1"}]},{"id":"server_sdk_isaborterror","label":"isAbortError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L14-L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L14"}],"snippet":"isAbortError = (error: unknown) =>\n  error !== null && typeof error === \"object\" && \"name\" in error && error.name === \"AbortError\""},{"id":"server_sdk_isstreamclosed","label":"isStreamClosed()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L17"}],"snippet":"isStreamClosed = (error: unknown, signal?: AbortSignal) => isAbortError(error) || signal?.aborted === true"},{"id":"server_sdk_resumestreamafterpageshow","label":"resumeStreamAfterPageShow()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L19-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L19"}],"snippet":"export function resumeStreamAfterPageShow(event: PageTransitionEvent, start: () => unknown) {\n  if (!event.persisted) return\n  start()\n}"},{"id":"server_sdk_createserversdkcontextbase","label":"createServerSdkContextBase()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L24-L262","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L24"}],"snippet":"function createServerSdkContextBase(server: ServerConnection.Any, scope: ServerScope) {\n  const platform = usePlatform()\n  const abort = new AbortController()\n\n  const eventFetch = (() => {\n    if (!platform.fetch || !server) return\n    try {\n      const url = new URL(server.http.url)\n      const loopback = url.hostname === \"localhost\" || url.hostname === \"127.0.0.1\" || url.hostname === \"::1\"\n      if (url.protocol === \"http:\" && !loopback) return platform.fetch\n    } catch {\n      return\n    }\n  })()\n\n  const eventSdk = createSdkForServer({\n    signal: abort.signal,\n    fetch: eventFetch,\n    server: server.http,\n  })\n  const emitter = createGlobalEmitter<{\n    [key: string]: Event\n  }>()\n\n  type Queued = { directory: string; payload: Event }"},{"id":"server_sdk_createserversdkcontextbase_deltakey","label":"deltaKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L60"}],"snippet":"deltaKey = (directory: string, messageID: string, partID: string) => `${directory}:${messageID}:${partID}`"},{"id":"server_sdk_createserversdkcontextbase_key","label":"key()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L62-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L62"}],"snippet":"key = (directory: string, payload: Event) => {\n    if (payload.type === \"session.status\") return `session.status:${directory}:${payload.properties.sessionID}`\n    if (payload.type === \"lsp.updated\") return `lsp.updated:${directory}`\n    if (payload.type === \"message.part.updated\") {\n      const part = payload.properties.part\n      return `message.part.updated:${directory}:${part.messageID}:${part.id}`\n    }\n  }"},{"id":"server_sdk_createserversdkcontextbase_flush","label":"flush()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L71-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L71"}],"snippet":"flush = () => {\n    if (timer) clearTimeout(timer)\n    timer = undefined\n\n    if (queue.length === 0) return\n\n    const events = queue\n    const skip = staleDeltas.size > 0 ? new Set(staleDeltas) : undefined\n    queue = buffer\n    buffer = events\n    queue.length = 0\n    coalesced.clear()\n    staleDeltas.clear()\n\n    last = Date.now()\n    batch(() => {\n      for (const event of events) {\n        if (skip && event.payload.type === \"message.part.delta\") {\n          const props = event.payload.properties\n          if (skip.has(deltaKey(event.directory, props.messageID, props.partID))) continue\n        }\n        emitter.emit(event.directory, event.payload)\n      }\n    })"},{"id":"server_sdk_createserversdkcontextbase_schedule","label":"schedule()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L99-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L99"}],"snippet":"schedule = () => {\n    if (timer) return\n    const elapsed = Date.now() - last\n    timer = setTimeout(flush, Math.max(0, FLUSH_FRAME_MS - elapsed))\n  }"},{"id":"server_sdk_createserversdkcontextbase_wait","label":"wait()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L106"}],"snippet":"wait = (ms: number) => new Promise<void>((resolve) => setTimeout(resolve, ms))"},{"id":"server_sdk_createserversdkcontextbase_resetheartbeat","label":"resetHeartbeat()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L114-L120","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L114"}],"snippet":"resetHeartbeat = () => {\n    lastEventAt = Date.now()\n    if (heartbeat) clearTimeout(heartbeat)\n    heartbeat = setTimeout(() => {\n      attempt?.abort()\n    }, HEARTBEAT_TIMEOUT_MS)\n  }"},{"id":"server_sdk_createserversdkcontextbase_clearheartbeat","label":"clearHeartbeat()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L121-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L121"}],"snippet":"clearHeartbeat = () => {\n    if (!heartbeat) return\n    clearTimeout(heartbeat)\n    heartbeat = undefined\n  }"},{"id":"server_sdk_createserversdkcontextbase_start","label":"start()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L127-L213","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L127"}],"snippet":"start = () => {\n    if (started) return run\n    started = true\n    const active = ++generation\n    const previous = run\n    const current = (async () => {\n      if (previous) await previous\n      // oxlint-disable-next-line no-unmodified-loop-condition -- `started` is set to false by stop() which also aborts; both flags are checked to allow graceful exit\n      while (!abort.signal.aborted && started && generation === active) {\n        attempt = new AbortController()\n        lastEventAt = Date.now()\n        const onAbort = () => {\n          attempt?.abort()\n        }\n        abort.signal.addEventListener(\"abort\", onAbort)\n        try {\n          const events = await eventSdk.global.event({\n            signal: attempt.signal,\n            onSseError: (error) => {\n              if (isStreamClosed(error, attempt?.signal)) return\n              if (streamErrorLogged) return\n              streamErrorLogged = true\n              console.error(\"[global-sdk] event stream error\", {\n                url: server.http.url,\n                fetch: eventFetch ? \"platform\" : \"webview\","},{"id":"server_sdk_createserversdkcontextbase_stop","label":"stop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L215-L220","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L215"}],"snippet":"stop = () => {\n    started = false\n    generation++\n    attempt?.abort()\n    clearHeartbeat()\n  }"},{"id":"server_sdk_createserversdkcontext","label":"createServerSdkContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L269-L274","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L269"}],"snippet":"export function createServerSdkContext(server: ServerConnection.Any, scope: ServerScope): ServerSDK {\n  const sdk = createServerSdkContextBase(server, scope)\n  return Object.assign(sdk, {\n    createDirSdkContext: createRefCountMap((dir) => createDirSdkContext(dir, sdk)),\n  })\n}"},{"id":"server_sdk_createdirsdkcontext","label":"createDirSdkContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L297-L322","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L297"}],"snippet":"function createDirSdkContext(directory: string, serverSDK: ServerSDKBase) {\n  const client = serverSDK.createClient({\n    directory,\n    throwOnError: true,\n  })\n\n  const emitter = createGlobalEmitter<SDKEventMap>()\n\n  const unsub = serverSDK.event.on(directory, (event) => {\n    emitter.emit(event.type, event)\n  })\n  onCleanup(unsub)\n\n  return {\n    scope: serverSDK.scope,\n    directory,\n    client,\n    event: emitter,\n    get url() {\n      return serverSDK.url\n    },\n    createClient(opts: Parameters<typeof serverSDK.createClient>[0]) {\n      return serverSDK.createClient(opts)\n    },\n  }"}],"edges":[{"source":"server_sdk","target":"client","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L1"}],"weight":1},{"source":"server_sdk","target":"context","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L2"}],"weight":1},{"source":"server_sdk","target":"event_bus","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L3"}],"weight":1},{"source":"server_sdk","target":"event_listener","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sdk.tsx","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowda