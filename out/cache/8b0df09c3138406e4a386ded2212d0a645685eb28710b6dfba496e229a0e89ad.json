{"__madarTsExtractorVersion":67,"__madarFileStem":"subagent-data.test","nodes":[{"id":"subagent_data_test","label":"subagent-data.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/subagent-data.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/subagent-data.test.ts","source_location":"L1"}]},{"id":"subagent_data_test_visible","label":"visible()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/subagent-data.test.ts","source_location":"L15-L40","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/subagent-data.test.ts","source_location":"L15"}],"snippet":"function visible(commits: Array<Parameters<typeof entryBody>[0]>) {\n  return commits.flatMap((item) => {\n    const body = entryBody(item)\n    if (body.type === \"none\") {\n      return []\n    }\n\n    if (body.type === \"structured\") {\n      if (body.snapshot.kind === \"code\" || body.snapshot.kind === \"task\") {\n        return [body.snapshot.title]\n      }\n\n      if (body.snapshot.kind === \"diff\") {\n        return body.snapshot.items.map((item) => item.title)\n      }\n\n      if (body.snapshot.kind === \"todo\") {\n        return [\"# Todos\"]\n      }\n\n      return [\"# Questions\"]\n    }\n\n    return [body.content]\n  })"},{"id":"subagent_data_test_reduce","label":"reduce()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/subagent-data.test.ts","source_location":"L42-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/subagent-data.test.ts","source_location":"L42"}],"snippet":"function reduce(data: ReturnType<typeof createSubagentData>, event: unknown) {\n  return reduceSubagentData({\n    data,\n    event: event as Event,\n    sessionID: \"parent-1\",\n    thinking: true,\n    limits: {},\n  })\n}"},{"id":"subagent_data_test_taskmessage","label":"taskMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/subagent-data.test.ts","source_location":"L52-L136","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/subagent-data.test.ts","source_location":"L52"}],"snippet":"function taskMessage(sessionID: string, status: \"running\" | \"completed\" | \"interrupted\" = \"completed\"): SessionMessage {\n  if (status === \"running\") {\n    return {\n      parts: [\n        {\n          id: `part-${sessionID}`,\n          sessionID: \"parent-1\",\n          messageID: `msg-${sessionID}`,\n          type: \"tool\",\n          callID: `call-${sessionID}`,\n          tool: \"task\",\n          state: {\n            status: \"running\",\n            input: {\n              description: \"Scan reducer paths\",\n              subagent_type: \"explore\",\n            },\n            title: \"Reducer touchpoints\",\n            metadata: {\n              sessionId: sessionID,\n              toolcalls: 4,\n            },\n            time: { start: 1 },\n          },\n        },"},{"id":"subagent_data_test_question","label":"question()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/subagent-data.test.ts","source_location":"L138-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/subagent-data.test.ts","sour