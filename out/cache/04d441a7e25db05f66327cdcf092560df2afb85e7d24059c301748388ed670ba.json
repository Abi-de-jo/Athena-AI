{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_desktop_src_main_wsl_sidecar","nodes":[{"id":"packages_desktop_src_main_wsl_sidecar","label":"sidecar.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L1"}]},{"id":"packages_desktop_src_main_wsl_sidecar_spawnwslsidecar","label":"spawnWslSidecar()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L16-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L16"}],"snippet":"export async function spawnWslSidecar(\n  distro: string,\n  opts: { onLine?: (line: WslCommandLine) => void; healthTimeoutMs?: number } = {},\n): Promise<WslSidecar> {\n  const opencode = await resolveWslOpencode(distro)\n  if (!opencode) throw new Error(`OpenCode is not installed in ${distro}`)\n\n  const port = await allocatePort()\n  const password = randomUUID()\n  const username = \"rimuru-ai\"\n  const script = [\n    \"set -euo pipefail\",\n    'cd \"$HOME\" || cd /',\n    'PATH=$(awk -v RS=: -v ORS=: \\'$0 !~ /^\\\\/mnt\\\\//\\' <<<\"$PATH\" | sed \"s/:$//\")',\n    \"export PATH\",\n    \"export WSLENV=\",\n    \"export OPENCODE_EXPERIMENTAL_DISABLE_FILEWATCHER=true\",\n    \"export RIMURU_CLIENT=desktop\",\n    `export RIMURU_SERVER_USERNAME=${shellEscape(username)}`,\n    `export RIMURU_SERVER_PASSWORD=${shellEscape(password)}`,\n    'export XDG_STATE_HOME=\"$HOME/.local/state\"',\n    `exec ${shellEscape(opencode)} --print-logs --log-level ${app.isPackaged ? \"WARN\" : \"INFO\"} serve --hostname 0.0.0.0 --port ${port}`,\n  ].join(\"\\n\")\n  const child = spawn(\"wsl\", wslArgs([\"bash\", \"-se\"], distro), {\n    stdio: [\"pipe\", \"pipe\", \"pipe\"],"},{"id":"packages_desktop_src_main_wsl_sidecar_spawnwslsidecar_emit","label":"emit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L46-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L46"}],"snippet":"emit = (line: WslCommandLine) => {\n    if (!line.text.trim()) return\n    recentOutput.push(`[${line.stream}] ${line.text}`)\n    if (recentOutput.length > 12) recentOutput.shift()\n    opts.onLine?.(line)\n  }"},{"id":"packages_desktop_src_main_wsl_sidecar_allocateport","label":"allocatePort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L92-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L92"}],"snippet":"function allocatePort() {\n  return new Promise<number>((resolve, reject) => {\n    const server = createServer()\n    server.on(\"error\", reject)\n    server.listen(0, \"127.0.0.1\", () => {\n      const address = server.address()\n      if (typeof address !== \"object\" || !address) {\n        server.close()\n        reject(new Error(\"Failed to get port\"))\n        return\n      }\n      server.close(() => resolve(address.port))\n    })\n  })\n}"},{"id":"packages_desktop_src_main_wsl_sidecar_forwardlines","label":"forwardLines()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L108-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L108"}],"snippet":"function forwardLines(\n  stream: NodeJS.ReadableStream,\n  source: WslCommandLine[\"stream\"],\n  onLine: (line: WslCommandLine) => void,\n) {\n  let pending = \"\"\n  stream.setEncoding(\"utf8\")\n  stream.on(\"data\", (chunk: string) => {\n    pending += chunk\n    const lines = pending.split(/\\r?\\n/g)\n    pending = lines.pop() ?? \"\"\n    lines.forEach((text) => onLine({ stream: source, text }))\n  })\n  stream.on(\"end\", () => {\n    if (pending) onLine({ stream: source, text: pending })\n  })\n}"},{"id":"packages_desktop_src_main_wsl_sidecar_startupfailure","label":"startupFailure()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L126-L129","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L126"}],"snippet":"function startupFailure(code: number | null, signal: NodeJS.Signals | null, recentOutput: string[]) {\n  const suffix = recentOutput.length ? `\\n${recentOutput.join(\"\\n\")}` : \"\"\n  return `WSL server exited before becoming healthy (code=${code ?? \"null\"} signal=${signal ?? \"null\"})${suffix}`\n}"}],"edges":[{"source":"packages_desktop_src_main_wsl_sidecar","target":"child_process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/wsl/sidecar.ts","source_location":"L