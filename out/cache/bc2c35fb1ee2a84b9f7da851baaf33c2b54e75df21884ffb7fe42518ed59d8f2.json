{"__madarTsExtractorVersion":67,"__madarFileStem":"keymap","nodes":[{"id":"keymap","label":"keymap.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L1"}]},{"id":"keymap_isvisiblepalettecommand","label":"isVisiblePaletteCommand()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L49-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L49"}],"snippet":"function isVisiblePaletteCommand(command: Command) {\n  return command.hidden !== true && command.name !== COMMAND_PALETTE_COMMAND\n}"},{"id":"keymap_createopencodemodestack","label":"createOpencodeModeStack()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L53-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L53"}],"snippet":"export function createOpencodeModeStack(keymap: OpenTuiKeymap) {\n  keymap.setData(OPENCODE_MODE_KEY, OPENCODE_BASE_MODE)\n\n  const offFields = keymap.registerLayerFields({\n    mode(value, ctx) {\n      ctx.require(OPENCODE_MODE_KEY, value)\n    },\n  })\n\n  const stack: { id: symbol; mode: string }[] = []\n  let disposed = false\n\n  const update = () => {\n    keymap.setData(OPENCODE_MODE_KEY, stack.at(-1)?.mode ?? OPENCODE_BASE_MODE)\n  }\n\n  const stackApi = {\n    current() {\n      return stack.at(-1)?.mode ?? OPENCODE_BASE_MODE\n    },\n    push(mode: string) {\n      if (disposed) return () => {}\n      const id = Symbol(mode)\n      let active = true\n      stack.push({ id, mode })"},{"id":"keymap_createopencodemodestack_update","label":"update()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L65-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L65"}],"snippet":"update = () => {\n    keymap.setData(OPENCODE_MODE_KEY, stack.at(-1)?.mode ?? OPENCODE_BASE_MODE)\n  }"},{"id":"keymap_useopencodemodestack","label":"useOpencodeModeStack()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L102-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L102"}],"snippet":"export function useOpencodeModeStack() {\n  return getOpencodeModeStack(useOpencodeKeymap())\n}"},{"id":"keymap_getopencodemodestack","label":"getOpencodeModeStack()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L106-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L106"}],"snippet":"export function getOpencodeModeStack(keymap: OpenTuiKeymap) {\n  const value = modeStacks.get(keymap)\n  if (!value) throw new Error(\"Opencode mode stack is not registered for this keymap\")\n  return value\n}"},{"id":"keymap_expandkeyaliases","label":"expandKeyAliases()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L119-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L119"}],"snippet":"function expandKeyAliases(input: string) {\n  const result = Object.entries(KEY_ALIASES).reduce(\n    (acc, [alias, key]) => acc.replace(new RegExp(`(^|[+,\\\\s>])${alias}(?=$|[+,\\\\s<])`, \"gi\"), `$1${key}`),\n    input,\n  )\n  if (result === input) return\n  return result\n}"},{"id":"keymap_registerkeyaliases","label":"registerKeyAliases()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L128-L134","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L128"}],"snippet":"function registerKeyAliases(keymap: OpenTuiKeymap) {\n  return keymap.appendBindingExpander((ctx) => {\n    const key = expandKeyAliases(ctx.input)\n    if (!key) return\n    return [{ key, displays: ctx.displays }]\n  })\n}"},{"id":"keymap_hasmanagedtextareafocus","label":"hasManagedTextareaFocus()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L175-L178","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L175"}],"snippet":"function hasManagedTextareaFocus(renderer: CliRenderer) {\n  const editor = renderer.currentFocusedEditor\n  return editor instanceof TextareaRenderable && !(editor instanceof InputRenderable)\n}"},{"id":"keymap_leaderdisplay","label":"leaderDisplay()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L180-L184","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L180"}],"snippet":"function leaderDisplay(config: FormatConfig) {\n  const key = config.keybinds.get(LEADER_TOKEN)?.[0]?.key\n  if (!key) return TuiKeybind.LeaderDefault\n  return typeof key === \"string\" ? key : stringifyKeyStroke(key)\n}"},{"id":"keymap_leaderkey","label":"leaderKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L186-L188","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L186"}],"snippet":"function leaderKey(config: FormatConfig) {\n  return config.keybinds.get(LEADER_TOKEN)?.[0]?.key\n}"},{"id":"keymap_formatoptions","label":"formatOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L190-L204","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L190"}],"snippet":"function formatOptions(config: FormatConfig) {\n  return {\n    tokenDisplay: {\n      [LEADER_TOKEN]: leaderDisplay(config),\n    },\n    keyNameAliases: {\n      pageup: \"pgup\",\n      pagedown: \"pgdn\",\n      delete: \"del\",\n    },\n    modifierAliases: {\n      meta: \"alt\",\n    },\n  } as const\n}"},{"id":"keymap_formatkeysequence","label":"formatKeySequence()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L206-L208","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L206"}],"snippet":"export function formatKeySequence(parts: Parameters<typeof formatKeySequenceExtra>[0], config: FormatConfig) {\n  return formatKeySequenceExtra(parts, formatOptions(config))\n}"},{"id":"keymap_formatkeybindings","label":"formatKeyBindings()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L210-L212","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L210"}],"snippet":"export function formatKeyBindings(bindings: Parameters<typeof formatCommandBindingsExtra>[0], config: FormatConfig) {\n  return formatCommandBindingsExtra(bindings, formatOptions(config))\n}"},{"id":"keymap_registeropencodekeymap","label":"registerOpencodeKeymap()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L214-L244","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L214"}],"snippet":"export function registerOpencodeKeymap(keymap: OpenTuiKeymap, renderer: CliRenderer, config: ResolvedKeymapConfig) {\n  const modeStack = createOpencodeModeStack(keymap)\n  const offCommaBindings = registerCommaBindings(keymap)\n  const offAliasExpander = registerKeyAliases(keymap)\n  const offBaseLayout = registerBaseLayoutFallback(keymap)\n  const leader = leaderKey(config)\n  const offLeader = leader\n    ? registerTimedLeader(keymap, {\n        trigger: leader,\n        name: LEADER_TOKEN,\n        timeoutMs: config.leader_timeout,\n      })\n    : () => {}\n  const offEscape = registerEscapeClearsPendingSequence(keymap)\n  const offBackspace = registerBackspacePopsPendingSequence(keymap)\n  const offInputBindings = registerManagedTextareaLayer(keymap, renderer, {\n    enabled: () => hasManagedTextareaFocus(renderer),\n    bindings: config.keybinds.gather(\"input\", inputCommands),\n  })\n\n  return () => {\n    offInputBindings()\n    offBackspace()\n    offEscape()\n    offLeader()"},{"id":"keymap_useleaderactive","label":"useLeaderActive()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L246-L248","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L246"}],"snippet":"export function useLeaderActive(): Accessor<boolean> {\n  return useKeymapSelector((keymap: OpenTuiKeymap) => keymap.getPendingSequence()[0]?.tokenName === LEADER_TOKEN)\n}"},{"id":"keymap_usecommandshortcut","label":"useCommandShortcut()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L250-L258","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L250"}],"snippet":"export function useCommandShortcut(command: string): Accessor<string> {\n  const config = useTuiConfig()\n  return useKeymapSelector((keymap: OpenTuiKeymap) =>\n    formatKeySequence(\n      keymap.getCommandBindings({ visibility: \"registered\", commands: [command] }).get(command)?.[0]?.sequence,\n      config,\n    ),\n  )\n}"},{"id":"keymap_usecommandslashes","label":"useCommandSlashes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L260-L290","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L260"}],"snippet":"export function useCommandSlashes(): Accessor<readonly CommandSlashEntry[]> {\n  const keymap = useOpencodeKeymap()\n  const entries = useKeymapSelector((keymap: OpenTuiKeymap) =>\n    keymap.getCommandEntries({\n      visibility: \"reachable\",\n      namespace: \"palette\",\n      filter: isVisiblePaletteCommand,\n    }),\n  )\n\n  return createMemo<CommandSlashEntry[]>(() =>\n    entries().flatMap((entry) => {\n      const slashName = entry.command.slashName\n      if (typeof slashName !== \"string\" || !slashName) return []\n      const slashAliases = entry.command.slashAliases\n      return {\n        display: `/${slashName}`,\n        description:\n          typeof entry.command.desc === \"string\"\n            ? entry.command.desc\n            : typeof entry.command.title === \"string\"\n              ? entry.command.title\n              : undefined,\n        aliases: Array.isArray(slashAliases)\n          ? slashAliases.filter((alias): alias is string => typeof alias === \"string\").map((alias) => `/${alias}`)"}],"edges":[{"source":"keymap","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L1"}],"weight":1},{"source":"keymap","target":"opentui","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/keymap.tsx","source_location":"L2"}],"weight":1},{"source":"keymap","target":"keymap","relation":"imports_from","confidence":"EXTRACTED","