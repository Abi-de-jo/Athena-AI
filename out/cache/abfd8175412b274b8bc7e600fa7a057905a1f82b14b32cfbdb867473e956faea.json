ode","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L175-L179","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L175"}],"snippet":"handleOpenChange = (value: boolean) => {\n    if (pending()) return\n    if (props.locked && !value) return\n    setOpen(value)\n  }"},{"id":"basic_tool_basictool_trigger","label":"trigger()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L181-L250","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L181"}],"snippet":"trigger = () => (\n    <div\n      data-component=\"tool-trigger\"\n      data-clickable={props.clickable ? \"true\" : undefined}\n      data-hide-details={props.hideDetails ? \"true\" : undefined}\n    >\n      <div data-slot=\"basic-tool-tool-trigger-content\">\n        <div data-slot=\"basic-tool-tool-info\">\n          <Switch>\n            <Match when={isTriggerTitle(props.trigger) && props.trigger}>\n              {(title) => (\n                <div data-slot=\"basic-tool-tool-info-structured\">\n                  <div data-slot=\"basic-tool-tool-info-main\">\n                    <span\n                      data-slot=\"basic-tool-tool-title\"\n                      classList={{\n                        [title().titleClass ?? \"\"]: !!title().titleClass,\n                      }}\n                    >\n                      <TextShimmer text={title().title} active={pending()} />\n                    </span>\n                    <Show when={!pending()}>\n                      <Show when={title().subtitle}>\n                        <span\n                          data-slot=\"basic-tool-tool-subtitle\""},{"id":"basic_tool_label","label":"label()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L298-L301","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L298"}],"snippet":"function label(input: Record<string, unknown> | undefined) {\n  const keys = [\"description\", \"query\", \"url\", \"filePath\", \"path\", \"pattern\", \"name\"]\n  return keys.map((key) => input?.[key]).find((value): value is string => typeof value === \"string\" && value.length > 0)\n}"},{"id":"basic_tool_args","label":"args()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L303-L315","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L303"}],"snippet":"function args(input: Record<string, unknown> | undefined) {\n  if (!input) return []\n  const skip = new Set([\"description\", \"query\", \"url\", \"filePath\", \"path\", \"pattern\", \"name\"])\n  return Object.entries(input)\n    .filter(([key]) => !skip.has(key))\n    .flatMap(([key, value]) => {\n      if (typeof value === \"string\") return [`${key}=${value}`]\n      if (typeof value === \"number\") return [`${key}=${value}`]\n      if (typeof value === \"boolean\") return [`${key}=${value}`]\n      return []\n    })\n    .slice(0, 3)\n}"},{"id":"basic_tool_generictool","label":"GenericTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L317-L337","layer":"base","provenance":[{"capab