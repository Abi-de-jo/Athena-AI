\n  triggerHref?: string\n  clickable?: boolean\n}"},{"id":"basic_tool_flushdeferredmounts","label":"flushDeferredMounts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L48-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L48"}],"snippet":"function flushDeferredMounts() {\n  while (deferredMounts.length > 0) {\n    // Timeline tools are mounted top-to-bottom, but the viewport starts at the latest turn.\n    // Pop from the end so heavy default-open bodies near the bottom become interactive first.\n    const item = deferredMounts.pop()!\n    if (item.active) {\n      deferredFrame = deferredMounts.length > 0 ? requestAnimationFrame(flushDeferredMounts) : undefined\n      item.fn()\n      return\n    }\n  }\n  deferredFrame = undefined\n}"},{"id":"basic_tool_scheduledeferredflush","label":"scheduleDeferredFlush()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L62-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L62"}],"snippet":"function scheduleDeferredFlush() {\n  if (deferredFrame !== undefined) return\n  deferredFrame = requestAnimationFrame(() => {\n    deferredFrame = requestAnimationFrame(flushDeferredMounts)\n  })\n}"},{"id":"basic_tool_scheduledeferredmount","label":"scheduleDeferredMount()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L69-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L69"}],"snippet":"function scheduleDeferredMount(fn: () => void) {\n  const item = { active: true, fn }\n  deferredMounts.push(item)\n  scheduleDeferredFlush()\n  return () => {\n    item.active = false\n  }\n}"},{"id":"basic_tool_scheduleframemount","label":"scheduleFrameMount()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L78-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L78"}],"snippet":"function scheduleFrameMount(fn: () => void) {\n  const frame = requestAnimationFrame(fn)\n  return () => cancelAnimationFrame(frame)\n}"},{"id":"basic_tool_basictool","label":"BasicTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L83-L296","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L83"}],"snippet":"export function BasicTool(props: BasicToolProps) {\n  const [state, setState] = createStore({\n    open: props.defaultOpen ?? false,\n    ready: !props.defer && (props.defaultOpen ?? false),\n  })\n  const open = () => props.open ?? state.open\n  const ready = () => state.ready\n  const pending = () => props.status === \"pending\" || props.status === \"running\"\n  const hasChildren = () => (props.defer ? \"children\" in props : props.children)\n\n  let cancelReady: (() => void) | undefined\n\n  const cancel = () => {\n    cancelReady?.()\n    cancelReady = undefined\n  }\n\n  const scheduleReady = (initial = false) => {\n    cancel()\n    cancelReady = (initial ? scheduleDeferredMount : scheduleFrameMount)(() => {\n      cancelReady = undefined\n      if (!open()) return\n      setState(\"ready\", true)\n    })\n  }","node_kind":"component"},{"id":"basic_tool_basictool_open","label":"open()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L88"}],"snippet":"open = () => props.open ?? state.open"},{"id":"basic_tool_basictool_ready","label":"ready()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L89"}],"snippet":"ready = () => state.ready"},{"id":"basic_tool_basictool_pending","label":"pending()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L90"}],"snippet":"pending = () => props.status === \"pending\" || props.status === \"running\""},{"id":"basic_tool_basictool_haschildren","label":"hasChildren()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/basic-tool.tsx","source_location":"L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/co