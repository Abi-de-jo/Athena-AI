{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_test_session_llm.test","nodes":[{"id":"packages_rimuru_test_session_llm_test","label":"llm.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L1"}]},{"id":"packages_rimuru_test_session_llm_test_openaiconfig","label":"openAIConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L33-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L33"}],"snippet":"openAIConfig = (model: ModelsDev.Provider[\"models\"][string], baseURL: string): Partial<ConfigV1.Info> => {\n  const { experimental: _experimental, ...configModel } = model\n  return {\n    enabled_providers: [\"openai\"],\n    provider: {\n      openai: {\n        name: \"OpenAI\",\n        env: [\"OPENAI_API_KEY\"],\n        npm: \"@ai-sdk/openai\",\n        api: \"https://api.openai.com/v1\",\n        models: {\n          [model.id]: JSON.parse(JSON.stringify(configModel)) as ConfigModel,\n        },\n        options: {\n          apiKey: \"test-openai-key\",\n          baseURL,\n        },\n      },\n    },\n  }\n}"},{"id":"packages_rimuru_test_session_llm_test_drain","label":"drain()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L58"}],"snippet":"drain = (input: LLM.StreamInput) => LLM.Service.use((svc) => svc.stream(input).pipe(Stream.runDrain))"},{"id":"packages_rimuru_test_session_llm_test_drainwith","label":"drainWith()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L64-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L64"}],"snippet":"drainWith = (layer: Layer.Layer<LLM.Service>, input: LLM.StreamInput) =>\n  Effect.gen(function* () {\n    const ctx = yield* InstanceRef\n    if (!ctx) return yield* Effect.die(\"InstanceRef not provided\")\n    return yield* Effect.promise(() =>\n      Effect.runPromise(\n        LLM.Service.use((svc) => svc.stream(input).pipe(Stream.runDrain)).pipe(\n          Effect.provide(layer),\n          Effect.provideService(InstanceRef, ctx),\n        ),\n      ),\n    )\n  })"},{"id":"packages_rimuru_test_session_llm_test_llmlayerwithexecutor","label":"llmLayerWithExecutor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L78-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L78"}],"snippet":"function llmLayerWithExecutor(executor: Layer.Layer<RequestExecutor.Service>, flags: Partial<RuntimeFlags.Info> = {}) {\n  return LLM.layer.pipe(\n    Layer.provide(Auth.defaultLayer),\n    Layer.provide(Config.defaultLayer),\n    Layer.provide(Provider.defaultLayer),\n    Layer.provide(Plugin.defaultLayer),\n    Layer.provide(LLMClient.layer.pipe(Layer.provide(Layer.mergeAll(executor, WebSocketExecutor.layer)))),\n    Layer.provide(RuntimeFlags.layer(flags)),\n  )\n}"},{"id":"packages_rimuru_test_session_llm_test_deferred","label":"deferred()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L574-L580","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L574"}],"snippet":"function deferred<T>() {\n  const result = {} as { promise: Promise<T>; resolve: (value: T) => void }\n  result.promise = new Promise((resolve) => {\n    result.resolve = resolve\n  })\n  return result\n}"},{"id":"packages_rimuru_test_session_llm_test_waitrequest","label":"waitRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L582-L586","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L582"}],"snippet":"function waitRequest(pathname: string, response: Response) {\n  const pending = deferred<Capture>()\n  state.queue.push({ path: pathname, response, resolve: pending.resolve })\n  return pending.promise\n}"},{"id":"packages_rimuru_test_session_llm_test_timeout","label":"timeout()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L588-L592","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L588"}],"snippet":"function timeout(ms: number) {\n  return new Promise<never>((_, reject) => {\n    setTimeout(() => reject(new Error(`timed out after ${ms}ms`)), ms)\n  })\n}"},{"id":"packages_rimuru_test_session_llm_test_waitstreamingrequest","label":"waitStreamingRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L594-L638","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L594"}],"snippet":"function waitStreamingRequest(pathname: string) {\n  const request = deferred<Capture>()\n  const requestAborted = deferred<void>()\n  const responseCanceled = deferred<void>()\n  const encoder = new TextEncoder()\n\n  state.queue.push({\n    path: pathname,\n    resolve: request.resolve,\n    response(req: Request) {\n      req.signal.addEventListener(\"abort\", () => requestAborted.resolve(), { once: true })\n\n      return new Response(\n        new ReadableStream<Uint8Array>({\n          start(controller) {\n            controller.enqueue(\n              encoder.encode(\n                [\n                  `data: ${JSON.stringify({\n                    id: \"chatcmpl-abort\",\n                    object: \"chat.completion.chunk\",\n                    choices: [{ delta: { role: \"assistant\" } }],\n                  })}`,\n                ].join(\"\\n\\n\") + \"\\n\\n\",\n              ),"},{"id":"packages_rimuru_test_session_llm_test_createchatstream","label":"createChatStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L672-L700","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L672"}],"snippet":"function createChatStream(text: string) {\n  const payload =\n    [\n      `data: ${JSON.stringify({\n        id: \"chatcmpl-1\",\n        object: \"chat.completion.chunk\",\n        choices: [{ delta: { role: \"assistant\" } }],\n      })}`,\n      `data: ${JSON.stringify({\n        id: \"chatcmpl-1\",\n        object: \"chat.completion.chunk\",\n        choices: [{ delta: { content: text } }],\n      })}`,\n      `data: ${JSON.stringify({\n        id: \"chatcmpl-1\",\n        object: \"chat.completion.chunk\",\n        choices: [{ delta: {}, finish_reason: \"stop\" }],\n      })}`,\n      \"data: [DONE]\",\n    ].join(\"\\n\\n\") + \"\\n\\n\"\n\n  const encoder = new TextEncoder()\n  return new ReadableStream<Uint8Array>({\n    start(controller) {\n      controller.enqueue(encoder.encode(payload))"},{"id":"packages_rimuru_test_session_llm_test_loadfixture","label":"loadFixture()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L706-L712","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L706"}],"snippet":"function loadFixture(providerID: string, modelID: string) {\n  const provider = MODELS_FIXTURE[providerID]\n  if (!provider) throw new Error(`Missing provider in fixture: ${providerID}`)\n  const model = provider.models[modelID]\n  if (!model) throw new Error(`Missing model in fixture: ${modelID}`)\n  return { provider, model }\n}"},{"id":"packages_rimuru_test_session_llm_test_configmodel","label":"configModel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L714-L731","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L714"}],"snippet":"function configModel(model: ModelsDev.Model) {\n  return {\n    id: model.id,\n    name: model.name,\n    family: model.family,\n    release_date: model.release_date,\n    attachment: model.attachment,\n    reasoning: model.reasoning,\n    temperature: model.temperature,\n    tool_call: model.tool_call,\n    interleaved: model.interleaved,\n    cost: model.cost ? { ...model.cost, tiers: undefined } : undefined,\n    limit: model.limit,\n    modalities: model.modalities,\n    status: model.status,\n    provider: model.provider,\n  }\n}"},{"id":"packages_rimuru_test_session_llm_test_createeventstream","label":"createEventStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L733-L746","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L733"}],"snippet":"function createEventStream(chunks: unknown[], includeDone = false) {\n  const lines = chunks.map((chunk) => `data: ${typeof chunk === \"string\" ? chunk : JSON.stringify(chunk)}`)\n  if (includeDone) {\n    lines.push(\"data: [DONE]\")\n  }\n  const payload = lines.join(\"\\n\\n\") + \"\\n\\n\"\n  const encoder = new TextEncoder()\n  return new ReadableStream<Uint8Array>({\n    start(controller) {\n      controller.enqueue(encoder.encode(payload))\n      controller.close()\n    },\n  })\n}"},{"id":"packages_rimuru_test_session_llm_test_createeventresponse","label":"createEventResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L748-L753","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm.test.ts","source_location":"L748"}],"snippet":"function createEventResponse(chunks: unknown[], includeDone = false) {\n  retu