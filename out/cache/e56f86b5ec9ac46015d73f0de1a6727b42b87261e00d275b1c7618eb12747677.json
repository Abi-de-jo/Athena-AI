iption}</p>\n            <Show when={item.media.type === \"video\"}>\n              <video src={item.media.src} controls autoplay loop muted playsinline />\n            </Show>\n            <Show when={item.media.type === \"image\"}>\n              <img\n                src={item.media.src}\n                alt={item.title}\n                width={(item.media as { width: string }).width}\n                height={(item.media as { height: string }).height}\n              />\n            </Show>\n          </div>\n        )}\n      </For>\n    </div>","node_kind":"component"},{"id":"packages_console_app_src_routes_changelog_index_collapsiblesection","label":"CollapsibleSection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/changelog/index.tsx","source_location":"L75-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/changelog/index.tsx","source_location":"L75"}],"snippet":"function CollapsibleSection(props: { section: { title: string; items: string[] } }) {\n  const [open, setOpen] = createSignal(false)\n\n  return (\n    <div data-component=\"collapsible-section\">\n      <button data-slot=\"toggle\" onClick={() => setOpen(!open())}>\n        <span data-slot=\"icon\">{open() ? \"▾\" : \"▸\"}</span>\n        <span>{props.section.title}</span>\n      </button>\n      <Show when={open()}>\n        <ul>\n          <For each={props.section.items}>{(item) => <ReleaseItem item={item} />}</For>\n        </ul>\n      </Show>\n    </div>\n  )\n}","node_kind":"component"},{"id":"packages_console_app_src_routes_changelog_index_collapsiblesections","label":"CollapsibleSections()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/changelog/index.tsx","source_location":"L93-L99","layer":"base","provenance":[{"capability_id":"b