{"__madarTsExtractorVersion":67,"__madarFileStem":"file-icon","nodes":[{"id":"file_icon","label":"file-icon.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L1"}]},{"id":"file_icon_fileicon","label":"FileIcon()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L12-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L12"}],"snippet":"FileIcon: Component<FileIconProps> = (props) => {\n  const [local, rest] = splitProps(props, [\"node\", \"class\", \"classList\", \"expanded\", \"mono\"])\n  const name = createMemo(() => chooseIconName(local.node.path, local.node.type, local.expanded || false))\n  const id = `file-icon-mono-${createUniqueId()}`\n  return (\n    <svg\n      data-component=\"file-icon\"\n      {...rest}\n      classList={{\n        ...local.classList,\n        [local.class ?? \"\"]: !!local.class,\n      }}\n    >\n      <Show when={local.mono} fallback={<use href={`${sprite}#${name()}`} />}>\n        <defs>\n          <mask id={id} mask-type=\"alpha\">\n            <use href={`${sprite}#${name()}`} />\n          </mask>\n        </defs>\n        <rect width=\"100%\" height=\"100%\" fill=\"currentColor\" mask={`url(#${id})`} />\n      </Show>\n    </svg>\n  )\n}","node_kind":"component"},{"id":"file_icon_toopenvariant","label":"toOpenVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L543-L548","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L543"}],"snippet":"toOpenVariant = (icon: IconName): IconName => {\n  if (!icon.startsWith(\"Folder\")) return icon\n  if (icon.endsWith(\"_light\")) return icon.replace(\"_light\", \"Open_light\") as IconName\n  if (!icon.endsWith(\"Open\")) return (icon + \"Open\") as IconName\n  return icon\n}"},{"id":"file_icon_basenameof","label":"basenameOf()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L550","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L550"}],"snippet":"basenameOf = (p: string) => p.split(\"\\\\\").join(\"/\").split(\"/\").filter(Boolean).pop() ?? \"\""},{"id":"file_icon_foldernamevariants","label":"folderNameVariants()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L552-L555","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L552"}],"snippet":"folderNameVariants = (name: string) => {\n  const n = name.toLowerCase()\n  return [n, `.${n}`, `_${n}`, `__${n}__`]\n}"},{"id":"file_icon_dottedsuffixesdesc","label":"dottedSuffixesDesc()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L557-L565","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L557"}],"snippet":"dottedSuffixesDesc = (name: string) => {\n  const n = name.toLowerCase()\n  const idxs: number[] = []\n  for (let i = 0; i < n.length; i++) if (n[i] === \".\") idxs.push(i)\n  const out = new Set<string>()\n  out.add(n) // allow exact whole-name \"extensions\" like \"dockerfile\"\n  for (const i of idxs) if (i + 1 < n.length) out.add(n.slice(i + 1))\n  return Array.from(out).sort((a, b) => b.length - a.length) // longest first\n}"},{"id":"file_icon_chooseiconname","label":"chooseIconName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L567-L588","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L567"}],"snippet":"export function chooseIconName(path: string, type: \"directory\" | \"file\", expanded: boolean): IconName {\n  const base = basenameOf(path)\n  const baseLower = base.toLowerCase()\n\n  if (type === \"directory\") {\n    for (const cand of folderNameVariants(baseLower)) {\n      const icon = ICON_MAPS.folderNames[cand]\n      if (icon) return expanded ? toOpenVariant(icon) : icon\n    }\n    return expanded ? ICON_MAPS.defaults.folderOpen : ICON_MAPS.defaults.folder\n  }\n\n  const byName = ICON_MAPS.fileNames[baseLower]\n  if (byName) return byName\n\n  for (const ext of dottedSuffixesDesc(baseLower)) {\n    const icon = ICON_MAPS.fileExtensions[ext]\n    if (icon) return icon\n  }\n\n  return ICON_MAPS.defaults.file\n}"}],"edges":[{"source":"file_icon","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/file-icon.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/go