{"__madarTsExtractorVersion":67,"__madarFileStem":"electron-builder.config","nodes":[{"id":"electron_builder_config","label":"electron-builder.config.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/electron-builder.config.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/electron-builder.config.ts","source_location":"L1"}]},{"id":"electron_builder_config_signwindows","label":"signWindows()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/electron-builder.config.ts","source_location":"L18-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/electron-builder.config.ts","source_location":"L18"}],"snippet":"async function signWindows(configuration: { path: string }) {\n  if (process.platform !== \"win32\") return\n  if (process.env.GITHUB_ACTIONS !== \"true\") return\n\n  await execFileAsync(\n    \"pwsh\",\n    [\"-NoLogo\", \"-NoProfile\", \"-ExecutionPolicy\", \"Bypass\", \"-File\", signScript, configuration.path],\n    { cwd: rootDir },\n  )\n}"},{"id":"electron_builder_config_getbase","label":"getBase()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/electron-builder.config.ts","source_location":"L41-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/electron-builder.config.ts","source_location":"L41"}],"snippet":"getBase = (appId: string): Configuration => ({\n  artifactName: \"opencode-desktop-${os}-${arch}.${ext}\",\n  directories: {\n    output: \"dist\",\n    buildResources: \"resources\",\n  },\n  // Linux launchers are .desktop files, so this is the desktop file name,\n  // not just the app id. For prod, app id \"ai.opencode.desktop\" becomes\n  // \"ai.opencode.desktop.desktop\".\n  // https://developer.gnome.org/documentation/guidelines/maintainer/integrating.html\n  // https://www.electron.build/docs/linux/\n  extraMetadata: {\n    desktopName: `${appId}.desktop`,\n  },\n  files: [\"out/**/*\", \"resources/**/*\"],\n  extraResources: [\n    {\n      from: \"native/\",\n      to: \"native/\",\n      filter: [\"index.js\", \"index.d.ts\", \"build/Release/mac_window.node\", \"swift-build/**\"],\n    },\n  ],\n  mac: {\n    category: \"public.app-category.developer-tools\",\n    icon: `resources/icons/icon.icns`,"},{"id":"electron_builder_config_getconfig","label":"getConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/electron-builder.config.ts","source_location":"L109-L144","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/electron-builder.config.ts","source_location":"L109"}],"snippet":"function getConfig() {\n  const appId = APP_IDS[channel]\n  const base = getBase(appId)\n\n  switch (channel) {\n    case \"dev\": {\n      return {\n        ...base,\n        appId,\n        productName: \"OpenCode Dev\",\n        rpm: { packageName: \"rimuru-ai-dev\" },\n      }\n    }\n    case \"beta\": {\n      return {\n        ...base,\n        appId,\n        productName: \"OpenCode Beta\",\n        protocols: { name: \"OpenCode Beta\", schemes: [\"rimuru-ai\"] },\n        publish: { provider: \"github\", owner: \"gowdaman\", repo: \"opencode-beta\", channel: \"latest\" },\n        rpm: { packageName: \"opencode-beta\" },\n      }\n    }\n    case \"prod\": {\n      return {"}],"edges":[{"source":"electron_builder_config","target":"child_process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/pers