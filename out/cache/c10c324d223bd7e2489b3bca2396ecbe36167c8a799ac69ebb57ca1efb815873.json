{"__madarTsExtractorVersion":67,"__madarFileStem":"gemini-tool-schema","nodes":[{"id":"gemini_tool_schema","label":"gemini-tool-schema.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L1"}]},{"id":"gemini_tool_schema_hascombiner","label":"hasCombiner()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L25-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L25"}],"snippet":"hasCombiner = (schema: unknown) =>\n  isRecord(schema) && (Array.isArray(schema.anyOf) || Array.isArray(schema.oneOf) || Array.isArray(schema.allOf))"},{"id":"gemini_tool_schema_hasschemaintent","label":"hasSchemaIntent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L28-L29","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L28"}],"snippet":"hasSchemaIntent = (schema: unknown) =>\n  isRecord(schema) && (hasCombiner(schema) || SCHEMA_INTENT_KEYS.some((key) => key in schema))"},{"id":"gemini_tool_schema_sanitizenode","label":"sanitizeNode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L31-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L31"}],"snippet":"sanitizeNode = (schema: unknown): unknown => {\n  if (!isRecord(schema)) return Array.isArray(schema) ? schema.map(sanitizeNode) : schema\n\n  const result: Record<string, unknown> = Object.fromEntries(\n    Object.entries(schema).map(([key, value]) => [\n      key,\n      key === \"enum\" && Array.isArray(value) ? value.map(String) : sanitizeNode(value),\n    ]),\n  )\n\n  if (Array.isArray(result.enum) && (result.type === \"integer\" || result.type === \"number\")) result.type = \"string\"\n\n  const properties = result.properties\n  if (result.type === \"object\" && isRecord(properties) && Array.isArray(result.required)) {\n    result.required = result.required.filter((field) => typeof field === \"string\" && field in properties)\n  }\n\n  if (result.type === \"array\" && !hasCombiner(result)) {\n    result.items = result.items ?? {}\n    if (isRecord(result.items) && !hasSchemaIntent(result.items)) result.items = { ...result.items, type: \"string\" }\n  }\n\n  if (typeof result.type === \"string\" && result.type !== \"object\" && !hasCombiner(result)) {\n    delete result.properties\n    delete result.required"},{"id":"gemini_tool_schema_emptyobjectschema","label":"emptyObjectSchema()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L61-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L61"}],"snippet":"emptyObjectSchema = (schema: Record<string, unknown>) =>\n  schema.type === \"object\" &&\n  (!isRecord(schema.properties) || Object.keys(schema.properties).length === 0) &&\n  !schema.additionalProperties"},{"id":"gemini_tool_schema_projectnode","label":"projectNode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L66-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L66"}],"snippet":"projectNode = (schema: unknown): Record<string, unknown> | undefined => {\n  if (!isRecord(schema)) return undefined\n  if (emptyObjectSchema(schema)) return undefined\n  return Object.fromEntries(\n    [\n      [\"description\", schema.description],\n      [\"required\", schema.required],\n      [\"format\", schema.format],\n      [\"type\", Array.isArray(schema.type) ? schema.type.filter((type) => type !== \"null\")[0] : schema.type],\n      [\"nullable\", Array.isArray(schema.type) && schema.type.includes(\"null\") ? true : undefined],\n      [\"enum\", schema.const !== undefined ? [schema.const] : schema.enum],\n      [\n        \"properties\",\n        isRecord(schema.properties)\n          ? Object.fromEntries(Object.entries(schema.properties).map(([key, value]) => [key, projectNode(value)]))\n          : undefined,\n      ],\n      [\n        \"items\",\n        Array.isArray(schema.items)\n          ? schema.items.map(projectNode)\n          : schema.items === undefined\n            ? undefined\n            : projectNode(schema.items),\n      ],"},{"id":"gemini_tool_schema_convert","label":"convert()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L99","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L99"}],"snippet":"convert = (schema: unknown) => projectNode(sanitizeNode(schema))"}],"edges":[{"source":"gemini_tool_schema","target":"shared","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L1"}],"weight":1},{"source":"gemini_tool_schema","target":"gemini_tool_schema_hascombiner","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L25","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L25"}],"weight":1},{"source":"gemini_tool_schema","target":"gemini_tool_schema_hasschemaintent","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L28"}],"weight":1},{"source":"gemini_tool_schema","target":"gemini_tool_schema_sanitizenode","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/utils/gemini-tool-schema.ts","source_location":"L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/P