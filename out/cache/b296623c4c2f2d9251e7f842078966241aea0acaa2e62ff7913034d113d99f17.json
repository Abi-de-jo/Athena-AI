{"__madarTsExtractorVersion":67,"__madarFileStem":"session-diff","nodes":[{"id":"session_diff","label":"session-diff.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L1"}]},{"id":"session_diff_resolvefilediff","label":"resolveFileDiff()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L30-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L30"}],"snippet":"export function resolveFileDiff(diff: DiffSource) {\n  if (typeof diff.patch === \"string\") return fileDiffFromPatch(diff.file, diff.patch)\n  return fileDiffFromContent(\n    diff.file,\n    typeof diff.before === \"string\" ? diff.before : \"\",\n    typeof diff.after === \"string\" ? diff.after : \"\",\n  )\n}"},{"id":"session_diff_normalize","label":"normalize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L39-L47","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L39"}],"snippet":"export function normalize(diff: ReviewDiff): ViewDiff {\n  return {\n    file: diff.file,\n    additions: diff.additions,\n    deletions: diff.deletions,\n    status: diff.status,\n    fileDiff: resolveFileDiff(diff),\n  }\n}"},{"id":"session_diff_text","label":"text()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L49-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L49"}],"snippet":"export function text(diff: ViewDiff, side: \"deletions\" | \"additions\") {\n  if (side === \"deletions\") return diff.fileDiff.deletionLines.join(\"\")\n  return diff.fileDiff.additionLines.join(\"\")\n}"},{"id":"session_diff_filedifffrompatch","label":"fileDiffFromPatch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L54-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L54"}],"snippet":"function fileDiffFromPatch(file: string, patch: string) {\n  const key = `${file}\\0${patch}`\n  const hit = patchFileDiffCache.get(key)\n  if (hit) {\n    patchFileDiffCache.delete(key)\n    patchFileDiffCache.set(key, hit)\n    return hit\n  }\n\n  const contents = completePatchContents(patch)\n  const input = contents ? undefined : patchInput(file, patch)\n  const value = contents\n    ? fileDiffFromContent(file, contents.before, contents.after)\n    : ((input ? parsePatchFiles(input)[0]?.files[0] : undefined) ?? emptyFileDiff(file))\n  patchFileDiffCache.set(key, value)\n  while (patchFileDiffCache.size > diffCacheLimit) patchFileDiffCache.delete(patchFileDiffCache.keys().next().value!)\n  return value\n}"},{"id":"session_diff_completepatchcontents","label":"completePatchContents()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L73-L123","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L73"}],"snippet":"function completePatchContents(patch: string) {\n  try {\n    const parsed = parsePatch(patch)[0]\n    if (!parsed || (!parsed.index && !parsed.oldFileName && !parsed.newFileName)) return\n    // Snapshot and VCS producers request full context. Tool patches use jsdiff's shorter default context.\n    if (!patch.startsWith(\"diff --git \") && !/^--- [^\\n]*\\t\\r?\\n\\+\\+\\+ [^\\n]*\\t(?:\\r?\\n|$)/m.test(patch)) return\n    // Full patches collapse into one leading hunk. Separated hunks omit ranges and must stay partial.\n    if (parsed.hunks.length !== 1) return\n\n    const hunk = parsed.hunks[0]\n    if (!hunk || hunk.oldStart > 1 || hunk.newStart > 1) return\n\n    const before: Array<{ text: string; newline: boolean }> = []\n    const after: Array<{ text: string; newline: boolean }> = []\n    let previous: \"-\" | \"+\" | \" \" | undefined\n\n    for (const line of hunk.lines) {\n      if (line.startsWith(\"\\\\\")) {\n        if (previous === \"-\" || previous === \" \") {\n          const value = before.at(-1)\n          if (value) value.newline = false\n        }\n        if (previous === \"+\" || previous === \" \") {\n          const value = after.at(-1)\n          if (value) value.newline = false"},{"id":"session_diff_completepatchcontents_text","label":"text()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L117-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L117"}],"snippet":"text = (lines: Array<{ text: string; newline: boolean }>) =>\n      lines.map((line) => line.text + (line.newline ? \"\\n\" : \"\")).join(\"\")"},{"id":"session_diff_patchinput","label":"patchInput()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L125-L135","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L125"}],"snippet":"function patchInput(file: string, patch: string) {\n  try {\n    const parsed = parsePatch(patch)[0]\n    if (!parsed) return\n    if (parsed.index || parsed.oldFileName || parsed.newFileName) return patch\n    if (!parsed.hunks.length) return\n    return `Index: ${file}\\n===================================================================\\n--- ${file}\\t\\n+++ ${file}\\t\\n${patch}`\n  } catch {\n    return\n  }\n}"},{"id":"session_diff_filedifffromcontent","label":"fileDiffFromContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L137-L140","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L137"}],"snippet":"function fileDiffFromContent(file: string, before: string, after: string) {\n  if (!before && !after) return emptyFileDiff(file)\n  return parseDiffFromFile({ name: file, contents: before }, { name: file, contents: after })\n}"},{"id":"session_diff_emptyfilediff","label":"emptyFileDiff()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L142-L144","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L142"}],"snippet":"function emptyFileDiff(file: string) {\n  return parseDiffFromFile({ name: file, contents: \"\" }, { name: file, contents: \"\" })\n}"}],"edges":[{"source":"session_diff","target":"diffs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L1"}],"weight":1},{"source":"session_diff","target":"diff","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L2"}],"weight":1},{"source":"session_diff","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L3"}],"weight":1},{"source":"session_diff","target":"session_diff_resolvefilediff","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/session-diff.ts","source_location":"L30"}],"weight":1},{"source":"session_diff","target":"session_diff