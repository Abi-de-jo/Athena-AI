{"__madarTsExtractorVersion":67,"__madarFileStem":"log-processor","nodes":[{"id":"log_processor","label":"log-processor.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L1"}]},{"id":"log_processor_getlakeingest","label":"getLakeIngest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L89-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L89"}],"snippet":"function getLakeIngest(): { url: string; secret: string } | undefined {\n  try {\n    return Resource.LakeIngest\n  } catch {\n    return undefined\n  }\n}"},{"id":"log_processor_tolakeevent","label":"toLakeEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L97-L153","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L97"}],"snippet":"function toLakeEvent(time: string, data: Record<string, unknown>) {\n  return {\n    _datalake_key: \"inference.event\",\n    event_timestamp: time,\n    event_date: time.slice(0, 10),\n    event_type: string(data, \"event_type\"),\n    dataset: \"zen\",\n    cf_continent: string(data, \"cf.continent\"),\n    cf_country: string(data, \"cf.country\"),\n    cf_city: string(data, \"cf.city\"),\n    cf_region: string(data, \"cf.region\"),\n    cf_latitude: number(data, \"cf.latitude\"),\n    cf_longitude: number(data, \"cf.longitude\"),\n    cf_timezone: string(data, \"cf.timezone\"),\n    duration: number(data, \"duration\"),\n    request_length: integer(data, \"request_length\"),\n    status: integer(data, \"status\"),\n    ip: string(data, \"ip\"),\n    ip_prefix: string(data, \"ip.prefix\"),\n    is_stream: boolean(data, \"is_stream\"),\n    session: string(data, \"session\"),\n    request: string(data, \"request\"),\n    client: string(data, \"client\"),\n    user_agent: string(data, \"user_agent\"),\n    model_variant: string(data, \"model.variant\"),"},{"id":"log_processor_ipprefix","label":"ipPrefix()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L160-L179","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L160"}],"snippet":"function ipPrefix(ip: string | undefined) {\n  if (!ip) return undefined\n  if (ip.includes(\".\") && !ip.includes(\":\")) return `${ip}/32`\n  if (!ip.includes(\":\")) return undefined\n\n  // Expand \"::\" to its full form, then keep the first 4 hextets.\n  const [head, tail] = ip.split(\"::\") as [string, string | undefined]\n  const headParts = head ? head.split(\":\") : []\n  const tailParts = tail !== undefined ? tail.split(\":\") : []\n  const missing = 8 - headParts.length - tailParts.length\n  if (missing < 0) return undefined\n  const full = [...headParts, ...new Array(missing).fill(\"0\"), ...tailParts]\n  if (full.length !== 8) return undefined\n\n  const prefix = full\n    .slice(0, 4)\n    .map((part) => part.toLowerCase().replace(/^0+(?=.)/, \"\"))\n    .join(\":\")\n  return `${prefix}::/64`\n}"},{"id":"log_processor_string","label":"string()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L181-L186","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L181"}],"snippet":"function string(data: Record<string, unknown>, key: string) {\n  const value = data[key]\n  if (typeof value === \"string\") return value\n  if (typeof value === \"number\" || typeof value === \"boolean\") return String(value)\n  return undefined\n}"},{"id":"log_processor_boolean","label":"boolean()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L188-L193","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L188"}],"snippet":"function boolean(data: Record<string, unknown>, key: string) {\n  const value = data[key]\n  if (typeof value === \"boolean\") return value\n  if (typeof value === \"string\") return value === \"true\" ? true : value === \"false\" ? false : undefined\n  return undefined\n}"},{"id":"log_processor_integer","label":"integer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L195-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L195"}],"snippet":"function integer(data: Record<string, unknown>, key: string) {\n  const value = number(data, key)\n  if (value === undefined) return undefined\n  return Math.round(value)\n}"},{"id":"log_processor_number","label":"number()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L201-L209","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L201"}],"snippet":"function number(data: Record<string, unknown>, key: string) {\n  const value = data[key]\n  if (typeof value === \"number\") return Number.isFinite(value) ? value : undefined\n  if (typeof value === \"string\") {\n    const parsed = Number(value)\n    return Number.isFinite(parsed) ? parsed : undefined\n  }\n  return undefined\n}"}],"edges":[{"source":"log_processor","target":"console_resource","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L1"}],"weight":1},{"source":"log_processor","target":"workers_types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L2"}],"weight":1},{"source":"log_processor","target":"log_processor_getlakeingest","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/function/src/log-processor.ts","source_location":"L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/g