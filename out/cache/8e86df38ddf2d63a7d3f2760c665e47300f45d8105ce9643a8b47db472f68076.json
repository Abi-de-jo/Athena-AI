{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_cli_src_commands_handlers_serve","nodes":[{"id":"packages_cli_src_commands_handlers_serve","label":"serve.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L1"}]},{"id":"packages_cli_src_commands_handlers_serve_listen","label":"listen()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L28-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L28"}],"snippet":"function listen(hostname: string, port: Option.Option<number>, password: string) {\n  if (Option.isSome(port)) return bind(hostname, port.value, password)\n  // Preserve the familiar default when available, but let the OS choose a free\n  // port when another local server already owns 4096.\n  return bind(hostname, 4096, password).pipe(Effect.catch(() => bind(hostname, 0, password)))\n}"},{"id":"packages_cli_src_commands_handlers_serve_bind","label":"bind()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L35-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L35"}],"snippet":"function bind(hostname: string, port: number, password: string) {\n  return Layer.build(\n    HttpRouter.serve(createRoutes(password), { disableListenLog: true, disableLogger: true }).pipe(\n      Layer.provideMerge(NodeHttpServer.layer(() => createServer(), { port, host: hostname })),\n      Layer.provide(Credential.defaultLayer),\n      Layer.provide(PermissionSaved.defaultLayer),\n    ),\n  ).pipe(Effect.map((context) => Context.get(context, HttpServer.HttpServer).address))\n}"}],"edges":[{"source":"packages_cli_src_commands_handlers_serve","target":"platform_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L1"}],"weight":1},{"source":"packages_cli_src_commands_handlers_serve","target":"credential","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L2"}],"weight":1},{"source":"packages_cli_src_commands_handlers_serve","target":"saved","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/handlers/serve.ts","source_location":"L3"}],"weight":1},{"source":"packages_cli_src_commands_handlers_serve","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/commands/han