app/src/lib/form-error.ts","source_location":"L64"}],"snippet":"export function localizeError(t: (key: Key, params?: Record<string, string | number>) => string, error?: string) {\n  if (!error) return \"\"\n\n  if (error.startsWith(\"error.reloadAmountMin:\")) {\n    const amount = Number(error.split(\":\")[1] ?? 0)\n    return t(\"error.reloadAmountMin\", { amount })\n  }\n\n  if (error.startsWith(\"error.reloadTriggerMin:\")) {\n    const amount = Number(error.split(\":\")[1] ?? 0)\n    return t(\"error.reloadTriggerMin\", { amount })\n  }\n\n  const amount = error.match(/^Reload amount must be at least \\$(\\d+)$/)\n  if (amount) return t(\"error.reloadAmountMin\", { amount: Number(amount[1]) })\n\n  const trigger = error.match(/^Balance trigger must be at least \\$(\\d+)$/)\n  if (trigger) return t(\"error.reloadTriggerMin\", { amount: Number(trigger[1]) })\n\n  const key = map[error as keyof typeof map]\n  if (key) return t(key)\n  return error\n}"}],"edges":[{"source":"form_error","target":"i18n","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/form-error.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/form-error.ts","source_location":"L1"}],"weight":1},{"source":"form_error","target":"form_error_formerrorreloadamountmin","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/form-error.ts","source_location":"L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/form-error.ts","source_location":"L56"}],"weight":1},{"source":"form_error","target":"form_error_formerrorreloadtriggermin","relation":"contains","conf