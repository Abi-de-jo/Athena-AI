{"__madarTsExtractorVersion":67,"__madarFileStem":"llm-native-recorded.test","nodes":[{"id":"llm_native_recorded_test","label":"llm-native-recorded.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L1"}]},{"id":"llm_native_recorded_test_zenurl","label":"zenURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L32"}],"snippet":"zenURL = (connection: string) => `https://github.com/gowdaman-dev/rimuru-ai/proxy/connections/${connection}/v1`"},{"id":"llm_native_recorded_test_clonemodel","label":"cloneModel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L57-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L57"}],"snippet":"cloneModel = (model: ModelsDev.Provider[\"models\"][string]) => {\n  const cloned = structuredClone(model)\n  const { experimental, ...rest } = cloned\n  // oxlint-disable-next-line typescript-eslint/no-unsafe-type-assertion -- The config schema accepts the same model shape except object-valued experimental metadata.\n  if (typeof experimental === \"boolean\") {\n    // oxlint-disable-next-line typescript-eslint/no-unsafe-type-assertion -- The fixture model already matches config input when experimental is boolean.\n    return cloned as NonNullable<NonNullable<ConfigV1.Info[\"provider\"]>[string][\"models\"]>[string]\n  }\n  // oxlint-disable-next-line typescript-eslint/no-unsafe-type-assertion -- Dropping non-boolean experimental metadata makes the fixture model match config input.\n  return rest as NonNullable<NonNullable<ConfigV1.Info[\"provider\"]>[string][\"models\"]>[string]\n}"},{"id":"llm_native_recorded_test_envvalue","label":"envValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L69"}],"snippet":"envValue = (...names: string[]) => names.map((name) => process.env[name]).find(Boolean)"},{"id":"llm_native_recorded_test_decoderecordopenaioauth","label":"decodeRecordOpenAIOAuth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L82-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L82"}],"snippet":"function decodeRecordOpenAIOAuth() {\n  const value = process.env.OPENCODE_RECORD_OPENAI_AUTH\n  if (!value) return undefined\n  try {\n    const auth = Option.getOrUndefined(decodeAuth(JSON.parse(value)))\n    return auth?.type === \"oauth\" ? auth : undefined\n  } catch {\n    return undefined\n  }\n}"},{"id":"llm_native_recorded_test_providerconfig","label":"providerConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L93-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L93"}],"snippet":"providerConfig = (input: {\n  readonly providerID: ProviderV2.ID\n  readonly name: string\n  readonly env: string[]\n  readonly npm: string\n  readonly api: string\n  readonly model: ModelsDev.Provider[\"models\"][string]\n  readonly options: Record<string, unknown>\n}): Partial<ConfigV1.Info> => ({\n  enabled_providers: [input.providerID],\n  provider: {\n    [input.providerID]: {\n      name: input.name,\n      env: input.env,\n      npm: input.npm,\n      api: input.api,\n      models: { [input.model.id]: cloneModel(input.model) },\n      options: input.options,\n    },\n  },\n})"},{"id":"llm_native_recorded_test_isselected","label":"isSelected()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L218-L223","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L218"}],"snippet":"function isSelected(scenario: RecordedScenario) {\n  if (selectedScenarios.size === 0) return true\n  return [scenario.id, scenario.name, scenario.providerID, scenario.cassette, ...scenario.tags]\n    .map((item) => item.toLowerCase())\n    .some((item) => selectedScenarios.has(item))\n}"},{"id":"llm_native_recorded_test_canrun","label":"canRun()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L225-L228","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L225"}],"snippet":"canRun = (scenario: RecordedScenario) =>\n  shouldRecord\n    ? scenario.canRecord()\n    : HttpRecorderInternal.hasCassetteSync(scenario.cassette, { directory: FIXTURES_DIR })"},{"id":"llm_native_recorded_test_recorderror","label":"recordError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L230-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L230"}],"snippet":"recordError = (scenario: RecordedScenario) =>\n  scenario.id === \"openai-oauth\"\n    ? \"Set OPENCODE_RECORD_OPENAI_AUTH to an OAuth auth JSON object in the recording environment.\"\n    : `Missing recording credentials for ${scenario.name}.`"},{"id":"llm_native_recorded_test_redactrecordedbody","label":"redactRecordedBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L235-L239","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L235"}],"snippet":"redactRecordedBody = (body: string) =>\n  body\n    .replace(/wrk_[A-Z0-9]+/g, \"wrk_redacted\")\n    .replace(/\"safety_identifier\"\\s*:\\s*\"user-[^\"]+\"/g, '\"safety_identifier\":\"user_redacted\"')\n    .replace(/\"(access|access_token|refresh|refresh_token|accountId|account_id)\"\\s*:\\s*\"[^\"]+\"/g, '\"$1\":\"redacted\"')"},{"id":"llm_native_recorded_test_authlayer","label":"authLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L241-L248","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L241"}],"snippet":"function authLayer(scenario: RecordedScenario) {\n  const replayAuth = shouldRecord ? scenario.recordAuth?.() : scenario.replayAuth\n  if (!replayAuth) return Auth.defaultLayer\n  return Layer.mock(Auth.Service)({\n    get: (providerID) => Effect.succeed(providerID === scenario.providerID ? replayAuth : undefined),\n    all: () => Effect.succeed({ [scenario.providerID]: replayAuth }),\n  })\n}"},{"id":"llm_native_recorded_test_loadfixture","label":"loadFixture()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L250-L257","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L250"}],"snippet":"async function loadFixture(providerID: string, modelID: string) {\n  const data = await modelsFixture\n  const provider = data[providerID]\n  if (!provider) throw new Error(`Missing provider in fixture: ${providerID}`)\n  const model = provider.models[modelID]\n  if (!model) throw new Error(`Missing model in fixture: ${modelID}`)\n  return model\n}"},{"id":"llm_native_recorded_test_recordednativellmlayer","label":"recordedNativeLLMLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L263-L308","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L263"}],"snippet":"function recordedNativeLLMLayer(scenario: RecordedScenario) {\n  const auth = authLayer(scenario)\n  const provider = Provider.layer.pipe(\n    Layer.provide(FSUtil.defaultLayer),\n    Layer.provide(Env.defaultLayer),\n    Layer.provide(Config.defaultLayer),\n    Layer.provide(auth),\n    Layer.provide(Plugin.defaultLayer),\n    Layer.provide(ModelsDev.defaultLayer),\n    Layer.provide(RuntimeFlags.defaultLayer),\n  )\n  // Only the HTTP client is recorded; RequestExecutor and the opencode LLM stack remain real.\n  const metadata = {\n    provider: scenario.providerID,\n    protocol: scenario.protocol,\n    route: scenario.protocol,\n    tags: scenario.tags,\n  }\n  const redact = {\n    url: (url: string) => url.replace(/\\/proxy\\/connections\\/[^/]+\\/v1/, \"/proxy/connections/{connection}/v1\"),\n    body: redactRecordedBody,\n  }\n  const recordedHttp = shouldRecord\n    ? HttpRecorderInternal.cassetteLayer(scenario.cassette, {\n        directory: FIXTURES_DIR,"},{"id":"llm_native_recorded_test_writeconfig","label":"writeConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L310-L316","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L310"}],"snippet":"writeConfig = (directory: string, scenario: RecordedScenario, model: ModelsDev.Provider[\"models\"][string]) =>\n  Effect.promise(() =>\n    Bun.write(\n      path.join(directory, \"rimuru.json\"),\n      JSON.stringify({ $schema: \"https://github.com/gowdaman-dev/rimuru-ai/config.json\", ...scenario.config(model) }),\n    ),\n  )"},{"id":"llm_native_recorded_test_collect","label":"collect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L318-L322","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L318"}],"snippet":"collect = (input: LLM.StreamInput) =>\n  Effect.gen(function* () {\n    const llm = yield* LLM.Service\n    return Array.from(yield* llm.stream(input).pipe(Stream.runCollect))\n  })"},{"id":"llm_native_recorded_test_toolroundtrip","label":"toolRoundtrip()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L335-L361","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L335"}],"snippet":"toolRoundtrip = (\n  events: ReadonlyArray<LLMEvent>,\n  call: { readonly id: string; readonly name: string; readonly input: unknown },\n  result: JSONValue,\n): ModelMessage[] => [\n  {\n    role: \"assistant\",\n    content: [\n      ...events.filter(LLMEvent.is.reasoningEnd).map((part) => ({\n        type: \"reasoning\" as const,\n        text: events\n          .filter(LLMEvent.is.reasoningDelta)\n          .filter((event) => event.id === part.id)\n          .map((event) => event.text)\n          .join(\"\"),\n        providerMetadata: part.providerMetadata,\n      })),\n      { type: \"tool-call\", toolCallId: call.id, toolName: call.name, input: call.input },\n    ],\n  },\n  {\n    role: \"tool\",\n    content: [\n      { type: \"tool-result\", toolCallId: call.id, toolName: call.name, output: { type: \"json\", value: result } },\n    ],"},{"id":"llm_native_recorded_test_drivetoolloop","label":"driveToolLoop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L363-L416","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L363"}],"snippet":"driveToolLoop = (scenario: RecordedScenario) =>\n  Effect.gen(function* () {\n    const test = yield* TestInstance\n    const model = yield* Effect.promise(() => loadFixture(scenario.providerID, scenario.modelID))\n    yield* writeConfig(test.directory, scenario, model)\n\n    const stableID = scenario.stableID ?? scenario.providerID\n    const sessionID = SessionID.make(`session-recorded-${stableID}-loop`)\n    const modelID = ModelV2.ID.make(model.id)\n    const agent = {\n      name: \"test\",\n      mode: \"primary\",\n      prompt: \"Answer using tools when appropriate.\",\n      options: {},\n      permission: [{ permission: \"*\", pattern: \"*\", action: \"allow\" }],\n      temperature: 0,\n    } satisfies Agent.Info\n    const provider = yield* Provider.Service\n    const resolved = yield* provider.getModel(scenario.providerID, modelID)\n\n    const userMessage = { role: \"user\", content: WEATHER_USER } satisfies ModelMessage\n    const base = {\n      user: {\n        id: MessageID.make(`msg_user-recorded-${stableID}-loop`),\n        sessionID,"}],"edges":[{"source":"llm_native_recorded_test","target":"config","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/session/llm-native-recorded.test.ts","source_location":"L1"}],"weight":1},{"