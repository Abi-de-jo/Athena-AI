{"__madarTsExtractorVersion":67,"__madarFileStem":"create-auto-scroll","nodes":[{"id":"create_auto_scroll","label":"create-auto-scroll.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L1"}]},{"id":"create_auto_scroll_autoscrolloptions","label":"AutoScrollOptions","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L6-L11","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L6"}],"snippet":"export interface AutoScrollOptions {\n  working: () => boolean\n  onUserInteracted?: () => void\n  overflowAnchor?: \"none\" | \"auto\" | \"dynamic\"\n  bottomThreshold?: number\n}"},{"id":"create_auto_scroll_createautoscroll","label":"createAutoScroll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L13-L237","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L13"}],"snippet":"export function createAutoScroll(options: AutoScrollOptions) {\n  let settling = false\n  let settleTimer: ReturnType<typeof setTimeout> | undefined\n  let autoTimer: ReturnType<typeof setTimeout> | undefined\n  let auto: { top: number; time: number } | undefined\n\n  const threshold = () => options.bottomThreshold ?? 10\n\n  const [store, setStore] = createStore({\n    contentRef: undefined as HTMLElement | undefined,\n    scrollRef: undefined as HTMLElement | undefined,\n    userScrolled: false,\n  })\n\n  const active = () => options.working() || settling\n\n  const distanceFromBottom = (el: HTMLElement) => {\n    return el.scrollHeight - el.clientHeight - el.scrollTop\n  }\n\n  const canScroll = (el: HTMLElement) => {\n    return el.scrollHeight - el.clientHeight > 1\n  }\n\n  // Browsers can dispatch scroll events asynchronously. If new content arrives"},{"id":"create_auto_scroll_createautoscroll_threshold","label":"threshold()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L19","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L19"}],"snippet":"threshold = () => options.bottomThreshold ?? 10"},{"id":"create_auto_scroll_createautoscroll_active","label":"active()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L27"}],"snippet":"active = () => options.working() || settling"},{"id":"create_auto_scroll_createautoscroll_distancefrombottom","label":"distanceFromBottom()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L29-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L29"}],"snippet":"distanceFromBottom = (el: HTMLElement) => {\n    return el.scrollHeight - el.clientHeight - el.scrollTop\n  }"},{"id":"create_auto_scroll_createautoscroll_canscroll","label":"canScroll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L33-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L33"}],"snippet":"canScroll = (el: HTMLElement) => {\n    return el.scrollHeight - el.clientHeight > 1\n  }"},{"id":"create_auto_scroll_createautoscroll_markauto","label":"markAuto()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L41-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L41"}],"snippet":"markAuto = (el: HTMLElement) => {\n    auto = {\n      top: Math.max(0, el.scrollHeight - el.clientHeight),\n      time: Date.now(),\n    }\n\n    if (autoTimer) clearTimeout(autoTimer)\n    autoTimer = setTimeout(() => {\n      auto = undefined\n      autoTimer = undefined\n    }, 1500)\n  }"},{"id":"create_auto_scroll_createautoscroll_isauto","label":"isAuto()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L54-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L54"}],"snippet":"isAuto = (el: HTMLElement) => {\n    const a = auto\n    if (!a) return false\n\n    if (Date.now() - a.time > 1500) {\n      auto = undefined\n      return false\n    }\n\n    return Math.abs(el.scrollTop - a.top) < 2\n  }"},{"id":"create_auto_scroll_createautoscroll_scrolltobottomnow","label":"scrollToBottomNow()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L66-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L66"}],"snippet":"scrollToBottomNow = (behavior: ScrollBehavior) => {\n    const el = store.scrollRef\n    if (!el) return\n    markAuto(el)\n    if (behavior === \"smooth\") {\n      el.scrollTo({ top: el.scrollHeight, behavior })\n      return\n    }\n\n    // `scrollTop` assignment bypasses any CSS `scroll-behavior: smooth`.\n    el.scrollTop = el.scrollHeight\n  }"},{"id":"create_auto_scroll_createautoscroll_scrolltobottom","label":"scrollToBottom()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L79-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L79"}],"snippet":"scrollToBottom = (force: boolean) => {\n    if (!force && !active()) return\n\n    if (force && store.userScrolled) setStore(\"userScrolled\", false)\n\n    const el = store.scrollRef\n    if (!el) return\n\n    if (!force && store.userScrolled) return\n\n    const distance = distanceFromBottom(el)\n    if (distance < 2) {\n      markAuto(el)\n      return\n    }\n\n    // For auto-following content we prefer immediate updates to avoid\n    // visible \"catch up\" animations while content is still settling.\n    scrollToBottomNow(\"auto\")\n  }"},{"id":"create_auto_scroll_createautoscroll_stop","label":"stop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L100-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L100"}],"snippet":"stop = () => {\n    const el = store.scrollRef\n    if (!el) return\n    if (!canScroll(el)) {\n      if (store.userScrolled) setStore(\"userScrolled\", false)\n      return\n    }\n    if (store.userScrolled) return\n\n    setStore(\"userScrolled\", true)\n    options.onUserInteracted?.()\n  }"},{"id":"create_auto_scroll_createautoscroll_handlewheel","label":"handleWheel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L113-L123","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L113"}],"snippet":"handleWheel = (e: WheelEvent) => {\n    if (e.deltaY >= 0) return\n    // If the user is scrolling within a nested scrollable region (tool output,\n    // code block, etc), don't treat it as leaving the \"follow bottom\" mode.\n    // Those regions opt in via `data-scrollable`.\n    const el = store.scrollRef\n    const target = e.target instanceof Element ? e.target : undefined\n    const nested = target?.closest(\"[data-scrollable]\")\n    if (el && nested && nested !== el) return\n    stop()\n  }"},{"id":"create_auto_scroll_createautoscroll_handlescroll","label":"handleScroll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L125-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L125"}],"snippet":"handleScroll = () => {\n    const el = store.scrollRef\n    if (!el) return\n\n    if (!canScroll(el)) {\n      if (store.userScrolled) setStore(\"userScrolled\", false)\n      return\n    }\n\n    if (distanceFromBottom(el) < threshold()) {\n      if (store.userScrolled) setStore(\"userScrolled\", false)\n      return\n    }\n\n    // Ignore scroll events triggered by our own scrollToBottom calls.\n    if (!store.userScrolled && isAuto(el)) {\n      scrollToBottom(false)\n      return\n    }\n\n    stop()\n  }"},{"id":"create_auto_scroll_createautoscroll_handleinteraction","label":"handleInteraction()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L148-L154","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L148"}],"snippet":"handleInteraction = () => {\n    if (!active()) return\n    const selection = window.getSelection()\n    if (selection && selection.toString().length > 0) {\n      stop()\n    }\n  }"},{"id":"create_auto_scroll_createautoscroll_updateoverflowanchor","label":"updateOverflowAnchor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L156-L170","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L156"}],"snippet":"updateOverflowAnchor = (el: HTMLElement) => {\n    const mode = options.overflowAnchor ?? \"dynamic\"\n\n    if (mode === \"none\") {\n      el.style.overflowAnchor = \"none\"\n      return\n    }\n\n    if (mode === \"auto\") {\n      el.style.overflowAnchor = \"auto\"\n      return\n    }\n\n    el.style.overflowAnchor = store.userScrolled ? \"auto\" : \"none\"\n  }"}],"edges":[{"source":"create_auto_scroll","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L1"}],"weight":1},{"source":"create_auto_scroll","target":"store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L2"}],"weight":1},{"source":"create_auto_scroll","target":"event_listener","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L3"}],"weight":1},{"source":"create_auto_scroll","target":"resize_observer","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/create-auto-scroll.tsx","sour