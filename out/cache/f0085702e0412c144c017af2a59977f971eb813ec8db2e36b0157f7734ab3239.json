dySerializer) {\n      opts.serializedBody = opts.bodySerializer(opts.body)\n    }\n\n    // remove Content-Type header if body is empty to avoid sending invalid requests"},{"id":"packages_sdk_js_src_v2_gen_client_client_gen_createclient_request","label":"request()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/client.gen.ts","source_location":"L68-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/client.gen.ts","source_location":"L68"}],"snippet":"request: Client[\"request\"] = async (options) => {\n    // @ts-expect-error\n    const { opts, url } = await beforeRequest(options)\n    const requestInit: ReqInit = {\n      redirect: \"follow\",\n      ...opts,\n      body: getValidRequestBody(opts),\n    }\n\n    let request = new Request(url, requestInit)\n\n    for (const fn of interceptors.request.fns) {\n      if (fn) {\n        request = await fn(request, opts)\n      }\n    }\n\n    // fetch must be assigned here, otherwise it would throw the error:\n    // TypeError: Failed to execute 'fetch' on 'Window': Illegal invocation\n    const _fetch = opts.fetch!\n    let response: Response\n\n    try {\n      response = await _fetch(request)\n    } catch (error) {"},{"id":"packages_sdk_js_src_v2_gen_client_client_gen_createclient_makemethodfn","label":"makeMethodFn()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/client.gen.ts","source_location":"L235","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/client.gen.ts","source_location":"L235"}],"snippet":"makeMethodFn = (method: Uppercase<HttpMethod>) => (options: RequestOptions) => request({ ...options, method })"},{"id"