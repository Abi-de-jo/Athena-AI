:"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L64-L70","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L64"}],"snippet":"function normalizeRepositoryInput(input: string) {\n  return input\n    .trim()\n    .replace(/^git\\+/, \"\")\n    .replace(/#.*$/, \"\")\n    .replace(/\\/+$/, \"\")\n}"},{"id":"packages_rimuru_src_util_repository_trimgitsuffix","label":"trimGitSuffix()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L72-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L72"}],"snippet":"function trimGitSuffix(input: string) {\n  return input.replace(/\\.git$/, \"\")\n}"},{"id":"packages_rimuru_src_util_repository_parts","label":"parts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L76-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L76"}],"snippet":"function parts(input: string) {\n  return input\n    .split(\"/\")\n    .map((item) => trimGitSuffix(item.trim()))\n    .filter(Boolean)\n}"},{"id":"packages_rimuru_src_util_repository_safehost","label":"safeHost()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L83-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L83"}],"snippet":"function safeHost(input: string) {\n  return Boolean(input) && !input.startsWith(\"-\") && !/[\\s/\\\\]/.test(input)\n}"},{"id":"packages_rimuru_src_util_repository_safesegment","label":"safeSegment()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L87-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L87"}],"snippet":"function safeSegment(input: string) {\n  return input !== \".\" && input !== \"..\" && !input.includes(\":\") && !/[\\s/\\\\]/.test(input)\n}"},{"id":"packages_rimuru_src_util_repository_hostlike","label":"hostLike()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L91-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L91"}],"snippet":"function hostLike(input: string) {\n  return input.includes(\".\") || input.includes(\":\") || input === \"localhost\"\n}"},{"id":"packages_rimuru_src_util_repository_withslash","label":"withSlash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L95-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L95"}],"snippet":"function withSlash(input: string) {\n  return input.endsWith(\"/\") ? input : `${input}/`\n}"},{"id":"packages_rimuru_src_util_repository_githubremote","label":"githubRemote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L99-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L99"}],"snippet":"function githubRemote(pathname: string) {\n  const base = process.env.OPENCODE_REPO_CLONE_GITHUB_BASE_URL\n  if (!base) return `https://github.com/${pathname}.git`\n  return new URL(`${pathname}.git`, withSlash(base)).href\n}"},{"id":"packages_rimuru_src_util_repository_buildremotereference","label":"buildRemoteReference()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L105-L121","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L105"}],"snippet":"function buildRemoteReference(input: { host: string; segments: string[]; remote?: string; protocol?: string }) {\n  const segments = input.segments.map(trimGitSuffix).filter(Boolean)\n  if (!safeHost(input.host) || !segments.length || segments.some((segment) => !safeSegment(segment))) return null\n  const pathname = segments.join(\"/\")\n  const repo = segments[segments.length - 1]\n  const host = input.host.toLowerCase()\n  return {\n    host,\n    path: pathname,\n    segments,\n    owner: segments.length === 2 ? segments[0] : undefined,\n    repo,\n    remote: input.remote ?? (host === \"github.com\" ? githubRemote(pathname) : `https://${host}/${pathname}.git`),\n    label: host === \"github.com\" && segments.length === 2 ? pathname : `${host}/${pathname}`,\n    protocol: input.protocol,\n  } satisfies RemoteReference\n}"},{"id":"packages_rimuru_src_util_repository_buildfilereference","label":"buildFileReference()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L123-L137","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L123"}],"snippet":"function buildFileReference(input: { url: URL; remote: string }) {\n  const filePath = path.normalize(fileURLToPath(input.url))\n  const segments = filePath.split(/[\\\\/]+/).filter(Boolean)\n  if (!segments.length) return null\n  return {\n    host: \"file\",\n    path: filePath,\n    segments: segments.map((segment) => segment.replace(/:$/, \"\")),\n    owner: undefined,\n    repo: trimGitSuffix(segments[segments.length - 1]),\n    remote: input.remote,\n    label: filePath,\n    protocol: \"file:\",\n  } satisfies FileReference\n}"},{"id":"packages_rimuru_src_util_repository_parserepositoryreference","label":"parseRepositoryReference()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L139-L176","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L139"}],"snippet":"export function parseRepositoryReference(input: string) {\n  const cleaned = normalizeRepositoryInput(input)\n  if (!cleaned) return null\n\n  const githubPrefixed = cleaned.match(/^github:([^/\\s]+)\\/([^/\\s]+)$/)\n  if (githubPrefixed) {\n    return buildRemoteReference({ host: \"github.com\", segments: [githubPrefixed[1], githubPrefixed[2]] })\n  }\n\n  if (!cleaned.includes(\"://\")) {\n    const scp = cleaned.match(/^(?:[^@/\\s]+@)?([^:/\\s]+):(.+)$/)\n    if (scp) return buildRemoteReference({ host: scp[1], segments: parts(scp[2]), remote: cleaned })\n\n    const direct = parts(cleaned)\n    if (direct.length >= 2 && hostLike(direct[0])) {\n      return buildRemoteReference({ host: direct[0], segments: direct.slice(1) })\n    }\n\n    if (direct.length === 2) {\n      return buildRemoteReference({ host: \"github.com\", segments: direct })\n    }\n  }\n\n  try {\n    const url = new URL(cleaned)"},{"id":"packages_rimuru_src_util_repository_isfilerepositoryreference","label":"isFileRepositoryReference()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L178-L180","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L178"}],"snippet":"export function isFileRepositoryReference(reference: Reference): reference is FileReference {\n  return reference.protocol === \"file:\"\n}"},{"id":"packages_rimuru_src_util_repository_isremoterepositoryreference","label":"isRemoteRepositoryReference()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L182-L184","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L182"}],"snippet":"export function isRemoteRepositoryReference(reference: Reference): reference is RemoteReference {\n  return !isFileRepositoryReference(reference)\n}"},{"id":"packages_rimuru_src_util_repository_parseremoterepositoryreference","label":"parseRemoteRepositoryReference()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L186-L201","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L186"}],"snippet":"export function parseRemoteRepositoryReference(input: string) {\n  const reference = parseRepositoryReference(input)\n  if (!reference) {\n    throw new InvalidRepositoryReferenceError({\n      repository: input,\n      message: \"Repository must be a git URL, host/path reference, or GitHub owner/repo shorthand\",\n    })\n  }\n  if (!isRemoteRepositoryReference(reference)) {\n    throw new UnsupportedLocalRepositoryError({\n      repository: input,\n      message: \"Local file repositories are not supported\",\n    })\n  }\n  return reference\n}"},{"id":"packages_rimuru_src_util_repository_validaterepositorybranch","label":"validateRepositoryBranch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L203-L211","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L203"}],"snippet":"export function validateRepositoryBranch(branch: string) {\n  if (!/^[A-Za-z0-9/_.-]+$/.test(branch) || branch.startsWith(\"-\") || branch.includes(\"..\")) {\n    throw new InvalidRepositoryBranchError({\n      branch,\n      message:\n        \"Branch must contain only alphanumeric characters, /, _, ., and -, and cannot start with - or contain ..\",\n    })\n  }\n}"},{"id":"packages_rimuru_src_util_repository_parsegithubremote","label":"parseGitHubRemote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L213-L220","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L213"}],"snippet":"export function parseGitHubRemote(input: string) {\n  const cleaned = normalizeRepositoryInput(input)\n  if (!cleaned.includes(\"://\") && !cleaned.match(/^(?:[^@/\\s]+@)?github\\.com:/)) return null\n\n  const parsed = parseRepositoryReference(cleaned)\n  if (!parsed || parsed.host !== \"github.com\" || !parsed.owner || parsed.segments.length !== 2) return null\n  return { owner: parsed.owner, repo: parsed.repo }\n}"},{"id":"packages_rimuru_src_util_repository_repositorycachepath","label":"repositoryCachePath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L222-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L222"}],"snippet":"export function repositoryCachePath(input: Reference) {\n  return path.join(Global.Path.repos, ...input.host.split(\":\"), ...input.segments)\n}"},{"id":"packages_rimuru_src_util_repository_repositorycacheidentity","label":"repositoryCacheIdentity()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L226-L228","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L226"}],"snippet":"export function repositoryCacheIdentity(input: Reference) {\n  return `${input.host}/${input.path}`\n}"},{"id":"packages_rimuru_src_util_repository_samerepositoryreference","label":"sameRepositoryReference()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/repository.ts","source_location":"L230-L232","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/package