le":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui.ts","source_location":"L47"}],"snippet":"function pluginScope(file: string, ctx: { directory: string }): ConfigPlugin.Scope {\n  if (Filesystem.contains(ctx.directory, file)) return \"local\"\n  // if (ctx.worktree !== \"/\" && Filesystem.contains(ctx.worktree, file)) return \"local\"\n  return \"global\"\n}"},{"id":"packages_opencode_src_config_tui_normalize","label":"normalize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui.ts","source_location":"L53-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui.ts","source_location":"L53"}],"snippet":"function normalize(raw: Record<string, unknown>) {\n  const data = { ...raw }\n  if (!(\"tui\" in data)) return data\n  if (!isRecord(data.tui)) {\n    delete data.tui\n    return data\n  }\n\n  const tui = data.tui\n  delete data.tui\n  return {\n    ...tui,\n    ...data,\n  }\n}"},{"id":"packages_opencode_src_config_tui_dropunknownkeybinds","label":"dropUnknownKeybinds()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui.ts","source_location":"L69-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui.ts","source_location":"L69"}],"snippet":"function dropUnknownKeybinds(input: Record<string, unknown>) {\n  if (!isRecord(input.keybinds)) return input\n\n  const invalid = TuiKeybind.unknownKeys(input.keybinds)\n  if (!invalid.length) return input\n\n  return {\n    ...input,\n    keybinds: Object.fromEntries(Object.entries(input.keybinds).filter(([key]) => !invalid.includes(key))),\n  }\n}"},{"id":"packages_opencode_src_config_tui_waitfordependencies","label"