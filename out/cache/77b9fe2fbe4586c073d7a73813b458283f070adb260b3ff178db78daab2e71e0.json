{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_sdk_js_src_v2_client","nodes":[{"id":"packages_sdk_js_src_v2_client","label":"client.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L1"}]},{"id":"packages_sdk_js_src_v2_client_pick","label":"pick()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L10-L16","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L10"}],"snippet":"function pick(value: string | null, fallback?: string, encode?: (value: string) => string) {\n  if (!value) return\n  if (!fallback) return value\n  if (value === fallback) return fallback\n  if (encode && value === encode(fallback)) return fallback\n  return value\n}"},{"id":"packages_sdk_js_src_v2_client_rewrite","label":"rewrite()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L18-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L18"}],"snippet":"function rewrite(request: Request, values: { directory?: string; workspace?: string }) {\n  if (request.method !== \"GET\" && request.method !== \"HEAD\") return request\n\n  const url = new URL(request.url)\n  let changed = false\n\n  for (const [name, key] of [\n    [\"x-opencode-directory\", \"directory\"],\n    [\"x-opencode-workspace\", \"workspace\"],\n  ] as const) {\n    const value = pick(\n      request.headers.get(name),\n      key === \"directory\" ? values.directory : values.workspace,\n      key === \"directory\" ? encodeURIComponent : undefined,\n    )\n    if (!value) continue\n    for (const query of url.pathname.startsWith(\"/api/\") ? [key, `location[${key}]`] : [key]) {\n      if (!url.searchParams.has(query)) {\n        url.searchParams.set(query, value)\n      }\n    }\n    changed = true\n  }\n\n  if (!changed) return request"},{"id":"packages_sdk_js_src_v2_client_createopencodeclient","label":"createOpencodeClient()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L50-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L50"}],"snippet":"export function createOpencodeClient(config?: Config & { directory?: string; experimental_workspaceID?: string }) {\n  if (!config?.fetch) {\n    const customFetch: any = (req: any) => {\n      // @ts-ignore\n      req.timeout = false\n      return fetch(req)\n    }\n    config = {\n      ...config,\n      fetch: customFetch,\n    }\n  }\n\n  if (config?.directory) {\n    config.headers = {\n      ...config.headers,\n      \"x-opencode-directory\": encodeURIComponent(config.directory),\n    }\n  }\n\n  if (config?.experimental_workspaceID) {\n    config.headers = {\n      ...config.headers,\n      \"x-opencode-workspace\": config.experimental_workspaceID,\n    }"},{"id":"packages_sdk_js_src_v2_client_createopencodeclient_customfetch","label":"customFetch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L52-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L52"}],"snippet":"customFetch: any = (req: any) => {\n      // @ts-ignore\n      req.timeout = false\n      return fetch(req)\n    }"}],"edges":[{"source":"packages_sdk_js_src_v2_client","target":"types_gen","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L1"}],"weight":1},{"source":"packages_sdk_js_src_v2_client","target":"client_gen","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L4"}],"weight":1},{"source":"packages_sdk_js_src_v2_client","target":"sdk_gen","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L6","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L6"}],"weight":1},{"source":"packages_sdk_js_src_v2_client","target":"error_interceptor","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L7","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/client.ts","source_location":"L7"}],"weight":1},{"so