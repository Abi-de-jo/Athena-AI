{"__madarTsExtractorVersion":67,"__madarFileStem":"use-session-hash-scroll","nodes":[{"id":"use_session_hash_scroll","label":"use-session-hash-scroll.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L1"}]},{"id":"use_session_hash_scroll_usesessionhashscroll","label":"useSessionHashScroll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L6-L202","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L6"}],"snippet":"useSessionHashScroll = (input: {\n  sessionKey: () => string\n  sessionID: () => string | undefined\n  messagesReady: () => boolean\n  visibleUserMessages: () => UserMessage[]\n  historyMore: () => boolean\n  historyLoading: () => boolean\n  loadMore: (sessionID: string) => Promise<void>\n  currentMessageId: () => string | undefined\n  pendingMessage: () => string | undefined\n  setPendingMessage: (value: string | undefined) => void\n  setActiveMessage: (message: UserMessage | undefined) => void\n  autoScroll: { pause: () => void; forceScrollToBottom: () => void }\n  scroller: () => HTMLDivElement | undefined\n  anchor: (id: string) => string\n  revealMessage?: (id: string) => void\n  scheduleScrollState: (el: HTMLDivElement) => void\n  consumePendingMessage: (key: string) => string | undefined\n}) => {\n  const visibleUserMessages = createMemo(() => input.visibleUserMessages())\n  const messageById = createMemo(() => new Map(visibleUserMessages().map((m) => [m.id, m])))\n  let pendingKey = \"\"\n  let clearing = false\n\n  const location = useLocation()"},{"id":"use_session_hash_scroll_usesessionhashscroll_queue","label":"queue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L34-L40","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L34"}],"snippet":"queue = (fn: () => void) => {\n    const id = requestAnimationFrame(() => {\n      frames.delete(id)\n      fn()\n    })\n    frames.add(id)\n  }"},{"id":"use_session_hash_scroll_usesessionhashscroll_cancel","label":"cancel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L41-L44","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L41"}],"snippet":"cancel = () => {\n    for (const id of frames) cancelAnimationFrame(id)\n    frames.clear()\n  }"},{"id":"use_session_hash_scroll_usesessionhashscroll_clearmessagehash","label":"clearMessageHash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L46-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L46"}],"snippet":"clearMessageHash = () => {\n    cancel()\n    input.consumePendingMessage(input.sessionKey())\n    if (input.pendingMessage()) input.setPendingMessage(undefined)\n    if (!location.hash) return\n    clearing = true\n    navigate(location.pathname + location.search, { replace: true })\n  }"},{"id":"use_session_hash_scroll_usesessionhashscroll_updatehash","label":"updateHash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L55-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L55"}],"snippet":"updateHash = (id: string) => {\n    const hash = `#${input.anchor(id)}`\n    if (location.hash === hash) return\n    clearing = false\n    navigate(location.pathname + location.search + hash, {\n      replace: true,\n    })\n  }"},{"id":"use_session_hash_scroll_usesessionhashscroll_scrolltoelement","label":"scrollToElement()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L64-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L64"}],"snippet":"scrollToElement = (el: HTMLElement, behavior: ScrollBehavior) => {\n    const root = input.scroller()\n    if (!root) return false\n\n    const a = el.getBoundingClientRect()\n    const b = root.getBoundingClientRect()\n    const sticky = root.querySelector(\"[data-session-title]\")\n    const inset = sticky instanceof HTMLElement ? sticky.offsetHeight : 0\n    const top = Math.max(0, a.top - b.top + root.scrollTop - inset)\n    root.scrollTo({ top, behavior })\n    return true\n  }"},{"id":"use_session_hash_scroll_usesessionhashscroll_seek","label":"seek()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L77-L86","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L77"}],"snippet":"seek = (id: string, behavior: ScrollBehavior, left = 4): boolean => {\n    input.revealMessage?.(id)\n    const el = document.getElementById(input.anchor(id))\n    if (el) return scrollToElement(el, behavior)\n    if (left <= 0) return false\n    queue(() => {\n      seek(id, behavior, left - 1)\n    })\n    return false\n  }"},{"id":"use_session_hash_scroll_usesessionhashscroll_scrolltomessage","label":"scrollToMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L88-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L88"}],"snippet":"scrollToMessage = (message: UserMessage, behavior: ScrollBehavior = \"smooth\") => {\n    cancel()\n    if (input.currentMessageId() !== message.id) input.setActiveMessage(message)\n    input.revealMessage?.(message.id)\n\n    if (seek(message.id, behavior)) {\n      updateHash(message.id)\n      return\n    }\n\n    updateHash(message.id)\n  }"},{"id":"use_session_hash_scroll_usesessionhashscroll_applyhash","label":"applyHash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L101-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L101"}],"snippet":"applyHash = (behavior: ScrollBehavior) => {\n    const hash = location.hash.slice(1)\n    if (!hash) {\n      input.autoScroll.forceScrollToBottom()\n      const el = input.scroller()\n      if (el) input.scheduleScrollState(el)\n      return\n    }\n\n    const messageId = messageIdFromHash(hash)\n    if (messageId) {\n      input.autoScroll.pause()\n      const msg = messageById().get(messageId)\n      if (msg) {\n        scrollToMessage(msg, behavior)\n        return\n      }\n      return\n    }\n\n    const target = document.getElementById(hash)\n    if (target) {\n      input.autoScroll.pause()\n      scrollToElement(target, behavior)\n      return"}],"edges":[{"source":"use_session_hash_scroll","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L1"}],"weight":1},{"source":"use_session_hash_scroll","target":"router","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L2"}],"weight":1},{"source":"use_session_hash_scroll","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/use-session-hash-scroll.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin