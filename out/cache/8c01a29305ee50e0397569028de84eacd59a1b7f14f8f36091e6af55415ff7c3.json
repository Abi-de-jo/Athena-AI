ai\" || Object.values(p.models).find((m) => m.cost?.input))\n  })\n\n  const popular = createMemo(() => {\n    const connectedIDs = new Set(connected().map((p) => p.id))\n    const items = providers\n      .popular()\n      .filter((p) => !connectedIDs.has(p.id))\n      .slice()\n    items.sort((a, b) => popularProviders.indexOf(a.id) - popularProviders.indexOf(b.id))\n    return items\n  })\n\n  const source = (item: ProviderItem): ProviderSource | undefined => {\n    if (!(\"source\" in item)) return","node_kind":"component"},{"id":"settings_providers_settingsproviderscontent_source","label":"source()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L62-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L62"}],"snippet":"source = (item: ProviderItem): ProviderSource | undefined => {\n    if (!(\"source\" in item)) return\n    const value = item.source\n    if (value === \"env\" || value === \"api\" || value === \"config\" || value === \"custom\") return value\n    return\n  }"},{"id":"settings_providers_settingsproviderscontent_type","label":"type()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L69-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L69"}],"snippet":"type = (item: ProviderItem) => {\n    const current = source(item)\n    if (current === \"env\") return language.t(\"settings.providers.tag.environment\")\n    if (current === \"api\") return language.t(\"provider.connect.method.apiKey\")\n    if (current === \"config\") {\n      if (isConfigCustom(item.id)) return language.t(\"settings.providers.tag.custom\")\n      return language.t(\"settings.providers.tag.config\")\n    }\n    if (current === \"custom\") return language.t(\"settings.providers.tag.custom\")\n    return language.t(\"settings.providers.tag.other\")\n  }"},{"id":"settings_providers_settingsproviderscontent_candisconnect","label":"canDisconnect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L81"}],"snippet":"canDisconnect = (item: ProviderItem) => source(item) !== \"env\""},{"id":"settings_providers_settingsproviderscontent_note","label":"note()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L83"}],"snippet":"note = (id: string) => PROVIDER_NOTES.find((item) => item.match(id))?.key"},{"id":"settings_providers_settingsproviderscontent_isconfigcustom","label":"isConfigCustom()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L85-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L85"}],"snippet":"isConfigCustom = (providerID: string) => {\n    const provider = serverSync().data.config.provider?.[providerID]\n    if (!provider) return false\n    if (provider.npm !== \"@ai-sdk/openai-compatible\") return false\n    if (!provider.models || Object.keys(provider.models).length === 0) return false\n    return true\n  }"},{"id":"settings_providers_settingsproviderscontent_disableprovider","label":"disableProvider()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L93-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L93"}],"snippet":"disableProvider = async (providerID: string, name: string) => {\n    const before = serverSync().data.config.disabled_providers ?? []\n    const next = before.includes(providerID) ? before : [...before, providerID]\n    serverSync().set(\"config\", \"disabled_providers\", next)\n\n    await serverSync()\n      .updateConfig({ disabled_providers: next })\n      .then(() => {\n        showToast({\n          variant: \"success\",\n          icon: \"circle-check\",\n          title: language.t(\"provider.disconnect.toast.disconnected.title\", { provider: name }),\n          description: language.t(\"provider.disconnect.toast.disconnected.description\", { provider: name }),\n        })\n      })\n      .catch((err: unknown) => {\n        serverSync().set(\"config\", \"disabled_providers\", before)\n        const message = err instanceof Error ? err.message : String(err)\n        showToast({ title: language.t(\"common.requestFailed\"), description: message })\n      })\n  }"},{"id":"settings_providers_settingsproviderscontent_disconnect","label":"disconnect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-providers.tsx","source_location":"L115-L138","layer":"base","provenance":[{"capability_i