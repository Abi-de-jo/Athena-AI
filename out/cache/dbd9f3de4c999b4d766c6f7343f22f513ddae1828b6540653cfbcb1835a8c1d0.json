{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_server_shared_workspace-routing","nodes":[{"id":"packages_rimuru_src_server_shared_workspace_routing","label":"workspace-routing.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_server_shared_workspace_routing_islocalworkspaceroute","label":"isLocalWorkspaceRoute()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L11-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L11"}],"snippet":"export function isLocalWorkspaceRoute(method: string, path: string) {\n  for (const rule of RULES) {\n    if (rule.method && rule.method !== method) continue\n    const match = rule.exact ? path === rule.path : path === rule.path || path.startsWith(rule.path + \"/\")\n    if (match) return rule.action === \"local\"\n  }\n  return false\n}"},{"id":"packages_rimuru_src_server_shared_workspace_routing_getworkspaceroutesessionid","label":"getWorkspaceRouteSessionID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L20-L29","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L20"}],"snippet":"export function getWorkspaceRouteSessionID(url: URL) {\n  if (url.pathname === \"/session/status\") return null\n\n  const id =\n    url.pathname.match(/^\\/session\\/([^/]+)(?:\\/|$)/)?.[1] ??\n    url.pathname.match(/^\\/experimental\\/session\\/([^/]+)\\/background$/)?.[1]\n  if (!id) return null\n\n  return SessionID.make(id)\n}"},{"id":"packages_rimuru_src_server_shared_workspace_routing_workspaceproxyurl","label":"workspaceProxyURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L31-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L31"}],"snippet":"export function workspaceProxyURL(target: string | URL, requestURL: URL) {\n  const proxyURL = new URL(target)\n  proxyURL.pathname = `${proxyURL.pathname.replace(/\\/$/, \"\")}${requestURL.pathname}`\n  proxyURL.search = requestURL.search\n  proxyURL.hash = requestURL.hash\n  proxyURL.searchParams.delete(\"workspace\")\n  return proxyURL\n}"}],"edges":[{"source":"packages_rimuru_src_server_shared_workspace_routing","target":"schema","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_server_shared_workspace_routing","target":"packages_rimuru_src_server_shared_workspace_routing_islocalworkspaceroute","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L11","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L11"}],"weight":1},{"source":"packages_rimuru_src_server_shared_workspace_routing","target":"packages_rimuru_src_server_shared_workspace_routing_getworkspaceroutesessionid","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L20"}],"weight":1},{"source":"packages_rimuru_src_server_shared_workspace_routing","target":"packages_rimuru_src_server_shared_workspace_routing_workspaceproxyurl","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/workspace-routing.ts","source_location":"L31"}],"weight":1}]}