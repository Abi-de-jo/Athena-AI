onst\n  }\n}"},{"id":"packages_enterprise_src_app_detectlocale","label":"detectLocale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/app.tsx","source_location":"L34-L55","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/app.tsx","source_location":"L34"}],"snippet":"function detectLocale() {\n  const event = getRequestEvent()\n  const header = event?.request.headers.get(\"accept-language\")\n  const headerLocale = detectLocaleFromHeader(header)\n  if (headerLocale) return headerLocale\n\n  if (typeof document === \"object\") {\n    const value = document.documentElement.lang?.toLowerCase() ?? \"\"\n    if (value.startsWith(\"zh\")) return \"zh\" as const\n    if (value.startsWith(\"en\")) return \"en\" as const\n  }\n\n  if (typeof navigator === \"object\") {\n    const languages = navigator.languages?.length ? navigator.languages : [navigator.language]\n    for (const language of languages) {\n      if (!language) continue\n      if (language.toLowerCase().startsWith(\"zh\")) return \"zh\" as const\n    }\n  }\n\n  return \"en\" as const\n}"},{"id":"packages_enterprise_src_app_uii18nbridge","label":"UiI18nBridge()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/app.tsx","source_location":"L57-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/app.tsx","source_location":"L57"}],"snippet":"function UiI18nBridge(props: ParentProps) {\n  const locale = createMemo(() => detectLocale())\n  const zh = uiZh as Partial<Record<string, string>>\n  const t = (key: keyof typeof uiEn, params?: UiI18nParams) => {\n    const value = locale() === \"zh\" ? (zh[key] ?? uiEn[key]) : uiEn[key]\n    const text = value ?? String(key)\n    return resolveTemplate(text, params)\n  }\n\n  createEffect(() => {\n    if (typeof document !== \"object\") return\n    document.documentElement.lang = locale()\n  })\n\n  return <I18nProvider value={{ locale, t }}>{props.children}</I18nProvider>\n}","node_kind":"component"},{"id":"packages_enterprise_src_app_uii18nbridge_t","label":"t()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/app.tsx","source_location":"L60-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/app.tsx","source_location":"L60"}],"snippet":"t = (key: keyof typeof uiEn, params?: UiI18nParams) => {\n    const value = locale() === \"zh\" ? (zh[key] ?? uiEn[key]) : uiEn[key]\n    const text = value ?? String(key)\n    return resolveTemplate(text, params)\n  }"},{"id":"packages_enterprise_src_app_app","label":"App()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/app.tsx","source_location":"L74-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/app.tsx","source_location":"L74"}],"snippet":"export default function App() {\n  return (\n    <Router\n      root={(props) => (\n        <MetaProvider>\n          <DialogProvider>\n            <MarkedProvider>\n              <Favicon />\n              <Font />\n              <UiI18nBridge>\n                <Suspense>{props.children}</Suspense>\n              </UiI18nBridge>\n            </MarkedProvider>\n          </DialogProvider>\n        </MetaProvider>\n      )}\n    >\n      <FileRoutes />\n    </Router>\n  )\n}","node_kind":"component"}],"edges":[{"source":"packages_enterprise_src_app","target":"router","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/