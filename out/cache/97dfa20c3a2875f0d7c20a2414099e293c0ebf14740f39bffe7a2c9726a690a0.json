xtract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L13"}],"snippet":"export async function hash(content: string, algorithm = \"SHA-256\"): Promise<string> {\n  const encoder = new TextEncoder()\n  const data = encoder.encode(content)\n  const hashBuffer = await crypto.subtle.digest(algorithm, data)\n  const hashArray = Array.from(new Uint8Array(hashBuffer))\n  const hashHex = hashArray.map((b) => b.toString(16).padStart(2, \"0\")).join(\"\")\n  return hashHex\n}"},{"id":"encode_checksum","label":"checksum()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L22-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L22"}],"snippet":"export function checksum(content: string): string | undefined {\n  if (!content) return undefined\n  let hash = 0x811c9dc5\n  for (let i = 0; i < content.length; i++) {\n    hash ^= content.charCodeAt(i)\n    hash = Math.imul(hash, 0x01000193)\n  }\n  return (hash >>> 0).toString(36)\n}"},{"id":"encode_sampledchecksum","label":"sampledChecksum()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L32-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L32"}],"snippet":"export function sampledChecksum(content: string, limit = 500_000): string | undefined {\n  if (!content) return undefined\n  if (content.length <= limit) return checksum(content)\n\n  const size = 4096\n  const points = [\n    0,\n    Math.floor(content.length * 0.25),\n    Math.floor(content.length * 0.5),\n    Math.floor(content.length * 0.75),\n    content.length - size,\n  ]\n  const hashes = points\n    .map((point) => {\n      const start = Math.max(0, Math.min(content.length - size, point - Math.floor(size / 2)))\n      return checksum(content.slice(start, start + size)) ?? \"\"\n    })\n    .join(\":\")\n  return `${content.length}:${hashes}`\n}"}],"edges":[{"source":"encode","target":"encode_base64encode","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L1"}],"weight":1},{"source":"encode","target":"encode_base64decode","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L7","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L7"}],"weight":1},{"source":"encode","target":"encode_hash","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L13","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L13"}],"weight":1},{"source":"encode","target":"encode_checksum","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/encode.ts","source_location":"L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/persona