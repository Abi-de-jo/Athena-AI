{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_context_terminal","nodes":[{"id":"packages_app_src_context_terminal","label":"terminal.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L1"}]},{"id":"packages_app_src_context_terminal_record","label":"record()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L26-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L26"}],"snippet":"function record(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value)\n}"},{"id":"packages_app_src_context_terminal_text","label":"text()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L30-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L30"}],"snippet":"function text(value: unknown) {\n  return typeof value === \"string\" ? value : undefined\n}"},{"id":"packages_app_src_context_terminal_num","label":"num()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L34-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L34"}],"snippet":"function num(value: unknown) {\n  return typeof value === \"number\" && Number.isFinite(value) ? value : undefined\n}"},{"id":"packages_app_src_context_terminal_numberfromtitle","label":"numberFromTitle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L38-L40","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L38"}],"snippet":"function numberFromTitle(title: string) {\n  return titleNumber(title, MAX_TERMINAL_SESSIONS)\n}"},{"id":"packages_app_src_context_terminal_pty","label":"pty()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L42-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L42"}],"snippet":"function pty(value: unknown): LocalPTY | undefined {\n  if (!record(value)) return\n\n  const id = text(value.id)\n  if (!id) return\n\n  const title = text(value.title) ?? \"\"\n  const number = num(value.titleNumber)\n  const rows = num(value.rows)\n  const cols = num(value.cols)\n  const buffer = text(value.buffer)\n  const scrollY = num(value.scrollY)\n  const cursor = num(value.cursor)\n\n  return {\n    id,\n    title,\n    titleNumber: number && number > 0 ? number : (numberFromTitle(title) ?? 0),\n    ...(rows !== undefined ? { rows } : {}),\n    ...(cols !== undefined ? { cols } : {}),\n    ...(buffer !== undefined ? { buffer } : {}),\n    ...(scrollY !== undefined ? { scrollY } : {}),\n    ...(cursor !== undefined ? { cursor } : {}),\n  }\n}"},{"id":"packages_app_src_context_terminal_migrateterminalstate","label":"migrateTerminalState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L68-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L68"}],"snippet":"export function migrateTerminalState(value: unknown) {\n  if (!record(value)) return value\n\n  const seen = new Set<string>()\n  const all = (Array.isArray(value.all) ? value.all : []).flatMap((item) => {\n    const next = pty(item)\n    if (!next || seen.has(next.id)) return []\n    seen.add(next.id)\n    return [next]\n  })\n\n  const active = text(value.active)\n\n  return {\n    active: active && seen.has(active) ? active : all[0]?.id,\n    all,\n  }\n}"},{"id":"packages_app_src_context_terminal_getworkspaceterminalcachekey","label":"getWorkspaceTerminalCacheKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L87-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L87"}],"snippet":"export function getWorkspaceTerminalCacheKey(dir: string, scope: ServerScopeValue = ServerScope.local) {\n  return ScopedKey.from(scope, dir, WORKSPACE_KEY)\n}"},{"id":"packages_app_src_context_terminal_getlegacyterminalstoragekeys","label":"getLegacyTerminalStorageKeys()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L91-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L91"}],"snippet":"export function getLegacyTerminalStorageKeys(dir: string, legacySessionID?: string) {\n  if (!legacySessionID) return [`${dir}/terminal.v1`]\n  return [`${dir}/terminal/${legacySessionID}.v1`, `${dir}/terminal.v1`]\n}"},{"id":"packages_app_src_context_terminal_trimterminal","label":"trimTerminal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L105-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L105"}],"snippet":"trimTerminal = (pty: LocalPTY) => {\n  if (!pty.buffer && pty.cursor === undefined && pty.scrollY === undefined) return pty\n  return {\n    ...pty,\n    buffer: undefined,\n    cursor: undefined,\n    scrollY: undefined,\n  }\n}"},{"id":"packages_app_src_context_terminal_terminalpersisttarget","label":"terminalPersistTarget()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L115-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L115"}],"snippet":"function terminalPersistTarget(scope: ServerScopeValue, dir: string, legacy?: string[]) {\n  return Persist.serverWorkspace(scope, dir, \"terminal\", legacy)\n}"},{"id":"packages_app_src_context_terminal_clearworkspaceterminals","label":"clearWorkspaceTerminals()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L119-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L119"}],"snippet":"export function clearWorkspaceTerminals(\n  dir: string,\n  sessionIDs?: string[],\n  platform?: Platform,\n  scope: ServerScopeValue = ServerScope.local,\n) {\n  const key = getWorkspaceTerminalCacheKey(dir, scope)\n  for (const cache of caches) {\n    const entry = cache.get(key)\n    entry?.value.clear()\n  }\n\n  void removePersisted(terminalPersistTarget(scope, dir), platform)\n\n  if (scope !== ServerScope.local) return\n  const legacy = new Set(getLegacyTerminalStorageKeys(dir))\n  for (const id of sessionIDs ?? []) {\n    for (const key of getLegacyTerminalStorageKeys(dir, id)) {\n      legacy.add(key)\n    }\n  }\n  for (const key of legacy) {\n    void removePersisted({ key }, platform)\n  }\n}"},{"id":"packages_app_src_context_terminal_createworkspaceterminalsession","label":"createWorkspaceTerminalSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L145-L370","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L145"}],"snippet":"function createWorkspaceTerminalSession(\n  sdk: DirectorySDK,\n  dir: string,\n  scope: ServerScopeValue,\n  legacySessionID?: string,\n) {\n  const legacy = scope === ServerScope.local ? getLegacyTerminalStorageKeys(dir, legacySessionID) : []\n\n  const [store, setStore, _, ready] = persisted(\n    {\n      ...terminalPersistTarget(scope, dir, legacy),\n      migrate: migrateTerminalState,\n    },\n    createStore<{\n      active?: string\n      all: LocalPTY[]\n    }>({\n      all: [],\n    }),\n  )\n\n  const pickNextTerminalNumber = () => {\n    const existingTitleNumbers = new Set(\n      store.all.flatMap((pty) => {\n        const direct = Number.isFinite(pty.titleNumber) && pty.titleNumber > 0 ? pty.titleNumber : undefined"},{"id":"packages_app_src_context_terminal_createworkspaceterminalsession_picknextterminalnumber","label":"pickNextTerminalNumber()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L166-L182","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L166"}],"snippet":"pickNextTerminalNumber = () => {\n    const existingTitleNumbers = new Set(\n      store.all.flatMap((pty) => {\n        const direct = Number.isFinite(pty.titleNumber) && pty.titleNumber > 0 ? pty.titleNumber : undefined\n        if (direct !== undefined) return [direct]\n        const parsed = numberFromTitle(pty.title)\n        if (parsed === undefined) return []\n        return [parsed]\n      }),\n    )\n\n    return (\n      Array.from({ length: existingTitleNumbers.size + 1 }, (_, index) => index + 1).find(\n        (number) => !existingTitleNumbers.has(number),\n      ) ?? 1\n    )\n  }"},{"id":"packages_app_src_context_terminal_createworkspaceterminalsession_removeexited","label":"removeExited()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L184-L198","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L184"}],"snippet":"removeExited = (id: string) => {\n    const all = store.all\n    const index = all.findIndex((x) => x.id === id)\n    if (index === -1) return\n    const active = store.active === id ? (index === 0 ? all[1]?.id : all[0]?.id) : store.active\n    batch(() => {\n      setStore(\"active\", active)\n      setStore(\n        \"all\",\n        produce((draft) => {\n          draft.splice(index, 1)\n        }),\n      )\n    })\n  }"},{"id":"packages_app_src_context_terminal_createworkspaceterminalsession_update","label":"update()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L205-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L205"}],"snippet":"update = (client: DirectorySDK[\"client\"], pty: Partial<LocalPTY> & { id: string }) => {\n    const index = store.all.findIndex((x) => x.id === pty.id)\n    const previous = index >= 0 ? store.all[index] : undefined\n    if (index >= 0) {\n      setStore(\"all\", index, (item) => ({ ...item, ...pty }))\n    }\n    client.pty\n      .update({\n        ptyID: pty.id,\n        title: pty.title,\n        size: pty.cols && pty.rows ? { rows: pty.rows, cols: pty.cols } : undefined,\n      })\n      .catch((error: unknown) => {\n        if (previous) {\n          const currentIndex = store.all.findIndex((item) => item.id === pty.id)\n          if (currentIndex >= 0) setStore(\"all\", currentIndex, previous)\n        }\n        console.error(\"Failed to update terminal\", error)\n      })\n  }"},{"id":"packages_app_src_context_terminal_createworkspaceterminalsession_clone","label":"clone()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L226-L257","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L226"}],"snippet":"clone = async (client: DirectorySDK[\"client\"], id: string) => {\n    const index = store.all.findIndex((x) => x.id === id)\n    const pty = store.all[index]\n    if (!pty) return\n    const next = await client.pty\n      .create({\n        title: pty.title,\n      })\n      .catch((error: unknown) => {\n        console.error(\"Failed to clone terminal\", error)\n        return undefined\n      })\n    if (!next?.data) return\n\n    const active = store.active === pty.id\n\n    batch(() => {\n      setStore(\"all\", index, {\n        id: next.data.id,\n        title: next.data.title ?? pty.title,\n        titleNumber: pty.titleNumber,\n        buffer: undefined,\n        cursor: undefined,\n        scrollY: undefined,\n        rows: undefined,"}],"edges":[{"source":"packages_app_src_context_terminal","target":"store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L1"}],"weight":1},{"source":"packages_app_src_context_terminal","target":"context","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L2"}],"weight":1},{"source":"packages_app_src_context_terminal","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/terminal.tsx","source_location":"L3"}],"weight":1},{"source":"packages_app_src_context_terminal","target":"router","relation":"imports_from","confidence":"EX