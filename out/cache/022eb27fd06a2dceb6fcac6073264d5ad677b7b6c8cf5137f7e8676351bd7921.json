{"__madarTsExtractorVersion":67,"__madarFileStem":"httpapi-workspace-routing.test","nodes":[{"id":"httpapi_workspace_routing_test","label":"httpapi-workspace-routing.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L1"}]},{"id":"httpapi_workspace_routing_test_requesturl","label":"requestURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L82"}],"snippet":"requestURL = (request: { readonly url: string }) => new URL(request.url, \"http://localhost\")"},{"id":"httpapi_workspace_routing_test_listenadditionalserver","label":"listenAdditionalServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L84-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L84"}],"snippet":"listenAdditionalServer = <E, R>(handler: TestHandler<E, R>) =>\n  Effect.gen(function* () {\n    const context = yield* Layer.build(NodeHttpServer.layer(Http.createServer, { host: \"127.0.0.1\", port: 0 }))\n    const server = Context.get(context, HttpServer.HttpServer)\n    yield* server.serve(HttpServerRequest.HttpServerRequest.use(handler))\n    return HttpServer.formatAddress(server.address)\n  })"},{"id":"httpapi_workspace_routing_test_localadapter","label":"localAdapter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L92-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L92"}],"snippet":"localAdapter = (directory: string): WorkspaceAdapter => ({\n  name: \"Local Test\",\n  description: \"Create a local test workspace\",\n  configure: (info) => ({ ...info, name: \"local-test\", directory }),\n  create: async () => {\n    await mkdir(directory, { recursive: true })\n  },\n  async remove() {},\n  target: () => ({ type: \"local\" as const, directory }),\n})"},{"id":"httpapi_workspace_routing_test_remoteadapter","label":"remoteAdapter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L103-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L103"}],"snippet":"remoteAdapter = (directory: string, url: string, headers?: HeadersInit): WorkspaceAdapter => ({\n  name: \"Remote Test\",\n  description: \"Create a remote test workspace\",\n  configure: (info) => ({ ...info, name: \"remote-test\", directory }),\n  create: async () => {\n    await mkdir(directory, { recursive: true })\n  },\n  async remove() {},\n  target: () => ({ type: \"remote\" as const, url, headers }),\n})"},{"id":"httpapi_workspace_routing_test_eventstreamresponse","label":"eventStreamResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L114-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L114"}],"snippet":"eventStreamResponse = () =>\n  HttpServerResponse.text('data: {\"payload\":{\"type\":\"server.connected\",\"properties\":{}}}\\n\\n', {\n    contentType: \"text/event-stream\",\n  })"},{"id":"httpapi_workspace_routing_test_syncresponse","label":"syncResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L119-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L119"}],"snippet":"syncResponse = (request: HttpServerRequest.HttpServerRequest) => {\n  const url = requestURL(request)\n  if (url.pathname === \"/base/global/event\") return Effect.succeed(eventStreamResponse())\n  if (url.pathname === \"/base/sync/history\") return HttpServerResponse.json([])\n  return undefined\n}"},{"id":"httpapi_workspace_routing_test_createworkspace","label":"createWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L126-L139","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L126"}],"snippet":"createWorkspace = (input: { projectID: Project.Info[\"id\"]; type: string; adapter: WorkspaceAdapter }) =>\n  Effect.acquireRelease(\n    Effect.gen(function* () {\n      registerAdapter(input.projectID, input.type, input.adapter)\n      const workspace = yield* Workspace.Service\n      return yield* workspace.create({\n        type: input.type,\n        branch: null,\n        extra: null,\n        projectID: input.projectID,\n      })\n    }),\n    (info) => Workspace.use.remove(info.id).pipe(Effect.ignore),\n  )"},{"id":"httpapi_workspace_routing_test_createremoteworkspace","label":"createRemoteWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L141-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L141"}],"snippet":"createRemoteWorkspace = (input: {\n  dir: string\n  projectID: Project.Info[\"id\"]\n  type: string\n  url: string\n  headers?: HeadersInit\n}) =>\n  // Workspace.create starts the remote sync loop. The test upstream exposes\n  // /global/event and /sync/history so middleware proxying sees the remote\n  // workspace as active, just like production would.\n  createWorkspace({\n    projectID: input.projectID,\n    type: input.type,\n    adapter: remoteAdapter(path.join(input.dir, `.${input.type}`), input.url, input.headers),\n  })"},{"id":"httpapi_workspace_routing_test_createlocalworkspace","label":"createLocalWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L157-L162","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L157"}],"snippet":"createLocalWorkspace = (input: { projectID: Project.Info[\"id\"]; type: string; directory: string }) =>\n  createWorkspace({\n    projectID: input.projectID,\n    type: input.type,\n    adapter: localAdapter(input.directory),\n  })"},{"id":"httpapi_workspace_routing_test_insertremoteworkspacewithoutsync","label":"insertRemoteWorkspaceWithoutSync()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L164-L180","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L164"}],"snippet":"insertRemoteWorkspaceWithoutSync = (input: {\n  dir: string\n  projectID: Project.Info[\"id\"]\n  type: string\n  url: string\n}) =>\n  Effect.gen(function* () {\n    const id = WorkspaceV2.ID.ascending()\n    registerAdapter(input.projectID, input.type, remoteAdapter(path.join(input.dir, `.${input.type}`), input.url))\n    const { db } = yield* Database.Service\n    yield* db\n      .insert(WorkspaceTable)\n      .values({ id, type: input.type, project_id: input.projectID })\n      .run()\n      .pipe(Effect.orDie)\n    return id\n  })"},{"id":"httpapi_workspace_routing_test_startremoteworkspacehttpserver","label":"startRemoteWorkspaceHttpServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L182-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L182"}],"snippet":"startRemoteWorkspaceHttpServer = <E, R>(\n  handler: (request: ProxiedRequest) => Effect.Effect<HttpServerResponse.HttpServerResponse, E, R>,\n) =>\n  listenAdditionalServer((request) =>\n    Effect.gen(function* () {\n      // Remote workspaces run a sync loop against their target server. These\n      // bootstrap routes make Workspace.isSyncing(...) true for proxy tests;\n      // everything else is the request being proxied by the middleware.\n      const sync = syncResponse(request)\n      if (sync) return yield* sync\n      return yield* handler({\n        url: request.url,\n        method: request.method,\n        headers: request.headers,\n        body: yield* request.text,\n      })\n    }),\n  )"},{"id":"httpapi_workspace_routing_test_listenremotewebsocket","label":"listenRemoteWebSocket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L201-L207","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L201"}],"snippet":"listenRemoteWebSocket = () =>\n  listenAdditionalServer((request) => {\n    const sync = syncResponse(request)\n    if (sync) return sync\n    if (requestURL(request).pathname !== \"/base/probe\") return Effect.succeed(HttpServerResponse.empty({ status: 404 }))\n    return echoWebSocket(request)\n  })"},{"id":"httpapi_workspace_routing_test_echowebsocket","label":"echoWebSocket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L209-L221","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L209"}],"snippet":"echoWebSocket = (request: HttpServerRequest.HttpServerRequest) =>\n  Effect.gen(function* () {\n    const socket = yield* Effect.orDie(request.upgrade)\n    const write = yield* socket.writer\n    yield* socket\n      .runRaw((message) => write(`echo:${String(message)}`), {\n        onOpen: write(`protocol:${request.headers[\"sec-websocket-protocol\"] ?? \"none\"}`).pipe(\n          Effect.catch(() => Effect.void),\n        ),\n      })\n      .pipe(Effect.catch(() => Effect.void))\n    return HttpServerResponse.empty()\n  })"}],"edges":[{"source":"httpapi_workspace_routing_test","target":"platform_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L1"}],"weight":1},{"source":"httpapi_workspace_routing_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L2"}],"weight":1},{"source":"httpapi_workspace_routing_test","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-workspace-routing.test.ts","source_location":"L3"}],"wei