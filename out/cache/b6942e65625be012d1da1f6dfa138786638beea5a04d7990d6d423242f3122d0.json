{"__madarTsExtractorVersion":67,"__madarFileStem":"oauth-provider","nodes":[{"id":"oauth_provider","label":"oauth-provider.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L1"}]},{"id":"oauth_provider_mcpoauthconfig","label":"McpOAuthConfig","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L14-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L14"}],"snippet":"export interface McpOAuthConfig {\n  clientId?: string\n  clientSecret?: string\n  scope?: string\n  callbackPort?: number\n  redirectUri?: string\n}"},{"id":"oauth_provider_mcpoauthcallbacks","label":"McpOAuthCallbacks","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L22-L24","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L22"}],"snippet":"export interface McpOAuthCallbacks {\n  onRedirect: (url: URL) => void | Promise<void>\n}"},{"id":"oauth_provider_mcpoauthprovider","label":"McpOAuthProvider","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L26-L185","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L26"}],"snippet":"export class McpOAuthProvider implements OAuthClientProvider {\n  constructor(\n    private mcpName: string,\n    private serverUrl: string,\n    private config: McpOAuthConfig,\n    private callbacks: McpOAuthCallbacks,\n    private auth: McpAuth.Interface,\n  ) {}\n\n  get redirectUrl(): string {\n    if (this.config.redirectUri) {\n      return this.config.redirectUri\n    }\n    const port = this.config.callbackPort ?? OAUTH_CALLBACK_PORT\n    return `http://127.0.0.1:${port}${OAUTH_CALLBACK_PATH}`\n  }\n\n  get clientMetadata(): OAuthClientMetadata {\n    return {\n      redirect_uris: [this.redirectUrl],\n      client_name: \"OpenCode\",\n      client_uri: \"https://rimuru-ai.github.io\",\n      grant_types: [\"authorization_code\", \"refresh_token\"],\n      response_types: [\"code\"],\n      token_endpoint_auth_method: this.config.clientSecret ? \"client_secret_post\" : \"none\","},{"id":"oauth_provider_oauthclientprovider","label":"OAuthClientProvider","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L26"}]},{"id":"oauth_provider_mcpoauthprovider_constructor","label":".constructor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L27-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L27"}],"snippet":"constructor(\n    private mcpName: string,\n    private serverUrl: string,\n    private config: McpOAuthConfig,\n    private callbacks: McpOAuthCallbacks,\n    private auth: McpAuth.Interface,\n  ) {}"},{"id":"oauth_provider_mcpoauthprovider_clientinformation","label":".clientInformation()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L55-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L55"}],"snippet":"async clientInformation(): Promise<OAuthClientInformation | undefined> {\n    // Check config first (pre-registered client)\n    if (this.config.clientId) {\n      return {\n        client_id: this.config.clientId,\n        client_secret: this.config.clientSecret,\n      }\n    }\n\n    // Check stored client info (from dynamic registration)\n    // Use getForUrl to validate credentials are for the current server URL\n    const entry = await Effect.runPromise(this.auth.getForUrl(this.mcpName, this.serverUrl))\n    if (entry?.clientInfo) {\n      // Check if client secret has expired\n      if (entry.clientInfo.clientSecretExpiresAt && entry.clientInfo.clientSecretExpiresAt < Date.now() / 1000) {\n        return undefined\n      }\n      return {\n        client_id: entry.clientInfo.clientId,\n        client_secret: entry.clientInfo.clientSecret,\n      }\n    }\n\n    // No client info or URL changed - will trigger dynamic registration\n    return undefined"},{"id":"oauth_provider_mcpoauthprovider_saveclientinformation","label":".saveClientInformation()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L82-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L82"}],"snippet":"async saveClientInformation(info: OAuthClientInformationFull): Promise<void> {\n    await Effect.runPromise(\n      this.auth.updateClientInfo(\n        this.mcpName,\n        {\n          clientId: info.client_id,\n          clientSecret: info.client_secret,\n          clientIdIssuedAt: info.client_id_issued_at,\n          clientSecretExpiresAt: info.client_secret_expires_at,\n        },\n        this.serverUrl,\n      ),\n    )\n  }"},{"id":"oauth_provider_mcpoauthprovider_tokens","label":".tokens()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L97-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L97"}],"snippet":"async tokens(): Promise<OAuthTokens | undefined> {\n    // Use getForUrl to validate tokens are for the current server URL\n    const entry = await Effect.runPromise(this.auth.getForUrl(this.mcpName, this.serverUrl))\n    if (!entry?.tokens) return undefined\n\n    return {\n      access_token: entry.tokens.accessToken,\n      token_type: \"Bearer\",\n      refresh_token: entry.tokens.refreshToken,\n      expires_in: entry.tokens.expiresAt\n        ? Math.max(0, Math.floor(entry.tokens.expiresAt - Date.now() / 1000))\n        : undefined,\n      scope: entry.tokens.scope,\n    }\n  }"},{"id":"oauth_provider_mcpoauthprovider_savetokens","label":".saveTokens()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L113-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L113"}],"snippet":"async saveTokens(tokens: OAuthTokens): Promise<void> {\n    await Effect.runPromise(\n      this.auth.updateTokens(\n        this.mcpName,\n        {\n          accessToken: tokens.access_token,\n          refreshToken: tokens.refresh_token,\n          expiresAt: tokens.expires_in ? Date.now() / 1000 + tokens.expires_in : undefined,\n          scope: tokens.scope,\n        },\n        this.serverUrl,\n      ),\n    )\n  }"},{"id":"oauth_provider_mcpoauthprovider_redirecttoauthorization","label":".redirectToAuthorization()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L128-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L128"}],"snippet":"async redirectToAuthorization(authorizationUrl: URL): Promise<void> {\n    await this.callbacks.onRedirect(authorizationUrl)\n  }"},{"id":"oauth_provider_mcpoauthprovider_savecodeverifier","label":".saveCodeVerifier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L132-L134","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L132"}],"snippet":"async saveCodeVerifier(codeVerifier: string): Promise<void> {\n    await Effect.runPromise(this.auth.updateCodeVerifier(this.mcpName, codeVerifier))\n  }"},{"id":"oauth_provider_mcpoauthprovider_codeverifier","label":".codeVerifier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L136-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L136"}],"snippet":"async codeVerifier(): Promise<string> {\n    const entry = await Effect.runPromise(this.auth.get(this.mcpName))\n    if (!entry?.codeVerifier) {\n      throw new Error(`No code verifier saved for MCP server: ${this.mcpName}`)\n    }\n    return entry.codeVerifier\n  }"},{"id":"oauth_provider_mcpoauthprovider_savestate","label":".saveState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L144-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L144"}],"snippet":"async saveState(state: string): Promise<void> {\n    await Effect.runPromise(this.auth.updateOAuthState(this.mcpName, state))\n  }"},{"id":"oauth_provider_mcpoauthprovider_state","label":".state()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L148-L163","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L148"}],"snippet":"async state(): Promise<string> {\n    const entry = await Effect.runPromise(this.auth.get(this.mcpName))\n    if (entry?.oauthState) {\n      return entry.oauthState\n    }\n\n    // Generate a new state if none exists — the SDK calls state() as a\n    // generator, not just a reader, so we need to produce a value even when\n    // startAuth() hasn't pre-saved one (e.g. during automatic auth on first\n    // connect).\n    const newState = Array.from(crypto.getRandomValues(new Uint8Array(32)))\n      .map((b) => b.toString(16).padStart(2, \"0\"))\n      .join(\"\")\n    await Effect.runPromise(this.auth.updateOAuthState(this.mcpName, newState))\n    return newState\n  }"},{"id":"oauth_provider_mcpoauthprovider_invalidatecredentials","label":".invalidateCredentials()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L165-L184","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L165"}],"snippet":"async invalidateCredentials(type: \"all\" | \"client\" | \"tokens\"): Promise<void> {\n    const entry = await Effect.runPromise(this.auth.get(this.mcpName))\n    if (!entry) {\n      return\n    }\n\n    switch (type) {\n      case \"all\":\n        await Effect.runPromise(this.auth.remove(this.mcpName))\n        break\n      case \"client\":\n        delete entry.clientInfo\n        await Effect.runPromise(this.auth.set(this.mcpName, entry))\n        break\n      case \"tokens\":\n        delete entry.tokens\n        await Effect.runPromise(this.auth.set(this.mcpName, entry))\n        break\n    }\n  }"},{"id":"oauth_provider_parseredirecturi","label":"parseRedirectUri()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L193-L206","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L193"}],"snippet":"export function parseRedirectUri(redirectUri?: string): { port: number; path: string } {\n  if (!redirectUri) {\n    return { port: OAUTH_CALLBACK_PORT, path: OAUTH_CALLBACK_PATH }\n  }\n\n  try {\n    const url = new URL(redirectUri)\n    const port = url.port ? parseInt(url.port, 10) : url.protocol === \"https:\" ? 443 : 80\n    const path = url.pathname || OAUTH_CALLBACK_PATH\n    return { port, path }\n  } catch {\n    return { port: OAUTH_CALLBACK_PORT, path: OAUTH_CALLBACK_PATH }\n  }\n}"}],"edges":[{"source":"oauth_provider","target":"auth","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L1"}],"weight":1},{"source":"oauth_provider","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L8","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L8"}],"weight":1},{"source":"oauth_provider","target":"oauth_provider_mcpoauthconfig","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L14","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L14"}],"weight":1},{"source":"oauth_provider","target":"oauth_provider_mcpoauthcallbacks","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/mcp/oauth-provider.ts","source_location":"L22"}],"weight":1},{"source":"oauth_provider","target":"oauth_provider_mcp