{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_desktop_src_renderer_i18n_index","nodes":[{"id":"packages_desktop_src_renderer_i18n_index","label":"index.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L1"}]},{"id":"packages_desktop_src_renderer_i18n_index_detectlocale","label":"detectLocale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L77-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L77"}],"snippet":"function detectLocale(): Locale {\n  if (typeof navigator !== \"object\") return \"en\"\n\n  const languages = navigator.languages?.length ? navigator.languages : [navigator.language]\n  for (const language of languages) {\n    if (!language) continue\n    if (language.toLowerCase().startsWith(\"en\")) return \"en\"\n    if (language.toLowerCase().startsWith(\"zh\")) {\n      if (language.toLowerCase().includes(\"hant\")) return \"zht\"\n      return \"zh\"\n    }\n    if (language.toLowerCase().startsWith(\"ko\")) return \"ko\"\n    if (language.toLowerCase().startsWith(\"de\")) return \"de\"\n    if (language.toLowerCase().startsWith(\"es\")) return \"es\"\n    if (language.toLowerCase().startsWith(\"fr\")) return \"fr\"\n    if (language.toLowerCase().startsWith(\"da\")) return \"da\"\n    if (language.toLowerCase().startsWith(\"ja\")) return \"ja\"\n    if (language.toLowerCase().startsWith(\"pl\")) return \"pl\"\n    if (language.toLowerCase().startsWith(\"ru\")) return \"ru\"\n    if (language.toLowerCase().startsWith(\"uk\")) return \"uk\"\n    if (language.toLowerCase().startsWith(\"ar\")) return \"ar\"\n    if (\n      language.toLowerCase().startsWith(\"no\") ||\n      language.toLowerCase().startsWith(\"nb\") ||\n      language.toLowerCase().startsWith(\"nn\")"},{"id":"packages_desktop_src_renderer_i18n_index_parselocale","label":"parseLocale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L111-L116","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L111"}],"snippet":"function parseLocale(value: unknown): Locale | null {\n  if (!value) return null\n  if (typeof value !== \"string\") return null\n  if ((LOCALES as readonly string[]).includes(value)) return value as Locale\n  return null\n}"},{"id":"packages_desktop_src_renderer_i18n_index_parserecord","label":"parseRecord()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L118-L122","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L118"}],"snippet":"function parseRecord(value: unknown) {\n  if (!value || typeof value !== \"object\") return null\n  if (Array.isArray(value)) return null\n  return value as Record<string, unknown>\n}"},{"id":"packages_desktop_src_renderer_i18n_index_parsestored","label":"parseStored()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L124-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L124"}],"snippet":"function parseStored(value: unknown) {\n  if (typeof value !== \"string\") return value\n  try {\n    return JSON.parse(value) as unknown\n  } catch {\n    return value\n  }\n}"},{"id":"packages_desktop_src_renderer_i18n_index_picklocale","label":"pickLocale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L133-L141","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L133"}],"snippet":"function pickLocale(value: unknown): Locale | null {\n  const direct = parseLocale(value)\n  if (direct) return direct\n\n  const record = parseRecord(value)\n  if (!record) return null\n\n  return parseLocale(record.locale)\n}"},{"id":"packages_desktop_src_renderer_i18n_index_build","label":"build()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L145-L162","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L145"}],"snippet":"function build(locale: Locale): Dictionary {\n  if (locale === \"en\") return base\n  if (locale === \"zh\") return { ...base, ...i18n.flatten(appZh), ...i18n.flatten(desktopZh) }\n  if (locale === \"zht\") return { ...base, ...i18n.flatten(appZht), ...i18n.flatten(desktopZht) }\n  if (locale === \"de\") return { ...base, ...i18n.flatten(appDe), ...i18n.flatten(desktopDe) }\n  if (locale === \"es\") return { ...base, ...i18n.flatten(appEs), ...i18n.flatten(desktopEs) }\n  if (locale === \"fr\") return { ...base, ...i18n.flatten(appFr), ...i18n.flatten(desktopFr) }\n  if (locale === \"da\") return { ...base, ...i18n.flatten(appDa), ...i18n.flatten(desktopDa) }\n  if (locale === \"ja\") return { ...base, ...i18n.flatten(appJa), ...i18n.flatten(desktopJa) }\n  if (locale === \"pl\") return { ...base, ...i18n.flatten(appPl), ...i18n.flatten(desktopPl) }\n  if (locale === \"ru\") return { ...base, ...i18n.flatten(appRu), ...i18n.flatten(desktopRu) }\n  if (locale === \"uk\") return { ...base, ...i18n.flatten(appUk), ...i18n.flatten(desktopUk) }\n  if (locale === \"ar\") return { ...base, ...i18n.flatten(appAr), ...i18n.flatten(desktopAr) }\n  if (locale === \"no\") return { ...base, ...i18n.flatten(appNo), ...i18n.flatten(desktopNo) }\n  if (locale === \"br\") return { ...base, ...i18n.flatten(appBr), ...i18n.flatten(desktopBr) }\n  if (locale === \"bs\") return { ...base, ...i18n.flatten(appBs), ...i18n.flatten(desktopBs) }\n  return { ...base, ...i18n.flatten(appKo), ...i18n.flatten(desktopKo) }\n}"},{"id":"packages_desktop_src_renderer_i18n_index_t","label":"t()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L174-L176","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L174"}],"snippet":"export function t(key: keyof Dictionary, params?: Record<string, string | number>) {\n  return translate(key, params)\n}"},{"id":"packages_desktop_src_renderer_i18n_index_initi18n","label":"initI18n()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L178-L194","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L178"}],"snippet":"export function initI18n(): Promise<Locale> {\n  const cached = state.init\n  if (cached) return cached\n\n  const promise = (async () => {\n    const raw = await window.api.storeGet(\"opencode.global.dat\", \"language\").catch(() => null)\n    const value = parseStored(raw)\n    const next = pickLocale(value) ?? state.locale\n\n    state.locale = next\n    state.dict = build(next)\n    return next\n  })().catch(() => state.locale)\n\n  state.init = promise\n  return promise\n}"}],"edges":[{"source":"packages_desktop_src_renderer_i18n_index","target":"i18n","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L1"}],"weight":1},{"source":"packages_desktop_src_renderer_i18n_index","target":"en","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L3"}],"weight":1},{"source":"packages_desktop_src_renderer_i18n_index","target":"zh","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/i18n/index.ts","source_location":"L4"}],"weight":1},{"source":"packages_desktop_src_renderer_i18n