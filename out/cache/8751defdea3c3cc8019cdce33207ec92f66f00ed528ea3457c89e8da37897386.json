{"__madarTsExtractorVersion":67,"__madarFileStem":"cross-spawn-spawner","nodes":[{"id":"cross_spawn_spawner","label":"cross-spawn-spawner.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L1"}]},{"id":"cross_spawn_spawner_toerror","label":"toError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L30"}],"snippet":"toError = (err: unknown): Error => (err instanceof globalThis.Error ? err : new globalThis.Error(String(err)))"},{"id":"cross_spawn_spawner_totag","label":"toTag()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L32-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L32"}],"snippet":"toTag = (err: NodeJS.ErrnoException): PlatformError.SystemErrorTag => {\n  switch (err.code) {\n    case \"ENOENT\":\n      return \"NotFound\"\n    case \"EACCES\":\n      return \"PermissionDenied\"\n    case \"EEXIST\":\n      return \"AlreadyExists\"\n    case \"EISDIR\":\n      return \"BadResource\"\n    case \"ENOTDIR\":\n      return \"BadResource\"\n    case \"EBUSY\":\n      return \"Busy\"\n    case \"ELOOP\":\n      return \"BadResource\"\n    default:\n      return \"Unknown\"\n  }\n}"},{"id":"cross_spawn_spawner_flatten","label":"flatten()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L53-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L53"}],"snippet":"flatten = (command: ChildProcess.Command) => {\n  const commands: Array<ChildProcess.StandardCommand> = []\n  const opts: Array<ChildProcess.PipeOptions> = []\n\n  const walk = (cmd: ChildProcess.Command): void => {\n    switch (cmd._tag) {\n      case \"StandardCommand\":\n        commands.push(cmd)\n        return\n      case \"PipedCommand\":\n        walk(cmd.left)\n        opts.push(cmd.options)\n        walk(cmd.right)\n        return\n    }\n  }\n\n  walk(command)\n  if (commands.length === 0) throw new Error(\"flatten produced empty commands array\")\n  const [head, ...tail] = commands\n  return {\n    commands: [head, ...tail] as Arr.NonEmptyReadonlyArray<ChildProcess.StandardCommand>,\n    opts,\n  }\n}"},{"id":"cross_spawn_spawner_flatten_walk","label":"walk()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L57-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L57"}],"snippet":"walk = (cmd: ChildProcess.Command): void => {\n    switch (cmd._tag) {\n      case \"StandardCommand\":\n        commands.push(cmd)\n        return\n      case \"PipedCommand\":\n        walk(cmd.left)\n        opts.push(cmd.options)\n        walk(cmd.right)\n        return\n    }\n  }"},{"id":"cross_spawn_spawner_toplatformerror","label":"toPlatformError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L79-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L79"}],"snippet":"toPlatformError = (\n  method: string,\n  err: NodeJS.ErrnoException,\n  command: ChildProcess.Command,\n): PlatformError.PlatformError => {\n  const cmd = flatten(command)\n    .commands.map((x) => `${x.command} ${x.args.join(\" \")}`)\n    .join(\" | \")\n  return PlatformError.systemError({\n    _tag: toTag(err),\n    module: \"ChildProcess\",\n    method,\n    pathOrDescriptor: cmd,\n    syscall: err.syscall,\n    cause: err,\n  })\n}"}],"edges":[{"source":"cross_spawn_spawner","target":"array","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L1"}],"weight":1},{"source":"cross_spawn_spawner","target":"platform_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L2"}],"weight":1},{"source":"cross_spawn_spawner","target":"nodepath","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/cross-spawn-spawner.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","s