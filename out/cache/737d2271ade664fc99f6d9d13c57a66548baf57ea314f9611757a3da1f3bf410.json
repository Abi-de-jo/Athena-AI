{"__madarTsExtractorVersion":67,"__madarFileStem":"model-section","nodes":[{"id":"model_section","label":"model-section.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/model-section.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/model-section.tsx","source_location":"L1"}]},{"id":"model_section_getmodellab","label":"getModelLab()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/model-section.tsx","source_location":"L27-L41","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/model-section.tsx","source_location":"L27"}],"snippet":"getModelLab = (modelId: string) => {\n  if (modelId.startsWith(\"claude\")) return \"Anthropic\"\n  if (modelId.startsWith(\"gpt\")) return \"OpenAI\"\n  if (modelId.startsWith(\"gemini\")) return \"Google\"\n  if (modelId.startsWith(\"deepseek\")) return \"DeepSeek\"\n  if (modelId.startsWith(\"kimi\")) return \"Moonshot AI\"\n  if (modelId.startsWith(\"glm\")) return \"Z.ai\"\n  if (modelId.startsWith(\"qwen\")) return \"Alibaba\"\n  if (modelId.startsWith(\"minimax\")) return \"MiniMax\"\n  if (modelId.startsWith(\"grok\")) return \"xAI\"\n  if (modelId.startsWith(\"mimo\")) return \"Xiaomi\"\n  if (modelId.startsWith(\"nemotron\")) return \"NVIDIA\"\n  if (modelId.startsWith(\"trinity\")) return \"Arcee\"\n  return \"Stealth\"\n}"},{"id":"model_section_modelsection","label":"ModelSection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/model-section.tsx","source_location":"L102-L209","lay