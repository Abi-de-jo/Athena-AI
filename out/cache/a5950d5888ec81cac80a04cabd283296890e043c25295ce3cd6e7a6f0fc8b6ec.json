{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_tool_websearch","nodes":[{"id":"packages_rimuru_src_tool_websearch","label":"websearch.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_tool_websearch_selectwebsearchprovider","label":"selectWebSearchProvider()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L30-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L30"}],"snippet":"export function selectWebSearchProvider(sessionID: string, flags = { exa: false, parallel: false }): WebSearchProvider {\n  const override = process.env.OPENCODE_WEBSEARCH_PROVIDER\n  if (override === \"exa\" || override === \"parallel\") return override\n  if (flags.parallel) return \"parallel\"\n  if (flags.exa) return \"exa\"\n\n  return Number.parseInt(checksum(sessionID) ?? \"0\", 36) % 2 === 0 ? \"exa\" : \"parallel\"\n}"},{"id":"packages_rimuru_src_tool_websearch_websearchproviderlabel","label":"webSearchProviderLabel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L39-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L39"}],"snippet":"export function webSearchProviderLabel(provider: unknown) {\n  if (provider === \"parallel\") return \"Parallel Web Search\"\n  if (provider === \"exa\") return \"Exa Web Search\"\n  return \"Web Search\"\n}"},{"id":"packages_rimuru_src_tool_websearch_websearchmodelname","label":"webSearchModelName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L45-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L45"}],"snippet":"export function webSearchModelName(extra: Tool.Context[\"extra\"]) {\n  const model = extra?.model\n  if (!model || typeof model !== \"object\") return undefined\n  const api = \"api\" in model && model.api && typeof model.api === \"object\" ? model.api : undefined\n  const apiID = api && \"id\" in api && typeof api.id === \"string\" ? api.id : undefined\n  const id = \"id\" in model && typeof model.id === \"string\" ? model.id : undefined\n  return (apiID ?? id)?.slice(0, 100)\n}"},{"id":"packages_rimuru_src_tool_websearch_parallelauthheaders","label":"parallelAuthHeaders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L54-L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L54"}],"snippet":"function parallelAuthHeaders() {\n  const headers = { \"User-Agent\": `rimuru-ai/${InstallationVersion}` }\n  if (!process.env.PARALLEL_API_KEY) return headers\n  return { ...headers, Authorization: `Bearer ${process.env.PARALLEL_API_KEY}` }\n}"},{"id":"packages_rimuru_src_tool_websearch_callprovider","label":"callProvider()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L60-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L60"}],"snippet":"function callProvider(\n  http: HttpClient.HttpClient,\n  provider: WebSearchProvider,\n  params: Schema.Schema.Type<typeof Parameters>,\n  ctx: Tool.Context,\n) {\n  if (provider === \"parallel\") {\n    return McpWebSearch.call(\n      http,\n      McpWebSearch.PARALLEL_URL,\n      \"web_search\",\n      McpWebSearch.ParallelSearchArgs,\n      {\n        objective: params.query,\n        search_queries: [params.query],\n        session_id: ctx.sessionID,\n        model_name: webSearchModelName(ctx.extra),\n      },\n      \"25 seconds\",\n      parallelAuthHeaders(),\n    )\n  }\n\n  return McpWebSearch.call(\n    http,"}],"edges":[{"source":"packages_rimuru_src_tool_websearch","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_tool_websearch","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts","source_location":"L2"}],"weight":1},{"source":"packages_rimuru_src_tool_websearch","target":"tool","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/websearch.ts",