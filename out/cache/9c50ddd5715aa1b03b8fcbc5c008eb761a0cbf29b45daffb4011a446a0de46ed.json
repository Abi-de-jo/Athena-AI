{"__madarTsExtractorVersion":67,"__madarFileStem":"httpapi-listen.test","nodes":[{"id":"httpapi_listen_test","label":"httpapi-listen.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L1"}]},{"id":"httpapi_listen_test_startlistener","label":"startListener()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L32-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L32"}],"snippet":"async function startListener() {\n  Flag.OPENCODE_SERVER_PASSWORD = auth.password\n  Flag.OPENCODE_SERVER_USERNAME = auth.username\n  process.env.OPENCODE_SERVER_PASSWORD = auth.password\n  process.env.OPENCODE_SERVER_USERNAME = auth.username\n  return Server.listen({ hostname: \"127.0.0.1\", port: 0 })\n}"},{"id":"httpapi_listen_test_startnoauthlistener","label":"startNoAuthListener()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L40-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L40"}],"snippet":"async function startNoAuthListener() {\n  Flag.OPENCODE_SERVER_PASSWORD = undefined\n  Flag.OPENCODE_SERVER_USERNAME = auth.username\n  delete process.env.OPENCODE_SERVER_PASSWORD\n  process.env.OPENCODE_SERVER_USERNAME = auth.username\n  return Server.listen({ hostname: \"127.0.0.1\", port: 0 })\n}"},{"id":"httpapi_listen_test_authorization","label":"authorization()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L48-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L48"}],"snippet":"function authorization() {\n  return `Basic ${btoa(`${auth.username}:${auth.password}`)}`\n}"},{"id":"httpapi_listen_test_socketurl","label":"socketURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L52-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L52"}],"snippet":"function socketURL(listener: Awaited<ReturnType<typeof startListener>>, id: string, dir: string, ticket?: string) {\n  const url = new URL(PtyPaths.connect.replace(\":ptyID\", id), listener.url)\n  url.protocol = \"ws:\"\n  url.searchParams.set(\"directory\", dir)\n  url.searchParams.set(\"cursor\", \"-1\")\n  if (ticket) url.searchParams.set(\"ticket\", ticket)\n  return url\n}"},{"id":"httpapi_listen_test_requestticket","label":"requestTicket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L61-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L61"}],"snippet":"async function requestTicket(\n  listener: Awaited<ReturnType<typeof startListener>>,\n  id: string,\n  dir: string,\n  options?: { ticketHeader?: boolean; origin?: string },\n) {\n  const response = await fetch(new URL(PtyPaths.connectToken.replace(\":ptyID\", id), listener.url), {\n    method: \"POST\",\n    headers: {\n      authorization: authorization(),\n      \"x-opencode-directory\": dir,\n      ...(options?.ticketHeader === false ? {} : { \"x-opencode-ticket\": \"1\" }),\n      ...(options?.origin ? { origin: options.origin } : {}),\n    },\n  })\n\n  return response\n}"},{"id":"httpapi_listen_test_connectticket","label":"connectTicket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L80-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L80"}],"snippet":"async function connectTicket(listener: Awaited<ReturnType<typeof startListener>>, id: string, dir: string) {\n  const response = await requestTicket(listener, id, dir)\n  expect(response.status).toBe(200)\n  return (await response.json()) as { ticket: string; expires_in: number }\n}"},{"id":"httpapi_listen_test_createcat","label":"createCat()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L86-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L86"}],"snippet":"async function createCat(listener: Awaited<ReturnType<typeof startListener>>, dir: string) {\n  const response = await fetch(new URL(PtyPaths.create, listener.url), {\n    method: \"POST\",\n    headers: {\n      authorization: authorization(),\n      \"x-opencode-directory\": dir,\n      \"content-type\": \"application/json\",\n    },\n    body: JSON.stringify({ command: \"/bin/cat\", title: \"listen-smoke\" }),\n  })\n  expect(response.status).toBe(200)\n  return (await response.json()) as { id: string }\n}"},{"id":"httpapi_listen_test_opensocket","label":"openSocket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L100-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L100"}],"snippet":"async function openSocket(url: URL) {\n  const ws = new WebSocket(url)\n  ws.binaryType = \"arraybuffer\"\n  await withTimeout(\n    new Promise<void>((resolve, reject) => {\n      ws.addEventListener(\"open\", () => resolve(), { once: true })\n      ws.addEventListener(\"error\", () => reject(new Error(\"websocket failed before open\")), { once: true })\n    }),\n    5_000,\n    \"timed out waiting for websocket open\",\n  )\n  return ws\n}"},{"id":"httpapi_listen_test_expectsocketrejected","label":"expectSocketRejected()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L114-L134","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L114"}],"snippet":"async function expectSocketRejected(url: URL, init?: { headers?: Record<string, string> }) {\n  // Bun's WebSocket accepts an init object with headers; standard DOM types don't reflect that.\n  const Ctor = WebSocket as unknown as new (url: URL, init?: { headers?: Record<string, string> }) => WebSocket\n  const ws = new Ctor(url, init)\n  await withTimeout(\n    new Promise<void>((resolve, reject) => {\n      ws.addEventListener(\n        \"open\",\n        () => {\n          ws.close(1000)\n          reject(new Error(\"websocket opened\"))\n        },\n        { once: true },\n      )\n      ws.addEventListener(\"error\", () => resolve(), { once: true })\n      ws.addEventListener(\"close\", () => resolve(), { once: true })\n    }),\n    5_000,\n    \"timed out waiting for websocket rejection\",\n  )\n}"},{"id":"httpapi_listen_test_stop","label":"stop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L136-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L136"}],"snippet":"function stop(listener: Awaited<ReturnType<typeof startListener>>, label: string) {\n  return withTimeout(listener.stop(true), 10_000, label)\n}"},{"id":"httpapi_listen_test_waitformessage","label":"waitForMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L140-L157","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L140"}],"snippet":"function waitForMessage(ws: WebSocket, predicate: (message: string) => boolean) {\n  const decoder = new TextDecoder()\n  let onMessage: ((event: MessageEvent) => void) | undefined\n  return withTimeout(\n    new Promise<string>((resolve) => {\n      onMessage = (event: MessageEvent) => {\n        const message = typeof event.data === \"string\" ? event.data : decoder.decode(event.data as ArrayBuffer)\n        if (!predicate(message)) return\n        resolve(message)\n      }\n      ws.addEventListener(\"message\", onMessage)\n    }),\n    5_000,\n    \"timed out waiting for websocket message\",\n  ).finally(() => {\n    if (onMessage) ws.removeEventListener(\"message\", onMessage)\n  })\n}"},{"id":"httpapi_listen_test_openptysocket","label":"openPtySocket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L159-L167","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L159"}],"snippet":"async function openPtySocket(listener: Awaited<ReturnType<typeof startListener>>, dir: string) {\n  const info = await createCat(listener, dir)\n  const ticket = await connectTicket(listener, info.id, dir)\n  const ws = await openSocket(socketURL(listener, info.id, dir, ticket.ticket))\n  return {\n    ws,\n    closed: new Promise<void>((resolve) => ws.addEventListener(\"close\", () => resolve(), { once: true })),\n  }\n}"},{"id":"httpapi_listen_test_isportfree","label":"isPortFree()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L450-L457","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L450"}],"snippet":"function isPortFree(port: number) {\n  return new Promise<boolean>((resolve) => {\n    const probe = net.createServer()\n    probe.once(\"error\", () => resolve(false))\n    probe.once(\"listening\", () => probe.close(() => resolve(true)))\n    probe.listen(port, \"127.0.0.1\")\n  })\n}"},{"id":"httpapi_listen_test_occupyport","label":"occupyPort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L459-L465","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L459"}],"snippet":"function occupyPort(port: number) {\n  return new Promise<net.Server | undefined>((resolve) => {\n    const server = net.createServer()\n    server.once(\"error\", () => resolve(undefined))\n    server.listen(port, \"127.0.0.1\", () => resolve(server))\n  })\n}"}],"edges":[{"source":"httpapi_listen_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L1"}],"weight":1},{"source":"httpapi_listen_test","target":"net","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L2"}],"weight":1},{"source":"httpapi_listen_test","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-listen.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects