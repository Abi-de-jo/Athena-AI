{"__madarTsExtractorVersion":67,"__madarFileStem":"redaction","nodes":[{"id":"redaction","label":"redaction.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L1"}]},{"id":"redaction_envsecrets","label":"envSecrets()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L43-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L43"}],"snippet":"envSecrets = () =>\n  Object.entries(process.env).flatMap(([name, value]) => {\n    if (!value) return []\n    if (!ENV_SECRET_NAMES.test(name)) return []\n    if (value.length < 12) return []\n    if (SAFE_ENV_VALUES.has(value.toLowerCase())) return []\n    return [{ name, value }]\n  })"},{"id":"redaction_pathfor","label":"pathFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L52"}],"snippet":"pathFor = (base: string, key: string) => (base ? `${base}.${key}` : key)"},{"id":"redaction_stringentries","label":"stringEntries()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L54-L61","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L54"}],"snippet":"stringEntries = (value: unknown, base = \"\"): ReadonlyArray<{ readonly path: string; readonly value: string }> => {\n  if (typeof value === \"string\") return [{ path: base, value }]\n  if (Array.isArray(value)) return value.flatMap((item, index) => stringEntries(item, `${base}[${index}]`))\n  if (value && typeof value === \"object\") {\n    return Object.entries(value).flatMap(([key, child]) => stringEntries(child, pathFor(base, key)))\n  }\n  return []\n}"},{"id":"redaction_redactionset","label":"redactionSet()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L63-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L63"}],"snippet":"redactionSet = (values: ReadonlyArray<string> | undefined, defaults: ReadonlyArray<string>) =>\n  new Set([...defaults, ...(values ?? [])].map((value) => value.toLowerCase()))"},{"id":"redaction_redacturl","label":"redactUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L68-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L68"}],"snippet":"redactUrl = (\n  raw: string,\n  query: ReadonlyArray<string> = DEFAULT_REDACT_QUERY,\n  urlRedactor?: UrlRedactor,\n) => {\n  if (!URL.canParse(raw)) return urlRedactor?.(raw) ?? raw\n  const url = new URL(raw)\n  if (url.username) url.username = REDACTED\n  if (url.password) url.password = REDACTED\n  const redacted = redactionSet(query, DEFAULT_REDACT_QUERY)\n  for (const key of url.searchParams.keys()) {\n    if (redacted.has(key.toLowerCase())) url.searchParams.set(key, REDACTED)\n  }\n  return urlRedactor?.(url.toString()) ?? url.toString()\n}"},{"id":"redaction_redactheaders","label":"redactHeaders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L84-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L84"}],"snippet":"redactHeaders = (\n  headers: Record<string, string>,\n  allow: ReadonlyArray<string>,\n  redact: ReadonlyArray<string> = DEFAULT_REDACT_HEADERS,\n) => {\n  const allowed = new Set(allow.map((name) => name.toLowerCase()))\n  const redacted = redactionSet(redact, DEFAULT_REDACT_HEADERS)\n  return Object.fromEntries(\n    Object.entries(headers)\n      .map(([name, value]) => [name.toLowerCase(), value] as const)\n      .filter(([name]) => allowed.has(name))\n      .map(([name, value]) => [name, redacted.has(name) ? REDACTED : value] as const)\n      .toSorted(([a], [b]) => a.localeCompare(b)),\n  )\n}"},{"id":"redaction_secretfindings","label":"secretFindings()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L106-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L106"}],"snippet":"secretFindings = (value: unknown): ReadonlyArray<SecretFinding> => {\n  const environment = envSecrets()\n  return stringEntries(value).flatMap((entry) => [\n    ...SECRET_PATTERNS.filter((item) => item.pattern.test(entry.value)).map((item) => ({\n      path: entry.path,\n      reason: item.label,\n    })),\n    ...environment\n      .filter((item) => entry.value.includes(item.value))\n      .map((item) => ({ path: entry.path, reason: `environment secret ${item.name}` })),\n  ])\n}"}],"edges":[{"source":"redaction","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L1"}],"weight":1},{"source":"redaction","target":"redaction_envsecrets","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L43"}],"weight":1},{"source":"redaction","target":"redaction_pathfor","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L52"}],"weight":1},{"source":"redaction","target":"redaction_stringentries","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/redaction.ts","source_location":"L54"}],"weight":1},{"source":"redaction","target":"redaction_re