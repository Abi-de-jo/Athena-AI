{"__madarTsExtractorVersion":67,"__madarFileStem":"session-timeline-collapse-state.spec","nodes":[{"id":"session_timeline_collapse_state_spec","label":"session-timeline-collapse-state.spec.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L1"}]},{"id":"session_timeline_collapse_state_spec_window","label":"Window","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L21-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L21"}],"snippet":"interface Window {\n    __timelineDiffProbe: {\n      reset: () => void\n      shadowRoots: () => number\n    }\n  }"},{"id":"session_timeline_collapse_state_spec_configurepage","label":"configurePage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L180-L194","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L180"}],"snippet":"async function configurePage(page: Page) {\n  await page.addInitScript(() => {\n    localStorage.setItem(\n      \"settings.v3\",\n      JSON.stringify({\n        general: {\n          editToolPartsExpanded: true,\n          shellToolPartsExpanded: true,\n          showReasoningSummaries: true,\n          showSessionProgressBar: true,\n        },\n      }),\n    )\n  })\n}"},{"id":"session_timeline_collapse_state_spec_expectexpanded","label":"expectExpanded()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L196-L198","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L196"}],"snippet":"async function expectExpanded(locator: Locator, expected: boolean) {\n  await expect.poll(() => locator.evaluate(readExpanded)).toBe(expected)\n}"},{"id":"session_timeline_collapse_state_spec_readtoolstate","label":"readToolState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L200-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L200"}],"snippet":"async function readToolState(page: Page) {\n  return page\n    .locator(`[data-timeline-part-id=\"${editPartID}\"]`)\n    .first()\n    .evaluate(\n      (element, textPartID) => ({\n        expanded: (() => {\n          const trigger = element.querySelector('[data-slot=\"collapsible-trigger\"]')\n          const aria = trigger?.getAttribute(\"aria-expanded\")\n          if (aria === \"true\") return true\n          if (aria === \"false\") return false\n\n          const root = element.querySelector('[data-component=\"collapsible\"]')\n          if (root?.hasAttribute(\"data-expanded\")) return true\n          if (root?.hasAttribute(\"data-closed\")) return false\n\n          const content = element.querySelector<HTMLElement>('[data-slot=\"collapsible-content\"]')\n          return !!content && content.getBoundingClientRect().height > 0\n        })(),\n        row: element.closest(\"[data-timeline-row]\")?.getAttribute(\"data-timeline-row\"),\n        streamedTextVisible: !!document.querySelector(`[data-timeline-part-id=\"${textPartID}\"]`),\n      }),\n      textPartID,\n    )\n}"},{"id":"session_timeline_collapse_state_spec_installdiffprobe","label":"installDiffProbe()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L226-L241","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L226"}],"snippet":"async function installDiffProbe(page: Page) {\n  await page.addInitScript(() => {\n    let shadowRootCount = 0\n    const attachShadow = Element.prototype.attachShadow\n    Element.prototype.attachShadow = function (init) {\n      shadowRootCount += 1\n      return attachShadow.call(this, init)\n    }\n    window.__timelineDiffProbe = {\n      reset: () => {\n        shadowRootCount = 0\n      },\n      shadowRoots: () => shadowRootCount,\n    }\n  })\n}"},{"id":"session_timeline_collapse_state_spec_markdiffprobe","label":"markDiffProbe()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L243-L256","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L243"}],"snippet":"async function markDiffProbe(page: Page) {\n  await page\n    .locator(`[data-timeline-part-id=\"${editPartID}\"]`)\n    .first()\n    .evaluate((element) => {\n      const tool = element as HTMLElement\n      const file = tool.querySelector<HTMLElement>('[data-component=\"file\"][data-mode=\"diff\"]')\n      if (!file) throw new Error(\"missing edit diff file\")\n\n      tool.dataset.timelineProbe = \"before\"\n      file.dataset.timelineProbe = \"before\"\n      window.__timelineDiffProbe.reset()\n    })\n}"},{"id":"session_timeline_collapse_state_spec_readdiffprobe","label":"readDiffProbe()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L258-L271","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L258"}],"snippet":"async function readDiffProbe(page: Page) {\n  return page\n    .locator(`[data-timeline-part-id=\"${editPartID}\"]`)\n    .first()\n    .evaluate((element) => {\n      const tool = element as HTMLElement\n      const file = tool.querySelector<HTMLElement>('[data-component=\"file\"][data-mode=\"diff\"]')\n      return {\n        fileMarker: file?.dataset.timelineProbe,\n        shadowRoots: window.__timelineDiffProbe.shadowRoots(),\n        toolMarker: tool.dataset.timelineProbe,\n      }\n    })\n}"},{"id":"session_timeline_collapse_state_spec_editpartwithadditions","label":"editPartWithAdditions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L273-L287","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L273"}],"snippet":"function editPartWithAdditions(additions: number) {\n  return {\n    ...editPart,\n    state: {\n      ...editPart.state,\n      metadata: {\n        ...editPart.state.metadata,\n        filediff: {\n          ...editPart.state.metadata.filediff,\n          additions,\n        },\n      },\n    },\n  }\n}"},{"id":"session_timeline_collapse_state_spec_readexpanded","label":"readExpanded()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L289-L301","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L289"}],"snippet":"function readExpanded(element: Element) {\n  const trigger = element.querySelector('[data-slot=\"collapsible-trigger\"]')\n  const aria = trigger?.getAttribute(\"aria-expanded\")\n  if (aria === \"true\") return true\n  if (aria === \"false\") return false\n\n  const root = element.querySelector('[data-component=\"collapsible\"]')\n  if (root?.hasAttribute(\"data-expanded\")) return true\n  if (root?.hasAttribute(\"data-closed\")) return false\n\n  const content = element.querySelector<HTMLElement>('[data-slot=\"collapsible-content\"]')\n  return !!content && content.getBoundingClientRect().height > 0\n}"},{"id":"session_timeline_collapse_state_spec_mockserver","label":"mockServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L303-L312","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L303"}],"snippet":"async function mockServer(page: Page, events: EventPayload[]) {\n  await mockOpenCodeServer(page, {\n    directory,\n    project: project(),\n    provider: provider(),\n    sessions: [session()],\n    pageMessages: () => ({ items: [userMessage, assistantMessage] }),\n    events: () => events.splice(0),\n  })\n}"},{"id":"session_timeline_collapse_state_spec_project","label":"project()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L314-L323","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L314"}],"snippet":"function project() {\n  return {\n    id: projectID,\n    worktree: directory,\n    vcs: \"git\",\n    name: \"timeline-state-regression\",\n    time: { created: 1700000000000, updated: 1700000000000 },\n    sandboxes: [],\n  }\n}"},{"id":"session_timeline_collapse_state_spec_session","label":"session()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L325-L335","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L325"}],"snippet":"function session() {\n  return {\n    id: sessionID,\n    slug: \"timeline-state-regression\",\n    projectID,\n    directory,\n    title,\n    version: \"dev\",\n    time: { created: 1700000000000, updated: 1700000000000 },\n  }\n}"},{"id":"session_timeline_collapse_state_spec_provider","label":"provider()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-collapse-state.spec.ts","source_location":"L337-L349","laye