{"__madarTsExtractorVersion":67,"__madarFileStem":"runtime.queue","nodes":[{"id":"runtime_queue","label":"runtime.queue.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L1"}]},{"id":"runtime_queue_defer","label":"defer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L43-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L43"}],"snippet":"function defer<T = void>(): Deferred<T> {\n  let resolve!: (value: T | PromiseLike<T>) => void\n  let reject!: (error?: unknown) => void\n  const promise = new Promise<T>((next, fail) => {\n    resolve = next\n    reject = fail\n  })\n\n  return { promise, resolve, reject }\n}"},{"id":"runtime_queue_runpromptqueue","label":"runPromptQueue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L59-L349","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L59"}],"snippet":"export async function runPromptQueue(input: QueueInput): Promise<void> {\n  const stop = defer<{ type: \"closed\" }>()\n  const done = defer()\n  const state: State = {\n    queue: [],\n    queued: [],\n    closed: input.footer.isClosed,\n  }\n  let draining: Promise<void> | undefined\n\n  const emit = (next: FooterEvent, row: Record<string, unknown>) => {\n    input.trace?.write(\"ui.patch\", row)\n    input.footer.event(next)\n  }\n\n  const syncQueue = () => {\n    const queue = state.queue.length\n    emit({ type: \"queue\", queue }, { queue })\n    emit(\n      {\n        type: \"queued.prompts\",\n        prompts: [...state.queued],\n      },\n      { queued: state.queued.length },\n    )"},{"id":"runtime_queue_runpromptqueue_emit","label":"emit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L69-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L69"}],"snippet":"emit = (next: FooterEvent, row: Record<string, unknown>) => {\n    input.trace?.write(\"ui.patch\", row)\n    input.footer.event(next)\n  }"},{"id":"runtime_queue_runpromptqueue_syncqueue","label":"syncQueue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L74-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L74"}],"snippet":"syncQueue = () => {\n    const queue = state.queue.length\n    emit({ type: \"queue\", queue }, { queue })\n    emit(\n      {\n        type: \"queued.prompts\",\n        prompts: [...state.queued],\n      },\n      { queued: state.queued.length },\n    )\n  }"},{"id":"runtime_queue_runpromptqueue_removelocalqueued","label":"removeLocalQueued()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L86-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L86"}],"snippet":"removeLocalQueued = (queued: FooterQueuedPrompt) => {\n    if (!state.queued.includes(queued)) return\n    state.queued = state.queued.filter((item) => item !== queued)\n    syncQueue()\n  }"},{"id":"runtime_queue_runpromptqueue_finish","label":"finish()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L92-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L92"}],"snippet":"finish = () => {\n    if (!state.closed || draining) {\n      return\n    }\n\n    done.resolve()\n  }"},{"id":"runtime_queue_runpromptqueue_close","label":"close()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L100-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L100"}],"snippet":"close = () => {\n    if (state.closed) {\n      return\n    }\n\n    state.closed = true\n    state.queue.length = 0\n    state.queued.length = 0\n    state.ctrl?.abort()\n    stop.resolve({ type: \"closed\" })\n    finish()\n  }"},{"id":"runtime_queue_runpromptqueue_drain","label":"drain()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L113-L266","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L113"}],"snippet":"drain = () => {\n    if (draining || state.closed || state.queue.length === 0) {\n      return\n    }\n\n    draining = (async () => {\n      try {\n        while (!state.closed && state.queue.length > 0) {\n          const prompt = state.queue.shift()\n          if (!prompt) {\n            continue\n          }\n\n          const queued = state.queued.find((item) => item.prompt === prompt)\n          if (queued) removeLocalQueued(queued)\n\n          if (prompt.mode !== \"shell\" && isNewCommand(prompt.text)) {\n            syncQueue()\n            if (!input.onNewSession) {\n              emit(\n                {\n                  type: \"stream.patch\",\n                  patch: {\n                    status: \"new sessions unavailable\",\n                  },"},{"id":"runtime_queue_runpromptqueue_submit","label":"submit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L268-L315","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.queue.ts","source_location":"L268"}],"snippet":"submit = (prompt: RunPrompt) => {\n    if (!prompt.text.trim() || state.closed) {\n      return\n    }\n\n    if (prompt.mode !== \"shell\" && isExitCommand(prompt.text)) {\n      input.footer.close()\n      return\n    }\n\n    const active = state.active\n    if (\n      active &&\n      active.mode !== \"shell\" &&\n      !active.command &&\n      prompt.mode !== \"shell\" &&\n      !prompt.command &&\n      !isNewCommand(prompt.text)\n    ) {\n      const queued: FooterQueuedPrompt = {\n        messageID: MessageID.ascending(),\n        partID: PartID.ascending(),\n        prompt,\n      }\n      state.queued = [...state.queued, queued]"}],"edges":[{"source":"runtime_que