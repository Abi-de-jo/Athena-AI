, [\n    \"class\",\n    \"classList\",\n    \"children\",\n    \"value\",\n    \"defaultValue\",\n    \"onChange\",\n    \"allowDeselect\",\n    \"disabled\",\n    \"ref\",\n  ])\n\n  const [internal, setInternal] = createSignal<string | null>(local.defaultValue ?? null)\n\n  const selected = createMemo(() => (isControlled() ? (local.value ?? null) : internal()))\n\n  const setSelected = (next: string | null) => {\n    if (!isControlled()) setInternal(next)\n    local.onChange?.(next)\n  }\n\n  const select = (value: string) => {","node_kind":"component"},{"id":"segmented_control_v2_segmentedcontrolv2_setselected","label":"setSelected()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L64-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L64"}],"snippet":"setSelected = (next: string | null) => {\n    if (!isControlled()) setInternal(next)\n    local.onChange?.(next)\n  }"},{"id":"segmented_control_v2_segmentedcontrolv2_select","label":"select()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L69-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L69"}],"snippet":"select = (value: string) => {\n    setSelected(value)\n  }"},{"id":"segmented_control_v2_segmentedcontrolv2_clearifallowed","label":"clearIfAllowed()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L73-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L73"}],"snippet":"clearIfAllowed = (value: string) => {\n    if (!local.allowDeselect || selected() !== value) return\n    setSelected(null)\n  }"},{"id":"segmented_control_v2_segmentedcontrolv2_focusnext","label":"focusNext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L78-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L78"}],"snippet":"focusNext = (from: HTMLButtonElement, direction: 1 | -1) => {\n    const root = from.closest(`[data-slot=\"segmented-control-v2\"]`)\n    if (!root) return\n    const buttons = Array.from(\n      root.querySelectorAll<HTMLButtonElement>(`button[data-slot=\"segmented-control-v2-item\"]`),\n    ).filter((b) => !b.disabled)\n    const i = buttons.indexOf(from)\n    const next = buttons[i + direction]\n    next?.focus()\n  }"},{"id":"segmented_control_v2_segmentedcontrolv2_assignref","label":"assignRef()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L97-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L97"}],"snippet":"assignRef = (el: HTMLDivElement | undefined) => {\n    const r = local.ref\n    if (typeof r === \"function\") (r as (el: HTMLDivElement | undefined) => void)(el)\n    else if (r != null && typeof r === \"object\" && \"value\" in r) (r as { value: HTMLDivElement | undefined }).value = el\n  }"},{"id":"segmented_control_v2_invokebuttonhandler","label":"invokeButtonHandler()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L128-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L128"}],"snippet":"function invokeButtonHandler<E extends Event>(\n  handler: JSX.EventHandlerUnion<HTMLButtonElement, E> | undefined,\n  e: E & { currentTarget: HTMLButtonElement },\n) {\n  if (typeof handler === \"function\") (handler as (ev: typeof e) => void)(e)\n}"},{"id":"segmented_control_v2_segmentedcontrolitemv2","label":"SegmentedControlItemV2()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L135-L208","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L135"}],"snippet":"export function SegmentedControlItemV2(props: SegmentedControlItemV2Props) {\n  const merged = mergeProps({ disabled: false }, props)\n  const [local, rest] = splitProps(merged, [\n    \"class\",\n    \"classList\",\n    \"children\",\n    \"value\",\n    \"disabled\",\n    \"onClick\",\n    \"onKeyDown\",\n  ])\n  const ctx = useSegmentedControlContext()\n\n  const pressed = createMemo(() => ctx.selected() === local.value)\n  const disabled = createMemo(() => ctx.groupDisabled() || !!local.disabled)\n\n  const onClick: JSX.EventHandlerUnion<HTMLButtonElement, MouseEvent> = (e) => {\n    invokeButtonHandler(local.onClick, e)\n    if (e.defaultPrevented || disabled()) return\n    if (pressed()) ctx.clearIfAllowed(local.value)\n    else ctx.select(local.value)\n  }\n\n  const onKeyDown: JSX.EventHandlerUnion<HTMLButtonElement, KeyboardEvent> = (e) => {\n    invokeButtonHandler(local.onKeyDown, e)","node_kind":"component"},{"id":"segmented_control_v2_segmentedcontrolitemv2_onclick","label":"onClick()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L151-L156","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L151"}],"snippet":"onClick: JSX.EventHandlerUnion<HTMLButtonElement, MouseEvent> = (e) => {\n    invokeButtonHandler(local.onClick, e)\n    if (e.defaultPrevented || disabled()) return\n    if (pressed()) ctx.clearIfAllowed(local.value)\n    else ctx.select(local.value)\n  }"},{"id":"segmented_control_v2_segmentedcontrolitemv2_onkeydown","label":"onKeyDown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L158-L188","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L158"}],"snippet":"onKeyDown: JSX.EventHandlerUnion<HTMLButtonElement, KeyboardEvent> = (e) => {\n    invokeButtonHandler(local.onKeyDown, e)\n    if (e.defaultPrevented || disabled()) return\n    const t = e.currentTarget\n\n    if (e.key === \"ArrowRight\") {\n      e.preventDefault()\n      ctx.focusNext(t, 1)\n    } else if (e.key === \"ArrowLeft\") {\n      e.preventDefault()\n      ctx.focusNext(t, -1)\n    }\n\n    // accessibility stuff\n    else if (e.key === \"Home\") {\n      e.preventDefault()\n      const root = t.closest(`[data-slot=\"segmented-control-v2\"]`)\n      const first = root?.querySelector<HTMLButtonElement>(\n        `button[data-slot=\"segmented-control-v2-item\"]:not(:disabled)`,\n      )\n      first?.focus()\n    } else if (e.key === \"End\") {\n      e.preventDefault()\n      const root = t.closest(`[data-slot=\"segmented-control-v2\"]`)\n      const buttons = root?.querySelectorAll<HTMLButtonElement>("}],"edges":[{"source":"segmented_control_v2","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L1"}],"weight":1},{"source":"segmented_control_v2","target":"segmented_control_v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L13","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L13"}],"weight":1},{"source":"segmented_control_v2","target":"segmented_control_v2_usesegmentedcontrolcontext","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/segmented-control-v2.tsx","source_location":"L27"}],"weight":1},{"source":"segmented_control_v2","target":"segmented_control_v2_segmentedcontrolv2","relation":"contains","confid