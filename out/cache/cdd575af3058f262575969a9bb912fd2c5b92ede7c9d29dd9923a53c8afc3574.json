ocess.ts","source_location":"L49"}],"snippet":"requireSuccess = (result: RunResult): Effect.Effect<RunResult, AppProcessError> =>\n  result.exitCode === 0\n    ? Effect.succeed(result)\n    : Effect.fail(\n        new AppProcessError({\n          command: result.command,\n          exitCode: result.exitCode,\n          stderr: result.stderr.toString(\"utf8\"),\n        }),\n      )"},{"id":"packages_core_src_process_requireexitin","label":"requireExitIn()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L60-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L60"}],"snippet":"requireExitIn =\n  (codes: ReadonlyArray<number>) =>\n  (result: RunResult): Effect.Effect<RunResult, AppProcessError> =>\n    codes.includes(result.exitCode)\n      ? Effect.succeed(result)\n      : Effect.fail(\n          new AppProcessError({\n            command: result.command,\n            exitCode: result.exitCode,\n            stderr: result.stderr.toString(\"utf8\"),\n          }),\n        )"},{"id":"packages_core_src_process_describecommand","label":"describeCommand()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L73-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L73"}],"snippet":"describeCommand = (command: ChildProcess.Command): string => {\n  if (command._tag === \"StandardCommand\") {\n    return command.args.length ? `${command.command} ${command.args.join(\" \")}` : command.command\n  }\n  return `${describeCommand(command.left)} | ${describeCommand(command.right)}`\n}"},{"id":"packages_core_src_process_wraperror","label":"wrapError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L80-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L80"}],"snippet":"wrapError = (description: string, cause: unknown): AppProcessError =>\n  cause instanceof AppProcessError ? cause : new AppProcessError({ command: description, cause })"},{"id":"packages_core_src_process_aborterror","label":"abortError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L83-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L83"}],"snippet":"abortError = (signal: AbortSignal): Error => {\n  const reason = signal.reason\n  if (reason instanceof Error) return reason\n  const err = new Error(\"Aborted\")\n  err.name = \"AbortError\"\n  return err\n}"},{"id":"packages_core_src_process_waitforabort","label":"waitForAbort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L91-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L91"}],"snippet":"waitForAbort = (signal: AbortSignal) =>\n  Effect.callback<never, Error>((resume) => {\n    if (signal.aborted) {\n      resume(Effect.fail(abortError(signal)))\n      return\n    }\n    const onabort = () => resume(Effect.fail(abortError(signal)))\n    signal.addEventListener(\"abort\", onabort, { once: true })\n    return Effect.sync(() => signal.removeEventListener(\"abort\", onabort))\n  })"},{"id":"packages_core_src_process_waitforabort_onabort","label":"onabort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L97"}],"snippet":"onabort = () => resume(Effect.fail(abortError(signal)))"},{"id":"packages_core_src_process_normalizestdin","label":"normalizeStdin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L102-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L102"}],"snippet":"normalizeStdin = (\n  input: string | Uint8Array | Stream.Stream<Uint8Array, PlatformError>,\n): Stream.Stream<Uint8Array, PlatformError> =>\n  typeof input === \"string\"\n    ? Stream.make(new TextEncoder().encode(input))\n    : input instanceof Uint8Array\n      ? Stream.make(input)\n      : input"},{"id":"packages_core_src_process_collectstream","label":"collectStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L111-L127","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L111"}],"snippet":"collectStream = (stream: Stream.Stream<Uint8Array, PlatformError>, maxOutputBytes: number | undefined) =>\n  Stream.runFold(\n    stream,\n    () => ({ chunks: [] as Uint8Array[], bytes: 0, truncated: false }),\n    (acc, chunk) => {\n      if (maxOutputBytes === undefined) {\n        acc.chunks.push(chunk)\n        acc.bytes += chunk.length\n        return acc\n      }\n      const remaining = maxOutputBytes - acc.bytes\n      if (remaining > 0) acc.chunks.push(remaining >= chunk.length ? chunk : chunk.slice(0, remaining))\n      acc.bytes += chunk.length\n      acc.truncated = acc.truncated || acc.bytes > maxOutputBytes\n      return acc\n    },\n  ).pipe(Effect.map((x) => ({ buffer: Buffer.concat(x.chunks), truncated: x.truncated })))"}],"edges":[{"source":"packages_core_src_process","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_src_process","target":"platformerror","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L2"}],"weight":1},{"source":"packages_core_src_process","target":"process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L3"}],"weight":1},{"source":"packages_core_src_process","target":"childprocessspawner","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/process.ts","source_location":"L4","layer":"base","provenance":[{"capability_i