e_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L27-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L27"}],"snippet":"interface PendingHandle<A, E> {\n  id: number\n  done: Deferred.Deferred<A, E | Cancelled>\n  work: Effect.Effect<A, E>\n}"},{"id":"packages_rimuru_src_effect_runner_make","label":"make()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L39-L215","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L39"}],"snippet":"make = <A, E = never>(\n  scope: Scope.Scope,\n  opts?: {\n    onIdle?: Effect.Effect<void>\n    onBusy?: Effect.Effect<void>\n    onInterrupt?: Effect.Effect<A, E>\n  },\n): Runner<A, E> => {\n  const ref = SynchronizedRef.makeUnsafe<State<A, E>>({ _tag: \"Idle\" })\n  const idle = opts?.onIdle ?? Effect.void\n  const onBusy = opts?.onBusy ?? Effect.void\n  const onInterrupt = opts?.onInterrupt\n  let ids = 0\n\n  const state = () => SynchronizedRef.getUnsafe(ref)\n  const next = () => {\n    ids += 1\n    return ids\n  }\n\n  const complete = (done: Deferred.Deferred<A, E | Cancelled>, exit: Exit.Exit<A, E>) =>\n    Exit.isFailure(exit) && Cause.hasInterruptsOnly(exit.cause)\n      ? Deferred.fail(done, new Cancelled()).pipe(Effect.asVoid)\n      : Deferred.done(done, exit).pipe(Effect.asVoid)"},{"id":"packages_rimuru_src_effect_runner_make_state","label":"state()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L53"}],"snippet":"state = () => SynchronizedRef.getUnsafe(ref)"},{"id":"packages_rimuru_src_effect_runner_make_next","label":"next()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L54-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L54"}],"snippet":"next = () => {\n    ids += 1\n    return ids\n  }"},{"id":"packages_rimuru_src_effect_runner_make_complete","label":"complete()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L59-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L59"}],"snippet":"complete = (done: Deferred.Deferred<A, E | Cancelled>, exit: Exit.Exit<A, E>) =>\n    Exit.isFailure(exit) && Cause.hasInterruptsOnly(exit.cause)\n      ? Deferred.fail(done, new Cancelled()).pipe(Effect.asVoid)\n      : Deferred.done(done, exit).pipe(Effect.asVoid)"},{"id":"packages_rimuru_src_effect_runner_make_awaitdone","label":"awaitDone()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L64-L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L64"}],"snippet":"awaitDone = (done: Deferred.Deferred<A, E | Cancelled>) =>\n    Deferred.await(done).pipe(Effect.catchTag(\"RunnerCancelled\", (e) => onInterrupt ?? Effect.die(e)))"},{"id":"packages_rimuru_src_effect_runner_make_idleifcurrent","label":"idleIfCurrent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L67-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L67"}],"snippet":"idleIfCurrent = () =>\n    SynchronizedRef.modify(ref, (st) => [st._tag === \"Idle\" ? idle : Effect.void, st] as const).pipe(Effect.flatten)"},{"id":"packages_rimuru_src_effect_runner_make_finishrun","label":"finishRun()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L70-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L70"}],"snippet":"finishRun = (id: number, done: Deferred.Deferred<A, E | Cancelled>, exit: Exit.Exit<A, E>) =>\n    SynchronizedRef.modify(\n      ref,\n      (st) =>\n        [\n          Effect.gen(function* () {\n            if (st._tag === \"Running\" && st.run.id === id) yield* idle\n            yield* complete(done, exit)\n          }),\n          st._tag === \"Running\" && st.run.id === id ? ({ _tag: \"Idle\" } as const) : st,\n        ] as const,\n    ).pipe(Effect.flatten)"},{"id":"packages_rimuru_src_effect_runner_make_startrun","label":"startRun()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L83-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L83"}],"snippet":"startRun = (work: Effect.Effect<A, E>, done: Deferred.Deferred<A, E | Cancelled>) =>\n    Effect.gen(function* () {\n      const id = next()\n      const fiber = yield* work.pipe(\n        Effect.onExit((exit) => finishRun(id, done, exit)),\n        Effect.forkIn(scope),\n      )\n      return { id, done, fiber } satisfies RunHandle<A, E>\n    })"},{"id":"packages_rimuru_src_effect_runner_make_finishshell","label":"finishShell()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L93-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L93"}],"snippet":"finishShell = (id: number) =>\n    SynchronizedRef.modifyEffect(\n      ref,\n      Effect.fnUntraced(function* (st) {\n        if (st._tag === \"Shell\" && st.shell.id === id) {\n          return [idle, { _tag: \"Idle\" }] as const\n        }\n        if (st._tag === \"ShellThenRun\" && st.shell.id === id) {\n          const run = yield* startRun(st.run.work, st.run.done)\n          return [Effect.void, { _tag: \"Running\", run }] as const\n        }\n        return [Effect.void, st] as const\n      }),\n    ).pipe(Effect.flatten)"},{"id":"packages_rimuru_src_effect_runner_make_stopshell","label":"stopShell()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L108-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L108"}],"snippet":"stopShell = (shell: ShellHandle<A, E>) =>\n    Effect.gen(function* () {\n      if (shell.ready) yield* shell.ready.await.pipe(Effect.exit, Effect.asVoid)\n      yield* Deferred.succeed(shell.cancelled, undefined).pipe(Effect.asVoid)\n      yield* Fiber.interrupt(shell.fiber)\n    })"},{"id":"packages_rimuru_src_effect_runner_make_ensurerunning","label":"ensureRunning()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L115-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L115"}],"snippet":"ensureRunning = (work: Effect.Effect<A, E>) =>\n    SynchronizedRef.modifyEffect(\n      ref,\n      Effect.fnUntraced(function* (st) {\n        switch (st._tag) {\n          case \"Running\":\n          case \"ShellThenRun\":\n            return [awaitDone(st.run.done), st] as const\n          case \"Shell\": {\n            const run = {\n              id: next(),\n              done: yield* Deferred.make<A, E | Cancelled>(),\n              work,\n            } satisfies PendingHandle<A, E>\n            return [awaitDone(run.done), { _tag: \"ShellThenRun\", shell: st.shell, run }] as const\n          }\n          case \"Idle\": {\n            const done = yield* Deferred.make<A, E | Cancelled>()\n            const run = yield* startRun(work, done)\n            return [awaitDone(done), { _tag: \"Running\", run }] as const\n          }\n        }\n      }),\n    ).pipe(Effect.flatten)"},{"id":"packages_rimuru_src_effect_runner_make_startshell","label":"startShell()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L140-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L140"}],"snippet":"startShell = (work: Effect.Effect<A, E>, ready?: Latch.Latch): Effect.Effect<A, E | Busy> =>\n    SynchronizedRef.modifyEffect(\n      ref,\n      Effect.fnUntraced(function* (st) {\n        if (st._tag !== \"Idle\") {\n          const reject: Effect.Effect<A, E | Busy> = Effect.fail(new Busy())\n          return [reject, st] as const\n        }\n        yield* onBusy\n        const id = next()\n        const cancelled = yield* Deferred.make<void>()\n        const fiber = yield* work.pipe(Effect.ensuring(finishShell(id)), Effect.forkChild)\n        const shell = { id, cancelled, ready, fiber } satisfies ShellHandle<A, E>\n        return [\n          Effect.gen(function* () {\n            const exit = yield* Fiber.await(fiber)\n            if (Exit.isSuccess(exit)) return exit.value\n            if (\n              Cause.hasInterruptsOnly(exit.cause) ||\n              ((yield* Deferred.isDone(cancelled)) && Cause.hasInterrupts(exit.cause) && !Cause.hasDies(exit.cause))\n            ) {\n              if (onInterrupt) return yield* onInterrupt\n              return yield* Effect.die(new Cancelled())\n            }\n            return yield* Effect.failCause(exit.cause)"}],"edges":[{"source":"packages_rimuru_src_effect_runner","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_effect_runner","target":"packages_rimuru_src_effect_runner_runner","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/effect/runner.ts","source_locatio