{"__madarTsExtractorVersion":67,"__madarFileStem":"create-api-key","nodes":[{"id":"create_api_key","label":"create-api-key.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","source_location":"L1"}]},{"id":"create_api_key_createsecretkey","label":"createSecretKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","source_location":"L113-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","source_location":"L113"}],"snippet":"function createSecretKey() {\n  const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789\"\n  const values = new Uint32Array(64)\n  crypto.getRandomValues(values)\n  return `sk-${Array.from(values, (value) => chars[value % chars.length]).join(\"\")}`\n}"},{"id":"create_api_key_parseargs","label":"parseArgs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","source_location":"L120-L140","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","source_location":"L120"}],"snippet":"function parseArgs(argv: string[]) {\n  const parsed = {\n    email: \"\",\n    workspaceID: \"\",\n    workspaceName: \"\",\n    keyName: \"\",\n    balanceDollars: 100,\n    allowProduction: false,\n  }\n  for (let index = 0; index < argv.length; index++) {\n    const arg = argv[index]\n    if (arg === \"--email\") parsed.email = requiredValue(argv, ++index, arg)\n    if (arg === \"--workspace-id\") parsed.workspaceID = requiredValue(argv, ++index, arg)\n    if (arg === \"--workspace-name\") parsed.workspaceName = requiredValue(argv, ++index, arg)\n    if (arg === \"--key-name\") parsed.keyName = requiredValue(argv, ++index, arg)\n    if (arg === \"--balance-dollars\") parsed.balanceDollars = Number(requiredValue(argv, ++index, arg))\n    if (arg === \"--allow-production\") parsed.allowProduction = true\n  }\n  if (!Number.isFinite(parsed.balanceDollars) || parsed.balanceDollars < 0) throw new Error(\"Invalid --balance-dollars\")\n  return parsed\n}"},{"id":"create_api_key_requiredvalue","label":"requiredValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","source_location":"L142-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","source_location":"L142"}],"snippet":"function requiredValue(argv: string[], index: number, arg: string) {\n  const value = argv[index]\n  if (!value || value.startsWith(\"--\")) throw new Error(`Missing value for ${arg}`)\n  return value\n}"}],"edges":[{"source":"create_api_key","target":"console_resource","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","source_location":"L1"}],"weight":1},{"source":"create_api_key","target":"index","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/create-api-key.ts","sour