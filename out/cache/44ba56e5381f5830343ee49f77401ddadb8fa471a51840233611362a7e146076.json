{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_sdk_js_src_process","nodes":[{"id":"packages_sdk_js_src_process","label":"process.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L1"}]},{"id":"packages_sdk_js_src_process_stop","label":"stop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L5-L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L5"}],"snippet":"export function stop(proc: ChildProcess) {\n  if (proc.exitCode !== null || proc.signalCode !== null) return\n  if (process.platform === \"win32\" && proc.pid) {\n    const out = spawnSync(\"taskkill\", [\"/pid\", String(proc.pid), \"/T\", \"/F\"], { windowsHide: true })\n    if (!out.error && out.status === 0) return\n  }\n  proc.kill()\n}"},{"id":"packages_sdk_js_src_process_bindabort","label":"bindAbort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L14-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L14"}],"snippet":"export function bindAbort(proc: ChildProcess, signal?: AbortSignal, onAbort?: () => void) {\n  if (!signal) return () => {}\n  const abort = () => {\n    clear()\n    stop(proc)\n    onAbort?.()\n  }\n  const clear = () => {\n    signal.removeEventListener(\"abort\", abort)\n    proc.off(\"exit\", clear)\n    proc.off(\"error\", clear)\n  }\n  signal.addEventListener(\"abort\", abort, { once: true })\n  proc.on(\"exit\", clear)\n  proc.on(\"error\", clear)\n  if (signal.aborted) abort()\n  return clear\n}"},{"id":"packages_sdk_js_src_process_bindabort_abort","label":"abort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L16-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L16"}],"snippet":"abort = () => {\n    clear()\n    stop(proc)\n    onAbort?.()\n  }"},{"id":"packages_sdk_js_src_process_bindabort_clear","label":"clear()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L21-L25","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L21"}],"snippet":"clear = () => {\n    signal.removeEventListener(\"abort\", abort)\n    proc.off(\"exit\", clear)\n    proc.off(\"error\", clear)\n  }"}],"edges":[{"source":"packages_sdk_js_src_process","target":"child_process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L1"}],"weight":1},{"source":"packages_sdk_js_src_process","target":"packages_sdk_js_src_process_stop","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/process.ts","source_location":"L5","layer":"base","provenance":[{"capability_id":"builtin: