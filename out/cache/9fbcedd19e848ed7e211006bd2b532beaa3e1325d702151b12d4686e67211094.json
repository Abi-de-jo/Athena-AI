{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_tui_src_audio","nodes":[{"id":"packages_tui_src_audio","label":"audio.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L1"}]},{"id":"packages_tui_src_audio_getaudio","label":"getAudio()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L7-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L7"}],"snippet":"function getAudio() {\n  if (audio !== undefined) return audio\n  try {\n    const next = Audio.create({ autoStart: false })\n    next.on(\"error\", (error: Error, context: AudioErrorContext) => {\n      console.debug(\"tui audio error\", { error, context })\n    })\n    audio = next\n    return next\n  } catch (error) {\n    console.debug(\"failed to create tui audio\", { error })\n    audio = null\n    return null\n  }\n}"},{"id":"packages_tui_src_audio_loadsoundfile","label":"loadSoundFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L23-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L23"}],"snippet":"export function loadSoundFile(file: string) {\n  const current = getAudio()\n  if (!current) return Promise.resolve(null)\n  const cached = sounds.get(file)\n  if (cached) return cached\n  const task = readFile(file)\n    .then((bytes) => current.loadSound(bytes))\n    .catch((error) => {\n      console.debug(\"failed to load tui sound\", { file, error })\n      return null\n    })\n  sounds.set(file, task)\n  return task\n}"},{"id":"packages_tui_src_audio_play","label":"play()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L38-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L38"}],"snippet":"export function play(sound: AudioSound, options?: AudioPlayOptions) {\n  const current = getAudio()\n  if (!current) return null\n  if (!current.isStarted() && !current.start()) return null\n  return current.play(sound, options)\n}"},{"id":"packages_tui_src_audio_stopvoice","label":"stopVoice()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L45-L47","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L45"}],"snippet":"export function stopVoice(voice: AudioVoice) {\n  return audio?.stopVoice(voice) ?? false\n}"},{"id":"packages_tui_src_audio_dispose","label":"dispose()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L49-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location":"L49"}],"snippet":"export function dispose() {\n  audio?.dispose()\n  audio = undefined\n  sounds.clear()\n}"}],"edges":[{"source":"packages_tui_src_audio","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/audio.ts","source_location