{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_components_prompt-input_attachments","nodes":[{"id":"packages_app_src_components_prompt_input_attachments","label":"attachments.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L1"}]},{"id":"packages_app_src_components_prompt_input_attachments_dataurl","label":"dataUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L11-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L11"}],"snippet":"function dataUrl(file: File, mime: string) {\n  return new Promise<string>((resolve) => {\n    const reader = new FileReader()\n    reader.addEventListener(\"error\", () => resolve(\"\"))\n    reader.addEventListener(\"load\", () => {\n      const value = typeof reader.result === \"string\" ? reader.result : \"\"\n      const idx = value.indexOf(\",\")\n      if (idx === -1) {\n        resolve(value)\n        return\n      }\n      resolve(`data:${mime};base64,${value.slice(idx + 1)}`)\n    })\n    reader.readAsDataURL(file)\n  })\n}"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments","label":"createPromptAttachments()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L39-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L39"}],"snippet":"export function createPromptAttachments(input: PromptAttachmentsInput) {\n  const prompt = input.prompt\n  const language = useLanguage()\n\n  const warn = () => {\n    showToast({\n      title: language.t(\"prompt.toast.pasteUnsupported.title\"),\n      description: language.t(\"prompt.toast.pasteUnsupported.description\"),\n    })\n  }\n\n  const add = async (file: File, toast = true) => {\n    const mime = await attachmentMime(file)\n    if (!mime) {\n      if (toast) warn()\n      return false\n    }\n\n    const editor = input.editor()\n    if (!editor) return false\n\n    const url = await dataUrl(file, mime)\n    if (!url) return false\n\n    const attachment: ImageAttachmentPart = {"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments_warn","label":"warn()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L43-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L43"}],"snippet":"warn = () => {\n    showToast({\n      title: language.t(\"prompt.toast.pasteUnsupported.title\"),\n      description: language.t(\"prompt.toast.pasteUnsupported.description\"),\n    })\n  }"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments_add","label":"add()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L50-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L50"}],"snippet":"add = async (file: File, toast = true) => {\n    const mime = await attachmentMime(file)\n    if (!mime) {\n      if (toast) warn()\n      return false\n    }\n\n    const editor = input.editor()\n    if (!editor) return false\n\n    const url = await dataUrl(file, mime)\n    if (!url) return false\n\n    const attachment: ImageAttachmentPart = {\n      type: \"image\",\n      id: uuid(),\n      filename: file.name,\n      sourcePath: input.getPathForFile?.(file) || undefined,\n      mime,\n      dataUrl: url,\n    }\n    const cursor = prompt.cursor() ?? getCursorPosition(editor)\n    prompt.set([...prompt.current(), attachment], cursor)\n    return true\n  }"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments_addattachment","label":"addAttachment()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L76"}],"snippet":"addAttachment = (file: File) => add(file)"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments_addattachments","label":"addAttachments()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L78-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L78"}],"snippet":"addAttachments = async (files: File[], toast = true) => {\n    let found = false\n\n    for (const file of files) {\n      const ok = await add(file, false)\n      if (ok) found = true\n    }\n\n    if (!found && files.length > 0 && toast) warn()\n    return found\n  }"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments_removeattachment","label":"removeAttachment()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L90-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L90"}],"snippet":"removeAttachment = (id: string) => {\n    const current = prompt.current()\n    const next = current.filter((part) => part.type !== \"image\" || part.id !== id)\n    prompt.set(next, prompt.cursor())\n  }"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments_handlepaste","label":"handlePaste()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L96-L144","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L96"}],"snippet":"handlePaste = async (event: ClipboardEvent) => {\n    const clipboardData = event.clipboardData\n    if (!clipboardData) return\n\n    event.preventDefault()\n    event.stopPropagation()\n\n    const files = Array.from(clipboardData.items).flatMap((item) => {\n      if (item.kind !== \"file\") return []\n      const file = item.getAsFile()\n      return file ? [file] : []\n    })\n\n    if (files.length > 0) {\n      await addAttachments(files)\n      return\n    }\n\n    const plainText = clipboardData.getData(\"text/plain\") ?? \"\"\n\n    // Desktop: Browser clipboard has no images and no text, try platform's native clipboard for images\n    if (input.readClipboardImage && !plainText) {\n      const file = await input.readClipboardImage()\n      if (file) {\n        await addAttachment(file)"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments_handlepaste_put","label":"put()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L129-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L129"}],"snippet":"put = () => {\n      if (input.addPart({ type: \"text\", content: text, start: 0, end: 0 })) return true\n      input.focusEditor()\n      return input.addPart({ type: \"text\", content: text, start: 0, end: 0 })\n    }"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments_handleglobaldragover","label":"handleGlobalDragOver()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L146-L157","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L146"}],"snippet":"handleGlobalDragOver = (event: DragEvent) => {\n    if (input.isDialogActive()) return\n\n    event.preventDefault()\n    const hasFiles = event.dataTransfer?.types.includes(\"Files\")\n    const hasText = event.dataTransfer?.types.includes(\"text/plain\")\n    if (hasFiles) {\n      input.setDraggingType(\"image\")\n    } else if (hasText) {\n      input.setDraggingType(\"@mention\")\n    }\n  }"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments_handleglobaldragleave","label":"handleGlobalDragLeave()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L159-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L159"}],"snippet":"handleGlobalDragLeave = (event: DragEvent) => {\n    if (input.isDialogActive()) return\n    if (!event.relatedTarget) {\n      input.setDraggingType(null)\n    }\n  }"},{"id":"packages_app_src_components_prompt_input_attachments_createpromptattachments_handleglobaldrop","label":"handleGlobalDrop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L166-L185","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/attachments.ts","source_location":"L166"}],"snippet":"handleGlobalDrop = async (event: DragEvent) => {\n    if (input.isDialogActive()) return\n\n    event.preventDefault()\n    input.setDraggingType(null)\n\n    const plainText = event.dataTransfer?.getData(\"text/plain\")\n    const filePrefix = \"file:\"\n    if (plainText?.startsWith(filePrefix)) {\n      const filePath = plainText.slice(filePrefix.length)\n      input.focusEditor()\n      input.addPart({ type: \"file\", path: filePath, content: \"@\" + filePath, start: 0, end: 0 })\n      return\n    }\n\n    const dropped = event.dataTransfer?.files\n    if (!dropped) return\n\n    await addAttachments(Array.from(dropped))\n  }"}],"edges":[{"source":"packages_app_src_components_prompt_input_attachments","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/pe