{"__madarTsExtractorVersion":67,"__madarFileStem":"httpapi-provider.test","nodes":[{"id":"httpapi_provider_test","label":"httpapi-provider.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L1"}]},{"id":"httpapi_provider_test_providerlisthasfetch","label":"providerListHasFetch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L24-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L24"}],"snippet":"function providerListHasFetch(list: unknown) {\n  if (!Array.isArray(list)) return false\n  return list.some((item: unknown) => {\n    if (typeof item !== \"object\" || item === null || !(\"id\" in item) || !(\"options\" in item)) return false\n    if (item.id !== \"google\") return false\n    if (typeof item.options !== \"object\" || item.options === null) return false\n    return \"fetch\" in item.options\n  })\n}"},{"id":"httpapi_provider_test_hasproviderwithfetch","label":"hasProviderWithFetch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L34-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L34"}],"snippet":"function hasProviderWithFetch(input: unknown, key: \"all\" | \"providers\") {\n  if (typeof input !== \"object\" || input === null) return false\n  if (key === \"all\") return \"all\" in input && providerListHasFetch(input.all)\n  return \"providers\" in input && providerListHasFetch(input.providers)\n}"},{"id":"httpapi_provider_test_isrecord","label":"isRecord()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L40-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L40"}],"snippet":"function isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value)\n}"},{"id":"httpapi_provider_test_providerlist","label":"providerList()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L44-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L44"}],"snippet":"function providerList(input: unknown, key: \"all\" | \"providers\") {\n  if (!isRecord(input)) return []\n  if (!Array.isArray(input[key])) return []\n  return input[key]\n}"},{"id":"httpapi_provider_test_providerbyid","label":"providerByID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L50-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L50"}],"snippet":"function providerByID(input: unknown, key: \"all\" | \"providers\", id: string) {\n  return providerList(input, key).find((provider) => isRecord(provider) && provider.id === id)\n}"},{"id":"httpapi_provider_test_hasnonzeromodelcost","label":"hasNonZeroModelCost()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L54-L63","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L54"}],"snippet":"function hasNonZeroModelCost(input: unknown, key: \"all\" | \"providers\", id: string) {\n  const provider = providerByID(input, key, id)\n  if (!isRecord(provider) || !isRecord(provider.models)) return false\n  return Object.values(provider.models).some((model) => {\n    if (!isRecord(model) || !isRecord(model.cost) || !isRecord(model.cost.cache)) return false\n    return [model.cost.input, model.cost.output, model.cost.cache.read, model.cost.cache.write].some(\n      (cost) => typeof cost === \"number\" && cost > 0,\n    )\n  })\n}"},{"id":"httpapi_provider_test_hasprovidermutationmarker","label":"hasProviderMutationMarker()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L65-L70","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L65"}],"snippet":"function hasProviderMutationMarker(input: unknown, key: \"all\" | \"providers\", id: string) {\n  const provider = providerByID(input, key, id)\n  if (!isRecord(provider)) return false\n  if (provider.name === \"mutated-provider\") return true\n  return isRecord(provider.options) && provider.options.mutatedByPlugin === true\n}"},{"id":"httpapi_provider_test_requestauthorize","label":"requestAuthorize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L72-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L72"}],"snippet":"function requestAuthorize(input: {\n  providerID: string\n  method: number\n  headers: HeadersInit\n  inputs?: Record<string, string>\n}) {\n  return Effect.gen(function* () {\n    const response = yield* request(`/provider/${input.providerID}/oauth/authorize`, {\n      method: \"POST\",\n      headers: input.headers,\n      body: JSON.stringify({ method: input.method, ...(input.inputs ? { inputs: input.inputs } : {}) }),\n    })\n    return {\n      status: response.status,\n      body: yield* response.text,\n    }\n  })\n}"},{"id":"httpapi_provider_test_requestcallback","label":"requestCallback()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L91-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L91"}],"snippet":"function requestCallback(input: { providerID: string; method: number; headers: HeadersInit; code?: string }) {\n  return Effect.gen(function* () {\n    const response = yield* request(`/provider/${input.providerID}/oauth/callback`, {\n      method: \"POST\",\n      headers: input.headers,\n      body: JSON.stringify({ method: input.method, ...(input.code ? { code: input.code } : {}) }),\n    })\n    return {\n      status: response.status,\n      body: yield* response.text,\n    }\n  })\n}"},{"id":"httpapi_provider_test_writeproviderauthplugin","label":"writeProviderAuthPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L105-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L105"}],"snippet":"function writeProviderAuthPlugin(dir: string) {\n  return Effect.gen(function* () {\n    const fs = yield* FSUtil.Service\n    yield* Effect.promise(() => markPluginDependenciesReady(path.join(dir, \".opencode\")))\n\n    yield* fs.writeWithDirs(\n      path.join(dir, \".opencode\", \"plugin\", \"provider-oauth-parity.ts\"),\n      [\n        \"export default {\",\n        '  id: \"test.provider-oauth-parity\",',\n        \"  server: async () => ({\",\n        \"    auth: {\",\n        `      provider: \"${providerID}\",`,\n        \"      methods: [\",\n        '        { type: \"api\", label: \"API key\" },',\n        \"        {\",\n        '          type: \"oauth\",',\n        '          label: \"OAuth\",',\n        \"          authorize: async () => ({\",\n        `            url: \"${oauthURL}\",`,\n        '            method: \"code\",',\n        `            instructions: \"${oauthInstructions}\",`,\n        \"            callback: async () => ({ type: 'success', key: 'token' }),\",\n        \"          }),\",\n        \"        },\","},{"id":"httpapi_provider_test_writeproviderauthvalidationplugin","label":"writeProviderAuthValidationPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L140-L180","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L140"}],"snippet":"function writeProviderAuthValidationPlugin(dir: string) {\n  return Effect.gen(function* () {\n    const fs = yield* FSUtil.Service\n    yield* Effect.promise(() => markPluginDependenciesReady(path.join(dir, \".opencode\")))\n\n    yield* fs.writeWithDirs(\n      path.join(dir, \".opencode\", \"plugin\", \"provider-oauth-validation.ts\"),\n      [\n        \"export default {\",\n        '  id: \"test.provider-oauth-validation\",',\n        \"  server: async () => ({\",\n        \"    auth: {\",\n        '      provider: \"test-oauth-validation\",',\n        \"      methods: [\",\n        \"        {\",\n        '          type: \"oauth\",',\n        '          label: \"OAuth\",',\n        \"          prompts: [\",\n        \"            {\",\n        '              type: \"text\",',\n        '              key: \"token\",',\n        '              message: \"Token\",',\n        \"              validate: (value) => value === 'ok' ? undefined : 'Token must be ok',\",\n        \"            },\",\n        \"          ],\","},{"id":"httpapi_provider_test_writefunctionoptionsplugin","label":"writeFunctionOptionsPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L182-L212","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L182"}],"snippet":"function writeFunctionOptionsPlugin(dir: string) {\n  return Effect.gen(function* () {\n    const fs = yield* FSUtil.Service\n    yield* Effect.promise(() => markPluginDependenciesReady(path.join(dir, \".opencode\")))\n\n    yield* fs.writeWithDirs(\n      path.join(dir, \".opencode\", \"plugin\", \"provider-function-options.ts\"),\n      [\n        \"export default {\",\n        '  id: \"test.provider-function-options\",',\n        \"  server: async () => ({\",\n        \"    auth: {\",\n        '      provider: \"google\",',\n        \"      loader: async (_getAuth, provider) => {\",\n        \"        for (const model of Object.values(provider.models ?? {})) {\",\n        \"          model.cost = { input: 0, output: 0 }\",\n        \"        }\",\n        \"        return {\",\n        '        apiKey: \"\",',\n        \"        fetch: async (input, init) => fetch(input, init),\",\n        \"        }\",\n        \"      },\",\n        \"      methods: [{ type: 'api', label: 'API key' }],\",\n        \"    },\",\n        \"  }),\","},{"id":"httpapi_provider_test_writeprovidermodelsmutationplugin","label":"writeProviderModelsMutationPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L214-L245","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L214"}],"snippet":"function writeProviderModelsMutationPlugin(dir: string) {\n  return Effect.gen(function* () {\n    const fs = yield* FSUtil.Service\n    yield* Effect.promise(() => markPluginDependenciesReady(path.join(dir, \".opencode\")))\n\n    yield* fs.writeWithDirs(\n      path.join(dir, \".opencode\", \"plugin\", \"provider-models-mutation.ts\"),\n      [\n        \"export default {\",\n        '  id: \"test.provider-models-mutation\",',\n        \"  server: async () => ({\",\n        \"    provider: {\",\n        '      id: \"google\",',\n        \"      models: async (provider) => {\",\n        \"        const models = Object.fromEntries(\",\n        \"          Object.entries(provider.models ?? {}).map(([id, model]) => [id, { ...model }]),\",\n        \"        )\",\n        '        provider.name = \"mutated-provider\"',\n        \"        provider.options = { ...provider.options, mutatedByPlugin: true }\",\n        \"        for (const model of Object.values(provider.models ?? {})) {\",\n        \"          model.cost = { input: 0, output: 0 }\",\n        \"        }\",\n        \"        return models\",\n        \"      },\",\n        \"    },\","},{"id":"httpapi_provider_test_setenvscoped","label":"setEnvScoped()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L247-L260","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L247"}],"snippet":"function setEnvScoped(key: string, value: string) {\n  return Effect.acquireRelease(\n    Effect.sync(() => {\n      const previous = process.env[key]\n      process.env[key] = value\n      return previous\n    }),\n    (previous) =>\n      Effect.sync(() => {\n        if (previous === undefined) delete process.env[key]\n        else process.env[key] = previous\n      }),\n  )\n}"}],"edges":[{"source":"httpapi_provider_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L1"}],"weight":1},{"source":"httpapi_provider_test","target":"fs_util","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-provider.test.ts","source_location":"L2","layer":"base","provenan