ion formatMessage(\n  msg: UserMessage | AssistantMessage,\n  parts: Part[],\n  options: TranscriptOptions,\n  providers?: Provider[] | ReadonlyMap<string, Provider>,\n): string {\n  let result = \"\"\n\n  if (msg.role === \"user\") {\n    result += `## User\\n\\n`\n  } else {\n    result += formatAssistantHeader(msg, options.assistantMetadata, providers ?? options.providers)\n  }\n\n  for (const part of parts) {\n    result += formatPart(part, options)\n  }\n\n  return result\n}"},{"id":"transcript_formatassistantheader","label":"formatAssistantHeader()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/transcript.ts","source_location":"L67-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/transcript.ts","source_location":"L67"}],"snippet":"export function formatAssistantHeader(\n  msg: AssistantMessage,\n  includeMetadata: boolean,\n  providers?: Provider[] | ReadonlyMap<string, Provider>,\n): string {\n  if (!includeMetadata) {\n    return `## Assistant\\n\\n`\n  }\n\n  const duration =\n    msg.time.completed && msg.time.created ? ((msg.time.completed - msg.time.created) / 1000).toFixed(1) + \"s\" : \"\"\n\n  const modelName = Model.name(providers, msg.providerID, msg.modelID)\n\n  return `## Assistant (${Locale.titlecase(msg.agent)} · ${modelName}${duration ? ` · ${duration}` : \"\"})\\n\\n`\n}"},{"id":"transcript_formatpart","label":"formatPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/transcript.ts","source_location":"L84-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/transcript.ts","source_location":"L84"}],"snippet":"export function formatPart(part: Part, options: TranscriptOptions): string {\n  if (part.type === \"text\" && !part.synthetic) {\n    return `${part.text}\\n\\n`\n  }\n\n  if (part.type === \"reasoning\") {\n    if (options.thinking) {\n      return `_Thinking:_\\n\\n${part.text}\\n\\n`\n    }\n    return \"\"\n  }\n\n  if (part.type === \"tool\") {\n    let result = `**Tool: ${part.tool}**\\n`\n    if (options.toolDetails && part.state.input) {\n      result += `\\n**Input:**\\n\\`\\`\\`json\\n${JSON.stringify(part.state.input, null, 2)}\\n\\`\\`\\`\\n`\n    }\n    if (options.toolDetails && part.state.status === \"completed\" && part.state.output) {\n      result += `\\n**Output:**\\n\\`\\`\\`\\n${part.state.output}\\n\\`\\`\\`\\n`\n    }\n    if (options.toolDetails && part.state.status === \"error\" && part.state.error) {\n      result += `\\n**Error:**\\n\\`\\`\\`\\n${part.state.error}\\n\\`\\`\\`\\n`\n    }\n    result += `\\n`\n    return result"}],"edges":[{"source":"transcript","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/transcript.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/transcript.ts","source_location":"L1"}],"weight":1},{"source":"transcript","target":"locale","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/transcript.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/transcript.ts","source_location":"L2"}],"weight":1},{"source":"transcript","target":"model","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/transcript.ts","source_location":"L3","layer":"base","provenanc