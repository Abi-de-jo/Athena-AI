aman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L36"}],"snippet":"close = () => view().terminal.close()"},{"id":"terminal_panel_terminalpanel_max","label":"max()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L46"}],"snippet":"max = () => store.view * 0.6"},{"id":"terminal_panel_terminalpanel_pane","label":"pane()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L47","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L47"}],"snippet":"pane = () => Math.min(height(), max())"},{"id":"terminal_panel_terminalpanel_sync","label":"sync()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L52"}],"snippet":"sync = () => setStore(\"view\", window.visualViewport?.height ?? window.innerHeight)"},{"id":"terminal_panel_terminalpanel_focus","label":"focus()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L82-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L82"}],"snippet":"focus = (id: string) => {\n    focusTerminalById(id)\n\n    const frame = requestAnimationFrame(() => {\n      if (!opened()) return\n      if (terminal.active() !== id) return\n      focusTerminalById(id)\n    })\n\n    const timers = delays.map((ms) =>\n      window.setTimeout(() => {\n        if (!opened()) return\n        if (terminal.active() !== id) return\n        focusTerminalById(id)\n      }, ms),\n    )\n\n    return () => {\n      cancelAnimationFrame(frame)\n      for (const timer of timers) clearTimeout(timer)\n    }\n  }"},{"id":"terminal_panel_terminalpanel_recoverterminal","label":"recoverTerminal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L151-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L151"}],"snippet":"recoverTerminal = (key: string, id: string, clone: (id: string) => Promise<void>) => {\n    if (store.recovered[key]) return\n    setStore(\"recovered\", key, true)\n    void clone(id)\n  }"},{"id":"terminal_panel_terminalpanel_terminalrecoverykey","label":"terminalRecoveryKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L157-L159","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L157"}],"snippet":"terminalRecoveryKey = (pty: { id: string; title: string; titleNumber: number }) => {\n    return String(pty.titleNumber || pty.title || pty.id)\n  }"},{"id":"terminal_panel_terminalpanel_markterminalconnected","label":"markTerminalConnected()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L161-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L161"}],"snippet":"markTerminalConnected = (key: string, id: string, trim: (id: string) => void) => {\n    setStore(\"recovered\", key, false)\n    trim(id)\n  }"},{"id":"terminal_panel_terminalpanel_handleterminaldragstart","label":"handleTerminalDragStart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L166-L170","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L166"}],"snippet":"handleTerminalDragStart = (event: unknown) => {\n    const id = getDraggableId(event)\n    if (!id) return\n    setStore(\"activeDraggable\", id)\n  }"},{"id":"terminal_panel_terminalpanel_handleterminaldragover","label":"handleTerminalDragOver()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L172-L182","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L172"}],"snippet":"handleTerminalDragOver = (event: DragEvent) => {\n    const { draggable, droppable } = event\n    if (!draggable || !droppable) return\n\n    const terminals = terminal.all()\n    const fromIndex = terminals.findIndex((t) => t.id === draggable.id.toString())\n    const toIndex = terminals.findIndex((t) => t.id === droppable.id.toString())\n    if (fromIndex !== -1 && toIndex !== -1 && fromIndex !== toIndex) {\n      terminal.move(draggable.id.toString(), toIndex)\n    }\n  }"},{"id":"terminal_panel_terminalpanel_handleterminaldragend","label":"handleTerminalDragEnd()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L184-L193","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L184"}],"snippet":"handleTerminalDragEnd = () => {\n    setStore(\"activeDraggable\", undefined)\n\n    const activeId = terminal.active()\n    if (!activeId) return\n    requestAnimationFrame(() => {\n      if (terminal.active() !== activeId) return\n      focusTerminalById(activeId)\n    })\n  }"}],"edges":[{"source":"terminal_panel","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L1"}],"weight":1},{"source":"terminal_panel","target":"store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/terminal-panel.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:ext