t:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/framework/runtime.ts","source_location":"L42"}],"snippet":"export function handlers<const Root extends Spec.Any>(root: Root, handlers: Handlers<Root>) {\n  const result: LazyHandler[] = []\n\n  function add(node: Spec.Any, value: RuntimeHandlers) {\n    if (typeof value === \"function\") {\n      result.push({ spec: node.spec, load: value as () => Promise<{ default: RuntimeHandler }> })\n      return\n    }\n    if (value.$) result.push({ spec: node.spec, load: value.$ as () => Promise<{ default: RuntimeHandler }> })\n    for (const [name, child] of Object.entries(node.commands)) add(child, value[name] as RuntimeHandlers)\n  }\n\n  add(root, handlers as RuntimeHandlers)\n  return result\n}"},{"id":"packages_cli_src_framework_runtime_handlers_add","label":"add()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/framework/runtime.ts","source_location":"L45-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/framework/runtime.ts","source_location":"L45"}],"snippet":"function add(node: Spec.Any, value: RuntimeHandlers) {\n    if (typeof value === \"function\") {\n      result.push({ spec: node.spec, load: value as () => Promise<{ default: RuntimeHandler }> })\n      return\n    }\n    if (value.$) result.push({ spec: node.spec, load: value.$ as () => Promise<{ default: RuntimeHandler }> })\n    for (const [name, child] of Object.entries(node.commands)) add(child, value[name] as RuntimeHandlers)\n  }"},{"id":"packages_cli_src_framework_runtime_run","label":"run()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/framework/runtime.ts","source_location":"L58-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/framework/runtime.ts","source_location":"L58"}],"snippet":"export function run(commands: Spec.Any, handlers: ReadonlyArray<LazyHandler>, options: { readonly version: string }) {\n  return Command.run(provide(commands, handlers), options) as Effect.Effect<void, unknown, Command.Environment>\n}"},{"id":"packages_cli_src_framework_runtime_provide","label":"provide()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/framework/runtime.ts","source_location":"L62-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/framework/runtime.ts","source_location":"L62"}],"snippet":"function provide(node: Spec.Any, handlers: ReadonlyArray<LazyHandler>): ProvidedCommand {\n  const handler = handlers.find((handler) => handler.spec === node.spec)\n  const spec = handler\n    ? node.spec.pipe(\n        Command.withHandler((input) =>\n          Effect.gen(function* () {\n            yield* Effect.flatMap(Effect.promise(handler.load), (module) => module.default(input))\n          }),\n        ),\n      )\n    : node.spec\n  if (!Object.keys(node.commands).length) return spec as ProvidedCommand\n  return spec.pipe(\n    Command.withSubcommands(Object.values(node.commands).map((child) => provide(child, handlers))),\n  ) as ProvidedCommand\n}"}],"edges":[{"source":"packages_cli_src_framework_runtime","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/framework/runtime.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/cli/src/framework/runtime.ts","source_location":"L1"}],"weight":1},{"source":"packages_cli_src_framework_runtime","target