ation":"L24-L29","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L24"}],"snippet":"applyQuery = (url: string, query: Record<string, string> | undefined) => {\n  if (!query) return url\n  const next = new URL(url)\n  Object.entries(query).forEach(([key, value]) => next.searchParams.set(key, value))\n  return next.toString()\n}"},{"id":"packages_llm_src_route_transport_http_bodywithoverlay","label":"bodyWithOverlay()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L31-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L31"}],"snippet":"bodyWithOverlay = <Body>(body: Body, request: LLMRequest, encodeBody: (body: Body) => string) =>\n  Effect.gen(function* () {\n    if (request.http?.body === undefined) return { jsonBody: body, bodyText: encodeBody(body) }\n    if (ProviderShared.isRecord(body)) {\n      const overlaid = mergeJsonRecords(body, request.http.body) ?? {}\n      return { jsonBody: overlaid, bodyText: ProviderShared.encodeJson(overlaid) }\n    }\n    return yield* ProviderShared.invalidRequest(\"http.body can only overlay JSON object request bodies\")\n  })"},{"id":"packages_llm_src_route_transport_http_httpjsoninput","label":"HttpJsonInput","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L61-L63","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L61"}],"snippet":"export interface HttpJsonInput<_Body, Frame> {\n  readonly framing: FramingDef<Frame>\n}"},{"id":"packages_llm_src_route_transport_http_httpjsontransport","label":"HttpJsonTransport","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L67-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L67"}],"snippet":"export interface HttpJsonTransport<Body, Frame> extends Transport<Body, HttpPrepared<Frame>, Frame> {\n  readonly with: (patch: HttpJsonPatch<Body, Frame>) => HttpJsonTransport<Body, Frame>\n}"},{"id":"packages_llm_src_route_transport_http_transport","label":"Transport","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L67"}]},{"id":"packages_llm_src_route_transport_http_httpjson","label":"httpJson()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L71-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L71"}],"snippet":"httpJson = <Body, Frame>(input: HttpJsonInput<Body, Frame>): HttpJsonTransport<Body, Frame> => ({\n  id: \"http-json\",\n  with: (patch) => httpJson({ ...input, ...patch }),\n  prepare: (prepareInput) =>\n    jsonRequestParts({\n      ...prepareInput,\n    }).pipe(\n      Effect.map((parts) => ({\n        request: ProviderShared.jsonPost({ url: parts.url, body: parts.bodyText, headers: parts.headers }),\n        framing: input.framing,\n      })),\n    ),\n  frames: (prepared, request, runtime) =>\n    Stream.unwrap(\n      runtime.http\n        .execute(prepared.request)\n        .pipe(\n          Effect.map((response) =>\n            prepared.framing.frame(\n              response.stream.pipe(\n                Stream.mapError((error) =>\n                  ProviderShared.eventError(\n                    `${request.model.provider}/${request.model.route.id}`,\n                    `Failed to read ${request.model.provider}/${request.model.route.id} stream`,\n                    ProviderShared.errorText(error),"}],"edges":[{"source":"packages_llm_src_route_transport_http","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L1"}],"weight":1},{"source":"packages_llm_src_route_transport_http","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L2"}],"weight":1},{"source":"packages_llm_src_route_transport_http","target":"auth","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/http.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/r