{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_llm_src_protocols_shared","nodes":[{"id":"packages_llm_src_protocols_shared","label":"shared.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L1"}]},{"id":"packages_llm_src_protocols_shared_optionalarray","label":"optionalArray()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L23"}],"snippet":"optionalArray = <const S extends Schema.Top>(schema: S) => Schema.optional(Schema.Array(schema))"},{"id":"packages_llm_src_protocols_shared_optionalnull","label":"optionalNull()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L24","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L24"}],"snippet":"optionalNull = <const S extends Schema.Top>(schema: S) => Schema.optional(Schema.NullOr(schema))"},{"id":"packages_llm_src_protocols_shared_openaitoolinputschema","label":"openAiToolInputSchema()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L27-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L27"}],"snippet":"openAiToolInputSchema = (schema: JsonSchema.JsonSchema): JsonSchema.JsonSchema => {\n  const variants = Array.isArray(schema.anyOf) ? schema.anyOf.filter(isRecord) : []\n  const flattened =\n    variants.length === 0\n      ? { ...schema, type: \"object\" }\n      : {\n          ...Object.fromEntries(Object.entries(schema).filter(([key]) => key !== \"anyOf\")),\n          type: \"object\",\n          properties: variants.reduce(\n            (properties, variant) => ({ ...(isRecord(variant.properties) ? variant.properties : {}), ...properties }),\n            {},\n          ),\n          additionalProperties: false,\n        }\n  const normalized = removeNullSchemas(flattened)\n  return isRecord(normalized) ? normalized : { type: \"object\" }\n}"},{"id":"packages_llm_src_protocols_shared_removenullschemas","label":"removeNullSchemas()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L45-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L45"}],"snippet":"removeNullSchemas = (value: unknown): unknown => {\n  if (Array.isArray(value)) return value.map(removeNullSchemas)\n  if (!isRecord(value)) return value\n  const fields = Object.fromEntries(\n    Object.entries(value)\n      .filter(([key]) => key !== \"anyOf\")\n      .map(([key, field]) => [key, removeNullSchemas(field)]),\n  )\n  if (!Array.isArray(value.anyOf)) return fields\n  const variants = value.anyOf.filter((variant) => !isRecord(variant) || variant.type !== \"null\").map(removeNullSchemas)\n  if (variants.length === 1 && isRecord(variants[0])) return { ...fields, ...variants[0] }\n  return { ...fields, anyOf: variants }\n}"},{"id":"packages_llm_src_protocols_shared_toolaccumulator","label":"ToolAccumulator","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L64-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L64"}],"snippet":"export interface ToolAccumulator {\n  readonly id: string\n  readonly name: string\n  readonly input: string\n}"},{"id":"packages_llm_src_protocols_shared_totaltokens","label":"totalTokens()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L83-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L83"}],"snippet":"totalTokens = (\n  inputTokens: number | undefined,\n  outputTokens: number | undefined,\n  total: number | undefined,\n) => {\n  if (total !== undefined) return total\n  if (inputTokens === undefined && outputTokens === undefined) return undefined\n  return (inputTokens ?? 0) + (outputTokens ?? 0)\n}"},{"id":"packages_llm_src_protocols_shared_subtracttokens","label":"subtractTokens()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L104-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L104"}],"snippet":"subtractTokens = (total: number | undefined, subtrahend: number | undefined): number | undefined => {\n  if (total === undefined) return undefined\n  if (subtrahend === undefined) return total\n  return Math.max(0, total - subtrahend)\n}"},{"id":"packages_llm_src_protocols_shared_sumtokens","label":"sumTokens()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L117-L120","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L117"}],"snippet":"sumTokens = (...values: ReadonlyArray<number | undefined>): number | undefined => {\n  if (values.every((value) => value === undefined)) return undefined\n  return values.reduce((acc: number, value) => acc + (value ?? 0), 0)\n}"},{"id":"packages_llm_src_protocols_shared_eventerror","label":"eventError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L122-L127","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L122"}],"snippet":"eventError = (route: string, message: string, raw?: string) =>\n  new LLMError({\n    module: \"ProviderShared\",\n    method: \"stream\",\n    reason: new InvalidProviderOutputReason({ route, message, raw }),\n  })"},{"id":"packages_llm_src_protocols_shared_parsejson","label":"parseJson()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L129-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L129"}],"snippet":"parseJson = (route: string, input: string, message: string) =>\n  Effect.try({\n    try: () => decodeJson(input),\n    catch: () => eventError(route, message, input),\n  })"},{"id":"packages_llm_src_protocols_shared_jointext","label":"joinText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L141","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L141"}],"snippet":"joinText = (parts: ReadonlyArray<{ readonly text: string }>) => parts.map((part) => part.text).join(\"\\n\")"},{"id":"packages_llm_src_protocols_shared_escapesystemupdatetext","label":"escapeSystemUpdateText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L143-L144","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L143"}],"snippet":"escapeSystemUpdateText = (text: string) =>\n  text.replaceAll(\"&\", \"&amp;\").replaceAll(\"<\", \"&lt;\").replaceAll(\">\", \"&gt;\")"},{"id":"packages_llm_src_protocols_shared_wrapsystemupdate","label":"wrapSystemUpdate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L152-L153","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L152"}],"snippet":"wrapSystemUpdate = (parts: ReadonlyArray<{ readonly text: string }>) =>\n  `<system-update>\\n${escapeSystemUpdateText(joinText(parts))}\\n</system-update>`"},{"id":"packages_llm_src_protocols_shared_parsetoolinput","label":"parseToolInput()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L187-L188","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L187"}],"snippet":"parseToolInput = (route: string, name: string, raw: string) =>\n  parseJson(route, raw || \"{}\", `Invalid JSON input for ${route} tool call ${name}`)"},{"id":"packages_llm_src_protocols_shared_validatedmedia","label":"ValidatedMedia","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L196-L201","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L196"}],"snippet":"export interface ValidatedMedia {\n  readonly mime: string\n  readonly base64: string\n  readonly dataUrl: string\n  readonly bytes: Uint8Array\n}"},{"id":"packages_llm_src_protocols_shared_validatetoolfile","label":"validateToolFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L237-L238","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L237"}],"snippet":"validateToolFile = (route: string, part: ToolFileContent, supportedMimes: ReadonlySet<string>) =>\n  validateMedia(route, { type: \"media\", mediaType: part.mime, data: part.uri, filename: part.name }, supportedMimes)"},{"id":"packages_llm_src_protocols_shared_trimbaseurl","label":"trimBaseUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L240","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L240"}],"snippet":"trimBaseUrl = (value: string) => value.replace(/\\/+$/, \"\")"},{"id":"packages_llm_src_protocols_shared_toolresulttext","label":"toolResultText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L242-L246","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L242"}],"snippet":"toolResultText = (part: ToolResultPart) => {\n  if (part.result.type === \"text\" || part.result.type === \"error\") return String(part.result.value)\n  if (part.result.type === \"content\") return encodeJson(part.result.value)\n  return encodeJson(part.result.value)\n}"},{"id":"packages_llm_src_protocols_shared_errortext","label":"errorText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L248-L255","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L248"}],"snippet":"errorText = (error: unknown) => {\n  if (error instanceof Error) return error.message\n  if (typeof error === \"string\") return error\n  if (typeof error === \"number\" || typeof error === \"boolean\" || typeof error === \"bigint\") return String(error)\n  if (error === null) return \"null\"\n  if (error === undefined) return \"undefined\"\n  return \"Unknown stream error\"\n}"},{"id":"packages_llm_src_protocols_shared_sseframing","label":"sseFraming()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L265-L272","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L265"}],"snippet":"sseFraming = (bytes: Stream.Stream<Uint8Array, LLMError>): Stream.Stream<string, LLMError> =>\n  bytes.pipe(\n    Stream.decodeText(),\n    Stream.pipeThroughChannel(Sse.decode()),\n    Stream.catchTag(\"Retry\", () => Stream.empty),\n    Stream.filter((event) => event.data.length > 0 && event.data !== \"[DONE]\"),\n    Stream.map((event) => event.data),\n  )"},{"id":"packages_llm_src_protocols_shared_invalidrequest","label":"invalidRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L281-L286","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L281"}],"snippet":"invalidRequest = (message: string) =>\n  new LLMError({\n    module: \"ProviderShared\",\n    method: \"request\",\n    reason: new InvalidRequestReason({ message }),\n  })"},{"id":"packages_llm_src_protocols_shared_matchtoolchoice","label":"matchToolChoice()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L288-L304","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L288"}],"snippet":"matchToolChoice = <Auto, None, Required, Tool>(\n  route: string,\n  toolChoice: NonNullable<LLMRequest[\"toolChoice\"]>,\n  cases: {\n    readonly auto: () => Auto\n    readonly none: () => None\n    readonly required: () => Required\n    readonly tool: (name: string) => Tool\n  },\n) =>\n  Effect.gen(function* () {\n    if (toolChoice.type === \"auto\") return cases.auto()\n    if (toolChoice.type === \"none\") return cases.none()\n    if (toolChoice.type === \"required\") return cases.required()\n    if (!toolChoice.name) return yield* invalidRequest(`${route} tool choice requires a tool name`)\n    return cases.tool(toolChoice.name)\n  })"},{"id":"packages_llm_src_protocols_shared_formatcontenttypes","label":"formatContentTypes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L308-L312","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L308"}],"snippet":"formatContentTypes = (types: ReadonlyArray<ContentType>) => {\n  if (types.length <= 1) return types[0] ?? \"\"\n  if (types.length === 2) return `${types[0]} and ${types[1]}`\n  return `${types.slice(0, -1).join(\", \")}, and ${types.at(-1)}`\n}"},{"id":"packages_llm_src_protocols_shared_supportscontent","label":"supportsContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L314-L317","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L314"}],"snippet":"supportsContent = <const Type extends ContentType>(\n  part: ContentPart,\n  types: ReadonlyArray<Type>,\n): part is Extract<ContentPart, { readonly type: Type }> => (types as ReadonlyArray<ContentType>).includes(part.type)"},{"id":"packages_llm_src_protocols_shared_unsupportedcontent","label":"unsupportedContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L319-L323","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L319"}],"snippet":"unsupportedContent = (\n  route: string,\n  role: LLMRequest[\"messages\"][number][\"role\"],\n  types: ReadonlyArray<ContentType>,\n) => invalidRequest(`${route} ${role} messages only support ${formatContentTypes(types)} content for now`)"},{"id":"packages_llm_src_protocols_shared_validatewith","label":"validateWith()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L331-L334","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L331"}],"snippet":"validateWith =\n  <A, I, E extends { readonly message: string }>(decode: (input: I) => Effect.Effect<A, E>) =>\n  (payload: I) =>\n    decode(payload).pipe(Effect.mapError((error) => invalidRequest(error.message)))"},{"id":"packages_llm_src_protocols_shared_jsonpost","label":"jsonPost()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L343-L347","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L343"}],"snippet":"jsonPost = (input: { readonly url: string; readonly body: string; readonly headers?: Headers.Input }) =>\n  HttpClientRequest.post(input.url).pipe(\n    HttpClientRequest.setHeaders(Headers.set(Headers.fromInput(input.headers), \"content-type\", \"application/json\")),\n    HttpClientRequest.bodyText(input.body, \"application/json\"),\n  )"}],"edges":[{"source":"packages_llm_src_protocols_shared","target":"buffer","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/shared.ts","source_location":"L