{"__madarTsExtractorVersion":67,"__madarFileStem":"close-prs","nodes":[{"id":"close_prs","label":"close-prs.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L1"}]},{"id":"close_prs_main","label":"main()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L142-L183","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L142"}],"snippet":"async function main() {\n  console.log(`${values.execute ? \"EXECUTE\" : \"DRY RUN\"}: PR cleanup for ${repo.owner}/${repo.name}`)\n  console.log(`Cutoff: ${cutoff.toISOString()}`)\n  console.log(`Threshold: fewer than ${threshold} positive reactions`)\n\n  const prs = await fetchOpenPullRequests()\n  const recentCount = prs.filter((pr) => new Date(pr.createdAt) >= cutoff).length\n  const matching = prs\n    .map((pr) => ({ ...pr, positiveReactions: positiveReactionCount(pr) }))\n    .filter((pr) => new Date(pr.createdAt) < cutoff && pr.positiveReactions < threshold)\n  const candidates = matching.filter((pr) => !hasPriorCleanup(pr))\n  const selected = maxClose === undefined ? candidates : candidates.slice(0, maxClose)\n\n  console.log(`Fetched ${prs.length} open PRs`)\n  console.log(`Matching cleanup criteria: ${matching.length}`)\n  console.log(`Skipped previously cleaned PRs: ${matching.length - candidates.length}`)\n  console.log(`Recent PRs untouched: ${recentCount}`)\n  console.log(\n    `Older PRs with at least ${threshold} positive reactions untouched: ${prs.length - matching.length - recentCount}`,\n  )\n\n  if (selected.length === 0) return\n\n  if (!values.execute) {\n    console.log(`\\nDry-run only. Re-run with --execute to comment and close matching PRs.`)"},{"id":"close_prs_fetchopenpullrequests","label":"fetchOpenPullRequests()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L185-L244","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L185"}],"snippet":"async function fetchOpenPullRequests() {\n  const prs: PullRequest[] = []\n  let endCursor: string | null = null\n\n  while (true) {\n    const page = await graphql({\n      query: `query($owner: String!, $name: String!, $endCursor: String) {\n        rateLimit {\n          cost\n          remaining\n          resetAt\n        }\n        repository(owner: $owner, name: $name) {\n          pullRequests(first: 100, states: OPEN, orderBy: { field: CREATED_AT, direction: ASC }, after: $endCursor) {\n            pageInfo {\n              hasNextPage\n              endCursor\n            }\n            nodes {\n              number\n              title\n              url\n              createdAt\n              reactionGroups {\n                content"},{"id":"close_prs_graphql","label":"graphql()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L246-L256","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L246"}],"snippet":"async function graphql(input: { query: string; variables: Record<string, string | null> }) {\n  const response = await githubRequest(\"/graphql\", {\n    method: \"POST\",\n    body: JSON.stringify(input),\n  })\n  const body = (await response.json()) as GraphqlResponse\n  if (body.errors?.length)\n    throw new Error(`GitHub GraphQL error: ${body.errors.map((error) => error.message).join(\", \")}`)\n  if (!body.data) throw new Error(\"GitHub GraphQL response did not include data\")\n  return body.data\n}"},{"id":"close_prs_closepullrequest","label":"closePullRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L258-L272","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L258"}],"snippet":"async function closePullRequest(pr: CleanupCandidate) {\n  await githubRequest(`/repos/${repo.owner}/${repo.name}/issues/${pr.number}/comments`, {\n    method: \"POST\",\n    body: JSON.stringify({ body: message }),\n  })\n  await githubRequest(`/repos/${repo.owner}/${repo.name}/pulls/${pr.number}`, {\n    method: \"PATCH\",\n    body: JSON.stringify({ state: \"closed\" }),\n  })\n  await githubRequest(`/repos/${repo.owner}/${repo.name}/issues/${pr.number}/labels`, {\n    method: \"POST\",\n    body: JSON.stringify({ labels: [cleanupLabel] }),\n  })\n  console.log(`Closed #${pr.number} positive=${pr.positiveReactions} ${pr.url}`)\n}"},{"id":"close_prs_ensurecleanuplabel","label":"ensureCleanupLabel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L274-L293","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L274"}],"snippet":"async function ensureCleanupLabel() {\n  const response = await fetch(\n    `https://api.github.com/repos/${repo.owner}/${repo.name}/labels/${encodeURIComponent(cleanupLabel)}`,\n    {\n      headers,\n    },\n  )\n  if (response.ok) return\n  if (response.status !== 404)\n    throw new Error(`Failed to check cleanup label: ${response.status} ${response.statusText}`)\n\n  await githubRequest(`/repos/${repo.owner}/${repo.name}/labels`, {\n    method: \"POST\",\n    body: JSON.stringify({\n      name: cleanupLabel,\n      color: \"ededed\",\n      description: \"PR was closed by automated cleanup\",\n    }),\n  })\n}"},{"id":"close_prs_githubrequest","label":"githubRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L295-L326","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L295"}],"snippet":"async function githubRequest(path: string, init: RequestInit, attempt = 0): Promise<Response> {\n  const response = await fetch(path.startsWith(\"https://\") ? path : `https://api.github.com${path}`, {\n    ...init,\n    headers: {\n      ...headers,\n      ...init.headers,\n    },\n  })\n\n  if (response.ok) return response\n\n  const body = await response.text()\n  const retryAfter = response.headers.get(\"retry-after\")\n  const reset = response.headers.get(\"x-ratelimit-reset\")\n  const retryMs = retryAfter\n    ? Number(retryAfter) * 1000\n    : response.headers.get(\"x-ratelimit-remaining\") === \"0\" && reset\n      ? Math.max(0, Number(reset) * 1000 - Date.now()) + 1_000\n      : body.toLowerCase().includes(\"secondary rate limit\")\n        ? 300_000\n        : response.status >= 500\n          ? Math.min(300_000, 10_000 * 2 ** attempt)\n          : 0\n\n  if ((response.status === 403 || response.status === 429 || response.status >= 500) && retryMs > 0 && attempt < 10) {"},{"id":"close_prs_positivereactioncount","label":"positiveReactionCount()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L328-L332","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L328"}],"snippet":"function positiveReactionCount(pr: PullRequest) {\n  return pr.reactionGroups\n    .filter((group) => positiveReactions.has(group.content))\n    .reduce((total, group) => total + group.users.totalCount, 0)\n}"},{"id":"close_prs_haspriorcleanup","label":"hasPriorCleanup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L334-L336","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L334"}],"snippet":"function hasPriorCleanup(pr: PullRequest) {\n  return pr.labels.nodes.some((label) => label.name === cleanupLabel)\n}"},{"id":"close_prs_requirerepo","label":"requireRepo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L338-L343","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L338"}],"snippet":"function requireRepo(value: string | undefined) {\n  if (!value) throw new Error(\"repo is required\")\n  const [owner, name] = value.split(\"/\")\n  if (!owner || !name) throw new Error(`Invalid repo ${value}; expected owner/name`)\n  return { owner, name }\n}"},{"id":"close_prs_requiretoken","label":"requireToken()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L345-L361","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L345"}],"snippet":"async function requireToken() {\n  const envToken = process.env.GITHUB_TOKEN ?? process.env.GH_TOKEN\n  if (envToken) return envToken\n\n  const proc = Bun.spawn([\"gh\", \"auth\", \"token\"], {\n    stdout: \"pipe\",\n    stderr: \"pipe\",\n  })\n  const stdout = await new Response(proc.stdout).text()\n  const stderr = await new Response(proc.stderr).text()\n  const exitCode = await proc.exited\n  if (exitCode === 0 && stdout.trim()) return stdout.trim()\n\n  throw new Error(\n    `GitHub authentication is required. Set GITHUB_TOKEN/GH_TOKEN or run gh auth login.\\n${stderr.trim()}`,\n  )\n}"},{"id":"close_prs_requirepositiveinteger","label":"requirePositiveInteger()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L363-L367","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L363"}],"snippet":"function requirePositiveInteger(name: string, value: string | undefined) {\n  const parsed = Number(value)\n  if (!Number.isInteger(parsed) || parsed <= 0) throw new Error(`${name} must be a positive integer`)\n  return parsed\n}"},{"id":"close_prs_requirenonnegativeinteger","label":"requireNonNegativeInteger()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L369-L373","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L369"}],"snippet":"function requireNonNegativeInteger(name: string, value: string | undefined) {\n  const parsed = Number(value)\n  if (!Number.isInteger(parsed) || parsed < 0) throw new Error(`${name} must be a non-negative integer`)\n  return parsed\n}"},{"id":"close_prs_subtractmonths","label":"subtractMonths()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L375-L384","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L375"}],"snippet":"function subtractMonths(date: Date, months: number) {\n  const result = new Date(date)\n  const day = result.getUTCDate()\n  result.setUTCDate(1)\n  result.setUTCMonth(result.getUTCMonth() - months)\n  result.setUTCDate(\n    Math.min(day, new Date(Date.UTC(result.getUTCFullYear(), result.getUTCMonth() + 1, 0)).getUTCDate()),\n  )\n  return result\n}"},{"id":"close_prs_sleep","label":"sleep()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L386-L388","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L386"}],"snippet":"function sleep(ms: number) {\n  return new Promise((resolve) => setTimeout(resolve, ms))\n}"}],"edges":[{"source":"close_prs","target":"util","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L3"}],"weight":1},{"source":"close_prs","target":"close_prs_main","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_location":"L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/github/close-prs.ts","source_locatio