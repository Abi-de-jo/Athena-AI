{"__madarTsExtractorVersion":67,"__madarFileStem":"markdown-stream","nodes":[{"id":"markdown_stream","label":"markdown-stream.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L1"}]},{"id":"markdown_stream_refs","label":"refs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L10-L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L10"}],"snippet":"function refs(text: string) {\n  return /^\\[[^\\]]+\\]:\\s+\\S+/m.test(text) || /^\\[\\^[^\\]]+\\]:\\s+/m.test(text)\n}"},{"id":"markdown_stream_open","label":"open()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L14-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L14"}],"snippet":"function open(raw: string) {\n  const match = raw.match(/^[ \\t]{0,3}(`{3,}|~{3,})/)\n  if (!match) return false\n  const mark = match[1]\n  if (!mark) return false\n  const char = mark[0]\n  const size = mark.length\n  const last = raw.trimEnd().split(\"\\n\").at(-1)?.trim() ?? \"\"\n  return !new RegExp(`^[\\\\t ]{0,3}${char}{${size},}[\\\\t ]*$`).test(last)\n}"},{"id":"markdown_stream_heal","label":"heal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L25-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L25"}],"snippet":"function heal(text: string) {\n  return remend(text, { linkMode: \"text-only\" })\n}"},{"id":"markdown_stream_stream","label":"stream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L29-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L29"}],"snippet":"export function stream(text: string, live: boolean) {\n  if (!live) return [{ raw: text, src: text, mode: \"full\" }] satisfies Block[]\n  const src = heal(text)\n  if (refs(text)) return [{ raw: text, src, mode: \"live\" }] satisfies Block[]\n  const tokens = marked.lexer(text)\n  const tail = tokens.findLastIndex((token) => token.type !== \"space\")\n  if (tail < 0) return [{ raw: text, src, mode: \"live\" }] satisfies Block[]\n  const last = tokens[tail]\n  if (!last || last.type !== \"code\") return [{ raw: text, src, mode: \"live\" }] satisfies Block[]\n  const code = last as Tokens.Code\n  if (!open(code.raw)) return [{ raw: text, src, mode: \"live\" }] satisfies Block[]\n  const head = tokens\n    .slice(0, tail)\n    .map((token) => token.raw)\n    .join(\"\")\n  if (!head) return [{ raw: code.raw, src: code.raw, mode: \"live\" }] satisfies Block[]\n  return [\n    { raw: head, src: heal(head), mode: \"live\" },\n    { raw: code.raw, src: code.raw, mode: \"live\" },\n  ] satisfies Block[]\n}"}],"edges":[{"source":"markdown_stream","target":"marked","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L1"}],"weight":1},{"source":"markdown_stream","target":"remend","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L2"}],"weight":1},{"source":"markdown_stream","target":"markdown_stream_refs","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L10","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L10"}],"weight":1},{"source":"markdown_stream","target":"markdown_stream_open","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L14","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L14"}],"weight":1},{"source":"markdown_stream","target":"markdown_stream_heal","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/markdown-stream.ts","source_location":"L25","layer":"base","provenance":[{"capability_id":"builtin:ext