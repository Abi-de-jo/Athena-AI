{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_test_cli_run_theme.test","nodes":[{"id":"packages_opencode_test_cli_run_theme_test","label":"theme.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L1"}]},{"id":"packages_opencode_test_cli_run_theme_test_terminalcolors","label":"terminalColors()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L7-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L7"}],"snippet":"function terminalColors(input: Partial<TerminalColors> = {}): TerminalColors {\n  return {\n    palette: Array.from({ length: 256 }, (_, index) => input.palette?.[index] ?? palette[index % palette.length]!),\n    defaultBackground: input.defaultBackground ?? \"#1a1b26\",\n    defaultForeground: input.defaultForeground ?? \"#c0caf5\",\n    cursorColor: input.cursorColor ?? \"#ff9e64\",\n    mouseForeground: input.mouseForeground ?? null,\n    mouseBackground: input.mouseBackground ?? null,\n    tekForeground: input.tekForeground ?? null,\n    tekBackground: input.tekBackground ?? null,\n    highlightBackground: input.highlightBackground ?? \"#33467c\",\n    highlightForeground: input.highlightForeground ?? \"#c0caf5\",\n  }\n}"},{"id":"packages_opencode_test_cli_run_theme_test_renderer","label":"renderer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L22-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L22"}],"snippet":"function renderer(\n  input: {\n    themeMode?: \"dark\" | \"light\"\n    colors?: TerminalColors\n    fail?: boolean\n  } = {},\n) {\n  return {\n    themeMode: input.themeMode,\n    getPalette: async () => {\n      if (input.fail) {\n        throw new Error(\"boom\")\n      }\n\n      return input.colors ?? terminalColors()\n    },\n  } as CliRenderer\n}"},{"id":"packages_opencode_test_cli_run_theme_test_expectrgba","label":"expectRgba()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L41-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L41"}],"snippet":"function expectRgba(color: unknown) {\n  expect(color).toBeInstanceOf(RGBA)\n  if (!(color instanceof RGBA)) {\n    throw new Error(\"expected RGBA\")\n  }\n\n  return color\n}"},{"id":"packages_opencode_test_cli_run_theme_test_expectindexed","label":"expectIndexed()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L50-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L50"}],"snippet":"function expectIndexed(color: unknown) {\n  const rgba = expectRgba(color)\n  expect(rgba.intent).toBe(\"indexed\")\n  expect(rgba.slot).toBeLessThan(256)\n}"},{"id":"packages_opencode_test_cli_run_theme_test_spread","label":"spread()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L56-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L56"}],"snippet":"function spread(color: RGBA) {\n  const [r, g, b] = color.toInts()\n  return Math.max(r, g, b) - Math.min(r, g, b)\n}"}],"edges":[{"source":"packages_opencode_test_cli_run_theme_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_test_cli_run_theme_test","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L2"}],"weight":1},{"source":"packages_opencode_test_cli_run_theme_test","target":"theme","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/theme.test.ts","source_location":"L3"}],"weight":1},{"source":"packages_opencode_test_cli_run_theme_test","target":"packages_opencode_test_cli