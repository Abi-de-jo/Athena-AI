{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_cli_cmd_providers","nodes":[{"id":"packages_opencode_src_cli_cmd_providers","label":"providers.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L1"}]},{"id":"packages_opencode_src_cli_cmd_providers_promptvalue","label":"promptValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L23-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L23"}],"snippet":"promptValue = <Value>(value: Option.Option<Value>) => {\n  if (Option.isNone(value)) return Effect.die(new UI.CancelledError())\n  return Effect.succeed(value.value)\n}"},{"id":"packages_opencode_src_cli_cmd_providers_clitry","label":"cliTry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L33-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L33"}],"snippet":"cliTry = <Value>(message: string, fn: () => PromiseLike<Value>) =>\n  Effect.tryPromise({\n    try: fn,\n    catch: (error) => new CliError({ message: message + errorMessage(error) }),\n  })"},{"id":"packages_opencode_src_cli_cmd_providers_resolvepluginproviders","label":"resolvePluginProviders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L212-L237","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L212"}],"snippet":"export function resolvePluginProviders(input: {\n  hooks: Hooks[]\n  existingProviders: Record<string, unknown>\n  disabled: Set<string>\n  enabled?: Set<string>\n  providerNames: Record<string, string | undefined>\n}): Array<{ id: string; name: string }> {\n  const seen = new Set<string>()\n  const result: Array<{ id: string; name: string }> = []\n\n  for (const hook of input.hooks) {\n    if (!hook.auth) continue\n    const id = hook.auth.provider\n    if (seen.has(id)) continue\n    seen.add(id)\n    if (Object.hasOwn(input.existingProviders, id)) continue\n    if (input.disabled.has(id)) continue\n    if (input.enabled && !input.enabled.has(id)) continue\n    result.push({\n      id,\n      name: input.providerNames[id] ?? id,\n    })\n  }\n\n  return result"}],"edges":[{"source":"packages_opencode_src_cli_cmd_providers","target":"yargs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_cli_cmd_providers","target":"auth","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/providers.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/pr