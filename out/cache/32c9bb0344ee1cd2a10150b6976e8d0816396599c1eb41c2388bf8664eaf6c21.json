),\n  ])\n}"},{"id":"packages_stats_core_src_domain_provider_torow","label":"toRow()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/provider.ts","source_location":"L193-L198","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/provider.ts","source_location":"L193"}],"snippet":"function toRow(data: ProviderStatAggregate): ProviderStatRow {\n  return {\n    ...toStatBaseRow(data),\n    provider: data.provider,\n  }\n}"},{"id":"packages_stats_core_src_domain_provider_dimensionkey","label":"dimensionKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/provider.ts","source_location":"L200-L202","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/provider.ts","source_location":"L200"}],"snippet":"function dimensionKey(row: ProviderStatRow) {\n  return row.provider\n}"}],"edges":[{"source":"packages_stats_core_src_domain_provider","target":"drizzle_orm","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/provider.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/provider.ts","source_location":"L1"}],"weight":1},{"source":"packages_stats_core_src_domain_provider","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/provider.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_fi