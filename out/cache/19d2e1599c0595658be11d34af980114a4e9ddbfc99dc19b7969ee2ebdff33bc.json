{"__madarTsExtractorVersion":67,"__madarFileStem":"selection-bridge","nodes":[{"id":"selection_bridge","label":"selection-bridge.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L1"}]},{"id":"selection_bridge_formatselectedlinelabel","label":"formatSelectedLineLabel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L10-L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L10"}],"snippet":"export function formatSelectedLineLabel(range: LineSpan, t: (key: SelectionKey, params: SelectionVars) => string) {\n  const start = Math.min(range.start, range.end)\n  const end = Math.max(range.start, range.end)\n  if (start === end) return t(\"ui.sessionReview.selection.line\", { line: start })\n  return t(\"ui.sessionReview.selection.lines\", { start, end })\n}"},{"id":"selection_bridge_previewselectedlines","label":"previewSelectedLines()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L17-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L17"}],"snippet":"export function previewSelectedLines(source: string, range: LineSpan) {\n  const start = Math.max(1, Math.min(range.start, range.end))\n  const end = Math.max(range.start, range.end)\n  const lines = source.split(\"\\n\").slice(start - 1, end)\n  if (lines.length === 0) return\n  return lines.slice(0, 2).join(\"\\n\")\n}"},{"id":"selection_bridge_cloneselectedlinerange","label":"cloneSelectedLineRange()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L25-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L25"}],"snippet":"export function cloneSelectedLineRange(range: SelectedLineRange): SelectedLineRange {\n  const next: SelectedLineRange = {\n    start: range.start,\n    end: range.end,\n  }\n\n  if (range.side) next.side = range.side\n  if (range.endSide) next.endSide = range.endSide\n  return next\n}"},{"id":"selection_bridge_lineinselectedrange","label":"lineInSelectedRange()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L36-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L36"}],"snippet":"export function lineInSelectedRange(range: SelectedLineRange | null | undefined, line: number, side?: Side) {\n  if (!range) return false\n\n  const start = Math.min(range.start, range.end)\n  const end = Math.max(range.start, range.end)\n  if (line < start || line > end) return false\n  if (!side) return true\n\n  const first = range.side\n  const last = range.endSide ?? first\n  if (!first && !last) return true\n  if (!first || !last) return (first ?? last) === side\n  if (first === last) return first === side\n  if (line === start) return first === side\n  if (line === end) return last === side\n  return true\n}"},{"id":"selection_bridge_issinglelineselection","label":"isSingleLineSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L54-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L54"}],"snippet":"export function isSingleLineSelection(range: SelectedLineRange | null) {\n  if (!range) return false\n  return range.start === range.end && (range.endSide == null || range.endSide === range.side)\n}"},{"id":"selection_bridge_torange","label":"toRange()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L59-L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L59"}],"snippet":"export function toRange(source: Range | StaticRange): Range {\n  if (source instanceof Range) return source\n  const range = new Range()\n  range.setStart(source.startContainer, source.startOffset)\n  range.setEnd(source.endContainer, source.endOffset)\n  return range\n}"},{"id":"selection_bridge_restoreshadowtextselection","label":"restoreShadowTextSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L67-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L67"}],"snippet":"export function restoreShadowTextSelection(root: ShadowRoot | undefined, range: Range | undefined) {\n  if (!root || !range) return\n\n  requestAnimationFrame(() => {\n    const selection =\n      (root as unknown as { getSelection?: () => Selection | null }).getSelection?.() ?? window.getSelection()\n    if (!selection) return\n\n    try {\n      selection.removeAllRanges()\n      selection.addRange(range)\n    } catch {}\n  })\n}"},{"id":"selection_bridge_createlinenumberselectionbridge","label":"createLineNumberSelectionBridge()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L82-L132","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L82"}],"snippet":"export function createLineNumberSelectionBridge() {\n  let mode: PointerMode = \"none\"\n  let line: number | undefined\n  let moved = false\n  let pending = false\n\n  const clear = () => {\n    mode = \"none\"\n    line = undefined\n    moved = false\n  }\n\n  return {\n    begin(numberColumn: boolean, next: number | undefined) {\n      if (!numberColumn) {\n        mode = \"text\"\n        return\n      }\n\n      mode = \"numbers\"\n      line = next\n      moved = false\n    },\n    track(buttons: number, next: number | undefined) {\n      if (mode !== \"numbers\") return false"},{"id":"selection_bridge_createlinenumberselectionbridge_clear","label":"clear()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L88-L92","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/selection-bridge.ts","source_location":"L88"}],"snippet":"clear = () => {\n    mode = \"none\"\n    line = undefined\n    moved = false\n  }"}],"edges":[{"source":"selection_bridge","target":"diffs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Proje