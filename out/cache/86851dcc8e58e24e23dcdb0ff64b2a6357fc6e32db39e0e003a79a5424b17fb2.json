ource_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-scope.ts","source_location":"L62"}],"snippet":"export function migrateLegacySessionStateKeys(value: unknown) {\n  if (!value || typeof value !== \"object\" || Array.isArray(value)) return value\n  const entries = Object.entries(value)\n  if (entries.every(([key]) => key.includes(separator))) return value\n  const scoped = Object.fromEntries(entries.filter(([key]) => key.includes(separator)))\n  for (const [key, item] of entries) {\n    if (key.includes(separator)) continue\n    const next = SessionStateKey.from(ServerScope.local, SessionRouteKey.fromLegacy(key))\n    if (!(next in scoped)) scoped[next] = item\n  }\n  return scoped\n}"}],"edges":[{"source":"server_scope","target":"server","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-scope.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-scope.ts","source_location":"L1"}],"weight":1},{"source":"server_scope","target":"server_scope_fragment","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-scope.ts","source_location":"L10","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-scope.ts","source_location":"L10"}],"weight":1},{"source":"server_scope","target":"server_scope_compose","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-scope.ts","source_location":"L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/per