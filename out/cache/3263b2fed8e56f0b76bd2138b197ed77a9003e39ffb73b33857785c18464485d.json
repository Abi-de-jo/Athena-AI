mplete\")\n        ) {\n          return new Response("}],"edges":[{"source":"packages_core_src_plugin_provider_snowflake_cortex","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/snowflake-cortex.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/snowflake-cortex.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_src_plugin_provider_snowflake_cortex","target":"plugin","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/snowflake-cortex.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/snowflake-cortex.ts","source_location":"L2"}],"weight":1},{"source":"packages_core_src_plugin_provider_snowflake_cortex","target":"provider","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/snowflake-cortex.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/snowflake-cortex.ts","source_location":"L3"}],"weight":1},{"source":"packages_core_src_plugin_provider_snowflake_cortex","target":"packages_core_src_plugin_provider_snowflake_cortex_cortexfetch","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/snowflake-cortex.ts","source_location":"L8","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","st