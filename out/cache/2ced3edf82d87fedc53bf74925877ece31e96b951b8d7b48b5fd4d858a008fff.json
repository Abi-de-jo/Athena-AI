{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_tool_shell","nodes":[{"id":"packages_opencode_src_tool_shell","label":"shell.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L1"}]},{"id":"packages_opencode_src_tool_shell_resolvewasm","label":"resolveWasm()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L84-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L84"}],"snippet":"resolveWasm = (asset: string) => {\n  if (asset.startsWith(\"file://\")) return fileURLToPath(asset)\n  if (asset.startsWith(\"/\") || /^[a-z]:/i.test(asset)) return asset\n  const url = new URL(asset, import.meta.url)\n  return fileURLToPath(url)\n}"},{"id":"packages_opencode_src_tool_shell_parts","label":"parts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L91-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L91"}],"snippet":"function parts(node: Node) {\n  const out: Part[] = []\n  for (let i = 0; i < node.childCount; i++) {\n    const child = node.child(i)\n    if (!child) continue\n    if (child.type === \"command_elements\") {\n      for (let j = 0; j < child.childCount; j++) {\n        const item = child.child(j)\n        if (!item || item.type === \"command_argument_sep\" || item.type === \"redirection\") continue\n        out.push({ type: item.type, text: item.text })\n      }\n      continue\n    }\n    if (\n      child.type !== \"command_name\" &&\n      child.type !== \"command_name_expr\" &&\n      child.type !== \"word\" &&\n      child.type !== \"string\" &&\n      child.type !== \"raw_string\" &&\n      child.type !== \"concatenation\"\n    ) {\n      continue\n    }\n    out.push({ type: child.type, text: child.text })\n  }"},{"id":"packages_opencode_src_tool_shell_source","label":"source()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L119-L121","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L119"}],"snippet":"function source(node: Node) {\n  return (node.parent?.type === \"redirected_statement\" ? node.parent.text : node.text).trim()\n}"},{"id":"packages_opencode_src_tool_shell_commands","label":"commands()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L123-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L123"}],"snippet":"function commands(node: Node) {\n  return node.descendantsOfType(\"command\").filter((child): child is Node => Boolean(child))\n}"},{"id":"packages_opencode_src_tool_shell_unquote","label":"unquote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L127-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L127"}],"snippet":"function unquote(text: string) {\n  if (text.length < 2) return text\n  const first = text[0]\n  const last = text[text.length - 1]\n  if ((first === '\"' || first === \"'\") && first === last) return text.slice(1, -1)\n  return text\n}"},{"id":"packages_opencode_src_tool_shell_home","label":"home()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L135-L139","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L135"}],"snippet":"function home(text: string) {\n  if (text === \"~\") return os.homedir()\n  if (text.startsWith(\"~/\") || text.startsWith(\"~\\\\\")) return path.join(os.homedir(), text.slice(2))\n  return text\n}"},{"id":"packages_opencode_src_tool_shell_envvalue","label":"envValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L141-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L141"}],"snippet":"function envValue(key: string) {\n  if (process.platform !== \"win32\") return process.env[key]\n  const name = Object.keys(process.env).find((item) => item.toLowerCase() === key.toLowerCase())\n  return name ? process.env[name] : undefined\n}"},{"id":"packages_opencode_src_tool_shell_auto","label":"auto()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L147-L152","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L147"}],"snippet":"function auto(key: string, cwd: string, shell: string) {\n  const name = key.toUpperCase()\n  if (name === \"HOME\") return os.homedir()\n  if (name === \"PWD\") return cwd\n  if (name === \"PSHOME\") return path.dirname(shell)\n}"},{"id":"packages_opencode_src_tool_shell_expand","label":"expand()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L154-L160","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L154"}],"snippet":"function expand(text: string, cwd: string, shell: string) {\n  const out = unquote(text)\n    .replace(/\\$\\{env:([^}]+)\\}/gi, (_, key: string) => envValue(key) || \"\")\n    .replace(/\\$env:([A-Za-z_][A-Za-z0-9_]*)/gi, (_, key: string) => envValue(key) || \"\")\n    .replace(/\\$(HOME|PWD|PSHOME)(?=$|[\\\\/])/gi, (_, key: string) => auto(key, cwd, shell) || \"\")\n  return home(out)\n}"},{"id":"packages_opencode_src_tool_shell_provider","label":"provider()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L162-L172","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L162"}],"snippet":"function provider(text: string) {\n  const match = text.match(/^([A-Za-z]+)::(.*)$/)\n  if (match) {\n    if (match[1].toLowerCase() !== \"filesystem\") return\n    return match[2]\n  }\n  const prefix = text.match(/^([A-Za-z]+):(.*)$/)\n  if (!prefix) return text\n  if (prefix[1].length === 1) return text\n  return\n}"},{"id":"packages_opencode_src_tool_shell_dynamic","label":"dynamic()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L174-L179","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L174"}],"snippet":"function dynamic(text: string, ps: boolean) {\n  if (text.startsWith(\"(\") || text.startsWith(\"@(\")) return true\n  if (text.includes(\"$(\") || text.includes(\"${\") || text.includes(\"`\")) return true\n  if (ps) return /\\$(?!env:)/i.test(text)\n  return text.includes(\"$\")\n}"},{"id":"packages_opencode_src_tool_shell_prefix","label":"prefix()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L181-L186","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L181"}],"snippet":"function prefix(text: string) {\n  const match = /[?*[]/.exec(text)\n  if (!match) return text\n  if (match.index === 0) return\n  return text.slice(0, match.index)\n}"},{"id":"packages_opencode_src_tool_shell_pathargs","label":"pathArgs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L188-L218","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L188"}],"snippet":"function pathArgs(list: Part[], ps: boolean, cmd = false) {\n  if (!ps) {\n    return list\n      .slice(1)\n      .filter(\n        (item) =>\n          !item.text.startsWith(\"-\") &&\n          !(cmd && item.text.startsWith(\"/\")) &&\n          !(list[0]?.text === \"chmod\" && item.text.startsWith(\"+\")),\n      )\n      .map((item) => item.text)\n  }\n\n  const out: string[] = []\n  let want = false\n  for (const item of list.slice(1)) {\n    if (want) {\n      out.push(item.text)\n      want = false\n      continue\n    }\n    if (item.type === \"command_parameter\") {\n      const flag = item.text.toLowerCase()\n      if (SWITCHES.has(flag)) continue\n      want = FLAGS.has(flag)"},{"id":"packages_opencode_src_tool_shell_preview","label":"preview()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L220-L223","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L220"}],"snippet":"function preview(text: string) {\n  if (text.length <= MAX_METADATA_LENGTH) return text\n  return \"...\\n\\n\" + text.slice(-MAX_METADATA_LENGTH)\n}"},{"id":"packages_opencode_src_tool_shell_tail","label":"tail()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L225-L255","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L225"}],"snippet":"function tail(text: string, maxLines: number, maxBytes: number) {\n  const lines = text.split(\"\\n\")\n  if (lines.length <= maxLines && Buffer.byteLength(text, \"utf-8\") <= maxBytes) {\n    return {\n      text,\n      cut: false,\n    }\n  }\n\n  const out: string[] = []\n  let bytes = 0\n  for (let i = lines.length - 1; i >= 0 && out.length < maxLines; i--) {\n    const size = Buffer.byteLength(lines[i], \"utf-8\") + (out.length > 0 ? 1 : 0)\n    if (bytes + size > maxBytes) {\n      if (out.length === 0) {\n        const buf = Buffer.from(lines[i], \"utf-8\")\n        let start = buf.length - maxBytes\n        if (start < 0) start = 0\n        while (start < buf.length && (buf[start] & 0xc0) === 0x80) start++\n        out.unshift(buf.subarray(start).toString(\"utf-8\"))\n      }\n      break\n    }\n    out.unshift(lines[i])\n    bytes += size"},{"id":"packages_opencode_src_tool_shell_cmd","label":"cmd()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L299-L316","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L299"}],"snippet":"function cmd(shell: string, command: string, cwd: string, env: NodeJS.ProcessEnv) {\n  if (process.platform === \"win32\" && Shell.ps(shell)) {\n    return ChildProcess.make(shell, [\"-NoLogo\", \"-NoProfile\", \"-NonInteractive\", \"-Command\", command], {\n      cwd,\n      env,\n      stdin: \"ignore\",\n      detached: false,\n    })\n  }\n\n  return ChildProcess.make(command, [], {\n    shell,\n    cwd,\n    env,\n    stdin: \"ignore\",\n    detached: process.platform !== \"win32\",\n  })\n}"}],"edges":[{"source":"packages_opencode_src_tool_shell","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_tool_shell","target":"os","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/shell.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/persona