omponent"},{"id":"session_sortable_terminal_tab_sortableterminaltab_isdefaulttitle","label":"isDefaultTitle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L29-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L29"}],"snippet":"isDefaultTitle = () => {\n    const number = props.terminal.titleNumber\n    if (!Number.isFinite(number) || number <= 0) return false\n    return isDefaultTerminalTitle(props.terminal.title, number)\n  }"},{"id":"session_sortable_terminal_tab_sortableterminaltab_label","label":"label()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L35-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L35"}],"snippet":"label = () => {\n    language.locale()\n    if (props.terminal.title && !isDefaultTitle()) return props.terminal.title\n\n    const number = props.terminal.titleNumber\n    if (Number.isFinite(number) && number > 0) return language.t(\"terminal.title.numbered\", { number })\n    if (props.terminal.title) return props.terminal.title\n    return language.t(\"terminal.title\")\n  }"},{"id":"session_sortable_terminal_tab_sortableterminaltab_close","label":"close()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L45-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L45"}],"snippet":"close = () => {\n    const count = terminal.all().length\n    void terminal.close(props.terminal.id)\n    if (count === 1) {\n      props.onClose?.()\n    }\n  }"},{"id":"session_sortable_terminal_tab_sortableterminaltab_focus","label":"focus()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L53-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L53"}],"snippet":"focus = () => {\n    if (store.editing) return\n    if (document.activeElement instanceof HTMLElement) document.activeElement.blur()\n    focusTerminalById(props.terminal.id)\n  }"},{"id":"session_sortable_terminal_tab_sortableterminaltab_edit","label":"edit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L59-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L59"}],"snippet":"edit = (e?: Event) => {\n    if (e) {\n      e.stopPropagation()\n      e.preventDefault()\n    }\n\n    setStore(\"blurEnabled\", false)\n    setStore(\"title\", props.terminal.title)\n    setStore(\"editing\", true)\n  }"},{"id":"session_sortable_terminal_tab_sortableterminaltab_save","label":"save()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L70-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L70"}],"snippet":"save = () => {\n    if (!store.blurEnabled) return\n\n    const value = store.title.trim()\n    if (value && value !== props.terminal.title) {\n      terminal.update({ id: props.terminal.id, title: value })\n    }\n    setStore(\"editing\", false)\n  }"},{"id":"session_sortable_terminal_tab_sortableterminaltab_keydown","label":"keydown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L80-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L80"}],"snippet":"keydown = (e: KeyboardEvent) => {\n    if (e.key === \"Enter\") {\n      e.preventDefault()\n      save()\n      return\n    }\n    if (e.key === \"Escape\") {\n      e.preventDefault()\n      setStore(\"editing\", false)\n    }\n  }"},{"id":"session_sortable_terminal_tab_sortableterminaltab_menu","label":"menu()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L92-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-sortable-terminal-tab.tsx","source_location":"L92"}],"snippet":"menu = (e: MouseEvent) => {\n    e.preventDefault()\n    setStore(\"menuPosition\", { x: e.clientX, y: e.clientY })\n    setStore(\"menuOpen\", true)\n  }"}],"edges":[{"source":"sessio