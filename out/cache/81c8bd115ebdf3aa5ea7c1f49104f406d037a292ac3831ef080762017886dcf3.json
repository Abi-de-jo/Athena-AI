{"__madarTsExtractorVersion":67,"__madarFileStem":"vcs","nodes":[{"id":"vcs","label":"vcs.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L1"}]},{"id":"vcs_emptypatch","label":"emptyPatch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L17"}],"snippet":"emptyPatch = (file: string) => formatPatch(structuredPatch(file, file, \"\", \"\", \"\", \"\", { context: 0 }))"},{"id":"vcs_nums","label":"nums()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L19-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L19"}],"snippet":"nums = (list: Git.Stat[]) =>\n  new Map(list.map((item) => [item.file, { additions: item.additions, deletions: item.deletions }] as const))"},{"id":"vcs_merge","label":"merge()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L22-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L22"}],"snippet":"merge = (...lists: Git.Item[][]) => {\n  const out = new Map<string, Git.Item>()\n  lists.flat().forEach((item) => {\n    if (!out.has(item.file)) out.set(item.file, item)\n  })\n  return [...out.values()]\n}"},{"id":"vcs_emptybatch","label":"emptyBatch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L30"}],"snippet":"emptyBatch = () => ({ patches: new Map<string, string>(), capped: false })"},{"id":"vcs_parsequotedpath","label":"parseQuotedPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L32-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L32"}],"snippet":"parseQuotedPath = (value: string) => {\n  let out = \"\"\n  for (let idx = 1; idx < value.length; idx++) {\n    const char = value[idx]\n    if (char === '\"') return { value: out, end: idx + 1 }\n    if (char !== \"\\\\\") {\n      out += char\n      continue\n    }\n\n    const next = value[++idx]\n    if (next === \"t\") out += \"\\t\"\n    else if (next === \"n\") out += \"\\n\"\n    else if (next === \"r\") out += \"\\r\"\n    else if (next === '\"' || next === \"\\\\\") out += next\n    else out += next ?? \"\"\n  }\n}"},{"id":"vcs_parsepathtoken","label":"parsePathToken()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L51-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L51"}],"snippet":"parsePathToken = (value: string) => {\n  if (!value.startsWith('\"')) return value.split(\"\\t\")[0]\n  return parseQuotedPath(value)?.value ?? value\n}"},{"id":"vcs_filefromdiffpath","label":"fileFromDiffPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L56-L61","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L56"}],"snippet":"fileFromDiffPath = (value: string | undefined) => {\n  if (!value || value === \"/dev/null\") return\n  const file = parsePathToken(value)\n  if (file.startsWith(\"a/\") || file.startsWith(\"b/\")) return file.slice(2)\n  return file\n}"},{"id":"vcs_filefromgitheader","label":"fileFromGitHeader()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L63-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L63"}],"snippet":"fileFromGitHeader = (header: string) => {\n  if (header.startsWith('\"')) {\n    const first = parseQuotedPath(header)\n    const second = first ? header.slice(first.end).trimStart() : undefined\n    if (!second) return\n    if (!second.startsWith('\"')) return fileFromDiffPath(second)\n    return fileFromDiffPath(parseQuotedPath(second)?.value)\n  }\n\n  const separator = header.indexOf(\" b/\")\n  if (separator === -1) return\n  return fileFromDiffPath(header.slice(separator + 1))\n}"},{"id":"vcs_filefrompatchchunk","label":"fileFromPatchChunk()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L77-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L77"}],"snippet":"fileFromPatchChunk = (chunk: string) => {\n  const next = /^\\+\\+\\+ (.+)$/m.exec(chunk)?.[1]\n  const before = /^--- (.+)$/m.exec(chunk)?.[1]\n  const file = fileFromDiffPath(next) ?? fileFromDiffPath(before)\n  if (file) return file\n\n  const header = /^diff --git (.+)$/m.exec(chunk)?.[1]\n  return fileFromGitHeader(header ?? \"\")\n}"},{"id":"vcs_splitgitpatch","label":"splitGitPatch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L87-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L87"}],"snippet":"splitGitPatch = (patch: Git.Patch) => {\n  const starts = [...patch.text.matchAll(/(?:^|\\n)diff --git /g)].map((match) =>\n    match[0].startsWith(\"\\n\") ? match.index + 1 : match.index,\n  )\n  const chunks = starts.map((start, index) => patch.text.slice(start, starts[index + 1] ?? patch.text.length))\n  if (!patch.truncated) return chunks\n  return chunks.slice(0, -1)\n}"},{"id":"vcs_totalpatch","label":"totalPatch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L143-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L143"}],"snippet":"totalPatch = (file: string, patch: string, total: number) => {\n  if (total + Buffer.byteLength(patch) <= MAX_TOTAL_PATCH_BYTES) return { patch, capped: false }\n  return { patch: emptyPatch(file), capped: true }\n}"},{"id":"vcs_patchapplyerror","label":"PatchApplyError","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L282-L285","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L282"}],"snippet":"export class PatchApplyError extends Schema.TaggedErrorClass<PatchApplyError>()(\"VcsPatchApplyError\", {\n  message: Schema.String,\n  reason: Schema.Literals([\"non-git\", \"not-clean\"]),\n}) {}"},{"id":"vcs_interface","label":"Interface","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L287-L295","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L287"}],"snippet":"export interface Interface {\n  readonly init: () => Effect.Effect<void>\n  readonly branch: () => Effect.Effect<string | undefined>\n  readonly defaultBranch: () => Effect.Effect<string | undefined>\n  readonly status: () => Effect.Effect<FileStatus[]>\n  readonly diff: (mode: Mode, options?: DiffOptions) => Effect.Effect<FileDiff[]>\n  readonly diffRaw: () => Effect.Effect<string>\n  readonly apply: (input: ApplyInput) => Effect.Effect<ApplyResult, PatchApplyError>\n}"},{"id":"vcs_state","label":"State","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L297-L300","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/project/vcs.ts","source_location":"L297"}],"snippet":"interface State {\n  current: string | undefined\n  root: Git.Base | undefined\n}"},{"id":"vcs_service","label":"Service