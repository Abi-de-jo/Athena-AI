{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_core_src_config_plugin_command","nodes":[{"id":"packages_core_src_config_plugin_command","label":"command.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/config/plugin/command.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/config/plugin/command.ts","source_location":"L1"}]},{"id":"packages_core_src_config_plugin_command_loaddirectory","label":"loadDirectory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/config/plugin/command.ts","source_location":"L53-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/config/plugin/command.ts","source_location":"L53"}],"snippet":"function loadDirectory(fs: FSUtil.Interface, directory: string) {\n  return Effect.gen(function* () {\n    const files = yield* fs\n      .glob(\"{command,commands}/**/*.md\", { cwd: directory, absolute: true, dot: true, symlink: true })\n      .pipe(Effect.catch(() => Effect.succeed([] as string[])))\n    return yield* Effect.forEach(files.toSorted(), (filepath) =>\n      fs.readFileStringSafe(filepath).pipe(\n        Effect.map((content) => (content === undefined ? undefined : decode(directory, filepath, content))),\n        Effect.catch(() => Effect.succeed(undefined)),\n      ),\n    ).pipe(\n      Effect.map((commands) =>\n        commands.filter((command): command is { name: string; info: ConfigCommand.Info } => command !== undefined),\n      ),\n    )\n  })\n}"},{"id":"packages_core_src_config_plugin_command_decode","label":"decode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/config/plugin/command.ts","source_location":"L7