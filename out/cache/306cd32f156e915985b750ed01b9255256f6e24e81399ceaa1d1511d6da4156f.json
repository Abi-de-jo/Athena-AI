] = next\n      return true\n    })\n    .some(Boolean)\n}"},{"id":"upgrade_opentui_editcatalog","label":"editCatalog()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/upgrade-opentui.ts","source_location":"L70-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/upgrade-opentui.ts","source_location":"L70"}],"snippet":"editCatalog = (obj: unknown) => {\n  if (!obj || typeof obj !== \"object\") return false\n  const map = obj as Record<string, unknown>\n  return keys\n    .map((key) => {\n      const cur = map[key]\n      if (typeof cur !== \"string\" || cur === ver) return false\n      map[key] = ver\n      return true\n    })\n    .some(Boolean)\n}"},{"id":"upgrade_opentui_editoverrides","label":"editOverrides()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/upgrade-opentui.ts","source_location":"L83-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/upgrade-opentui.ts","source_location":"L83"}],"snippet":"editOverrides = (obj: unknown) => {\n  if (!obj || typeof obj !== \"object\") return false\n  const map = obj as Record<string, unknown>\n  return keys\n    .map((key) => {\n      const cur = map[key]\n      if (typeof cur !== \"string\") return false\n      const next = snapshot ? ver : \"catalog:\"\n      if (next === cur) return false\n      map[key] = next\n      return true\n    })\n    .some(Boolean)\n}"},{"id":"upgrade_opentui_fixknownlockfileissues","label":"fixKnownLockfileIssues()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/upgrade-opentui.ts","source_location":"L157-L178","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/upgrade-opentui.ts","source_location":"L157"}],"snippet":"async function fixKnownLockfileIssues() {\n  const txt = await Bun.file(lockfile).text()\n  const stale = findStaleLockfileEntriesInText(txt)\n  if (stale.length === 0) return []\n  if (stale.some((item) => !item.entry.startsWith(\"opentui-spinner/@opentui/\"))) return []\n\n  const removed = txt\n    .split(\"\\n\")\n    .map((line) => line.match(/^    \"(opentui-spinner\\/@opentui\\/[^\\\"]+)\": /)?.[1])\n    .filter((item): item is string => item !== undefined)\n\n  if (removed.length === 0) return []\n\n  await Bun.write(\n    lockfile,\n    txt\n      .split(\"\\n\")\n      .filter((line) => !line.match(/^    \"opentui-spinner\\/@opentui\\//))\n      .join(\"\\n\"),\n  )\n  return removed\n}"},{"id":"upgrade_opentui_findstalelockfileentries","label":"findStaleLockfileEntries()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/upgrade-opentui.ts","source_location":"L180-L182","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/upgrade-opentui.ts","source_location":"L180"}],"snippet":"async function findStaleLockfileEntries() {\n  return findStaleLockfileEntriesInText(await Bun.file(lockfile).text())\n}"},{"id":"upgrade_opentui_findstalelockfileentriesintext","label":"findStaleLockfileEntriesInText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/upgrade-opentui.ts","source_location":"L184-L192","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/upgrade-opentui.ts","source_location":"L184"}],"snippet":"function findStaleLockfileEntriesInText(txt: string) {\n  return Array.from(txt.matchAll(/^    \"([^\"]+)\": \\[\"(@opentui\\/(?:core(?:-[^@\"]+)?|keymap|solid))@([^\"]+)\"/gm))\n    .map((match) => ({\n      entry: matc