ring[], opts: Process.RunOptions = {}) => Process.text(cmd, { ...opts, nothrow: true })"},{"id":"packages_rimuru_src_lsp_server_handle","label":"Handle","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L25-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L25"}],"snippet":"export interface Handle {\n  process: ChildProcessWithoutNullStreams\n  initialization?: Record<string, any>\n}"},{"id":"packages_rimuru_src_lsp_server_nearestroot","label":"NearestRoot()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L32-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L32"}],"snippet":"NearestRoot = (includePatterns: string[], excludePatterns?: string[]): RootFunction => {\n  return async (file, ctx) => {\n    if (excludePatterns) {\n      const excludedFiles = Filesystem.up({\n        targets: excludePatterns,\n        start: path.dirname(file),\n        stop: ctx.directory,\n      })\n      const excluded = await excludedFiles.next()\n      await excludedFiles.return()\n      if (excluded.value) return undefined\n    }\n    const files = Filesystem.up({\n      targets: includePatterns,\n      start: path.dirname(file),\n      stop: ctx.directory,\n    })\n    const first = await files.next()\n    await files.return()\n    if (!first.value) return ctx.directory\n    return path.dirname(first.value)\n  }\n}"},{"id":"packages_rimuru_src_lsp_server_strictnearestroot","label":"StrictNearestRoot()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L56-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L56"}],"snippet":"StrictNearestRoot = (includePatterns: string[], excludePatterns?: string[]): RootFunction => {\n  return async (file, ctx) => {\n    if (excludePatterns) {\n      const excludedFiles = Filesystem.up({\n        targets: excludePatterns,\n        start: path.dirname(file),\n        stop: ctx.directory,\n      })\n      const excluded = await excludedFiles.next()\n      await excludedFiles.return()\n      if (excluded.value) return undefined\n    }\n    const files = Filesystem.up({\n      targets: includePatterns,\n      start: path.dirname(file),\n      stop: ctx.directory,\n    })\n    const first = await files.next()\n    await files.return()\n    if (!first.value) return undefined\n    return path.dirname(first.value)\n  }\n}"},{"id":"packages_rimuru_src_lsp_server_info","label":"Info","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L80-L86","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L80"}],"snippet":"export interface Info {\n  id: string\n  extensions: string[]\n  global?: boolean\n  root: RootFunction\n  spawn(root: string, ctx: InstanceContext, flags: RuntimeFlags.Info): Promise<Handle | undefined>\n}"},{"id":"packages_rimuru_src_lsp_server_getroslynlanguageserver","label":"getRoslynLanguageServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L737-L748","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L737"}],"snippet":"async function getRoslynLanguageServer(disableLspDownload: boolean) {\n  const existing = which(\"roslyn-language-server\")\n  if (existing) return existing\n\n  const global = await roslynLanguageServerGlobalPath()\n  if (global) return global\n\n  roslynLanguageServerInstall ||= installRoslynLanguageServer(disableLspDownload).finally(() => {\n    roslynLanguageServerInstall = undefined\n  })\n  return roslynLanguageServerInstall\n}"},{"id":"packages_rimuru_src_lsp_server_installroslynlanguageserver","label":"installRoslynLanguageServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L750-L775","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L750"}],"snippet":"async function installRoslynLanguageServer(disableLspDownload: boolean) {\n  if (!which(\"dotnet\")) {\n    return\n  }\n\n  if (disableLspDownload) return\n  const proc = Process.spawn([\"dotnet\", \"tool\", \"install\", \"--global\", \"roslyn-language-server\", \"--prerelease\"], {\n    stdout: \"pipe\",\n    stderr: \"pipe\",\n    stdin: \"pipe\",\n  })\n  const exit = await proc.exited\n  if (exit !== 0) {\n    return\n  }\n\n  const resolved = which(\"roslyn-language-server\")\n  if (resolved) {\n    return resolved\n  }\n\n  const global = await roslynLanguageServerGlobalPath()\n  if (global) {\n    return global\n  }"},{"id":"packages_rimuru_src_lsp_server_roslynlanguageserverglobalpath","label":"roslynLanguageServerGlobalPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L777-L785","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L777"}],"snippet":"async function roslynLanguageServerGlobalPath() {\n  const bin = path.join(\n    process.env.DOTNET_CLI_HOME ?? os.homedir(),\n    \".dotnet\",\n    \"tools\",\n    \"roslyn-language-server\" + (process.platform === \"win32\" ? \".cmd\" : \"\"),\n  )\n  return (await pathExists(bin)) ? bin : undefined\n}"},{"id":"packages_rimuru_src_lsp_server_findvscoderazorextension","label":"findVscodeRazorExtension()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L787-L821","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L787"}],"snippet":"async function findVscodeRazorExtension() {\n  const roots = [\n    process.env.VSCODE_EXTENSIONS,\n    path.join(os.homedir(), \".vscode\", \"extensions\"),\n    path.join(os.homedir(), \".vscode-insiders\", \"extensions\"),\n    path.join(os.homedir(), \".vscode-server\", \"extensions\"),\n    path.join(os.homedir(), \".vscode-server-insiders\", \"extensions\"),\n  ].filter((item) => item !== undefined)\n\n  for (const root of [...new Set(roots)]) {\n    const entries = await fs.readdir(root, { withFileTypes: true }).catch(() => [])\n    const candidates = await Promise.all(\n      entries\n        .filter((entry) => entry.isDirectory() && entry.name.startsWith(\"ms-dotnettools.csharp-\"))\n        .map(async (entry) => ({\n          path: path.join(root, entry.name, \".razorExtension\"),\n          modified: (await fs.stat(path.join(root, entry.name)).catch(() => undefined))?.mtimeMs ?? 0,\n        })),\n    )\n    for (const entry of candidates.sort((a, b) => b.modified - a.modified).map((candidate) => candidate.path)) {\n      const result = {\n        compiler: path.join(entry, \"Microsoft.CodeAnalysis.Razor.Compiler.dll\"),\n        targets: path.join(entry, \"Targets\", \"Microsoft.NET.Sdk.Razor.DesignTime.targets\"),\n        extension: path.join(entry, \"Microsoft.VisualStudioCode.RazorExtension.dll\"),\n      }"},{"id":"packages_rimuru_src_lsp_server_ismoduleof","label":"isModuleOf()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L1133-L1145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L1133"}],"snippet":"function isModuleOf(pomContent: string, modulePath: string): boolean {\n  const normalized = modulePath.replace(/\\\\/g, \"/\").replace(/\\/$/, \"\")\n  if (!normalized) return false\n  const modulesBlocks = pomContent.match(/<modules>([\\s\\S]*?)<\\/modules>/g) ?? []\n  for (const block of modulesBlocks) {\n    const stripped = block.replace(/<!--[\\s\\S]*?-->/g, \"\")\n    for (const m of stripped.matchAll(/<module>\\s*([^<]+?)\\s*<\\/module>/g)) {\n      const decl = m[1].replace(/\\\\/g, \"/\").replace(/^\\.\\//, \"\").replace(/\\/$/, \"\")\n      if (decl === normalized) return true\n    }\n  }\n  return false\n}"}],"edges":[{"source":"packages_rimuru_src_lsp_server","target":"child_process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_lsp_server","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/server.ts","source_location":"L