{"__madarTsExtractorVersion":67,"__madarFileStem":"aisdk","nodes":[{"id":"aisdk","label":"aisdk.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/aisdk.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/aisdk.ts","source_location":"L1"}]},{"id":"aisdk_wrapsse","label":"wrapSSE()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/aisdk.ts","source_location":"L12-L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/aisdk.ts","source_location":"L12"}],"snippet":"function wrapSSE(res: Response, ms: number, ctl: AbortController) {\n  if (typeof ms !== \"number\" || ms <= 0) return res\n  if (!res.body) return res\n  if (!res.headers.get(\"content-type\")?.includes(\"text/event-stream\")) return res\n\n  const reader = res.body.getReader()\n  const body = new ReadableStream<Uint8Array>({\n    async pull(ctrl) {\n      const part = await new Promise<Awaited<ReturnType<typeof reader.read>>>((resolve, reject) => {\n        const id = setTimeout(() => {\n          const err = new Error(\"SSE read timed out\")\n          ctl.abort(err)\n          void reader.cancel(err)\n          reject(err)\n        }, ms)\n\n        reader.read().then(\n          (part) => {\n            clearTimeout(id)\n            resolve(part)\n          },\n          (err) => {\n            clearTimeout(id)\n            reject(err)\n          },"},{"id":"aisdk_prepareoptions","label":"prepareOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/aisdk.ts","source_location":"L60-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/aisdk.ts","source_location":"L60"}],"snippet":"function prepareOptions(model: ModelV2.Info, pkg: string) {\n  const options: Record<string, any> = {\n    name: model.providerID,\n    ...(model.api.type === \"aisdk\" ? (model.api.settings ?? {}) : {}),\n    ...model.request.body,\n  }\n  if (model.api.type === \"aisdk\" && model.api.url) options.baseURL = model.api.url\n\n  const customFetch = options.fetch\n  const chunkTimeout = options.chunkTimeout\n  delete options.chunkTimeout\n  options.fetch = async (input: Parameters<typeof fetch>[0], init?: RequestInit) => {\n    const opts = { ...(init ?? {}) }\n    const signals = [\n      opts.signal,\n      typeof chunkTimeout === \"number\" && chunkTimeout > 0 ? new AbortController() : undefined,\n      options.timeout !== undefined && options.timeout !== null && options.timeout !== false\n        ? AbortSignal.timeout(options.timeout)\n        : undefined,\n    ].filter((item): item is AbortSignal | AbortController => Boolean(item))\n    const chunkAbortCtl = signals.find((item): item is AbortController => item instanceof AbortController)\n    const abortSignals = signals.map((item) => (item instanceof AbortController ? item.signal : item))\n    if (abortSignals.length === 1) opts.signal = abortSignals[0]\n    if (abortSignals.length > 1) opts.signal = AbortSignal.any(abortSignals)"},{"id":"aisdk_initerror","label":"InitError","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/aisdk.ts","source_location":"L110-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/aisdk.ts","source_location":"L110"}],"snippet":"export class InitError extends Schema.TaggedErrorClass<InitError>()(\"AISDK.InitError\", {\n  providerID: ProviderV2.ID,\n  cause: Schema.Defect,\n}) {}"},{"id":"aisdk_taggederrorclass","label":"Tagg