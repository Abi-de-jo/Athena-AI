{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_config_config","nodes":[{"id":"packages_rimuru_src_config_config","label":"config.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_config_config_mergeconfig","label":"mergeConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L41-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L41"}],"snippet":"function mergeConfig(target: Info, source: Info): Info {\n  return mergeDeep(target, source) as Info\n}"},{"id":"packages_rimuru_src_config_config_mergeconfigconcatarrays","label":"mergeConfigConcatArrays()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L45-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L45"}],"snippet":"function mergeConfigConcatArrays(target: Info, source: Info): Info {\n  const merged = mergeConfig(target, source)\n  if (target.instructions && source.instructions) {\n    merged.instructions = Array.from(new Set([...target.instructions, ...source.instructions]))\n  }\n  return merged\n}"},{"id":"packages_rimuru_src_config_config_normalizeloadedconfig","label":"normalizeLoadedConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L53-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L53"}],"snippet":"function normalizeLoadedConfig(data: unknown) {\n  if (!isRecord(data)) return data\n  const copy = { ...data }\n  const hadLegacy = \"theme\" in copy || \"keybinds\" in copy || \"tui\" in copy\n  if (!hadLegacy) return copy\n  delete copy.theme\n  delete copy.keybinds\n  delete copy.tui\n  return copy\n}"},{"id":"packages_rimuru_src_config_config_substitutewellknownremoteconfig","label":"substituteWellKnownRemoteConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L64-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L64"}],"snippet":"async function substituteWellKnownRemoteConfig(input: {\n  value: unknown\n  dir: string\n  source: string\n  env: Record<string, string>\n}) {\n  if (!isRecord(input.value) || typeof input.value.url !== \"string\") return undefined\n\n  const url = await ConfigVariable.substitute({\n    text: input.value.url,\n    type: \"virtual\",\n    dir: input.dir,\n    source: input.source,\n    env: input.env,\n  })\n  const headers = isRecord(input.value.headers)\n    ? Object.fromEntries(\n        await Promise.all(\n          Object.entries(input.value.headers)\n            .filter((entry): entry is [string, string] => typeof entry[1] === \"string\")\n            .map(async ([key, value]) => [\n              key,\n              await ConfigVariable.substitute({\n                text: value,\n                type: \"virtual\","},{"id":"packages_rimuru_src_config_config_resolveloadedplugins","label":"resolveLoadedPlugins()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L101-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L101"}],"snippet":"async function resolveLoadedPlugins<T extends { plugin?: ConfigPluginV1.Spec[] }>(config: T, filepath: string) {\n  if (!config.plugin) return config\n  for (let i = 0; i < config.plugin.length; i++) {\n    // Normalize path-like plugin specs while we still know which config file declared them.\n    // This prevents `./plugin.ts` from being reinterpreted relative to some later merge location.\n    config.plugin[i] = await ConfigPlugin.resolvePluginSpec(config.plugin[i], filepath)\n  }\n  return config\n}"},{"id":"packages_rimuru_src_config_config_interface","label":"Interface","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L124-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L124"}],"snippet":"export interface Interface {\n  readonly get: () => Effect.Effect<Info>\n  readonly getGlobal: () => Effect.Effect<Info>\n  readonly getConsoleState: () => Effect.Effect<ConsoleState>\n  readonly update: (config: Info) => Effect.Effect<void>\n  readonly updateGlobal: (config: Info) => Effect.Effect<{ info: Info; changed: boolean }>\n  readonly invalidate: () => Effect.Effect<void>\n  readonly directories: () => Effect.Effect<string[]>\n  readonly waitForDependencies: () => Effect.Effect<void>\n}"},{"id":"packages_rimuru_src_config_config_service","label":"Service","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L135","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L135"}],"snippet":"export class Service extends Context.Service<Service, Interface>()(\"@rimuru/Config\") {}"},{"id":"packages_rimuru_src_config_config_globalconfigfile","label":"globalConfigFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L139-L147","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L139"}],"snippet":"function globalConfigFile() {\n  const candidates = [\"rimuru.jsonc\", \"rimuru.json\", \"config.json\"].map((file) =>\n    path.join(Global.Path.config, file),\n  )\n  for (const file of candidates) {\n    if (existsSync(file)) return file\n  }\n  return candidates[0]\n}"},{"id":"packages_rimuru_src_config_config_patchjsonc","label":"patchJsonc()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L149-L161","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L149"}],"snippet":"function patchJsonc(input: string, patch: unknown, path: string[] = []): string {\n  if (!isRecord(patch)) {\n    const edits = modify(input, path, patch, {\n      formattingOptions: {\n        insertSpaces: true,\n        tabSize: 2,\n      },\n    })\n    return applyEdits(input, edits)\n  }\n\n  return Object.entries(patch).reduce((result, [key, value]) => patchJsonc(result, value, [...path, key]), input)\n}"},{"id":"packages_rimuru_src_config_config_writable","label":"writable()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L163-L166","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L163"}],"snippet":"function writable(info: Info) {\n  const { plugin_origins: _plugin_origins, ...next } = info\n  return next\n}"},{"id":"packages_rimuru_src_config_config_writableglobal","label":"writableGlobal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L168-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L168"}],"snippet":"function writableGlobal(info: Info) {\n  const next = writable(info)\n  // When a user changes config from a value back to default in the Desktop app, we don't want to leave a blank `\"shell\": \"\",` key\n  if (\"shell\" in next && next.shell === \"\") return { ...next, shell: undefined }\n  return next\n}"}],"edges":[{"source":"packages_rimuru_src_config_config","target":"layer_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_config_config","target":"layer_node_platform","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/config.ts","