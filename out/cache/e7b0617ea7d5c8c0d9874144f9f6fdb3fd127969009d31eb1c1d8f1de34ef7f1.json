{"__madarTsExtractorVersion":67,"__madarFileStem":"model-tooltip","nodes":[{"id":"model_tooltip","label":"model-tooltip.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L1"}]},{"id":"model_tooltip_modeltooltip","label":"ModelTooltip()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L26-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L26"}],"snippet":"ModelTooltip: Component<{ model: ModelInfo; latest?: boolean; free?: boolean }> = (props) => {\n  const language = useLanguage()\n  const sourceName = (model: ModelInfo) => {\n    const value = `${model.id} ${model.name}`.toLowerCase()\n\n    if (/claude|anthropic/.test(value)) return language.t(\"model.provider.anthropic\")\n    if (/gpt|o[1-4]|codex|openai/.test(value)) return language.t(\"model.provider.openai\")\n    if (/gemini|palm|bard|google/.test(value)) return language.t(\"model.provider.google\")\n    if (/grok|xai/.test(value)) return language.t(\"model.provider.xai\")\n    if (/llama|meta/.test(value)) return language.t(\"model.provider.meta\")\n\n    return model.provider.name\n  }\n  const inputLabel = (value: string) => {\n    if (value === \"text\") return language.t(\"model.input.text\")\n    if (value === \"image\") return language.t(\"model.input.image\")\n    if (value === \"audio\") return language.t(\"model.input.audio\")\n    if (value === \"video\") return language.t(\"model.input.video\")\n    if (value === \"pdf\") return language.t(\"model.input.pdf\")\n    return value\n  }\n  const title = () => {\n    const tags: Array<string> = []\n    if (props.latest) tags.push(language.t(\"model.tag.latest\"))\n    if (props.free) tags.push(language.t(\"model.tag.free\"))","node_kind":"component"},{"id":"model_tooltip_modeltooltip_sourcename","label":"sourceName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L28-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L28"}],"snippet":"sourceName = (model: ModelInfo) => {\n    const value = `${model.id} ${model.name}`.toLowerCase()\n\n    if (/claude|anthropic/.test(value)) return language.t(\"model.provider.anthropic\")\n    if (/gpt|o[1-4]|codex|openai/.test(value)) return language.t(\"model.provider.openai\")\n    if (/gemini|palm|bard|google/.test(value)) return language.t(\"model.provider.google\")\n    if (/grok|xai/.test(value)) return language.t(\"model.provider.xai\")\n    if (/llama|meta/.test(value)) return language.t(\"model.provider.meta\")\n\n    return model.provider.name\n  }"},{"id":"model_tooltip_modeltooltip_inputlabel","label":"inputLabel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L39-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L39"}],"snippet":"inputLabel = (value: string) => {\n    if (value === \"text\") return language.t(\"model.input.text\")\n    if (value === \"image\") return language.t(\"model.input.image\")\n    if (value === \"audio\") return language.t(\"model.input.audio\")\n    if (value === \"video\") return language.t(\"model.input.video\")\n    if (value === \"pdf\") return language.t(\"model.input.pdf\")\n    return value\n  }"},{"id":"model_tooltip_modeltooltip_title","label":"title()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L47-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L47"}],"snippet":"title = () => {\n    const tags: Array<string> = []\n    if (props.latest) tags.push(language.t(\"model.tag.latest\"))\n    if (props.free) tags.push(language.t(\"model.tag.free\"))\n    const suffix = tags.length ? ` (${tags.join(\", \")})` : \"\"\n    return `${sourceName(props.model)} ${props.model.name}${suffix}`\n  }"},{"id":"model_tooltip_modeltooltip_inputs","label":"inputs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L54-L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L54"}],"snippet":"inputs = () => {\n    if (props.model.capabilities) {\n      const input = props.model.capabilities.input\n      const order: Array<InputKey> = [\"text\", \"image\", \"audio\", \"video\", \"pdf\"]\n      const entries = order.filter((key) => input[key]).map((key) => inputLabel(key))\n      return entries.length ? entries.join(\", \") : undefined\n    }\n    const raw = props.model.modalities?.input\n    if (!raw) return\n    const entries = raw.map((value) => inputLabel(value))\n    return entries.length ? entries.join(\", \") : undefined\n  }"},{"id":"model_tooltip_modeltooltip_reasoning","label":"reasoning()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L66-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L66"}],"snippet":"reasoning = () => {\n    if (props.model.capabilities)\n      return props.model.capabilities.reasoning\n        ? language.t(\"model.tooltip.reasoning.allowed\")\n        : language.t(\"model.tooltip.reasoning.none\")\n    return props.model.reasoning\n      ? language.t(\"model.tooltip.reasoning.allowed\")\n      : language.t(\"model.tooltip.reasoning.none\")\n  }"},{"id":"model_tooltip_modeltooltip_context","label":"context()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L75"}],"snippet":"context = () => language.t(\"model.tooltip.context\", { limit: props.model.limit.context.toLocaleString() })"}],"edges":[{"source":"model_tooltip","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","source_location":"L1"}],"weight":1},{"source":"model_tooltip","target":"language","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/model-tooltip.tsx","sour