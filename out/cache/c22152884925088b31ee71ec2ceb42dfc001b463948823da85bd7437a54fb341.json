{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_core_test_permission.test","nodes":[{"id":"packages_core_test_permission_test","label":"permission.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L1"}]},{"id":"packages_core_test_permission_test_setup","label":"setup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L47-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L47"}],"snippet":"function setup(rules: PermissionV2.Ruleset = []) {\n  return Effect.gen(function* () {\n    const { db } = yield* Database.Service\n    yield* db\n      .insert(ProjectTable)\n      .values({ id: Project.ID.global, worktree: AbsolutePath.make(\"/project\"), sandboxes: [] })\n      .onConflictDoNothing()\n      .run()\n      .pipe(Effect.orDie)\n    yield* db\n      .insert(SessionTable)\n      .values({\n        id: SessionV2.ID.make(\"ses_test\"),\n        project_id: Project.ID.global,\n        slug: \"test\",\n        directory: \"/project\",\n        title: \"test\",\n        version: \"test\",\n        agent: \"test\",\n      })\n      .onConflictDoNothing()\n      .run()\n      .pipe(Effect.orDie)\n    yield* setRules(rules)\n  })"},{"id":"packages_core_test_permission_test_setrules","label":"setRules()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L74-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L74"}],"snippet":"function setRules(rules: PermissionV2.Ruleset) {\n  return Effect.gen(function* () {\n    const agents = yield* AgentV2.Service\n    const update = yield* agents.transform()\n    yield* update((editor) =>\n      editor.update(AgentV2.ID.make(\"test\"), (agent) => {\n        agent.permissions = [...rules]\n      }),\n    )\n  })\n}"},{"id":"packages_core_test_permission_test_assertion","label":"assertion()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L86-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L86"}],"snippet":"function assertion(input: Partial<PermissionV2.AssertInput> = {}) {\n  return {\n    id: PermissionV2.ID.create(\"per_test\"),\n    sessionID: SessionV2.ID.make(\"ses_test\"),\n    action: \"read\",\n    resources: [\"src/index.ts\"],\n    ...input,\n  } satisfies PermissionV2.AssertInput\n}"},{"id":"packages_core_test_permission_test_waitforrequest","label":"waitForRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L96-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L96"}],"snippet":"function waitForRequest() {\n  return Effect.gen(function* () {\n    const service = yield* PermissionV2.Service\n    const events = yield* EventV2.Service\n    const asked = yield* Deferred.make<PermissionV2.Request>()\n    const unsubscribe = yield* events.listen((event) =>\n      event.type === PermissionV2.Event.Asked.type\n        ? Deferred.succeed(asked, event.data as PermissionV2.Request).pipe(Effect.asVoid)\n        : Effect.void,\n    )\n    yield* Effect.addFinalizer(() => unsubscribe)\n    const fiber = yield* service.assert(assertion()).pipe(Effect.forkScoped)\n    const request = yield* Deferred.await(asked)\n    return { service, fiber, request }\n  })\n}"}],"edges":[{"source":"packages_core_test_permission_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_test_permission_test","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L2"}],"weight":1},{"source":"packages_core_test_permission_test","target":"agent","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location":"L3"}],"weight":1},{"source":"packages_core_test_permission_test","target":"database","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/permission.test.ts","source_location"