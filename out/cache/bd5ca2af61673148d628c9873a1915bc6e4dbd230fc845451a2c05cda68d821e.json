{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_session_compaction","nodes":[{"id":"packages_rimuru_src_session_compaction","label":"compaction.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_session_compaction_summarytext","label":"summaryText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L62-L70","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L62"}],"snippet":"function summaryText(message: SessionV1.WithParts) {\n  const text = message.parts\n    .filter((part): part is SessionV1.TextPart => part.type === \"text\")\n    .map((part) => part.text.trim())\n    .filter(Boolean)\n    .join(\"\\n\\n\")\n    .trim()\n  return text || undefined\n}"},{"id":"packages_rimuru_src_session_compaction_completedcompactions","label":"completedCompactions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L72-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L72"}],"snippet":"function completedCompactions(messages: SessionV1.WithParts[]) {\n  const users = new Map<MessageID, number>()\n  for (let i = 0; i < messages.length; i++) {\n    const msg = messages[i]\n    if (msg.info.role !== \"user\") continue\n    if (!msg.parts.some((part) => part.type === \"compaction\")) continue\n    users.set(msg.info.id, i)\n  }\n\n  return messages.flatMap((msg, assistantIndex): CompletedCompaction[] => {\n    if (msg.info.role !== \"assistant\") return []\n    if (!msg.info.summary || !msg.info.finish || msg.info.error) return []\n    const userIndex = users.get(msg.info.parentID)\n    if (userIndex === undefined) return []\n    return [{ userIndex, assistantIndex, summary: summaryText(msg) }]\n  })\n}"},{"id":"packages_rimuru_src_session_compaction_preserverecentbudget","label":"preserveRecentBudget()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L90-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L90"}],"snippet":"function preserveRecentBudget(input: { cfg: ConfigV1.Info; model: Provider.Model }) {\n  return (\n    input.cfg.compaction?.preserve_recent_tokens ??\n    Math.min(MAX_PRESERVE_RECENT_TOKENS, Math.max(MIN_PRESERVE_RECENT_TOKENS, Math.floor(usable(input) * 0.25)))\n  )\n}"},{"id":"packages_rimuru_src_session_compaction_turns","label":"turns()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L97-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L97"}],"snippet":"function turns(messages: SessionV1.WithParts[]) {\n  const result: Turn[] = []\n  for (let i = 0; i < messages.length; i++) {\n    const msg = messages[i]\n    if (msg.info.role !== \"user\") continue\n    if (msg.parts.some((part) => part.type === \"compaction\")) continue\n    result.push({\n      start: i,\n      end: messages.length,\n      id: msg.info.id,\n    })\n  }\n  for (let i = 0; i < result.length - 1; i++) {\n    result[i].end = result[i + 1].start\n  }\n  return result\n}"},{"id":"packages_rimuru_src_session_compaction_splitturn","label":"splitTurn()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L115-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L115"}],"snippet":"function splitTurn(input: {\n  messages: SessionV1.WithParts[]\n  turn: Turn\n  model: Provider.Model\n  budget: number\n  estimate: (input: { messages: SessionV1.WithParts[]; model: Provider.Model }) => Effect.Effect<number>\n}) {\n  return Effect.gen(function* () {\n    if (input.budget <= 0) return undefined\n    if (input.turn.end - input.turn.start <= 1) return undefined\n    for (let start = input.turn.start + 1; start < input.turn.end; start++) {\n      const size = yield* input.estimate({\n        messages: input.messages.slice(start, input.turn.end),\n        model: input.model,\n      })\n      if (size > input.budget) continue\n      return {\n        start,\n        id: input.messages[start]!.info.id,\n      } satisfies Tail\n    }\n    return undefined\n  })\n}"},{"id":"packages_rimuru_src_session_compaction_interface","label":"Interface","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L140-L160","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L140"}],"snippet":"export interface Interface {\n  readonly isOverflow: (input: {\n    tokens: SessionV1.Assistant[\"tokens\"]\n    model: Provider.Model\n  }) => Effect.Effect<boolean>\n  readonly prune: (input: { sessionID: SessionID }) => Effect.Effect<void>\n  readonly process: (input: {\n    parentID: MessageID\n    messages: SessionV1.WithParts[]\n    sessionID: SessionID\n    auto: boolean\n    overflow?: boolean\n  }) => Effect.Effect<\"continue\" | \"stop\">\n  readonly create: (input: {\n    sessionID: SessionID\n    agent: string\n    model: { providerID: ProviderV2.ID; modelID: ModelV2.ID }\n    auto: boolean\n    overflow?: boolean\n  }) => Effect.Effect<void>\n}"},{"id":"packages_rimuru_src_session_compaction_service","label":"Service","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L162","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L162"}],"snippet":"export class Service extends Context.Service<Service, Interface>()(\"@rimuru/SessionCompaction\") {}"}],"edges":[{"source":"packages_rimuru_src_session_compaction","target":"layer_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_session_compaction","target":"session","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/session/compaction.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimur