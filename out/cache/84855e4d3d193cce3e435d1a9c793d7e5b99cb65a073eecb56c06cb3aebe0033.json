{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_function_src_api","nodes":[{"id":"packages_function_src_api","label":"api.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/function/src/api.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/function/src/api.ts","source_location":"L1"}]},{"id":"packages_function_src_api_syncserver","label":"SyncServer","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/function/src/api.ts","source_location":"L15-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/function/src/api.ts","source_location":"L15"}],"snippet":"export class SyncServer extends DurableObject<Env> {\n  // oxlint-disable-next-line no-useless-constructor\n  constructor(ctx: DurableObjectState, env: Env) {\n    super(ctx, env)\n  }\n  async fetch() {\n    console.log(\"SyncServer subscribe\")\n\n    const webSocketPair = new WebSocketPair()\n    const [client, server] = Object.values(webSocketPair)\n\n    this.ctx.acceptWebSocket(server)\n\n    const data = await this.ctx.storage.list()\n    Array.from(data.entries())\n      .filter(([key, _]) => key.startsWith(\"session/\"))\n      .map(([key, content]) => server.send(JSON.stringify({ key, content })))\n\n    return new Response(null, {\n      status: 101,\n      webSocket: client,\n    })\n  }\n\n  async webSocketMessage(_ws, _message) {}"},{"id":"packages_function_src_api_durableobject","label":"DurableObject","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/function/src/api.ts","source_location":"L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimu