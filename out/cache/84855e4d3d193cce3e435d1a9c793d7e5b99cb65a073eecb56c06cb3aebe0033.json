{}"},{"id":"packages_function_src_api_syncserver_websocketclose","label":".webSocketClose()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/function/src/api.ts","source_location":"L41-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/function/src/api.ts","source_location":"L41"}],"snippet":"async webSocketClose(ws, code, _reason, _wasClean) {\n    ws.close(code, \"Durable Object is closing WebSocket\")\n  }"},{"id":"packages_function_src_api_syncserver_publish","label":".publish()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/function/src/api.ts","source_location":"L45-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/function/src/api.ts","source_location":"L45"}],"snippet":"async publish(key: string, content: any) {\n    const sessionID = await this.getSessionID()\n    if (\n      !key.startsWith(`session/info/${sessionID}`) &&\n      !key.startsWith(`session/message/${sessionID}/`) &&\n      !key.startsWith(`session/part/${sessionID}/`)\n    )\n      return new Response(\"Error: Invalid key\", { status: 400 })\n\n    // store message\n    await this.env.Bucket.put(`share/${key}.json`, JSON.stringify(content), {\n      httpMetadata: {\n        contentType: \"application/json\",\n      },\n    })\n    await this.ctx.storage.put(key, content)\n    const clients = this.ctx.getWebSockets()\n    console.log(\"SyncServer publish\", key, \"to\", clients.length, \"subscribers\")\n    for (const client of clients) {\n      client.send(JSON.stringify({ key, content }))\n    }\n  }"},{"id":"packages_function_src_api_syncserver_share","label":".share()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/function/src/api.ts","source_locati