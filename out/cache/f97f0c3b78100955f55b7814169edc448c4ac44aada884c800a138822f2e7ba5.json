{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_ui_src_pierre_media","nodes":[{"id":"packages_ui_src_pierre_media","label":"media.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L1"}]},{"id":"packages_ui_src_pierre_media_mediarecord","label":"mediaRecord()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L10-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L10"}],"snippet":"function mediaRecord(value: unknown) {\n  if (!value || typeof value !== \"object\") return\n  return value as Partial<FileContent> & {\n    content?: unknown\n    encoding?: unknown\n    mimeType?: unknown\n    type?: unknown\n  }\n}"},{"id":"packages_ui_src_pierre_media_normalizemimetype","label":"normalizeMimeType()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L20-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L20"}],"snippet":"export function normalizeMimeType(type: string | undefined) {\n  if (!type) return\n  const mime = type.split(\";\", 1)[0]?.trim().toLowerCase()\n  if (!mime) return\n  if (mime === \"audio/x-aac\") return \"audio/aac\"\n  if (mime === \"audio/x-m4a\") return \"audio/mp4\"\n  return mime\n}"},{"id":"packages_ui_src_pierre_media_fileextension","label":"fileExtension()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L29-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L29"}],"snippet":"export function fileExtension(path: string | undefined) {\n  if (!path) return \"\"\n  const idx = path.lastIndexOf(\".\")\n  if (idx === -1) return \"\"\n  return path.slice(idx + 1).toLowerCase()\n}"},{"id":"packages_ui_src_pierre_media_mediakindfrompath","label":"mediaKindFromPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L36-L41","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L36"}],"snippet":"export function mediaKindFromPath(path: string | undefined): MediaKind | undefined {\n  const ext = fileExtension(path)\n  if (ext === \"svg\") return \"svg\"\n  if (imageExtensions.has(ext)) return \"image\"\n  if (audioExtensions.has(ext)) return \"audio\"\n}"},{"id":"packages_ui_src_pierre_media_isbinarycontent","label":"isBinaryContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L43-L45","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L43"}],"snippet":"export function isBinaryContent(value: MediaValue) {\n  return mediaRecord(value)?.type === \"binary\"\n}"},{"id":"packages_ui_src_pierre_media_validdataurl","label":"validDataUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L47-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L47"}],"snippet":"function validDataUrl(value: string, kind: MediaKind) {\n  if (kind === \"svg\") return value.startsWith(\"data:image/svg+xml\") ? value : undefined\n  if (kind === \"image\") return value.startsWith(\"data:image/\") ? value : undefined\n  if (value.startsWith(\"data:audio/x-aac;\")) return value.replace(\"data:audio/x-aac;\", \"data:audio/aac;\")\n  if (value.startsWith(\"data:audio/x-m4a;\")) return value.replace(\"data:audio/x-m4a;\", \"data:audio/mp4;\")\n  if (value.startsWith(\"data:audio/\")) return value\n}"},{"id":"packages_ui_src_pierre_media_dataurlfrommediavalue","label":"dataUrlFromMediaValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L55-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L55"}],"snippet":"export function dataUrlFromMediaValue(value: MediaValue, kind: MediaKind) {\n  if (!value) return\n\n  if (typeof value === \"string\") {\n    return validDataUrl(value, kind)\n  }\n\n  const record = mediaRecord(value)\n  if (!record) return\n\n  if (typeof record.content !== \"string\") return\n\n  const mime = normalizeMimeType(typeof record.mimeType === \"string\" ? record.mimeType : undefined)\n  if (!mime) return\n\n  if (kind === \"svg\") {\n    if (mime !== \"image/svg+xml\") return\n    if (record.encoding === \"base64\") return `data:image/svg+xml;base64,${record.content}`\n    return `data:image/svg+xml;charset=utf-8,${encodeURIComponent(record.content)}`\n  }\n\n  if (kind === \"image\" && !mime.startsWith(\"image/\")) return\n  if (kind === \"audio\" && !mime.startsWith(\"audio/\")) return\n  if (record.encoding !== \"base64\") return"},{"id":"packages_ui_src_pierre_media_decodebase64utf8","label":"decodeBase64Utf8()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L83-L92","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L83"}],"snippet":"function decodeBase64Utf8(value: string) {\n  if (typeof atob !== \"function\") return\n\n  try {\n    const raw = atob(value)\n    const bytes = Uint8Array.from(raw, (x) => x.charCodeAt(0))\n    if (typeof TextDecoder === \"function\") return new TextDecoder().decode(bytes)\n    return raw\n  } catch {}\n}"},{"id":"packages_ui_src_pierre_media_svgtextfromvalue","label":"svgTextFromValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L94-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L94"}],"snippet":"export function svgTextFromValue(value: MediaValue) {\n  const record = mediaRecord(value)\n  if (!record) return\n  if (typeof record.content !== \"string\") return\n\n  const mime = normalizeMimeType(typeof record.mimeType === \"string\" ? record.mimeType : undefined)\n  if (mime !== \"image/svg+xml\") return\n  if (record.encoding === \"base64\") return decodeBase64Utf8(record.content)\n  return record.content\n}"},{"id":"packages_ui_src_pierre_media_hasmediavalue","label":"hasMediaValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L105-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L105"}],"snippet":"export function hasMediaValue(value: MediaValue) {\n  if (typeof value === \"string\") return value.length > 0\n  const record = mediaRecord(value)\n  if (!record) return false\n  return typeof record.content === \"string\" && record.content.length > 0\n}"}],"edges":[{"source":"packages_ui_src_pierre_media","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L1"}],"weight":1},{"source":"packages_ui_src_pierre_media","target":"packages_ui_src_pierre_media_mediarecord","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L10","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L10"}],"weight":1},{"source":"packages_ui_src_pierre_media","target":"packages_ui_src_pierre_media_normalizemimetype","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/media.ts","source_location":"L20"}],"weight":1},{"source":"packages_ui_src_pierre_media","target":"packages_ui_src_pierre_media_fileextension","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/