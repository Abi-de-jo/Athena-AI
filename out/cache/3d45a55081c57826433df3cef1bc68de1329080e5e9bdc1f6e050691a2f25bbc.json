{"__madarTsExtractorVersion":67,"__madarFileStem":"variant.shared","nodes":[{"id":"variant_shared","label":"variant.shared.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L1"}]},{"id":"variant_shared_service","label":"Service","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L32"}],"snippet":"class Service extends Context.Service<Service, VariantService>()(\"@rimuru/RunVariant\") {}"},{"id":"variant_shared_modelkey","label":"modelKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L34-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L34"}],"snippet":"function modelKey(provider: string, model: string): string {\n  return `${provider}/${model}`\n}"},{"id":"variant_shared_variantkey","label":"variantKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L38-L40","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L38"}],"snippet":"function variantKey(model: NonNullable<RunInput[\"model\"]>): string {\n  return modelKey(model.providerID, model.modelID)\n}"},{"id":"variant_shared_modelinfo","label":"modelInfo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L42-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L42"}],"snippet":"export function modelInfo(providers: RunProvider[] | undefined, model: NonNullable<RunInput[\"model\"]>) {\n  const provider = providers?.find((item) => item.id === model.providerID)\n  return {\n    provider: provider?.name ?? model.providerID,\n    model: provider?.models[model.modelID]?.name ?? model.modelID,\n  }\n}"},{"id":"variant_shared_formatmodellabel","label":"formatModelLabel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L50-L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L50"}],"snippet":"export function formatModelLabel(\n  model: NonNullable<RunInput[\"model\"]>,\n  variant: string | undefined,\n  providers?: RunProvider[],\n): string {\n  const names = modelInfo(providers, model)\n  const label = variant ? ` · ${variant}` : \"\"\n  return `${names.model} · ${names.provider}${label}`\n}"},{"id":"variant_shared_cyclevariant","label":"cycleVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L60-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L60"}],"snippet":"export function cycleVariant(current: string | undefined, variants: string[]): string | undefined {\n  if (variants.length === 0) {\n    return undefined\n  }\n\n  if (!current) {\n    return variants[0]\n  }\n\n  const idx = variants.indexOf(current)\n  if (idx === -1 || idx === variants.length - 1) {\n    return undefined\n  }\n\n  return variants[idx + 1]\n}"},{"id":"variant_shared_pickvariant","label":"pickVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L77-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L77"}],"snippet":"export function pickVariant(model: RunInput[\"model\"], input: RunSession | SessionMessages): string | undefined {\n  return sessionVariant(Array.isArray(input) ? createSession(input) : input, model)\n}"},{"id":"variant_shared_fitvariant","label":"fitVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L81-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L81"}],"snippet":"function fitVariant(value: string | undefined, variants: string[]): string | undefined {\n  if (!value) {\n    return undefined\n  }\n\n  if (variants.length === 0 || variants.includes(value)) {\n    return value\n  }\n\n  return undefined\n}"},{"id":"variant_shared_resolvevariant","label":"resolveVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L96-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L96"}],"snippet":"export function resolveVariant(\n  input: string | undefined,\n  session: string | undefined,\n  saved: string | undefined,\n  variants: string[],\n): string | undefined {\n  if (input !== undefined) {\n    return input\n  }\n\n  const fallback = fitVariant(saved, variants)\n  const current = fitVariant(session, variants)\n  if (current !== undefined) {\n    return current\n  }\n\n  return fallback\n}"},{"id":"variant_shared_state","label":"state()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L115-L136","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L115"}],"snippet":"function state(value: unknown): ModelState {\n  if (!isRecord(value)) {\n    return {}\n  }\n\n  const variant = isRecord(value.variant)\n    ? Object.fromEntries(\n        Object.entries(value.variant).flatMap(([key, item]) => {\n          if (typeof item !== \"string\") {\n            return []\n          }\n\n          return [[key, item] as const]\n        }),\n      )\n    : undefined\n\n  return {\n    ...value,\n    variant,\n  }\n}"},{"id":"variant_shared_createlayer","label":"createLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L138-L196","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L138"}],"snippet":"function createLayer(fs = FSUtil.defaultLayer) {\n  return Layer.fresh(\n    Layer.effect(\n      Service,\n      Effect.gen(function* () {\n        const file = yield* FSUtil.Service\n\n        const read = Effect.fn(\"RunVariant.read\")(function* () {\n          return yield* file.readJson(MODEL_FILE).pipe(\n            Effect.map(state),\n            Effect.catchCause(() => Effect.succeed(state(undefined))),\n          )\n        })\n\n        const resolveSavedVariant = Effect.fn(\"RunVariant.resolveSavedVariant\")(function* (model: RunInput[\"model\"]) {\n          if (!model) {\n            return undefined\n          }\n\n          return (yield* read()).variant?.[variantKey(model)]\n        })\n\n        const saveVariant = Effect.fn(\"RunVariant.saveVariant\")(function* (\n          model: RunInput[\"model\"],\n          variant: string | undefined,"},{"id":"variant_shared_createvariantruntime","label":"createVariantRuntime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L199-L205","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L199"}],"snippet":"export function createVariantRuntime(fs = FSUtil.defaultLayer): VariantRuntime {\n  const runtime = makeRuntime(Service, createLayer(fs))\n  return {\n    resolveSavedVariant: (model) => runtime.runPromise((svc) => svc.resolveSavedVariant(model)).catch(() => undefined),\n    saveVariant: (model, variant) => runtime.runPromise((svc) => svc.saveVariant(model, variant)).catch(() => {}),\n  }\n}"},{"id":"variant_shared_resolvesavedvariant","label":"resolveSavedVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L209-L211","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L209"}],"snippet":"export async function resolveSavedVariant(model: RunInput[\"model\"]): Promise<string | undefined> {\n  return runtime.resolveSavedVariant(model)\n}"},{"id":"variant_shared_savevariant","label":"saveVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L213-L215","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L213"}],"snippet":"export function saveVariant(model: RunInput[\"model\"], variant: string | undefined): void {\n  void runtime.saveVariant(model, variant)\n}"}],"edges":[{"source":"variant_shared","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L9","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L9"}],"weight":1},{"source":"variant_shared","target":"fs_util","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":"L10","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/variant.shared.ts","source_location":