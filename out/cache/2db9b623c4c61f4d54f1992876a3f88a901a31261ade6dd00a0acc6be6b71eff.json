mark[0]?.length ?? 0) + 2\n\n    for (let i = 0; i < mark.length; i += 1) {\n      draw(lines, mark[i] ?? \"\", {\n        left: 0,\n        top: top + i,\n        fg: left,\n        shadow: leftShadow,\n      })\n    }\n\n    push(lines, body_left, top, \"OpenCode\", right, undefined, TextAttributes.BOLD)\n    if (input.detail) {"},{"id":"splash_splashmeta","label":"splashMeta()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L267-L272","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L267"}],"snippet":"export function splashMeta(input: SplashInput): SplashMeta {\n  return {\n    title: title(input.title),\n    session_id: input.session_id,\n  }\n}"},{"id":"splash_entrysplash","label":"entrySplash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L274-L276","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L274"}],"snippet":"export function entrySplash(input: SplashWriterInput): ScrollbackWriter {\n  return (ctx) => build(input, \"entry\", ctx)\n}"},{"id":"splash_exitsplash","label":"exitSplash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L278-L280","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L278"}],"snippet":"export function exitSplash(input: SplashWriterInput): ScrollbackWriter {\n  retur