{"__madarTsExtractorVersion":67,"__madarFileStem":"splash","nodes":[{"id":"splash","label":"splash.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L1"}]},{"id":"splash_cells","label":"cells()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L48-L70","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L48"}],"snippet":"function cells(line: string): Cell[] {\n  const list: Cell[] = []\n  for (const char of line) {\n    if (char === \"_\") {\n      list.push({ char: \" \", mark: \"full\" })\n      continue\n    }\n\n    if (char === \"^\") {\n      list.push({ char: \"▀\", mark: \"mix\" })\n      continue\n    }\n\n    if (char === \"~\") {\n      list.push({ char: \"▀\", mark: \"top\" })\n      continue\n    }\n\n    list.push({ char, mark: \"text\" })\n  }\n\n  return list\n}"},{"id":"splash_title","label":"title()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L72-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L72"}],"snippet":"function title(text: string | undefined): string {\n  if (!text) {\n    return SPLASH_TITLE_FALLBACK\n  }\n\n  let value = \"\"\n  let gap = false\n  for (const char of text.trim()) {\n    if (char === \" \" || char === \"\\n\" || char === \"\\r\" || char === \"\\t\") {\n      gap = true\n      continue\n    }\n\n    if (gap && value.length > 0) {\n      value += \" \"\n    }\n\n    value += char\n    gap = false\n  }\n\n  if (!value) {\n    return SPLASH_TITLE_FALLBACK\n  }"},{"id":"splash_write","label":"write()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L100-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L100"}],"snippet":"function write(\n  root: BoxRenderable,\n  ctx: ScrollbackRenderContext,\n  line: {\n    left: number\n    top: number\n    text: string\n    fg: ColorInput\n    bg?: ColorInput\n    attrs?: number\n  },\n): void {\n  if (line.left >= ctx.width) {\n    return\n  }\n\n  root.add(\n    new TextRenderable(ctx.renderContext, {\n      position: \"absolute\",\n      left: line.left,\n      top: line.top,\n      width: Math.max(1, ctx.width - line.left),\n      height: 1,\n      wrapMode: \"none\",\n      content: line.text,"},{"id":"splash_push","label":"push()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L132-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/splash.ts","source_location":"L132"}],"snippet":"function push(\n  lines: Array<{ left: number; top: number; text: string; fg: ColorInput; bg?: ColorInput; attrs?: number }>,\n  left: number,\n  top: number,\n  text: string,\n  fg: ColorInput,\n  bg?: ColorInput,\n  attrs?: number,\n): void {\n  lines.push({ left, top, text, fg, bg, attrs })\n}"},{"id":"splash_draw","label":"draw()","file_type":"code","sourc