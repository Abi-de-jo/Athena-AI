{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_server_shared_fence","nodes":[{"id":"packages_opencode_src_server_shared_fence","label":"fence.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/shared/fence.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/shared/fence.ts","source_location":"L1"}]},{"id":"packages_opencode_src_server_shared_fence_load","label":"load()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/shared/fence.ts","source_location":"L11-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/shared/fence.ts","source_location":"L11"}],"snippet":"export function load(db: Database.Interface[\"db\"], ids?: string[]) {\n  return Effect.gen(function* () {\n    const rows = yield* (\n      ids?.length\n        ? db.select().from(EventSequenceTable).where(inArray(EventSequenceTable.aggregate_id, ids)).all()\n        : db.select().from(EventSequenceTable).all()\n    ).pipe(Effect.orDie)\n\n    return Object.fromEntries(rows.map((row) => [row.aggregate_id, row.seq]))\n  })\n}"},{"id":"packages_opencode_src_server_shared_fence_diff","label":"diff()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/shared/fence.ts","source_location":"L23-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/shared/fence.ts","source_location":"L23"}],"snippet":"export function diff(prev: State, next: State) {\n  const ids = new Set([...Object.keys(prev), ...Object.keys(next)])\n  return Object.fromEntries(\n    [...ids]\n      .map((id) => [id, next[id] ?? -1] as const)\n      .filter(([id, seq]) => {\n        return (prev[id] ?? -1) !== seq\n      }),\n  )\n}"},{"id":"packages_opencode_src_server_shared_fence_parse","label":"parse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/shared/fence.ts","source_location":"L34-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/shared/fence.ts","source_location":"L34"}],"snippet":"export function parse(headers: Headers): State | undefined {\n  const raw = headers.get(HEADER)\n  if (!raw) return\n\n  let data\n  try {\n    data = JSON.parse(raw)\n  } catch {\n    return\n  }\n\n  if (!data || typeof data !== \"object\") return\n\n  return Object.fromEntries(\n    Object.entries(data).filter((entry): entry is [string, number] => {\n      return typeof entry[0] === \"string\" && Number.isInteger(entry[1])\n    }),\n  )\n}"},{"id":"packages_opencode_src_server_shared_fence_wait","label":"wait()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/shared/fence.ts","source_location":"L54-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/shared/fence.ts","source_location":"L54"}],"snippet":"export function wait(workspaceID: WorkspaceV2.ID, state: State, signal?: AbortSignal) {\n  return Effect.gen(function* () {\n    yield* Effect.logInfo(\"waiting for state\", { workspaceID, state })\n    yield* Workspace.Service.use((workspace) => workspace.waitForSync(workspaceID, state, signal))\n    yield* Effect.logInfo(\"state fully synced\", { workspaceID, state })\n  })\n}"}],"edges":[{"source":"packages_opencode_src_server_shared_