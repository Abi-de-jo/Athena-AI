{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_mcp_catalog","nodes":[{"id":"packages_opencode_src_mcp_catalog","label":"catalog.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L1"}]},{"id":"packages_opencode_src_mcp_catalog_paginate","label":"paginate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L18-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L18"}],"snippet":"export async function paginate<T, R extends { nextCursor?: string }>(\n  list: (cursor?: string) => Promise<R>,\n  items: (result: R) => T[],\n) {\n  const result: T[] = []\n  const cursors = new Set<string>()\n  let cursor: string | undefined\n\n  for (let page = 0; page < MAX_LIST_PAGES; page++) {\n    const page = await list(cursor)\n    result.push(...items(page))\n    if (page.nextCursor === undefined) return result\n    if (cursors.has(page.nextCursor)) throw new Error(`MCP list returned duplicate cursor: ${page.nextCursor}`)\n    cursors.add(page.nextCursor)\n    cursor = page.nextCursor\n  }\n\n  throw new Error(`MCP list exceeded ${MAX_LIST_PAGES} pages`)\n}"},{"id":"packages_opencode_src_mcp_catalog_defs","label":"defs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L38-L40","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L38"}],"snippet":"export function defs(client: Client, timeout?: number) {\n  return listTools(client, timeout ?? DEFAULT_TIMEOUT).pipe(Effect.catch(() => Effect.void))\n}"},{"id":"packages_opencode_src_mcp_catalog_converttool","label":"convertTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L42-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L42"}],"snippet":"export function convertTool(mcpTool: MCPToolDef, client: Client, timeout?: number): Tool {\n  const inputSchema: JSONSchema7 = {\n    ...(mcpTool.inputSchema as JSONSchema7),\n    type: \"object\",\n    properties: (mcpTool.inputSchema.properties ?? {}) as JSONSchema7[\"properties\"],\n    additionalProperties: false,\n  }\n\n  return dynamicTool({\n    description: mcpTool.description ?? \"\",\n    inputSchema: jsonSchema(inputSchema),\n    execute: async (args: unknown, options) => {\n      const result = await client.callTool(\n        {\n          name: mcpTool.name,\n          arguments: (args || {}) as Record<string, unknown>,\n        },\n        CallToolResultSchema,\n        {\n          resetTimeoutOnProgress: true,\n          signal: options.abortSignal,\n          timeout,\n          // The MCP SDK only sends a progress token when this hook is present, enabling timeout resets.\n          onprogress: () => {},\n        },"},{"id":"packages_opencode_src_mcp_catalog_fetch","label":"fetch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L84-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L84"}],"snippet":"export function fetch<T extends { name: string }>(\n  clientName: string,\n  client: Client,\n  list: (client: Client) => Promise<T[]>,\n  label: string,\n) {\n  return Effect.tryPromise({\n    try: () => list(client),\n    catch: (error) => error,\n  }).pipe(\n    Effect.tapError((error) =>\n      Effect.logWarning(`failed to get ${label}`, {\n        clientName,\n        error: error instanceof Error ? error.message : String(error),\n      }),\n    ),\n    Effect.map((items) => {\n      const sanitizedClient = sanitize(clientName)\n      return Object.fromEntries(\n        items.map((item) => [sanitizedClient + \":\" + sanitize(item.name), { ...item, client: clientName }]),\n      )\n    }),\n    Effect.orElseSucceed(() => undefined),\n  )\n}"},{"id":"packages_opencode_src_mcp_catalog_sanitize","label":"sanitize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L110"}],"snippet":"sanitize = (value: string) => value.replace(/[^a-zA-Z0-9_-]/g, \"_\")"},{"id":"packages_opencode_src_mcp_catalog_prompts","label":"prompts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L112-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L112"}],"snippet":"export function prompts(client: Client, timeout?: number) {\n  if (!client.getServerCapabilities()?.prompts) return Promise.resolve([])\n  return paginate(\n    (cursor) => client.listPrompts(cursor === undefined ? undefined : { cursor }, { timeout }),\n    (result) => result.prompts,\n  )\n}"},{"id":"packages_opencode_src_mcp_catalog_resources","label":"resources()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L120-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L120"}],"snippet":"export function resources(client: Client, timeout?: number) {\n  if (!client.getServerCapabilities()?.resources) return Promise.resolve([])\n  return paginate(\n    (cursor) => client.listResources(cursor === undefined ? undefined : { cursor }, { timeout }),\n    (result) => result.resources,\n  )\n}"},{"id":"packages_opencode_src_mcp_catalog_listtools","label":"listTools()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L128-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L128"}],"snippet":"function listTools(client: Client, timeout: number) {\n  return Effect.tryPromise({\n    try: () =>\n      paginate(\n        async (cursor) => {\n          const params = cursor === undefined ? undefined : { cursor }\n          try {\n            return await client.listTools(params, { timeout })\n          } catch (error) {\n            if (!(error instanceof Error) || !isOutputSchemaValidationError(error)) throw error\n            return client.request({ method: \"tools/list\", params }, TolerantListToolsResultSchema, { timeout })\n          }\n        },\n        (result) => result.tools,\n      ),\n    catch: (error) => (error instanceof Error ? error : new Error(String(error))),\n  })\n}"},{"id":"packages_opencode_src_mcp_catalog_isoutputschemavalidationerror","label":"isOutputSchemaValidationError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L147-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L147"}],"snippet":"function isOutputSchemaValidationError(error: Error) {\n  return /can't resolve reference|resolves to more than one schema|outputSchema|schema.*reference|reference.*schema/i.test(\n    error.message,\n  )\n}"}],"edges":[{"source":"packages_opencode_src_mcp_catalog","target":"index","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_mcp_catalog","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L2"}],"weight":1},{"source":"packages_opencode_src_mcp_catalog","target":"ai","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts","source_location":"L8","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/catalog.ts"