ation":"L40-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L40"}],"snippet":"eventMessage = (event: Event) => {\n  if (\"message\" in event && typeof event.message === \"string\") return event.message\n  return event.type\n}"},{"id":"packages_llm_src_route_transport_websocket_binarymessage","label":"binaryMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L45-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L45"}],"snippet":"binaryMessage = (data: unknown) => {\n  if (data instanceof Uint8Array) return data\n  if (data instanceof ArrayBuffer) return new Uint8Array(data)\n  if (ArrayBuffer.isView(data)) return new Uint8Array(data.buffer, data.byteOffset, data.byteLength)\n  return undefined\n}"},{"id":"packages_llm_src_route_transport_websocket_waitopen","label":"waitOpen()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L52-L102","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L52"}],"snippet":"waitOpen = (ws: globalThis.WebSocket, input: WebSocketRequest) => {\n  if (ws.readyState === globalThis.WebSocket.OPEN) return Effect.void\n  if (ws.readyState === globalThis.WebSocket.CLOSING || ws.readyState === globalThis.WebSocket.CLOSED) {\n    return Effect.fail(\n      transportError(\"open\", `WebSocket closed before opening (state ${ws.readyState})`, {\n        url: input.url,\n        kind: \"open\",\n      }),\n    )\n  }\n  return Effect.callback<void, LLMError>((resume, signal) => {\n    const cleanup = () => {\n      ws.removeEventListener(\"open\", onOpen)\n      ws.removeEventListener(\"error\", onError)\n      ws.removeEventListener(\"close\", onClose)\n      signal.removeEventListener(\"abort\", onAbort)\n    }\n    const onAbort = () => {\n      cleanup()\n      if (ws.readyState !== globalThis.WebSocket.CLOSED && ws.readyState !== globalThis.WebSocket.CLOSING)\n        ws.close(1000)\n    }\n    const onOpen = () => {\n      cleanup()\n      resume(Effect.void)"},{"id":"packages_llm_src_route_transport_websocket_waitopen_cleanup","label":"cleanup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L63-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L63"}],"snippet":"cleanup = () => {\n      ws.removeEventListener(\"open\", onOpen)\n      ws.removeEventListener(\"error\", onError)\n      ws.removeEventListener(\"close\", onClose)\n      signal.removeEventListener(\"abort\", onAbort)\n    }"},{"id":"packages_llm_src_route_transport_websocket_waitopen_onabort","label":"onAbort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L69-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L69"}],"snippet":"onAbort = () => {\n      cleanup()\n      if (ws.readyState !== globalThis.WebSocket.CLOSED && ws.readyState !== globalThis.WebSocket.CLOSING)\n        ws.close(1000)\n    }"},{"id":"packages_llm_src_route_transport_websocket_waitopen_onopen","label":"onOpen()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L74-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L74"}],"snippet":"onOpen = () => {\n      cleanup()\n      resume(Effect.void)\n    }"},{"id":"packages_llm_src_route_transport_websocket_waitopen_onerror","label":"onError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L78-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L78"}],"snippet":"onError = (event: Event) => {\n      cleanup()\n      resume(\n        Effect.fail(\n          transportError(\"open\", `Failed to open WebSocket: ${eventMessage(event)}`, { url: input.url, kind: \"open\" }),\n        ),\n      )\n    }"},{"id":"packages_llm_src_route_transport_websocket_waitopen_onclose","label":"onClose()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L86-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L86"}],"snippet":"onClose = (event: CloseEvent) => {\n      cleanup()\n      resume(\n        Effect.fail(\n          transportError(\"open\", `WebSocket closed before opening with code ${event.code}`, {\n            url: input.url,\n            kind: \"open\",\n          }),\n        ),\n      )\n    }"},{"id":"packages_llm_src_route_transport_websocket_websocketurl","label":"webSocketUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L104-L123","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L104"}],"snippet":"webSocketUrl = (value: string) =>\n  Effect.try({\n    try: () => {\n      const url = new URL(value)\n      if (url.protocol === \"https:\") {\n        url.protocol = \"wss:\"\n        return url.toString()\n      }\n      if (url.protocol === \"http:\") {\n        url.protocol = \"ws:\"\n        return url.toString()\n      }\n      throw new Error(`Unsupported WebSocket URL protocol ${url.protocol}`)\n    },\n    catch: (error) =>\n      transportError(\"prepare\", error instanceof Error ? error.message : \"Invalid WebSocket URL\", {\n        url: value,\n        kind: \"websocket\",\n      }),\n  })"},{"id":"packages_llm_src_route_transport_websocket_open","label":"open()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L125-L134","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L125"}],"snippet":"open = (input: WebSocketRequest) =>\n  Effect.try({\n    try: () =>\n      new (globalThis.WebSocket as unknown as WebSocketConstructorWithHeaders)(input.url, { headers: input.headers }),\n    catch: (error) =>\n      transportError(\"open\", error instanceof Error ? error.message : \"Failed to construct WebSocket\", {\n        url: input.url,\n        kind: \"open\",\n      }),\n  }).pipe(Effect.flatMap((ws) => fromWebSocket(ws, input)))"},{"id":"packages_llm_src_route_transport_websocket_fromwebsocket","label":"fromWebSocket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L138-L204","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L138"}],"snippet":"fromWebSocket = (\n  ws: globalThis.WebSocket,\n  input: WebSocketRequest,\n): Effect.Effect<WebSocketConnection, LLMError> =>\n  Effect.gen(function* () {\n    yield* waitOpen(ws, input)\n    const messages = yield* Queue.bounded<string | Uint8Array, LLMError | Cause.Done<void>>(128)\n\n    const onMessage = (event: MessageEvent) => {\n      if (typeof event.data === \"string\") return Queue.offerUnsafe(messages, event.data)\n      const binary = binaryMessage(event.data)\n      if (binary) return Queue.offerUnsafe(messages, binary)\n      Queue.failCauseUnsafe(\n        messages,\n        Cause.fail(\n          transportError(\"message\", \"Unsupported WebSocket message payload\", { url: input.url, kind: \"message\" }),\n        ),\n      )\n    }\n    const onError = (event: Event) => {\n      Queue.failCauseUnsafe(\n        messages,\n        Cause.fail(\n          transportError(\"message\", `WebSocket error: ${eventMessage(event)}`, { url: input.url, kind: \"message\" }),\n        ),"},{"id":"packages_llm_src_route_transport_websocket_fromwebsocket_onmessage","label":"onMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L146-L156","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L146"}],"snippet":"onMessage = (event: MessageEvent) => {\n      if (typeof event.data === \"string\") return Queue.offerUnsafe(messages, event.data)\n      const binary = binaryMessage(event.data)\n      if (binary) return Queue.offerUnsafe(messages, binary)\n      Queue.failCauseUnsafe(\n        messages,\n        Cause.fail(\n          transportError(\"message\", \"Unsupported WebSocket message payload\", { url: input.url, kind: \"message\" }),\n        ),\n      )\n    }"},{"id":"packages_llm_src_route_transport_websocket_fromwebsocket_onerror","label":"onError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L157-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L157"}],"snippet":"onError = (event: Event) => {\n      Queue.failCauseUnsafe(\n        messages,\n        Cause.fail(\n          transportError(\"message\", `WebSocket error: ${eventMessage(event)}`, { url: input.url, kind: \"message\" }),\n        ),\n      )\n    }"},{"id":"packages_llm_src_route_transport_websocket_fromwebsocket_onclose","label":"onClose()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L165-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L165"}],"snippet":"onClose = (event: CloseEvent) => {\n      if (event.code === 1000 || event.code === 1005) return Queue.endUnsafe(messages)\n      Queue.failCauseUnsafe(\n        messages,\n        Cause.fail(\n          transportError(\"message\", `WebSocket closed with code ${event.code}`, { url: input.url, kind: \"close\" }),\n        ),\n      )\n    }"},{"id":"packages_llm_src_route_transport_websocket_messagetext","label":"messageText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L206-L207","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L206"}],"snippet":"messageText = (message: string | Uint8Array, decoder: TextDecoder) =>\n  typeof message === \"string\" ? message : decoder.decode(message)"},{"id":"packages_llm_src_route_transport_websocket_jsonprepared","label":"JsonPrepared","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L209-L213","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L209"}],"snippet":"export interface JsonPrepared {\n  readonly url: string\n  readonly headers: Headers.Headers\n  readonly message: string\n}"},{"id":"packages_llm_src_route_transport_websocket_jsoninput","label":"JsonInput","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L215-L218","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L215"}],"snippet":"export interface JsonInput<Body, Message> {\n  readonly toMessage: (body: Body | Record<string, unknown>) => Effect.Effect<Message, LLMError>\n  readonly encodeMessage: (message: Message) => string\n}"},{"id":"packages_llm_src_route_transport_websocket_jsontransport","label":"JsonTransport","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L222-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L222"}],"snippet":"export interface JsonTransport<Body, Message> extends Transport<Body, JsonPrepared, string> {\n  readonly with: (patch: JsonPatch<Body, Message>) => JsonTransport<Body, Message>\n}"},{"id":"packages_llm_src_route_transport_websocket_transport","label":"Transport","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L222","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L222"}]},{"id":"packages_llm_src_route_transport_websocket_json","label":"json()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L226-L262","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L226"}],"snippet":"json = <Body, Message>(input: JsonInput<Body, Message>): JsonTransport<Body, Message> => ({\n  id: \"websocket-json\",\n  with: (patch) => json({ ...input, ...patch }),\n  prepare: (prepareInput) =>\n    Effect.gen(function* () {\n      const parts = yield* HttpTransport.jsonRequestParts({\n        ...prepareInput,\n      })\n      return {\n        url: yield* webSocketUrl(parts.url),\n        headers: parts.headers,\n        message: input.encodeMessage(yield* input.toMessage(parts.jsonBody)),\n      }\n    }),\n  frames: (prepared, _request, runtime) => {\n    const webSocket = runtime.webSocket\n    if (!webSocket) {\n      return Stream.fail(\n        transportError(\"json\", \"WebSocket JSON transport requires WebSocketExecutor.Service\", {\n          url: prepared.url,\n          kind: \"websocket\",\n        }),\n      )\n    }\n    const decoder = new TextDecoder()"}],"edges":[{"source":"packages_llm_src_route_transport_websocket","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L1"}],"weight":1},{"source":"packages_llm_src_route_transport_websocket","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L2"}],"weight":1},{"source":"packages_llm_src_route_transport_websocket","target":"schema","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L3"}],"weight":1},{"source":"packages_llm_src_route_transport_websocket","target":"index","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/person