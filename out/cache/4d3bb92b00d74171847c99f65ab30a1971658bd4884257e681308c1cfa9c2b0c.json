{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_llm_src_route_transport_websocket","nodes":[{"id":"packages_llm_src_route_transport_websocket","label":"websocket.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L1"}]},{"id":"packages_llm_src_route_transport_websocket_websocketrequest","label":"WebSocketRequest","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L7-L10","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L7"}],"snippet":"export interface WebSocketRequest {\n  readonly url: string\n  readonly headers: Headers.Headers\n}"},{"id":"packages_llm_src_route_transport_websocket_websocketconnection","label":"WebSocketConnection","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L12-L16","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/transport/websocket.ts","source_location":"L12"}],"snippet":"export interface WebSocketConnection {\n  readonly sendText: (message: string) => Effect.Effect<void, LLMError>\n  readonly messages: Stream.Stream<string | Uint8Array, LLMError>\n  readonly close: Effect.Effect<void, never>\n}"},{"id":"packages_llm_src_route_transport_websocket_interface","label":"Interface","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rim