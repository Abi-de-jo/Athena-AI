 year: \"numeric\",\n    month: \"short\",\n    day: \"numeric\",\n    hour: \"numeric\",\n    minute: \"2-digit\",\n    second: \"2-digit\",\n    timeZoneName: \"short\",\n    timeZone: \"UTC\",\n  }\n  return date.toLocaleDateString(undefined, options)\n}"},{"id":"packages_console_app_src_routes_workspace_common_formatbalance","label":"formatBalance()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common.tsx","source_location":"L36-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common.tsx","source_location":"L36"}],"snippet":"export function formatBalance(amount: number) {\n  const balance = ((amount ?? 0) / 100000000).toFixed(2)\n  return balance === \"-0.00\" ? \"0.00\" : balance\n}"},{"id":"packages_console_app_src_routes_workspace_common_getlastseenworkspaceid","label":"getLastSeenWorkspaceID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common.tsx","source_location":"L41-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common.tsx","source_location":"L41"}],"snippet":"export async function getLastSeenWorkspaceID() {\n  \"use server\"\n  return withActor(async () => {\n    const actor = Actor.assert(\"account\")\n    return Database.use(async (tx) =>\n      tx\n        .select({ id: WorkspaceTable.id })\n        .from(UserTable)\n        .innerJoin(WorkspaceTable, eq(UserTable.workspaceID, WorkspaceTable.id))\n        .where(\n          and(\n            eq(UserTable.accountID, actor.properties.accountID),\n            isNull(UserTable.timeDeleted),\n            isNull(WorkspaceTable.timeDeleted),\n          ),\n        )\n        .orderBy(desc(UserTable.timeSeen))\n        .limit(1)\n        .then((x) => x[0]?.id),\n    )\n  })\n}","node_kind":"function","framework":"nextjs","framework_role":"next_server_action","runtime_boundary":"server"}],"edges":[{"source":"packages_console_app_src_routes_workspace_common","target":"console_resource","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common.tsx","source_location":"L1"}],"weight":1},{"source":"packages_console_app_src_routes_workspace_common","target":"actor","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common.tsx","source_location":"L2"}],"weight":1},{"source":"packages_console_app_src_routes_workspace_common","target":"router","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common.tsx","source_location":"L3"}],"weight":1},{"source":"packages_console_app_src_routes_workspace_common","target":"auth","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/common