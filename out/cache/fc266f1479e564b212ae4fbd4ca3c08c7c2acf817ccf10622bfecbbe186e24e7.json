{"__madarTsExtractorVersion":67,"__madarFileStem":"directory-sync","nodes":[{"id":"directory_sync","label":"directory-sync.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L1"}]},{"id":"directory_sync_sortparts","label":"sortParts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L19-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L19"}],"snippet":"function sortParts(parts: Part[]) {\n  return parts.filter((part) => !!part?.id).sort((a, b) => cmp(a.id, b.id))\n}"},{"id":"directory_sync_runinflight","label":"runInflight()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L23-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L23"}],"snippet":"function runInflight(map: Map<string, Promise<void>>, key: string, task: () => Promise<void>) {\n  const pending = map.get(key)\n  if (pending) return pending\n  const promise = task().finally(() => {\n    map.delete(key)\n  })\n  map.set(key, promise)\n  return promise\n}"},{"id":"directory_sync_keyfor","label":"keyFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L33"}],"snippet":"keyFor = (directory: string, id: string) => `${directory}\\n${id}`"},{"id":"directory_sync_cmp","label":"cmp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L35"}],"snippet":"cmp = (a: string, b: string) => (a < b ? -1 : a > b ? 1 : 0)"},{"id":"directory_sync_isnotfound","label":"isNotFound()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L37-L41","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L37"}],"snippet":"isNotFound = (error: unknown) =>\n  error instanceof Error &&\n  typeof error.cause === \"object\" &&\n  error.cause !== null &&\n  (error.cause as { status?: unknown }).status === 404"},{"id":"directory_sync_merge","label":"merge()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L43-L47","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L43"}],"snippet":"function merge<T extends { id: string }>(a: readonly T[], b: readonly T[]) {\n  const map = new Map(a.map((item) => [item.id, item] as const))\n  for (const item of b) map.set(item.id, item)\n  return [...map.values()].sort((x, y) => cmp(x.id, y.id))\n}"},{"id":"directory_sync_hasparts","label":"hasParts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L77-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L77"}],"snippet":"hasParts = (parts: Part[] | undefined, want: Part[]) => {\n  if (!parts) return want.length === 0\n  return want.every((part) => Binary.search(parts, part.id, (item) => item.id).found)\n}"},{"id":"directory_sync_mergeparts","label":"mergeParts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L82-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L82"}],"snippet":"mergeParts = (parts: Part[] | undefined, want: Part[]) => {\n  if (!parts) return sortParts(want)\n  const next = [...parts]\n  let changed = false\n  for (const part of want) {\n    const result = Binary.search(next, part.id, (item) => item.id)\n    if (result.found) continue\n    next.splice(result.index, 0, part)\n    changed = true\n  }\n  if (!changed) return parts\n  return next\n}"},{"id":"directory_sync_mergeoptimisticpage","label":"mergeOptimisticPage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L96-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L96"}],"snippet":"export function mergeOptimisticPage(page: MessagePage, items: OptimisticItem[]) {\n  if (items.length === 0) return { ...page, confirmed: [] as string[] }\n\n  const session = [...page.session]\n  const part = new Map(page.part.map((item) => [item.id, sortParts(item.part)]))\n  const confirmed: string[] = []\n\n  for (const item of items) {\n    const result = Binary.search(session, item.message.id, (message) => message.id)\n    const found = result.found\n    if (!found) session.splice(result.index, 0, item.message)\n\n    const current = part.get(item.message.id)\n    if (found && hasParts(current, item.parts)) {\n      confirmed.push(item.message.id)\n      continue\n    }\n\n    part.set(item.message.id, mergeParts(current, item.parts))\n  }\n\n  return {\n    cursor: page.cursor,\n    complete: page.complete,\n    session,"},{"id":"directory_sync_applyoptimisticadd","label":"applyOptimisticAdd()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L126-L135","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L126"}],"snippet":"export function applyOptimisticAdd(draft: OptimisticStore, input: OptimisticAddInput) {\n  const messages = draft.message[input.sessionID]\n  if (messages) {\n    const result = Binary.search(messages, input.message.id, (m) => m.id)\n    messages.splice(result.index, 0, input.message)\n  } else {\n    draft.message[input.sessionID] = [input.message]\n  }\n  draft.part[input.message.id] = sortParts(input.parts)\n}"},{"id":"directory_sync_applyoptimisticremove","label":"applyOptimisticRemove()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L137-L144","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L137"}],"snippet":"export function applyOptimisticRemove(draft: OptimisticStore, input: OptimisticRemoveInput) {\n  const messages = draft.message[input.sessionID]\n  if (messages) {\n    const result = Binary.search(messages, input.messageID, (m) => m.id)\n    if (result.found) messages.splice(result.index, 1)\n  }\n  delete draft.part[input.messageID]\n}"},{"id":"directory_sync_setoptimisticadd","label":"setOptimisticAdd()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L146-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L146"}],"snippet":"function setOptimisticAdd(setStore: (...args: unknown[]) => void, input: OptimisticAddInput) {\n  setStore(\"message\", input.sessionID, (messages: Message[] | undefined) => {\n    if (!messages) return [input.message]\n    const result = Binary.search(messages, input.message.id, (m) => m.id)\n    const next = [...messages]\n    next.splice(result.index, 0, input.message)\n    return next\n  })\n  setStore(\"part\", input.message.id, sortParts(input.parts))\n}"},{"id":"directory_sync_setoptimisticremove","label":"setOptimisticRemove()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L157-L172","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L157"}],"snippet":"function setOptimisticRemove(setStore: (...args: unknown[]) => void, input: OptimisticRemoveInput) {\n  setStore(\"message\", input.sessionID, (messages: Message[] | undefined) => {\n    if (!messages) return messages\n    const result = Binary.search(messages, input.messageID, (m) => m.id)\n    if (!result.found) return messages\n    const next = [...messages]\n    next.splice(result.index, 1)\n    return next\n  })\n  setStore(\"part\", (part: Record<string, Part[] | undefined>) => {\n    if (!(input.messageID in part)) return part\n    const next = { ...part }\n    delete next[input.messageID]\n    return next\n  })\n}"},{"id":"directory_sync_createdirsynccontext","label":"createDirSyncContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L174-L620","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L174"}],"snippet":"createDirSyncContext = (\n  directory: string,\n  serverSync: ReturnType<typeof createServerSyncContextInner>,\n  serverSDK: ReturnType<typeof createServerSdkContext>,\n) => {\n  const client = serverSDK.createClient({ directory, throwOnError: true })\n\n  type Child = ReturnType<(typeof serverSync)[\"child\"]>\n  type Setter = Child[1]\n\n  const current = createMemo(() => serverSync.child(directory, { mcp: true }))\n  const target = (directory?: string) => {\n    if (!directory || directory === directory) return current()\n    return serverSync.child(directory)\n  }\n  const absolute = (path: string) => (current()[0].path.directory + \"/\" + path).replace(\"//\", \"/\")\n  const initialMessagePageSize = 80\n  const historyMessagePageSize = 200\n  const inflight = new Map<string, Promise<void>>()\n  const inflightDiff = new Map<string, Promise<void>>()\n  const inflightTodo = new Map<string, Promise<void>>()\n  const optimistic = new Map<string, Map<string, OptimisticItem>>()\n  const maxDirs = 30\n  const seen = new Map<string, Set<string>>()\n  const [meta, setMeta] = createStore({"},{"id":"directory_sync_createdirsynccontext_target","label":"target()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L185-L188","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L185"}],"snippet":"target = (directory?: string) => {\n    if (!directory || directory === directory) return current()\n    return serverSync.child(directory)\n  }"},{"id":"directory_sync_createdirsynccontext_absolute","label":"absolute()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L189","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L189"}],"snippet":"absolute = (path: string) => (current()[0].path.directory + \"/\" + path).replace(\"//\", \"/\")"},{"id":"directory_sync_createdirsynccontext_getsession","label":"getSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L205-L210","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L205"}],"snippet":"getSession = (sessionID: string) => {\n    const store = current()[0]\n    const match = Binary.search(store.session, sessionID, (s) => s.id)\n    if (match.found) return store.session[match.index]\n    return undefined\n  }"},{"id":"directory_sync_createdirsynccontext_setoptimistic","label":"setOptimistic()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L212-L220","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L212"}],"snippet":"setOptimistic = (directory: string, sessionID: string, item: OptimisticItem) => {\n    const key = keyFor(directory, sessionID)\n    const list = optimistic.get(key)\n    if (list) {\n      list.set(item.message.id, { message: item.message, parts: sortParts(item.parts) })\n      return\n    }\n    optimistic.set(key, new Map([[item.message.id, { message: item.message, parts: sortParts(item.parts) }]]))\n  }"},{"id":"directory_sync_createdirsynccontext_clearoptimistic","label":"clearOptimistic()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L222-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L222"}],"snippet":"clearOptimistic = (directory: string, sessionID: string, messageID?: string) => {\n    const key = keyFor(directory, sessionID)\n    if (!messageID) {\n      optimistic.delete(key)\n      return\n    }\n\n    const list = optimistic.get(key)\n    if (!list) return\n    list.delete(messageID)\n    if (list.size === 0) optimistic.delete(key)\n  }"},{"id":"directory_sync_createdirsynccontext_getoptimistic","label":"getOptimistic()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L235-L237","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L235"}],"snippet":"getOptimistic = (directory: string, sessionID: string) => [\n    ...(optimistic.get(keyFor(directory, sessionID))?.values() ?? []),\n  ]"},{"id":"directory_sync_createdirsynccontext_seenfor","label":"seenFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L239-L257","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L239"}],"snippet":"seenFor = (directory: string) => {\n    const existing = seen.get(directory)\n    if (existing) {\n      seen.delete(directory)\n      seen.set(directory, existing)\n      return existing\n    }\n    const created = new Set<string>()\n    seen.set(directory, created)\n    while (seen.size > maxDirs) {\n      const first = seen.keys().next().value\n      if (!first) break\n      const stale = [...(seen.get(first) ?? [])]\n      seen.delete(first)\n      const [, setStore] = serverSync.child(first, { bootstrap: false })\n      evict(first, setStore, stale)\n    }\n    return created\n  }"},{"id":"directory_sync_createdirsynccontext_clearmeta","label":"clearMeta()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L259-L275","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L259"}],"snippet":"clearMeta = (directory: string, sessionIDs: string[]) => {\n    if (sessionIDs.length === 0) return\n    for (const sessionID of sessionIDs) {\n      clearOptimistic(directory, sessionID)\n    }\n    setMeta(\n      produce((draft) => {\n        for (const sessionID of sessionIDs) {\n          const key = keyFor(directory, sessionID)\n          delete draft.limit[key]\n          delete draft.cursor[key]\n          delete draft.complete[key]\n          delete draft.loading[key]\n        }\n      }),\n    )\n  }"},{"id":"directory_sync_createdirsynccontext_evict","label":"evict()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L277-L289","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L277"}],"snippet":"evict = (directory: string, setStore: Setter, sessionIDs: string[]) => {\n    if (sessionIDs.length === 0) return\n    clearSessionPrefetch(serverSDK.scope, directory, sessionIDs)\n    for (const sessionID of sessionIDs) {\n      serverSync.todo.set(sessionID, undefined)\n    }\n    setStore(\n      produce((draft) => {\n        dropSessionCaches(draft, sessionIDs)\n      }),\n    )\n    clearMeta(directory, sessionIDs)\n  }"},{"id":"directory_sync_createdirsynccontext_touch","label":"touch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L291-L298","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L291"}],"snippet":"touch = (directory: string, setStore: Setter, sessionID: string) => {\n    const stale = pickSessionCacheEvictions({\n      seen: seenFor(directory),\n      keep: sessionID,\n      limit: SESSION_CACHE_LIMIT,\n    })\n    evict(directory, setStore, stale)\n  }"},{"id":"directory_sync_createdirsynccontext_fetchmessages","label":"fetchMessages()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L300-L314","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L300"}],"snippet":"fetchMessages = async (input: { client: typeof client; sessionID: string; limit: number; before?: string }) => {\n    const messages = await retry(() =>\n      input.client.session.messages({ sessionID: input.sessionID, limit: input.limit, before: input.before }),\n    )\n    const items = (messages.data ?? []).filter((x) => !!x?.info?.id)\n    const session = items.map((x) => clean(x.info)).sort((a, b) => cmp(a.id, b.id))\n    const part = items.map((message) => ({ id: message.info.id, part: sortParts(message.parts) }))\n    const cursor = messages.response.headers.get(\"x-next-cursor\") ?? undefined\n    return {\n      session,\n      part,\n      cursor,\n      complete: !cursor,\n    }\n  }"},{"id":"directory_sync_createdirsynccontext_tracked","label":"tracked()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L316","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L316"}],"snippet":"tracked = (directory: string, sessionID: string) => seen.get(directory)?.has(sessionID) ?? false"},{"id":"directory_sync_createdirsynccontext_loadmessages","label":"loadMessages()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L318-L375","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L318"}],"snippet":"loadMessages = async (input: {\n    directory: string\n    client: typeof client\n    setStore: Setter\n    sessionID: string\n    limit: number\n    before?: string\n    mode?: \"replace\" | \"prepend\"\n  }) => {\n    const key = keyFor(input.directory, input.sessionID)\n    if (meta.loading[key]) return\n\n    setMeta(\"loading\", key, true)\n    await fetchMessages(input)\n      .then((page) => {\n        if (!tracked(input.directory, input.sessionID)) return\n        const next = mergeOptimisticPage(page, getOptimistic(input.directory, input.sessionID))\n        for (const messageID of next.confirmed) {\n          clearOptimistic(input.directory, input.sessionID, messageID)\n        }\n        const [store] = serverSync.child(input.directory, { bootstrap: false })\n        const cached = input.mode === \"prepend\" ? (store.message[input.sessionID] ?? []) : []\n        const message = input.mode === \"prepend\" ? merge(cached, next.session) : next.session\n        batch(() => {\n          input.setStore(\"message\", input.sessionID, reconcile(message, { key: \"id\" }))"}],"edges":[{"source":"directory_sync","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L1"}],"weight":1},{"source":"directory_sync","target":"store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/directory-sync.ts"