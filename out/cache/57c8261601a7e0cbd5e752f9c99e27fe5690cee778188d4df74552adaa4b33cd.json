e/src/util/filesystem.ts","source_location":"L57-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L57"}],"snippet":"function isEnoent(e: unknown): e is { code: \"ENOENT\" } {\n  return typeof e === \"object\" && e !== null && \"code\" in e && (e as { code: string }).code === \"ENOENT\"\n}"},{"id":"packages_opencode_src_util_filesystem_write","label":"write()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L61-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L61"}],"snippet":"export async function write(p: string, content: string | Buffer | Uint8Array, mode?: number): Promise<void> {\n  try {\n    if (mode) {\n      await writeFile(p, content, { mode })\n    } else {\n      await writeFile(p, content)\n    }\n  } catch (e) {\n    if (isEnoent(e)) {\n      await mkdir(dirname(p), { recursive: true })\n      if (mode) {\n        await writeFile(p, content, { mode })\n      } else {\n        await writeFile(p, content)\n      }\n      return\n    }\n    throw e\n  }\n}"},{"id":"packages_opencode_src_util_filesystem_writejson","label":"writeJson()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L82-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L82"}],"snippet":"export async function writeJson(p: string, data: unknown, mode?: number): Promise<void> {\n  return write(p, JSON.stringify(data, null, 2), mode)\n}"},{"id":"packages_opencode_src_util_filesystem_writestream","label":"writeStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L86-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L86"}],"snippet":"export async function writeStream(\n  p: string,\n  stream: ReadableStream<Uint8Array> | Readable,\n  mode?: number,\n): Promise<void> {\n  const dir = dirname(p)\n  if (!existsSync(dir)) {\n    await mkdir(dir, { recursive: true })\n  }\n\n  const nodeStream = stream instanceof ReadableStream ? Readable.fromWeb(stream as any) : stream\n  const writeStream = createWriteStream(p)\n  await pipeline(nodeStream, writeStream)\n\n  if (mode) {\n    await chmod(p, mode)\n  }\n}"},{"id":"packages_opencode_src_util_filesystem_mimetype","label":"mimeType()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L105-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L105"}],"snippet":"export async function mimeType(p: string): Promise<string> {\n  const { lookup } = await import(\"mime-types\")\n  return lookup(p) || \"application/octet-stream\"\n}"},{"id":"packages_opencode_src_util_filesystem_normalizepath","label":"normalizePath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L115-L123","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L115"}],"snippet":"export function normalizePath(p: string): string {\n  if (process.platform !== \"win32\") return p\n  const resolved = win32.normalize(win32.resolve(windowsPath(p)))\n  try {\n    return realpathSync.native(resolved)\n  } catch {\n    return resolved\n  }\n}"},{"id":"packages_opencode_src_util_filesystem_normalizepathpattern","label":"normalizePathPattern()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L125-L132","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L125"}],"snippet":"export function normalizePathPattern(p: string): string {\n  if (process.platform !== \"win32\") return p\n  if (p === \"*\") return p\n  const match = p.match(/^(.*)[\\\\/]\\*$/)\n  if (!match) return normalizePath(p)\n  const dir = /^[A-Za-z]:$/.test(match[1]) ? match[1] + \"\\\\\" : match[1]\n  return join(normalizePath(dir), \"*\")\n}"},{"id":"packages_opencode_src_util_filesystem_resolve","label":"resolve()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L137-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L137"}],"snippet":"export function resolve(p: string): string {\n  const resolved = pathResolve(windowsPath(p))\n  try {\n    return normalizePath(realpathSync(resolved))\n  } catch (e) {\n    if (isEnoent(e)) return normalizePath(resolved)\n    throw e\n  }\n}"},{"id":"packages_opencode_src_util_filesystem_resolvefilepath","label":"resolveFilePath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L147-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L147"}],"snippet":"export function resolveFilePath(root: string, file: string): string {\n  const raw = file.startsWith(\"file://\") ? fileURLToPath(file) : file\n  if (isAbsolute(raw)) return raw\n  return pathResolve(root, raw)\n}"},{"id":"packages_opencode_src_util_filesystem_windowspath","label":"windowsPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L153-L165","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L153"}],"snippet":"export function windowsPath(p: string): string {\n  if (process.platform !== \"win32\") return p\n  return (\n    p\n      .replace(/^\\/([a-zA-Z]):(?:[\\\\/]|$)/, (_, drive) => `${drive.toUpperCase()}:/`)\n      // Git Bash for Windows paths are typically /<drive>/...\n      .replace(/^\\/([a-zA-Z])(?:\\/|$)/, (_, drive) => `${drive.toUpperCase()}:/`)\n      // Cygwin git paths are typically /cygdrive/<drive>/...\n      .replace(/^\\/cygdrive\\/([a-zA-Z])(?:\\/|$)/, (_, drive) => `${drive.toUpperCase()}:/`)\n      // WSL paths are typically /mnt/<drive>/...\n      .replace(/^\\/mnt\\/([a-zA-Z])(?:\\/|$)/, (_, drive) => `${drive.toUpperCase()}:/`)\n  )\n}"},{"id":"packages_opencode_src_util_filesystem_overlaps","label":"overlaps()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L166-L168","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L166"}],"snippet":"export function overlaps(a: string, b: string) {\n  return FSUtil.overlaps(a, b)\n}"},{"id":"packages_opencode_src_util_filesystem_contains","label":"contains()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L170-L172","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L170"}],"snippet":"export function contains(parent: string, child: string) {\n  return FSUtil.contains(parent, child)\n}"},{"id":"packages_opencode_src_util_filesystem_findup","label":"findUp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L174-L179","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L174"}],"snippet":"export async function findUp(\n  target: string,\n  start: string,\n  stop?: string,\n  options?: { rootFirst?: boolean },\n): Promise<string[]>"},{"id":"packages_opencode_src_util_filesystem_up","label":"up()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L213-L226","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L213"}],"snippet":"export async function* up(options: { targets: string[]; start: string; stop?: string }) {\n  const { targets, start, stop } = options\n  let current = start\n  while (true) {\n    for (const target of targets) {\n      const search = join(current, target)\n      if (await exists(search)) yield search\n    }\n    if (stop === current) break\n    const parent = dirname(current)\n    if (parent === current) break\n    current = parent\n  }\n}"},{"id":"packages_opencode_src_util_filesystem_globup","label":"globUp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L228-L249","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L228"}],"snippet":"export async function globUp(pattern: string, start: string, stop?: string) {\n  let current = start\n  const result = []\n  while (true) {\n    try {\n      const matches = await Glob.scan(pattern, {\n        cwd: current,\n        absolute: true,\n        include: \"file\",\n        dot: true,\n      })\n      result.push(...matches)\n    } catch {\n      // Skip invalid glob patterns\n    }\n    if (stop === current) break\n    const parent = dirname(current)\n    if (parent === current) break\n    current = parent\n  }\n  return result\n}"}],"edges":[{"source":"packages_opencode_src_util_filesystem","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_util_filesystem","target":"fs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/util/filesystem.ts","source_location":"L2","layer":"base","provenance":[{"capability_i