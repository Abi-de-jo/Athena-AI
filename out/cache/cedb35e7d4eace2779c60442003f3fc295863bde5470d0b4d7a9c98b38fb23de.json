) : callback\n\n  if (!token) {\n    return\n  }\n\n  if (auth.scheme === \"bearer\") {\n    return `Bearer ${token}`\n  }\n\n  if (auth.scheme === \"basic\") {\n    return `Basic ${btoa(token)}`\n  }\n\n  return token\n}"}],"edges":[{"source":"packages_sdk_js_src_gen_core_auth_gen","target":"packages_sdk_js_src_gen_core_auth_gen_auth","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/auth.gen.ts","source_location":"L5","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/auth.gen.ts","source_location":"L5"}],"weight":1},{"source":"packages_sdk_js_src_gen_core_auth_gen","target":"packages_sdk_js_src_gen_core_auth_gen_getauthtoken","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/auth.gen.ts","source_location":"L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/auth.gen.ts","source_location":"L22"}],"weight":1}]}