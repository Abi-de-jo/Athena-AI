{"__madarTsExtractorVersion":67,"__madarFileStem":"ipRateLimiter","nodes":[{"id":"ipratelimiter","label":"ipRateLimiter.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/ipRateLimiter.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/ipRateLimiter.ts","source_location":"L1"}]},{"id":"ipratelimiter_createratelimiter","label":"createRateLimiter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/ipRateLimiter.ts","source_location":"L8-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/ipRateLimiter.ts","source_location":"L8"}],"snippet":"export function createRateLimiter(modelId: string, rateLimit: number | undefined, rawIp: string, request: Request) {\n  const dict = i18n(localeFromRequest(request))\n\n  const limits = Subscription.getFreeLimits()\n  // temporarily disable check headers\n  //const headersExist = Object.entries(limits.checkHeaders).every(\n  //  ([name, value]) => request.headers.get(name)?.toLowerCase().includes(value) ?? false,\n  //)\n  //const dailyLimit = !headersExist ? limits.dailyRequestsFallback : (rateLimit ?? limits.dailyRequests)\n  const headersExist = true\n  const dailyLimit = !headersExist ? limits.dailyRequestsFallback : (rateLimit ?? limits.dailyRequests)\n  const isDefaultModel = headersExist && !rateLimit\n\n  const ip = !rawIp.length ? \"unknown\" : rawIp\n  const now = Date.now()\n  const dailyInterval = rateLimit ? `${buildYYYYMMDD(now)}${modelId.substring(0, 2)}` : buildYYYYMMDD(now)\n  const retryAfter = getRetryAfterDay(now)\n  const redis = getRedis()\n  const lifetimeKey = buildRateLimitKey(\"ip\", ip)\n  const dailyKey = buildRateLimitKey(\"ip\", ip, dailyInterval)\n  let isNew = false\n\n  return {\n    check: async () => {\n      const counts = await redis.mget<(string | number | null)[]>(isDefaultModel ? [lifetimeKey, dailyKey] : [dailyKey])"},{"id":"ipratelimiter_getretryafterday","label":"getRetryAfterDay()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/ipRateLimiter.ts","source_location":"L52-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/ipRateLimiter.ts","source_location":"L52"}],"snippet":"export function getRetryAfterDay(now: number) {\n  return Math.ceil((86_400_000 - (now % 86_400_000)) / 1000)\n}"},{"id":"ipratelimiter_buildyyyymmdd","label":"buildYYYYMMDD()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/ipRateLimiter.ts","source_location":"L56-L61","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/ipRateLimiter.ts","source_location":"L56"}],"snippet":"function buildYYYYMMDD(timestamp: number) {\n  return new Date(timestamp)\n    .toISOString()\n    .replace(/[^0-9]/g, \"\")\n    .substring(0, 8)\n}"}],"edges":[{"source":"ipratelimiter","target":"error","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/ipRateLimiter.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/ipRateLimiter.ts","source_location":"L1"}],"weight":1},{"source":"ip