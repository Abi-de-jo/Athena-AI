{"__madarTsExtractorVersion":67,"__madarFileStem":"color","nodes":[{"id":"color","label":"color.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L1"}]},{"id":"color_clamp","label":"clamp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L3-L5","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L3"}],"snippet":"function clamp(v: number, min: number, max: number) {\n  return Math.max(min, Math.min(max, v))\n}"},{"id":"color_hue","label":"hue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L7-L9","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L7"}],"snippet":"function hue(v: number) {\n  return ((v % 360) + 360) % 360\n}"},{"id":"color_hextorgb","label":"hexToRgb()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L11-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L11"}],"snippet":"export function hexToRgb(hex: HexColor): { r: number; g: number; b: number } {\n  const h = hex.replace(\"#\", \"\")\n  const full =\n    h.length === 3 || h.length === 4\n      ? h\n          .split(\"\")\n          .map((c) => c + c)\n          .join(\"\")\n      : h\n  const rgb = full.length === 8 ? full.slice(0, 6) : full\n\n  const num = parseInt(rgb, 16)\n  return {\n    r: ((num >> 16) & 255) / 255,\n    g: ((num >> 8) & 255) / 255,\n    b: (num & 255) / 255,\n  }\n}"},{"id":"color_rgbtohex","label":"rgbToHex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L30-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L30"}],"snippet":"export function rgbToHex(r: number, g: number, b: number): HexColor {\n  const toHex = (v: number) => {\n    const clamped = clamp(v, 0, 1)\n    const int = Math.round(clamped * 255)\n    return int.toString(16).padStart(2, \"0\")\n  }\n  return `#${toHex(r)}${toHex(g)}${toHex(b)}`\n}"},{"id":"color_rgbtohex_tohex","label":"toHex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L31-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L31"}],"snippet":"toHex = (v: number) => {\n    const clamped = clamp(v, 0, 1)\n    const int = Math.round(clamped * 255)\n    return int.toString(16).padStart(2, \"0\")\n  }"},{"id":"color_lineartosrgb","label":"linearToSrgb()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L39-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L39"}],"snippet":"function linearToSrgb(c: number): number {\n  if (c <= 0.0031308) return c * 12.92\n  return 1.055 * Math.pow(c, 1 / 2.4) - 0.055\n}"},{"id":"color_srgbtolinear","label":"srgbToLinear()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L44-L47","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L44"}],"snippet":"function srgbToLinear(c: number): number {\n  if (c <= 0.04045) return c / 12.92\n  return Math.pow((c + 0.055) / 1.055, 2.4)\n}"},{"id":"color_rgbtooklch","label":"rgbToOklch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L49-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L49"}],"snippet":"export function rgbToOklch(r: number, g: number, b: number): OklchColor {\n  const lr = srgbToLinear(r)\n  const lg = srgbToLinear(g)\n  const lb = srgbToLinear(b)\n\n  const l_ = 0.4122214708 * lr + 0.5363325363 * lg + 0.0514459929 * lb\n  const m_ = 0.2119034982 * lr + 0.6806995451 * lg + 0.1073969566 * lb\n  const s_ = 0.0883024619 * lr + 0.2817188376 * lg + 0.6299787005 * lb\n\n  const l = Math.cbrt(l_)\n  const m = Math.cbrt(m_)\n  const s = Math.cbrt(s_)\n\n  const L = 0.2104542553 * l + 0.793617785 * m - 0.0040720468 * s\n  const a = 1.9779984951 * l - 2.428592205 * m + 0.4505937099 * s\n  const bOk = 0.0259040371 * l + 0.7827717662 * m - 0.808675766 * s\n\n  const C = Math.sqrt(a * a + bOk * bOk)\n  let H = Math.atan2(bOk, a) * (180 / Math.PI)\n  if (H < 0) H += 360\n\n  return { l: L, c: C, h: H }\n}"},{"id":"color_oklchtorgb","label":"oklchToRgb()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L73-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L73"}],"snippet":"export function oklchToRgb(oklch: OklchColor): { r: number; g: number; b: number } {\n  const { l: L, c: C, h: H } = oklch\n\n  const a = C * Math.cos((H * Math.PI) / 180)\n  const b = C * Math.sin((H * Math.PI) / 180)\n\n  const l = L + 0.3963377774 * a + 0.2158037573 * b\n  const m = L - 0.1055613458 * a - 0.0638541728 * b\n  const s = L - 0.0894841775 * a - 1.291485548 * b\n\n  const l3 = l * l * l\n  const m3 = m * m * m\n  const s3 = s * s * s\n\n  const lr = 4.0767416621 * l3 - 3.3077115913 * m3 + 0.2309699292 * s3\n  const lg = -1.2684380046 * l3 + 2.6097574011 * m3 - 0.3413193965 * s3\n  const lb = -0.0041960863 * l3 - 0.7034186147 * m3 + 1.707614701 * s3\n\n  return {\n    r: linearToSrgb(lr),\n    g: linearToSrgb(lg),\n    b: linearToSrgb(lb),\n  }\n}"},{"id":"color_hextooklch","label":"hexToOklch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L98-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L98"}],"snippet":"export function hexToOklch(hex: HexColor): OklchColor {\n  const { r, g, b } = hexToRgb(hex)\n  return rgbToOklch(r, g, b)\n}"},{"id":"color_fitoklch","label":"fitOklch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L103-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L103"}],"snippet":"export function fitOklch(oklch: OklchColor): OklchColor {\n  const base = {\n    l: clamp(oklch.l, 0, 1),\n    c: Math.max(0, oklch.c),\n    h: hue(oklch.h),\n  }\n\n  const rgb = oklchToRgb(base)\n  if (rgb.r >= 0 && rgb.r <= 1 && rgb.g >= 0 && rgb.g <= 1 && rgb.b >= 0 && rgb.b <= 1) {\n    return base\n  }\n\n  let c = base.c\n  for (let i = 0; i < 24; i++) {\n    c *= 0.9\n    const next = { ...base, c }\n    const out = oklchToRgb(next)\n    if (out.r >= 0 && out.r <= 1 && out.g >= 0 && out.g <= 1 && out.b >= 0 && out.b <= 1) {\n      return next\n    }\n  }\n\n  return { ...base, c: 0 }\n}"},{"id":"color_oklchtohex","label":"oklchToHex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L128-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L128"}],"snippet":"export function oklchToHex(oklch: OklchColor): HexColor {\n  const { r, g, b } = oklchToRgb(fitOklch(oklch))\n  return rgbToHex(r, g, b)\n}"},{"id":"color_generatescale","label":"generateScale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L133-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L133"}],"snippet":"export function generateScale(seed: HexColor, isDark: boolean): HexColor[] {\n  const base = hexToOklch(seed)\n  const scale: HexColor[] = []\n\n  const lightSteps = isDark\n    ? [\n        0.118,\n        0.138,\n        0.167,\n        0.202,\n        0.246,\n        0.304,\n        0.378,\n        0.468,\n        clamp(base.l * 0.825, 0.53, 0.705),\n        clamp(base.l * 0.89, 0.61, 0.79),\n        clamp(base.l + 0.033, 0.868, 0.943),\n        0.984,\n      ]\n    : [0.993, 0.983, 0.962, 0.936, 0.906, 0.866, 0.811, 0.74, base.l, Math.max(0, base.l - 0.036), 0.49, 0.27]\n\n  const chromaMultipliers = isDark\n    ? [0.52, 0.68, 0.86, 1.02, 1.14, 1.24, 1.36, 1.48, 1.56, 1.64, 1.62, 1.15]\n    : [0.12, 0.24, 0.46, 0.68, 0.84, 0.98, 1.08, 1.16, 1.22, 1.26, 1.18, 0.98]"},{"id":"color_generateneutralscale","label":"generateNeutralScale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L171-L216","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L171"}],"snippet":"export function generateNeutralScale(seed: HexColor, isDark: boolean, ink?: HexColor): HexColor[] {\n  if (ink) {\n    const base = hexToOklch(seed)\n    const lift = (tone: number) =>\n      oklchToHex({\n        l: base.l + (1 - base.l) * tone,\n        c: base.c * Math.max(0, 1 - tone),\n        h: base.h,\n      })\n    const sink = (tone: number) =>\n      oklchToHex({\n        l: base.l * (1 - tone),\n        c: base.c * Math.max(0, 1 - tone * (isDark ? 0.12 : 0.3)),\n        h: base.h,\n      })\n    const bg = isDark\n      ? sink(clamp(0.19 + Math.max(0, base.l - 0.12) * 0.33 + base.c * 1.95, 0.17, 0.27))\n      : base.l < 0.82\n        ? lift(0.86)\n        : lift(clamp(0.1 + base.c * 3.2 + Math.max(0, 0.95 - base.l) * 0.35, 0.1, 0.28))\n    const steps = isDark\n      ? [0, 0.018, 0.039, 0.064, 0.097, 0.143, 0.212, 0.31, 0.46, 0.649, 0.845, 0.984]\n      : [0, 0.022, 0.042, 0.068, 0.102, 0.146, 0.208, 0.296, 0.432, 0.61, 0.81, 0.965]\n    return steps.map((step) => mixColors(bg, ink, step))\n  }"},{"id":"color_generateneutralscale_lift","label":"lift()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L174-L179","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L174"}],"snippet":"lift = (tone: number) =>\n      oklchToHex({\n        l: base.l + (1 - base.l) * tone,\n        c: base.c * Math.max(0, 1 - tone),\n        h: base.h,\n      })"},{"id":"color_generateneutralscale_sink","label":"sink()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L180-L185","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L180"}],"snippet":"sink = (tone: number) =>\n      oklchToHex({\n        l: base.l * (1 - tone),\n        c: base.c * Math.max(0, 1 - tone * (isDark ? 0.12 : 0.3)),\n        h: base.h,\n      })"},{"id":"color_generatealphascale","label":"generateAlphaScale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L218-L234","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L218"}],"snippet":"export function generateAlphaScale(scale: HexColor[], isDark: boolean): HexColor[] {\n  const alphas = isDark\n    ? [0.02, 0.04, 0.08, 0.12, 0.16, 0.2, 0.26, 0.36, 0.44, 0.52, 0.76, 0.96]\n    : [0.01, 0.03, 0.06, 0.09, 0.12, 0.15, 0.2, 0.28, 0.48, 0.56, 0.64, 0.88]\n\n  return scale.map((hex, i) => {\n    const { r, g, b } = hexToRgb(hex)\n    const a = alphas[i]\n\n    const bg = isDark ? 0 : 1\n    const blendedR = r * a + bg * (1 - a)\n    const blendedG = g * a + bg * (1 - a)\n    const blendedB = b * a + bg * (1 - a)\n\n    return rgbToHex(blendedR, blendedG, blendedB)\n  })\n}"},{"id":"color_mixcolors","label":"mixColors()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L236-L246","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L236"}],"snippet":"export function mixColors(color1: HexColor, color2: HexColor, amount: number): HexColor {\n  const c1 = hexToOklch(color1)\n  const c2 = hexToOklch(color2)\n  const delta = ((((c2.h - c1.h) % 360) + 540) % 360) - 180\n\n  return oklchToHex({\n    l: c1.l + (c2.l - c1.l) * amount,\n    c: c1.c + (c2.c - c1.c) * amount,\n    h: c1.h + delta * amount,\n  })\n}"},{"id":"color_shift","label":"shift()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L248-L255","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L248"}],"snippet":"export function shift(color: HexColor, value: { l?: number; c?: number; h?: number }): HexColor {\n  const base = hexToOklch(color)\n  return oklchToHex({\n    l: base.l + (value.l ?? 0),\n    c: base.c * (value.c ?? 1),\n    h: base.h + (value.h ?? 0),\n  })\n}"},{"id":"color_contrastratio","label":"contrastRatio()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L257-L268","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L257"}],"snippet":"export function contrastRatio(foreground: HexColor, background: HexColor) {\n  const linear = (c: number) => (c <= 0.03928 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4)\n  const luminance = (hex: HexColor) => {\n    const { r, g, b } = hexToRgb(hex)\n    return 0.2126 * linear(r) + 0.587 * linear(g) + 0.0722 * linear(b)\n  }\n  const fg = luminance(foreground)\n  const bg = luminance(background)\n  const lighter = Math.max(fg, bg)\n  const darker = Math.min(fg, bg)\n  return (lighter + 0.05) / (darker + 0.05)\n}"},{"id":"color_contrastratio_linear","label":"linear()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L258","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L258"}],"snippet":"linear = (c: number) => (c <= 0.03928 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4)"},{"id":"color_contrastratio_luminance","label":"luminance()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L259-L262","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L259"}],"snippet":"luminance = (hex: HexColor) => {\n    const { r, g, b } = hexToRgb(hex)\n    return 0.2126 * linear(r) + 0.587 * linear(g) + 0.0722 * linear(b)\n  }"},{"id":"color_blend","label":"blend()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L270-L278","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L270"}],"snippet":"export function blend(color: HexColor, background: HexColor, alpha: number): HexColor {\n  const fg = hexToRgb(color)\n  const bg = hexToRgb(background)\n  return rgbToHex(\n    fg.r * alpha + bg.r * (1 - alpha),\n    fg.g * alpha + bg.g * (1 - alpha),\n    fg.b * alpha + bg.b * (1 - alpha),\n  )\n}"},{"id":"color_lighten","label":"lighten()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L280-L286","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L280"}],"snippet":"export function lighten(color: HexColor, amount: number): HexColor {\n  const oklch = hexToOklch(color)\n  return oklchToHex({\n    ...oklch,\n    l: clamp(oklch.l + amount, 0, 1),\n  })\n}"},{"id":"color_darken","label":"darken()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L288-L294","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L288"}],"snippet":"export function darken(color: HexColor, amount: number): HexColor {\n  const oklch = hexToOklch(color)\n  return oklchToHex({\n    ...oklch,\n    l: clamp(oklch.l - amount, 0, 1),\n  })\n}"},{"id":"color_withalpha","label":"withAlpha()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L296-L299","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/color.ts","source_location":"L296"}],"snippet":"export function withAlpha(color: HexColor, alpha: number): string {\n  const { r, g, b } = hexToRgb(color)\n  return `rgba(${Math.round(r * 255)}, ${Math.round(g * 255)}, ${Math.round(b * 255)}, ${alpha})`\n}"}],"edges":[{"source":"color","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman