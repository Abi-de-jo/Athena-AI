{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_session_retry","nodes":[{"id":"packages_opencode_src_session_retry","label":"retry.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L1"}]},{"id":"packages_opencode_src_session_retry_cap","label":"cap()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L31-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L31"}],"snippet":"function cap(ms: number) {\n  return Math.min(ms, RETRY_MAX_DELAY)\n}"},{"id":"packages_opencode_src_session_retry_delay","label":"delay()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L35-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L35"}],"snippet":"export function delay(attempt: number, error?: SessionV1.APIError) {\n  if (error) {\n    const headers = error.data.responseHeaders\n    if (headers) {\n      const retryAfterMs = headers[\"retry-after-ms\"]\n      if (retryAfterMs) {\n        const parsedMs = Number.parseFloat(retryAfterMs)\n        if (!Number.isNaN(parsedMs)) {\n          return cap(parsedMs)\n        }\n      }\n\n      const retryAfter = headers[\"retry-after\"]\n      if (retryAfter) {\n        const parsedSeconds = Number.parseFloat(retryAfter)\n        if (!Number.isNaN(parsedSeconds)) {\n          // convert seconds to milliseconds\n          return cap(Math.ceil(parsedSeconds * 1000))\n        }\n        // Try parsing as HTTP date format\n        const parsed = Date.parse(retryAfter) - Date.now()\n        if (!Number.isNaN(parsed) && parsed > 0) {\n          return cap(Math.ceil(parsed))\n        }\n      }"},{"id":"packages_opencode_src_session_retry_retryable","label":"retryable()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L68-L152","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L68"}],"snippet":"export function retryable(error: Err, provider: string) {\n  // context overflow errors should not be retried\n  if (SessionV1.ContextOverflowError.isInstance(error)) return undefined\n  if (SessionV1.APIError.isInstance(error)) {\n    const status = error.data.statusCode\n    // 5xx errors are transient server failures and should always be retried,\n    // even when the provider SDK doesn't explicitly mark them as retryable.\n    if (!error.data.isRetryable && !(status !== undefined && status >= 500)) return undefined\n    if (error.data.responseBody?.includes(\"FreeUsageLimitError\")) {\n      return {\n        message: GO_UPSELL_MESSAGE,\n        action: {\n          reason: \"free_tier_limit\",\n          provider,\n          title: \"Free limit reached\",\n          message: \"Subscribe to OpenCode Go for reliable access to the best open-source models, starting at $5/month.\",\n          label: \"subscribe\",\n          link: GO_UPSELL_URL,\n        },\n      }\n    }\n    if (error.data.responseBody?.includes(\"GoUsageLimitError\")) {\n      const body = parseJSON(error.data.responseBody)\n      const workspace = str(body?.metadata?.workspace)\n      const limitName = str(body?.metadata?.limitName)"},{"id":"packages_opencode_src_session_retry_str","label":"str()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L154-L157","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L154"}],"snippet":"function str(value: unknown) {\n  if (value === undefined || value === null) return \"\"\n  return String(value)\n}"},{"id":"packages_opencode_src_session_retry_num","label":"num()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L159-L163","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L159"}],"snippet":"function num(value: unknown) {\n  const parsed = Number.parseFloat(str(value))\n  if (Number.isNaN(parsed)) return undefined\n  return parsed\n}"},{"id":"packages_opencode_src_session_retry_parsejson","label":"parseJSON()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L165-L174","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L165"}],"snippet":"function parseJSON(value: unknown) {\n  return iife(() => {\n    try {\n      if (typeof value !== \"string\") return undefined\n      return JSON.parse(value)\n    } catch {\n      return undefined\n    }\n  })\n}"},{"id":"packages_opencode_src_session_retry_policy","label":"policy()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L176-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L176"}],"snippet":"export function policy(opts: {\n  provider: string\n  parse: (error: unknown) => Err\n  set: (input: { attempt: number; message: string; action?: Retryable[\"action\"]; next: number }) => Effect.Effect<void>\n}) {\n  return Schedule.fromStepWithMetadata(\n    Effect.succeed((meta: Schedule.InputMetadata<unknown>) => {\n      const error = opts.parse(meta.input)\n      const retry = retryable(error, opts.provider)\n      if (!retry) return Cause.done(meta.attempt)\n      return Effect.gen(function* () {\n        const wait = delay(meta.attempt, SessionV1.APIError.isInstance(error) ? error : undefined)\n        const now = yield* Clock.currentTimeMillis\n        yield* opts.set({\n          attempt: meta.attempt,\n          message: retry.message,\n          action: retry.action,\n          next: now + wait,\n        })\n        return [meta.attempt, Duration.millis(wait)] as [number, Duration.Duration]\n      })\n    }),\n  )\n}"}],"edges":[{"source":"packages_opencode_src_session_retry","target":"error","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_session_retry","target":"session","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/retry.ts","source_location":"L2","layer":"base","provenance":[{"capabil