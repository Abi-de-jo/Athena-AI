{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_desktop_src_main_sidecar","nodes":[{"id":"packages_desktop_src_main_sidecar","label":"sidecar.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L1"}]},{"id":"packages_desktop_src_main_sidecar_start","label":"start()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L51-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L51"}],"snippet":"async function start(command: StartCommand) {\n  try {\n    prepareSidecarEnv(command.password, command.userDataPath)\n    ensureLoopbackNoProxy()\n    useSystemCertificates()\n    useEnvProxy()\n    const { Server } = await import(\"virtual:opencode-server\")\n\n    listener = await Server.listen({\n      port: command.port,\n      hostname: command.hostname,\n      username: \"rimuru-ai\",\n      password: command.password,\n      cors: [\"oc://renderer\"],\n    })\n    parentPort.postMessage({ type: \"ready\" })\n  } catch (error) {\n    parentPort.postMessage({ type: \"error\", error: serializeError(error) })\n    setImmediate(() => process.exit(1))\n  }\n}"},{"id":"packages_desktop_src_main_sidecar_stop","label":"stop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L73-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L73"}],"snippet":"async function stop() {\n  try {\n    await listener?.stop()\n  } finally {\n    listener = undefined\n    parentPort.postMessage({ type: \"stopped\" })\n    setImmediate(() => process.exit(0))\n  }\n}"},{"id":"packages_desktop_src_main_sidecar_preparesidecarenv","label":"prepareSidecarEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L83-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L83"}],"snippet":"function prepareSidecarEnv(password: string, userDataPath: string) {\n  Object.assign(process.env, {\n    OPENCODE_SERVER_USERNAME: \"rimuru-ai\",\n    OPENCODE_SERVER_PASSWORD: password,\n    XDG_STATE_HOME: process.env.XDG_STATE_HOME ?? userDataPath,\n  })\n}"},{"id":"packages_desktop_src_main_sidecar_ensureloopbacknoproxy","label":"ensureLoopbackNoProxy()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L91-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L91"}],"snippet":"function ensureLoopbackNoProxy() {\n  const loopback = [\"127.0.0.1\", \"localhost\", \"::1\"]\n  const upsert = (key: string) => {\n    const items = (process.env[key] ?? \"\")\n      .split(\",\")\n      .map((value: string) => value.trim())\n      .filter((value: string) => Boolean(value))\n\n    for (const host of loopback) {\n      if (items.some((value: string) => value.toLowerCase() === host)) continue\n      items.push(host)\n    }\n\n    process.env[key] = items.join(\",\")\n  }\n\n  upsert(\"NO_PROXY\")\n  upsert(\"no_proxy\")\n}"},{"id":"packages_desktop_src_main_sidecar_ensureloopbacknoproxy_upsert","label":"upsert()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L93-L105","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L93"}],"snippet":"upsert = (key: string) => {\n    const items = (process.env[key] ?? \"\")\n      .split(\",\")\n      .map((value: string) => value.trim())\n      .filter((value: string) => Boolean(value))\n\n    for (const host of loopback) {\n      if (items.some((value: string) => value.toLowerCase() === host)) continue\n      items.push(host)\n    }\n\n    process.env[key] = items.join(\",\")\n  }"},{"id":"packages_desktop_src_main_sidecar_usesystemcertificates","label":"useSystemCertificates()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L111-L120","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L111"}],"snippet":"function useSystemCertificates() {\n  try {\n    const nodeTls = tls as NodeTlsWithSystemCertificates\n    nodeTls.setDefaultCACertificates([\n      ...new Set([...nodeTls.getCACertificates(\"default\"), ...nodeTls.getCACertificates(\"system\")]),\n    ])\n  } catch (error) {\n    console.warn(\"failed to load system certificates\", error)\n  }\n}"},{"id":"packages_desktop_src_main_sidecar_useenvproxy","label":"useEnvProxy()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L122-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L122"}],"snippet":"function useEnvProxy() {\n  try {\n    ;(http as NodeHttpWithEnvProxy).setGlobalProxyFromEnv()\n  } catch (error) {\n    console.warn(\"failed to load proxy environment\", error)\n  }\n}"},{"id":"packages_desktop_src_main_sidecar_parsecommand","label":"parseCommand()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L130-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L130"}],"snippet":"function parseCommand(value: unknown): SidecarCommand | undefined {\n  if (!value || typeof value !== \"object\") return\n  const command = value as Partial<StartCommand | StopCommand>\n  if (command.type === \"stop\") return { type: \"stop\" }\n  if (command.type !== \"start\") return\n  if (typeof command.hostname !== \"string\") return\n  if (typeof command.port !== \"number\") return\n  if (typeof command.password !== \"string\") return\n  if (typeof command.userDataPath !== \"string\") return\n  return {\n    type: \"start\",\n    hostname: command.hostname,\n    port: command.port,\n    password: command.password,\n    userDataPath: command.userDataPath,\n  }\n}"},{"id":"packages_desktop_src_main_sidecar_serializeerror","label":"serializeError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L148-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L148"}],"snippet":"function serializeError(error: unknown) {\n  if (error instanceof Error) return { message: error.message, stack: error.stack }\n  return { message: String(error) }\n}"},{"id":"packages_desktop_src_main_sidecar_getparentport","label":"getParentPort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L153-L157","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L153"}],"snippet":"function getParentPort() {\n  const port = process.parentPort as ParentPort | undefined\n  if (!port) throw new Error(\"Sidecar parent port unavailable\")\n  return port\n}"}],"edges":[{"source":"packages_desktop_src_main_sidecar","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L1"}],"weight":1},{"source":"packages_desktop_src_main_sidecar","target":"tls","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L2"}],"weight":1},{"source":"packages_desktop_src_main_sidecar","target":"packages_desktop_src_main_sidecar_start","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/sidecar.ts","source_location":"L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdam