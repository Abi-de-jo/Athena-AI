    const db = yield* DrizzleClient\n\n      const listDaily = Effect.fn(\"ModelStatRepo.listDaily\")(function* () {\n        return yield* Effect.tryPromise({\n          try: () =>\n            db\n              .select({\n                periodKey: modelStat.period_key,\n                updatedAt: modelStat.updated_at,\n                tier: modelStat.tier,\n                provider: modelStat.provider,\n                model: modelStat.model,\n                sessions: modelStat.sessions,\n                inputTokens: modelStat.input_tokens,\n                outputTokens: modelStat.output_tokens,\n                reasoningTokens: modelStat.reasoning_tokens,\n                cacheReadTokens: modelStat.cache_read_tokens,\n                totalTokens: modelStat.total_tokens,\n                inputCostMicrocents: modelStat.input_cost_microcents,"},{"id":"packages_stats_core_src_domain_model_rowsfromaggregates","label":"rowsFromAggregates()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model.ts","source_location":"L165-L176","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model.ts","source_location":"L165"}],"snippet":"export function rowsFromAggregates(aggregates: ModelStatAggregate[]) {\n  return rankRows([\n    ...synthesizeAllTierRows(\n      collapseRows(aggregates.filter((item) => item.grain === \"week\").map(toRow), dimensionKey),\n      dimensionKey,\n    ),\n    ...synthesizeAllTierRows(\n      collapseRows(aggregates.filter((item) => item.grain === \"day\").map(toRow), dimensionKey),\n      dimensionKey,\n    ),\n  ])\n}"},{"id":"packages_stats_core_src_domain_model_torow","label":"toRow()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model.ts","source_location":"L178-L185","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model.ts","source_location":"L178"}],"snippet":"function toRow(data: ModelStatAggregate): ModelStatRow {\n  return {\n    ...toStatBaseRow(data),\n    provider: data.provider,\n    model: data.model,\n    provider_model: data.provider_model,\n  }\n}"},{"id":"packages_stats_core_src_domain_model_rankrows","label":"rankRows()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model.ts","source_location":"L187-L205","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model.ts","source_location":"L187"}],"snippet":"function rankRows(rows: ModelStatRow[]) {\n  return Object.values(\n    rows.reduce<Record<string, ModelStatRow[]>>((result, row) => {\n      const key = statPeriodKey(row)\n      result[key] = [...(result[key] ?? []), row]\n      return result\n    }, {}),\n  ).flatMap((group) => {\n    const tokenRanks = rankBy(group, (row) => row.total_tokens ?? 0)\n    const requestRanks = rankBy(group, (row) => row.requests ?? 0)\n    const costRanks = rankBy(group, (row) => row.total_cost_microcents ?? 0)\n    return group.map((row) => ({\n      ...row,\n      rank_by_tokens: tokenRanks.get(row) ?? null,\n      rank_by_requests: requestRanks.get(row) ?? null,\n      rank_by_cost: costRanks.get(row) ?? null,\n    }))\n  })\n}"},{"id":"packages_stats_core_src_domain_model_dimensionkey","label":"dimensionKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model.ts","source_location":"L207-L209","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/mod