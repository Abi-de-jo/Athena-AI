{"__madarTsExtractorVersion":67,"__madarFileStem":"session-context-breakdown","nodes":[{"id":"session_context_breakdown","label":"session-context-breakdown.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L1"}]},{"id":"session_context_breakdown_estimatetokens","label":"estimateTokens()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L12"}],"snippet":"estimateTokens = (chars: number) => Math.ceil(chars / 4)"},{"id":"session_context_breakdown_topercent","label":"toPercent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L13","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L13"}],"snippet":"toPercent = (tokens: number, input: number) => (tokens / input) * 100"},{"id":"session_context_breakdown_topercentlabel","label":"toPercentLabel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L14","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L14"}],"snippet":"toPercentLabel = (tokens: number, input: number) => Math.round(toPercent(tokens, input) * 10) / 10"},{"id":"session_context_breakdown_charsfromuserpart","label":"charsFromUserPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L16-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L16"}],"snippet":"charsFromUserPart = (part: Part) => {\n  if (part.type === \"text\") return part.text.length\n  if (part.type === \"file\") return part.source?.text.value.length ?? 0\n  if (part.type === \"agent\") return part.source?.value.length ?? 0\n  return 0\n}"},{"id":"session_context_breakdown_charsfromassistantpart","label":"charsFromAssistantPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L23-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L23"}],"snippet":"charsFromAssistantPart = (part: Part) => {\n  if (part.type === \"text\") return { assistant: part.text.length, tool: 0 }\n  if (part.type === \"reasoning\") return { assistant: part.text.length, tool: 0 }\n  if (part.type !== \"tool\") return { assistant: 0, tool: 0 }\n\n  const input = Object.keys(part.state.input).length * 16\n  if (part.state.status === \"pending\") return { assistant: 0, tool: input + part.state.raw.length }\n  if (part.state.status === \"completed\") return { assistant: 0, tool: input + part.state.output.length }\n  if (part.state.status === \"error\") return { assistant: 0, tool: input + part.state.error.length }\n  return { assistant: 0, tool: input }\n}"},{"id":"session_context_breakdown_build","label":"build()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L35-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L35"}],"snippet":"build = (\n  tokens: { system: number; user: number; assistant: number; tool: number; other: number },\n  input: number,\n) => {\n  return [\n    {\n      key: \"system\",\n      tokens: tokens.system,\n    },\n    {\n      key: \"user\",\n      tokens: tokens.user,\n    },\n    {\n      key: \"assistant\",\n      tokens: tokens.assistant,\n    },\n    {\n      key: \"tool\",\n      tokens: tokens.tool,\n    },\n    {\n      key: \"other\",\n      tokens: tokens.other,\n    },"},{"id":"session_context_breakdown_estimatesessioncontextbreakdown","label":"estimateSessionContextBreakdown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L70-L132","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L70"}],"snippet":"export function estimateSessionContextBreakdown(args: {\n  messages: Message[]\n  parts: Record<string, Part[] | undefined>\n  input: number\n  systemPrompt?: string\n}) {\n  if (!args.input) return []\n\n  const counts = args.messages.reduce(\n    (acc, msg) => {\n      const parts = args.parts[msg.id] ?? []\n      if (msg.role === \"user\") {\n        const user = parts.reduce((sum, part) => sum + charsFromUserPart(part), 0)\n        return { ...acc, user: acc.user + user }\n      }\n\n      if (msg.role !== \"assistant\") return acc\n      const assistant = parts.reduce(\n        (sum, part) => {\n          const next = charsFromAssistantPart(part)\n          return {\n            assistant: sum.assistant + next.assistant,\n            tool: sum.tool + next.tool,\n          }\n        },"}],"edges":[{"source":"session_context_breakdown","target":"client","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L1"}],"weight":1},{"source":"session_context_breakdown","target":"session_context_breakdown_estimatetokens","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L12"}],"weight":1},{"source":"session_context_breakdown","target":"session_context_breakdown_topercent","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-context-breakdown.ts","source_location":"L13","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file