{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_acp_permission","nodes":[{"id":"packages_opencode_src_acp_permission","label":"permission.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L1"}]},{"id":"packages_opencode_src_acp_permission_handler","label":"Handler","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L19-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L19"}],"snippet":"export class Handler {\n  private readonly queues = new Map<string, Promise<void>>()\n\n  constructor(\n    private readonly input: {\n      sdk: OpencodeClient\n      connection: Connection\n      session: ACPSession.Interface\n    },\n  ) {}\n\n  handle(event: PermissionEvent) {\n    const permission = event.properties\n    const previous = this.queues.get(permission.sessionID) ?? Promise.resolve()\n    const next = previous\n      .then(() => this.process(event))\n      .catch(() => {})\n      .finally(() => {\n        if (this.queues.get(permission.sessionID) === next) {\n          this.queues.delete(permission.sessionID)\n        }\n      })\n    this.queues.set(permission.sessionID, next)\n  }"},{"id":"packages_opencode_src_acp_permission_handler_constructor","label":".constructor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L22-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L22"}],"snippet":"constructor(\n    private readonly input: {\n      sdk: OpencodeClient\n      connection: Connection\n      session: ACPSession.Interface\n    },\n  ) {}"},{"id":"packages_opencode_src_acp_permission_handler_handle","label":".handle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L30-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L30"}],"snippet":"handle(event: PermissionEvent) {\n    const permission = event.properties\n    const previous = this.queues.get(permission.sessionID) ?? Promise.resolve()\n    const next = previous\n      .then(() => this.process(event))\n      .catch(() => {})\n      .finally(() => {\n        if (this.queues.get(permission.sessionID) === next) {\n          this.queues.delete(permission.sessionID)\n        }\n      })\n    this.queues.set(permission.sessionID, next)\n  }"},{"id":"packages_opencode_src_acp_permission_handler_process","label":".process()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L44-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L44"}],"snippet":"private async process(event: PermissionEvent) {\n    const permission = event.properties\n    const session = await Effect.runPromise(this.input.session.tryGet(permission.sessionID))\n    if (!session) return\n\n    if (!this.input.connection.requestPermission) {\n      await this.reply(permission.id, \"reject\", session.cwd)\n      return\n    }\n\n    const result = await this.input.connection\n      .requestPermission({\n        sessionId: permission.sessionID,\n        toolCall: {\n          toolCallId: permission.tool?.callID ?? permission.id,\n          status: \"pending\",\n          title: permission.permission,\n          rawInput: permission.metadata,\n          kind: toToolKind(permission.permission),\n          locations: toLocations(permission.permission, permission.metadata),\n        },\n        options: permissionOptions,\n      })\n      .catch(async () => {\n        await this.reply(permission.id, \"reject\", session.cwd)"},{"id":"packages_opencode_src_acp_permission_handler_reply","label":".reply()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L87-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L87"}],"snippet":"private async reply(requestID: string, reply: Reply, directory: string) {\n    await this.input.sdk.permission.reply({\n      requestID,\n      reply,\n      directory,\n    })\n  }"},{"id":"packages_opencode_src_acp_permission_handler_writeproposededit","label":".writeProposedEdit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L95-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L95"}],"snippet":"private async writeProposedEdit(sessionId: string, metadata: ToolInput) {\n    const filepath = stringValue(metadata.filepath)\n    const diff = stringValue(metadata.diff)\n    if (!filepath || !diff || !this.input.connection.writeTextFile) return\n\n    const content = (await exists(filepath)) ? await readText(filepath) : \"\"\n    const next = applyPatch(content, diff)\n    if (next === false) {\n      return\n    }\n\n    void this.input.connection.writeTextFile({\n      sessionId,\n      path: filepath,\n      content: next,\n    })\n  }"},{"id":"packages_opencode_src_acp_permission_selectedreply","label":"selectedReply()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L114-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L114"}],"snippet":"function selectedReply(result: RequestPermissionResponse): Reply {\n  if (result.outcome.outcome !== \"selected\") return \"reject\"\n  if (result.outcome.optionId === \"once\" || result.outcome.optionId === \"always\") return result.outcome.optionId\n  return \"reject\"\n}"},{"id":"packages_opencode_src_acp_permission_stringvalue","label":"stringValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L120-L122","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L120"}],"snippet":"function stringValue(value: unknown) {\n  return typeof value === \"string\" ? value : undefined\n}"}],"edges":[{"source":"packages_opencode_src_acp_permission","target":"sdk","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/permission.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/p