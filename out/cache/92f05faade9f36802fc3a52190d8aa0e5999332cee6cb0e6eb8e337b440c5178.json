{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_server_shared_ui","nodes":[{"id":"packages_rimuru_src_server_shared_ui","label":"ui.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_server_shared_ui_csp","label":"csp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L11-L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L11"}],"snippet":"csp = (hash = \"\") =>\n  `default-src 'self'; script-src 'self' 'wasm-unsafe-eval'${hash ? ` 'sha256-${hash}'` : \"\"}; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; media-src 'self' data:; connect-src * data:`"},{"id":"packages_rimuru_src_server_shared_ui_themepreloadhash","label":"themePreloadHash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L15-L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L15"}],"snippet":"export function themePreloadHash(body: string) {\n  return body.match(/<script\\b(?![^>]*\\bsrc\\s*=)[^>]*\\bid=(['\"])oc-theme-preload-script\\1[^>]*>([\\s\\S]*?)<\\/script>/i)\n}"},{"id":"packages_rimuru_src_server_shared_ui_cspforhtml","label":"cspForHtml()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L19-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L19"}],"snippet":"export function cspForHtml(body: string) {\n  const match = themePreloadHash(body)\n  return csp(match ? createHash(\"sha256\").update(match[2]).digest(\"base64\") : \"\")\n}"},{"id":"packages_rimuru_src_server_shared_ui_requestbody","label":"requestBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L24-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L24"}],"snippet":"function requestBody(request: HttpServerRequest.HttpServerRequest) {\n  if (request.method === \"GET\" || request.method === \"HEAD\") return HttpBody.empty\n  const len = request.headers[\"content-length\"]\n  return HttpBody.stream(request.stream, request.headers[\"content-type\"], len === undefined ? undefined : Number(len))\n}"},{"id":"packages_rimuru_src_server_shared_ui_proxyresponseheaders","label":"proxyResponseHeaders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L30-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L30"}],"snippet":"function proxyResponseHeaders(headers: Record<string, string>) {\n  const result = new Headers(headers)\n  // FetchHttpClient exposes decoded response bodies, so forwarding upstream\n  // transfer metadata makes browsers decode already-decoded assets again.\n  result.delete(\"content-encoding\")\n  result.delete(\"content-length\")\n  result.delete(\"transfer-encoding\")\n  return result\n}"},{"id":"packages_rimuru_src_server_shared_ui_upstreamurl","label":"upstreamURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L40-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L40"}],"snippet":"export function upstreamURL(path: string) {\n  return new URL(path, UI_UPSTREAM).toString()\n}"},{"id":"packages_rimuru_src_server_shared_ui_embeddedui","label":"embeddedUI()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L44-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L44"}],"snippet":"export function embeddedUI(disableEmbeddedWebUi: boolean) {\n  if (disableEmbeddedWebUi) return Promise.resolve(null)\n  return (embeddedUIPromise ??=\n    // @ts-expect-error - generated file at build time\n    import(\"opencode-web-ui.gen.ts\").then((module) => module.default as Record<string, string>).catch(() => null))\n}"},{"id":"packages_rimuru_src_server_shared_ui_notfound","label":"notFound()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L51-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L51"}],"snippet":"function notFound() {\n  return HttpServerResponse.jsonUnsafe({ error: \"Not Found\" }, { status: 404 })\n}"},{"id":"packages_rimuru_src_server_shared_ui_embeddeduiresponse","label":"embeddedUIResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L55-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L55"}],"snippet":"function embeddedUIResponse(file: string, body: Uint8Array) {\n  const mime = FSUtil.mimeType(file)\n  const headers = new Headers({ \"content-type\": mime })\n  if (mime.startsWith(\"text/html\")) {\n    headers.set(\"content-security-policy\", cspForHtml(new TextDecoder().decode(body)))\n  }\n  return HttpServerResponse.raw(body, { headers })\n}"},{"id":"packages_rimuru_src_server_shared_ui_serveembeddeduieffect","label":"serveEmbeddedUIEffect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L64-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L64"}],"snippet":"export function serveEmbeddedUIEffect(\n  requestPath: string,\n  fs: FSUtil.Interface,\n  embeddedWebUI: Record<string, string>,\n) {\n  const file = embeddedWebUI[requestPath.replace(/^\\//, \"\")] ?? embeddedWebUI[\"index.html\"] ?? null\n  if (!file) return Effect.succeed(notFound())\n\n  return fs.readFile(file).pipe(\n    Effect.map((body) => embeddedUIResponse(file, body)),\n    Effect.catchReason(\"PlatformError\", \"NotFound\", () => Effect.succeed(notFound())),\n  )\n}"},{"id":"packages_rimuru_src_server_shared_ui_serveuieffect","label":"serveUIEffect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L78-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L78"}],"snippet":"export function serveUIEffect(\n  request: HttpServerRequest.HttpServerRequest,\n  services: { fs: FSUtil.Interface; client: HttpClient.HttpClient; disableEmbeddedWebUi: boolean },\n) {\n  return Effect.gen(function* () {\n    const embeddedWebUI = yield* Effect.promise(() => embeddedUI(services.disableEmbeddedWebUi))\n    const path = new URL(request.url, \"http://localhost\").pathname\n\n    if (embeddedWebUI) return yield* serveEmbeddedUIEffect(path, services.fs, embeddedWebUI)\n\n    const response = yield* services.client.execute(\n      HttpClientRequest.make(request.method)(upstreamURL(path), {\n        headers: ProxyUtil.headers(request.headers, { host: UI_UPSTREAM.host }),\n        body: requestBody(request),\n      }),\n    )\n    const headers = proxyResponseHeaders(response.headers)\n\n    if (response.headers[\"content-type\"]?.includes(\"text/html\")) {\n      const body = yield* response.text\n      headers.set(\"Content-Security-Policy\", cspForHtml(body))\n      return HttpServerResponse.text(body, { status: response.status, headers })\n    }\n\n    headers.set(\"Content-Security-Policy\", csp())"}],"edges":[{"source":"packages_rimuru_src_server_shared_ui","target":"fs_util","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/shared/ui.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_server_shared_ui","target":"effect","relation":"imports_from"