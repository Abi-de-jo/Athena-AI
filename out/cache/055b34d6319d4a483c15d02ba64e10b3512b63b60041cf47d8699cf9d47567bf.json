{"__madarTsExtractorVersion":67,"__madarFileStem":"openai-auth","nodes":[{"id":"openai_auth","label":"openai-auth.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L1"}]},{"id":"openai_auth_headers","label":"headers()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L148-L150","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L148"}],"snippet":"function headers(contentType: string) {\n  return { \"Content-Type\": contentType, \"User-Agent\": `opencode/${InstallationVersion}` }\n}"},{"id":"openai_auth_exchange","label":"exchange()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L152-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L152"}],"snippet":"function exchange(code: string, redirect: string, pkce: Pkce) {\n  return request<TokenResponse>(`${issuer}/oauth/token`, {\n    method: \"POST\",\n    headers: headers(\"application/x-www-form-urlencoded\"),\n    body: new URLSearchParams({\n      grant_type: \"authorization_code\",\n      code,\n      redirect_uri: redirect,\n      client_id: clientID,\n      code_verifier: pkce.verifier,\n    }).toString(),\n  })\n}"},{"id":"openai_auth_refresh","label":"refresh()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L166-L184","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L166"}],"snippet":"function refresh(value: Credential.OAuth) {\n  return request<TokenResponse>(`${issuer}/oauth/token`, {\n    method: \"POST\",\n    headers: headers(\"application/x-www-form-urlencoded\"),\n    body: new URLSearchParams({\n      grant_type: \"refresh_token\",\n      refresh_token: value.refresh,\n      client_id: clientID,\n    }).toString(),\n  }).pipe(\n    Effect.map((tokens) => {\n      const next = credential(value.methodID, tokens)\n      return new Credential.OAuth({\n        ...next,\n        metadata: next.metadata ?? value.metadata,\n      })\n    }),\n  )\n}"},{"id":"openai_auth_request","label":"request()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L186-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L186"}],"snippet":"function request<A>(url: string, init: RequestInit) {\n  return Effect.tryPromise({\n    try: async (signal) => {\n      const response = await fetch(url, { ...init, signal })\n      if (!response.ok) throw new Error(`Request failed: ${response.status}`)\n      return response.json() as Promise<A>\n    },\n    catch: (cause) => cause,\n  })\n}"},{"id":"openai_auth_credential","label":"credential()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L197-L207","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L197"}],"snippet":"function credential(methodID: Integration.MethodID, tokens: TokenResponse) {\n  const accountID = extractAccountID(tokens)\n  return new Credential.OAuth({\n    type: \"oauth\",\n    methodID,\n    refresh: tokens.refresh_token,\n    access: tokens.access_token,\n    expires: Date.now() + (tokens.expires_in ?? 3600) * 1000,\n    metadata: accountID ? { accountID } : undefined,\n  })\n}"},{"id":"openai_auth_generatepkce","label":"generatePKCE()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L209-L214","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L209"}],"snippet":"async function generatePKCE(): Promise<Pkce> {\n  const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~\"\n  const verifier = Array.from(crypto.getRandomValues(new Uint8Array(43)), (byte) => chars[byte % chars.length]).join(\"\")\n  const challenge = base64UrlEncode(await crypto.subtle.digest(\"SHA-256\", new TextEncoder().encode(verifier)))\n  return { verifier, challenge }\n}"},{"id":"openai_auth_base64urlencode","label":"base64UrlEncode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L216-L218","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L216"}],"snippet":"function base64UrlEncode(buffer: ArrayBuffer) {\n  return Buffer.from(buffer).toString(\"base64url\")\n}"},{"id":"openai_auth_authorizeurl","label":"authorizeURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L220-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L220"}],"snippet":"function authorizeURL(redirect: string, pkce: Pkce, state: string) {\n  return `${issuer}/oauth/authorize?${new URLSearchParams({\n    response_type: \"code\",\n    client_id: clientID,\n    redirect_uri: redirect,\n    scope: \"openid profile email offline_access\",\n    code_challenge: pkce.challenge,\n    code_challenge_method: \"S256\",\n    id_token_add_organizations: \"true\",\n    codex_cli_simplified_flow: \"true\",\n    state,\n    originator: \"rimuru-ai\",\n  })}`\n}"},{"id":"openai_auth_extractaccountid","label":"extractAccountID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L235-L237","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L235"}],"snippet":"function extractAccountID(tokens: TokenResponse) {\n  return claim(tokens.id_token) ?? claim(tokens.access_token)\n}"},{"id":"openai_auth_claim","label":"claim()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L239-L252","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L239"}],"snippet":"function claim(token: string) {\n  const part = token.split(\".\")[1]\n  if (!part) return\n  try {\n    const claims = JSON.parse(Buffer.from(part, \"base64url\").toString()) as Claims\n    return (\n      claims.chatgpt_account_id ??\n      claims[\"https://api.openai.com/auth\"]?.chatgpt_account_id ??\n      claims.organizations?.[0]?.id\n    )\n  } catch {\n    return\n  }\n}"},{"id":"openai_auth_errorpage","label":"errorPage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L256-L257","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L256"}],"snippet":"errorPage = (message: string) =>\n  `<!doctype html><title>OpenCode</title><h1>Authorization failed</h1><p>${message.replace(/[&<>\"']/g, \"\")}</p>`"}],"edges":[{"source":"openai_auth","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L1"}],"weight":1},{"source":"openai_auth","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/openai-auth.ts","source_location":"L2"}],"weight":1},{"source":"openai_auth","target":"integration","relation":"imports_from","confidence"