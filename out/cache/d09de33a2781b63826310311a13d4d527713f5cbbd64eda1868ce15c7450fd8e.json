ipt","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L105"}],"snippet":"function exportValue(value: unknown): string | undefined {\n  if (typeof value === \"string\") {\n    const next = value.trim()\n    if (next) return next\n    return\n  }\n  if (!isRecord(value)) return\n  for (const key of [\"import\", \"default\"]) {\n    const next = value[key]\n    if (typeof next !== \"string\") continue\n    const hit = next.trim()\n    if (!hit) continue\n    return hit\n  }\n}"},{"id":"install_exportoptions","label":"exportOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L121-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L121"}],"snippet":"function exportOptions(value: unknown): Record<string, unknown> | undefined {\n  if (!isRecord(value)) return\n  const config = value.config\n  if (!isRecord(config)) return\n  return config\n}"},{"id":"install_exporttarget","label":"exportTarget()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L128-L137","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L128"}],"snippet":"function exportTarget(pkg: Record<string, unknown>, kind: Kind) {\n  const exports = pkg.exports\n  if (!isRecord(exports)) return\n  const value = exports[`./${kind}`]\n  const entry = exportValue(value)\n  if (!entry) return\n  return {\n    opts: exportOptions(value),\n  }\n}"},{"id":"install_hasmaintarget","label":"hasMainTarget()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L139-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L139"}],"snippet":"function hasMainTarget(pkg: Record<string, unknown>) {\n  const main = pkg.main\n  if (typeof main !== \"string\") return false\n  return Boolean(main.trim())\n}"},{"id":"install_packagetargets","label":"packageTargets()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L145-L166","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L145"}],"snippet":"function packageTargets(pkg: { json: Record<string, unknown>; dir: string; pkg: string }) {\n  const spec =\n    typeof pkg.json.name === \"string\" && pkg.json.name.trim().length > 0 ? pkg.json.name.trim() : path.basename(pkg.dir)\n  const targets: Target[] = []\n  const server = exportTarget(pkg.json, \"server\")\n  if (server) {\n    targets.push({ kind: \"server\", opts: server.opts })\n  } else if (hasMainTarget(pkg.json)) {\n    targets.push({ kind: \"server\" })\n  }\n\n  const tui = exportTarget(pkg.json, \"tui\")\n  if (tui) {\n    targets.push({ kind: \"tui\", opts: tui.opts })\n  }\n\n  if (!targets.some((item) => item.kind === \"tui\") && readPackageThemes(spec, pkg).length) {\n    targets.push({ kind: \"tui\" })\n  }\n\n  return targets\n}"},{"id":"install_patch","label":"patch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L168-L179","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L168"}],"snippet":"function patch(text: string, path: Array<string | number>, value: unknown, insert = false) {\n  return applyEdits(\n    text,\n    modify(text, path, value, {\n      formattingOptions: {\n        tabSize: 2,\n        insertSpaces: true,\n      },\n      isArrayInsertion: insert,\n    }),\n  )\n}"},{"id":"install_patchpluginlist","label":"patchPluginList()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L181-L257","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L181"}],"snippet":"function patchPluginList(\n  text: string,\n  list: unknown[] | undefined,\n  spec: string,\n  next: unknown,\n  force = false,\n): { mode: Mode; text: string } {\n  const pkg = parsePluginSpecifier(spec).pkg\n  const rows = (list ?? []).map((item, i) => ({\n    item,\n    i,\n    spec: pluginSpec(item),\n  }))\n  const dup = rows.filter((item) => {\n    if (!item.spec) return false\n    if (item.spec === spec) return true\n    if (item.spec.startsWith(\"file://\")) return false\n    return parsePluginSpecifier(item.spec).pkg === pkg\n  })\n\n  if (!dup.length) {\n    if (!list) {\n      return {\n        mode: \"add\",\n        text: patch(text, [\"plugin\"], [next]),"},{"id":"install_installplugin","label":"installPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L259-L281","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L259"}],"snippet":"export async function installPlugin(spec: string, dep: InstallDeps = defaultInstallDeps): Promise<InstallResult> {\n  const target = await dep.resolve(spec).then(\n    (item) => ({\n      ok: true as const,\n      item,\n    }),\n    (error: unknown) => ({\n      ok: false as const,\n      error,\n    }),\n  )\n  if (!target.ok) {\n    return {\n      ok: false,\n      code: \"install_failed\",\n      error: target.error,\n    }\n  }\n  return {\n    ok: true,\n    target: target.item,\n  }\n}"},{"id":"install_readpluginmanifest","label":"readPluginManifest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L283-L331","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L283"}],"snippet":"export async function readPluginManifest(target: string): Promise<ManifestResult> {\n  const pkg = await readPluginPackage(target).then(\n    (item) => ({\n      ok: true as const,\n      item,\n    }),\n    (error: unknown) => ({\n      ok: false as const,\n      error,\n    }),\n  )\n  if (!pkg.ok) {\n    return {\n      ok: false,\n      code: \"manifest_read_failed\",\n      file: target,\n      error: pkg.error,\n    }\n  }\n\n  const targets = await Promise.resolve()\n    .then(() => packageTargets(pkg.item))\n    .then(\n      (item) => ({ ok: true as const, item }),\n      (error: unknown) => ({ ok: false as const, error }),"},{"id":"install_patchdir","label":"patchDir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L333-L338","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L333"}],"snippet":"function patchDir(input: PatchInput) {\n  if (input.global) return input.config ?? Global.Path.config\n  const git = input.vcs === \"git\" && input.worktree !== \"/\"\n  const root = git ? input.worktree : input.directory\n  return path.join(root, \".opencode\")\n}"},{"id":"install_patchname","label":"patchName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L340-L343","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L340"}],"snippet":"function patchName(kind: Kind): \"rimuru-ai\" | \"tui\" {\n  if (kind === \"server\") return \"rimuru-ai\"\n  return \"tui\"\n}"},{"id":"install_patchone","label":"patchOne()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L345-L419","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/install.ts","source_location":"L345"}],"snippet":"async function patchOne(dir: string, target: Target, spec: string, force: boolean, dep: PatchDeps): Promise<PatchOne> {\n  const name = patchName(target.kind)\n  await using _ = await Flock.acquire(`plug-config:${Filesystem.resolve(path.join(dir, name))}`)\n\n  const files = dep.files(dir, name)\n  let cfg = files[0]\n  for (const file of files) {\n    if (!(await dep.exists(file))) continue\n    cfg = file\n    break\n  }\n\n  const src = await dep.readText(cfg).catch((err: NodeJS.ErrnoException) => {\n    if (err.code === \"ENOENT\") return \"{}\"\n    return err\n  })\n  if (src instanceof Error) {\n    return {\n      ok: false,\n      code: \"patch_failed\",\n      kind: target.kind,\n      error: src,\n    }\n  }\n  const text = src.trim() ? sr