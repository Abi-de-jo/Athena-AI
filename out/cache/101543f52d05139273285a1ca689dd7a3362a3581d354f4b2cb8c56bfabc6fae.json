,"provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/tool.ts","source_location":"L151"}],"snippet":"export function define<\n  Parameters extends Schema.Decoder<unknown>,\n  Result extends Metadata,\n  R,\n  ID extends string = string,\n>(\n  id: ID,\n  init: Effect.Effect<Init<Parameters, Result>, never, R>,\n): Effect.Effect<Info<Parameters, Result>, never, R | Truncate.Service | Agent.Service> & { id: ID } {\n  return Object.assign(\n    Effect.gen(function* () {\n      const resolved = yield* init\n      const truncate = yield* Truncate.Service\n      const agents = yield* Agent.Service\n      return { id, init: wrap(id, resolved, truncate, agents) }\n    }),\n    { id },\n  )\n}"},{"id":"packages_rimuru_src_tool_tool_init","label":"init()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/tool.ts","source_location":"L171-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/tool.ts","source_location":"L171"}],"snippet":"export function init<P extends Schema.Decoder<unknown>, M extends Metadata>(\n  info: Info<P, M>,\n): Effect.Effect<Def<P, M>> {\n  return Effect.gen(function* () {\n    const init = yield* info.init()\n    return {\n      ...init,\n      id: info.id,\n    }\n  })\n}"}],"edges":[{"source":"packages_rimuru_src_tool_tool","target":"permission","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/tool.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/tool.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_tool_tool