{"__madarTsExtractorVersion":67,"__madarFileStem":"editor-context.test","nodes":[{"id":"editor_context_test","label":"editor-context.test.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L1"}]},{"id":"editor_context_test_nexttick","label":"nextTick()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L20-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L20"}],"snippet":"function nextTick() {\n  return new Promise<void>((resolve) => queueMicrotask(resolve))\n}"},{"id":"editor_context_test_mounteditorcontext","label":"mountEditorContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L24-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L24"}],"snippet":"function mountEditorContext(WebSocketImpl?: typeof WebSocket) {\n  let editor!: ReturnType<typeof useEditorContext>\n  let dispose!: () => void\n\n  createRoot((nextDispose) => {\n    dispose = nextDispose\n\n    const Consumer = () => {\n      editor = useEditorContext()\n      return null\n    }\n\n    const value = process.env.CLAUDE_CODE_SSE_PORT || process.env.OPENCODE_EDITOR_SSE_PORT\n    return (\n      <TestTuiContexts cwd={process.cwd()} paths={{ home: os.homedir() }}>\n        <EditorContextProvider integration={editorService} WebSocketImpl={WebSocketImpl}>\n          <Consumer />\n        </EditorContextProvider>\n      </TestTuiContexts>\n    )\n  })\n\n  return {\n    editor,\n    dispose,"},{"id":"editor_context_test_mounteditorcontext_consumer","label":"Consumer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L31-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L31"}],"snippet":"Consumer = () => {\n      editor = useEditorContext()\n      return null\n    }"},{"id":"editor_context_test_createwebsocketimpl","label":"createWebSocketImpl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L56-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L56"}],"snippet":"function createWebSocketImpl(...sockets: FakeWebSocket[]) {\n  let index = 0\n\n  return class {\n    constructor(url: string, options?: { headers?: Record<string, string> }) {\n      const socket = sockets[index]\n      index += 1\n      expect(socket).toBeDefined()\n      expect(url).toBe(socket!.url)\n      expect(options).toEqual(socket!.options)\n      return socket as unknown as object\n    }\n  } as unknown as typeof WebSocket\n}"},{"id":"editor_context_test_sendselection","label":"sendSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L71-L86","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L71"}],"snippet":"function sendSelection(socket: FakeWebSocket, filePath: string, text = \"foo\") {\n  socket.message(\n    JSON.stringify({\n      jsonrpc: \"2.0\",\n      method: \"selection_changed\",\n      params: {\n        text,\n        filePath,\n        selection: {\n          start: { line: 1, character: 1 },\n          end: { line: 1, character: 4 },\n        },\n      },\n    }),\n  )\n}"},{"id":"editor_context_test_expectedselection","label":"expectedSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L88-L102","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L88"}],"snippet":"function expectedSelection(filePath: string, text = \"foo\") {\n  return {\n    filePath,\n    source: \"websocket\" as const,\n    ranges: [\n      {\n        text,\n        selection: {\n          start: { line: 1, character: 1 },\n          end: { line: 1, character: 4 },\n        },\n      },\n    ],\n  }\n}"}],"edges":[{"source":"editor_context_test","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/tui/editor-context.test.tsx","source_location":"L1"}],"weight":1},{"source":"editor_context_test","target":"os","relation":"imports_from