{"__madarTsExtractorVersion":67,"__madarFileStem":"recording-cost-report","nodes":[{"id":"recording_cost_report","label":"recording-cost-report.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L1"}]},{"id":"recording_cost_report_isrecord","label":"isRecord()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L34-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L34"}],"snippet":"isRecord = (value: unknown): value is JsonRecord =>\n  value !== null && typeof value === \"object\" && !Array.isArray(value)"},{"id":"recording_cost_report_asnumber","label":"asNumber()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L37"}],"snippet":"asNumber = (value: unknown) => (typeof value === \"number\" && Number.isFinite(value) ? value : 0)"},{"id":"recording_cost_report_asstring","label":"asString()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L39"}],"snippet":"asString = (value: unknown) => (typeof value === \"string\" ? value : undefined)"},{"id":"recording_cost_report_readjson","label":"readJson()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L41","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L41"}],"snippet":"readJson = async (file: string) => JSON.parse(await Bun.file(file).text()) as unknown"},{"id":"recording_cost_report_walk","label":"walk()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L43-L55","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L43"}],"snippet":"walk = async (dir: string): Promise<ReadonlyArray<string>> =>\n  (await fs.readdir(dir, { withFileTypes: true }))\n    .flatMap((entry) => {\n      const file = path.join(dir, entry.name)\n      return entry.isDirectory() ? [] : [file]\n    })\n    .concat(\n      ...(await Promise.all(\n        (await fs.readdir(dir, { withFileTypes: true }))\n          .filter((entry) => entry.isDirectory())\n          .map((entry) => walk(path.join(dir, entry.name))),\n      )),\n    )"},{"id":"recording_cost_report_providerfromurl","label":"providerFromUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L57-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L57"}],"snippet":"providerFromUrl = (url: string) => {\n  if (url.includes(\"api.openai.com\")) return \"openai\"\n  if (url.includes(\"api.anthropic.com\")) return \"anthropic\"\n  if (url.includes(\"generativelanguage.googleapis.com\")) return \"google\"\n  if (url.includes(\"bedrock\")) return \"amazon-bedrock\"\n  if (url.includes(\"openrouter.ai\")) return \"openrouter\"\n  if (url.includes(\"api.x.ai\")) return \"xai\"\n  if (url.includes(\"api.groq.com\")) return \"groq\"\n  if (url.includes(\"api.deepseek.com\")) return \"deepseek\"\n  if (url.includes(\"api.together.xyz\")) return \"togetherai\"\n  return \"unknown\"\n}"},{"id":"recording_cost_report_modelaliases","label":"modelAliases()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L82-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L82"}],"snippet":"modelAliases = (model: string) => [\n  model,\n  model.replace(/^models\\//, \"\"),\n  model.replace(/-\\d{8}$/, \"\"),\n  model.replace(/-\\d{4}-\\d{2}-\\d{2}$/, \"\"),\n  model.replace(/-\\d{4}-\\d{2}-\\d{2}$/, \"\").replace(/-\\d{8}$/, \"\"),\n  model.replace(/^openai\\//, \"\"),\n  model.replace(/^anthropic\\//, \"\"),\n  model.replace(/^google\\//, \"\"),\n]"},{"id":"recording_cost_report_pricingfor","label":"pricingFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L93-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L93"}],"snippet":"pricingFor = (models: JsonRecord, provider: string, model: string) => {\n  for (const providerID of providerAliases[provider] ?? [provider]) {\n    const providerEntry = models[providerID]\n    if (!isRecord(providerEntry) || !isRecord(providerEntry.models)) continue\n    for (const modelID of modelAliases(model)) {\n      const modelEntry = providerEntry.models[modelID]\n      if (isRecord(modelEntry) && isRecord(modelEntry.cost))\n        return { pricing: modelEntry.cost as Pricing, source: `${providerID}/${modelID}` }\n    }\n  }\n  return { pricing: undefined, source: \"missing\" }\n}"},{"id":"recording_cost_report_estimatecost","label":"estimateCost()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L106-L116","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L106"}],"snippet":"estimateCost = (usage: Usage, pricing: Pricing | undefined) => {\n  if (!pricing) return 0\n  return (\n    (usage.inputTokens * (pricing.input ?? 0) +\n      usage.outputTokens * (pricing.output ?? 0) +\n      usage.cacheReadTokens * (pricing.cache_read ?? 0) +\n      usage.cacheWriteTokens * (pricing.cache_write ?? 0) +\n      usage.reasoningTokens * (pricing.reasoning ?? 0)) /\n    1_000_000\n  )\n}"},{"id":"recording_cost_report_emptyusage","label":"emptyUsage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L118-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L118"}],"snippet":"emptyUsage = (): Usage => ({\n  inputTokens: 0,\n  outputTokens: 0,\n  cacheReadTokens: 0,\n  cacheWriteTokens: 0,\n  reasoningTokens: 0,\n  reportedCost: 0,\n})"},{"id":"recording_cost_report_addusage","label":"addUsage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L127-L134","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L127"}],"snippet":"addUsage = (a: Usage, b: Usage): Usage => ({\n  inputTokens: a.inputTokens + b.inputTokens,\n  outputTokens: a.outputTokens + b.outputTokens,\n  cacheReadTokens: a.cacheReadTokens + b.cacheReadTokens,\n  cacheWriteTokens: a.cacheWriteTokens + b.cacheWriteTokens,\n  reasoningTokens: a.reasoningTokens + b.reasoningTokens,\n  reportedCost: a.reportedCost + b.reportedCost,\n})"},{"id":"recording_cost_report_usagefromobject","label":"usageFromObject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L136-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L136"}],"snippet":"usageFromObject = (usage: unknown): Usage => {\n  if (!isRecord(usage)) return emptyUsage()\n  const promptDetails = isRecord(usage.prompt_tokens_details) ? usage.prompt_tokens_details : {}\n  const completionDetails = isRecord(usage.completion_tokens_details) ? usage.completion_tokens_details : {}\n  const inputDetails = isRecord(usage.input_tokens_details) ? usage.input_tokens_details : {}\n  const outputDetails = isRecord(usage.output_tokens_details) ? usage.output_tokens_details : {}\n  const cacheWriteTokens = asNumber(promptDetails.cache_write_tokens) + asNumber(inputDetails.cache_write_tokens)\n  return {\n    inputTokens: asNumber(usage.prompt_tokens) + asNumber(usage.input_tokens),\n    outputTokens: asNumber(usage.completion_tokens) + asNumber(usage.output_tokens),\n    cacheReadTokens: asNumber(promptDetails.cached_tokens) + asNumber(inputDetails.cached_tokens),\n    cacheWriteTokens,\n    reasoningTokens: asNumber(completionDetails.reasoning_tokens) + asNumber(outputDetails.reasoning_tokens),\n    reportedCost: asNumber(usage.cost),\n  }\n}"},{"id":"recording_cost_report_jsonpayloads","label":"jsonPayloads()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L153-L166","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L153"}],"snippet":"jsonPayloads = (body: string) =>\n  body\n    .split(\"\\n\")\n    .map((line) => line.trim())\n    .filter((line) => line.startsWith(\"data:\"))\n    .map((line) => line.slice(\"data:\".length).trim())\n    .filter((line) => line !== \"\" && line !== \"[DONE]\")\n    .flatMap((line) => {\n      try {\n        return [JSON.parse(line) as unknown]\n      } catch {\n        return []\n      }\n    })"},{"id":"recording_cost_report_usagefromresponsebody","label":"usageFromResponseBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L168-L178","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L168"}],"snippet":"usageFromResponseBody = (body: string) =>\n  jsonPayloads(body).reduce<Usage>((usage, payload) => {\n    if (!isRecord(payload)) return usage\n    return addUsage(\n      usage,\n      addUsage(\n        usageFromObject(payload.usage),\n        usageFromObject(isRecord(payload.response) ? payload.response.usage : undefined),\n      ),\n    )\n  }, emptyUsage())"},{"id":"recording_cost_report_modelfromrequest","label":"modelFromRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L180-L191","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L180"}],"snippet":"modelFromRequest = (request: unknown) => {\n  if (!isRecord(request)) return \"unknown\"\n  const requestBody = asString(request.body)\n  if (!requestBody) return \"unknown\"\n  try {\n    const body = JSON.parse(requestBody) as unknown\n    if (!isRecord(body)) return \"unknown\"\n    return asString(body.model) ?? \"unknown\"\n  } catch {\n    return \"unknown\"\n  }\n}"},{"id":"recording_cost_report_rowfor","label":"rowFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L193-L214","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L193"}],"snippet":"rowFor = (models: JsonRecord, file: string, cassette: unknown): Row | undefined => {\n  if (!isRecord(cassette) || !Array.isArray(cassette.interactions)) return undefined\n  const first = cassette.interactions.find(isRecord)\n  if (!first || !isRecord(first.request)) return undefined\n  const provider = providerFromUrl(asString(first.request.url) ?? \"\")\n  const model = modelFromRequest(first.request)\n  const usage = cassette.interactions.filter(isRecord).reduce<Usage>((total, interaction) => {\n    if (!isRecord(interaction.response)) return total\n    const responseBody = asString(interaction.response.body)\n    if (!responseBody) return total\n    return addUsage(total, usageFromResponseBody(responseBody))\n  }, emptyUsage())\n  const priced = pricingFor(models, provider, model)\n  return {\n    cassette: path.relative(RECORDINGS_DIR, file),\n    provider,\n    model,\n    ...usage,\n    estimatedCost: estimateCost(usage, priced.pricing),\n    pricingSource: priced.source,\n  }\n}"},{"id":"recording_cost_report_money","label":"money()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L216","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L216"}],"snippet":"money = (value: number) => (value === 0 ? \"$0.000000\" : `$${value.toFixed(6)}`)"},{"id":"recording_cost_report_tokens","label":"tokens()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L217","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L217"}],"snippet":"tokens = (value: number) => value.toLocaleString(\"en-US\")"}],"edges":[{"source":"recording_cost_report","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/recording-cost-report.ts","source_location":"L1"}],"weight":1},{"source":"recording_cost_report","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/g