{"__madarTsExtractorVersion":67,"__madarFileStem":"file-runtime","nodes":[{"id":"file_runtime","label":"file-runtime.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L1"}]},{"id":"file_runtime_createreadywatcher","label":"createReadyWatcher()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L6-L8","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L6"}],"snippet":"export function createReadyWatcher(): ReadyWatcher {\n  return { token: 0 }\n}"},{"id":"file_runtime_clearreadywatcher","label":"clearReadyWatcher()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L10-L13","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L10"}],"snippet":"export function clearReadyWatcher(state: ReadyWatcher) {\n  state.observer?.disconnect()\n  state.observer = undefined\n}"},{"id":"file_runtime_getviewerhost","label":"getViewerHost()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L15-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L15"}],"snippet":"export function getViewerHost(container: HTMLElement | undefined) {\n  if (!container) return\n  const host = container.querySelector(\"diffs-container\")\n  if (!(host instanceof HTMLElement)) return\n  return host\n}"},{"id":"file_runtime_getviewerroot","label":"getViewerRoot()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L22-L24","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L22"}],"snippet":"export function getViewerRoot(container: HTMLElement | undefined) {\n  return getViewerHost(container)?.shadowRoot ?? undefined\n}"},{"id":"file_runtime_applyviewerscheme","label":"applyViewerScheme()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L26-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L26"}],"snippet":"export function applyViewerScheme(host: HTMLElement | undefined) {\n  if (!host) return\n  if (typeof document === \"undefined\") return\n\n  const scheme = document.documentElement.dataset.colorScheme\n  if (scheme === \"dark\" || scheme === \"light\") {\n    host.dataset.colorScheme = scheme\n    return\n  }\n\n  host.removeAttribute(\"data-color-scheme\")\n}"},{"id":"file_runtime_observeviewerscheme","label":"observeViewerScheme()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L39-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L39"}],"snippet":"export function observeViewerScheme(getHost: () => HTMLElement | undefined) {\n  if (typeof document === \"undefined\") return () => {}\n\n  applyViewerScheme(getHost())\n  if (typeof MutationObserver === \"undefined\") return () => {}\n\n  const root = document.documentElement\n  const monitor = new MutationObserver(() => applyViewerScheme(getHost()))\n  monitor.observe(root, { attributes: true, attributeFilter: [\"data-color-scheme\"] })\n  return () => monitor.disconnect()\n}"},{"id":"file_runtime_notifyshadowready","label":"notifyShadowReady()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L51-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L51"}],"snippet":"export function notifyShadowReady(opts: {\n  state: ReadyWatcher\n  container: HTMLElement\n  getRoot: () => ShadowRoot | undefined\n  isReady: (root: ShadowRoot) => boolean\n  onReady: () => void\n  settleFrames?: number\n}) {\n  clearReadyWatcher(opts.state)\n  opts.state.token += 1\n\n  const token = opts.state.token\n  const settle = Math.max(0, opts.settleFrames ?? 0)\n\n  const runReady = () => {\n    const step = (left: number) => {\n      if (token !== opts.state.token) return\n      if (left <= 0) {\n        opts.onReady()\n        return\n      }\n      requestAnimationFrame(() => step(left - 1))\n    }\n\n    requestAnimationFrame(() => step(settle))"},{"id":"file_runtime_notifyshadowready_runready","label":"runReady()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L65-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L65"}],"snippet":"runReady = () => {\n    const step = (left: number) => {\n      if (token !== opts.state.token) return\n      if (left <= 0) {\n        opts.onReady()\n        return\n      }\n      requestAnimationFrame(() => step(left - 1))\n    }\n\n    requestAnimationFrame(() => step(settle))\n  }"},{"id":"file_runtime_notifyshadowready_runready_step","label":"step()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L66-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L66"}],"snippet":"step = (left: number) => {\n      if (token !== opts.state.token) return\n      if (left <= 0) {\n        opts.onReady()\n        return\n      }\n      requestAnimationFrame(() => step(left - 1))\n    }"},{"id":"file_runtime_notifyshadowready_observeroot","label":"observeRoot()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L78-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/file-runtime.ts","source_location":"L78"}],"snippet":"observeRoot = (root: ShadowRoot) => {\n    if (opts.isReady(root)) {\n      runReady()\n      return\n    }\n\n    if (typeof MutationObserver === \"undefined\") return\n\n    clearReadyWatcher(opts.state)\n    opts.state.observer = new MutationObserver(() => {\n      if (token !== opts.state.token) return\n      if (!opts.isReady(root)) return\n\n      clearReadyWatcher(opts.state)\n      runReady()\n    })\n    opts.state.observer.observe(root, { childList: true, subtree: true })\n  }"}],"edges":[{"source":"file_runtime"