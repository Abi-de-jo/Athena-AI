{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_tui_src_util_layout","nodes":[{"id":"packages_tui_src_util_layout","label":"layout.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L1"}]},{"id":"packages_tui_src_util_layout_setprelayoutsiblingmargin","label":"setPreLayoutSiblingMargin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L8-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L8"}],"snippet":"export function setPreLayoutSiblingMargin(el: BoxRenderable, margin: (previous?: BaseRenderable) => number) {\n  // Run before Yoga layout so scroll geometry matches the rendered frame.\n  el.onLifecyclePass = () => {\n    const parent = el.parent\n    if (!parent) return\n    const cached = previousByParent.get(parent)\n    const previous = cached?.frameID === el.ctx.frameId ? cached.previous : previousSiblings(parent, el.ctx.frameId)\n    const value = margin(previous.get(el))\n    if (el.marginTop !== value) el.marginTop = value\n  }\n}"},{"id":"packages_tui_src_util_layout_previoussiblings","label":"previousSiblings()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L20-L25","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L20"}],"snippet":"function previousSiblings(parent: BaseRenderable, frameID: number) {\n  const previous = new WeakMap<BaseRenderable, BaseRenderable | undefined>()\n  parent.getChildren().forEach((child, index, children) => previous.set(child, children[index - 1]))\n  previousByParent.set(parent, { frameID, previous })\n  return previous\n}"}],"edges":[{"source":"packages_tui_src_util_layout","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L1"}],"weight":1},{"source":"packages_tui_src_util_layout","target":"packages_tui_src_util_layout_setprelayoutsiblingmargin","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L8","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L8"}],"weight":1},{"source":"packages_tui_src_util_layout","target":"packages_tui_src_util_layout_previoussiblings","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/layout.ts","source_location":"L20"}],"weight":1}]}