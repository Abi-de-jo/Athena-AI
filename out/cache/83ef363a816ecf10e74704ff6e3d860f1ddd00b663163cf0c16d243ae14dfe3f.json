{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_tui_src_feature-plugins_system_notifications","nodes":[{"id":"packages_tui_src_feature_plugins_system_notifications","label":"notifications.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L1"}]},{"id":"packages_tui_src_feature_plugins_system_notifications_notify","label":"notify()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L9-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L9"}],"snippet":"function notify(api: TuiPluginApi, sessionID: string | undefined, message: string, sound: TuiAttentionSoundName) {\n  const session = sessionID ? api.state.session.get(sessionID) : undefined\n  const isSubagent = session?.parentID !== undefined\n  void api.attention.notify({\n    title: session?.title,\n    message,\n    notification: isSubagent ? false : { when: \"blurred\" },\n    sound: { name: sound, when: \"always\" },\n  })\n}"},{"id":"packages_tui_src_feature_plugins_system_notifications_sessionerrormessage","label":"sessionErrorMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L20-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L20"}],"snippet":"function sessionErrorMessage(error: SessionError) {\n  if (error?.name === \"MessageAbortedError\") return \"Session aborted\"\n  const data = error?.data\n  if (data && typeof data === \"object\" && \"message\" in data && data.message === \"SSE read timed out\") {\n    return \"Model stopped responding\"\n  }\n  return \"Session error\"\n}"},{"id":"packages_tui_src_feature_plugins_system_notifications_tui","label":"tui()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L29-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L29"}],"snippet":"tui: TuiPlugin = async (api) => {\n  const active = new Set<string>()\n  const errored = new Set<string>()\n  const questions = new Set<string>()\n  const permissions = new Set<string>()\n\n  api.event.on(\"question.asked\", (event) => {\n    if (questions.has(event.properties.id)) return\n    questions.add(event.properties.id)\n    notify(api, event.properties.sessionID, \"Question needs input\", \"question\")\n  })\n\n  api.event.on(\"question.replied\", (event) => {\n    questions.delete(event.properties.requestID)\n  })\n\n  api.event.on(\"question.rejected\", (event) => {\n    questions.delete(event.properties.requestID)\n  })\n\n  api.event.on(\"permission.asked\", (event) => {\n    if (permissions.has(event.properties.id)) return\n    permissions.add(event.properties.id)\n    notify(api, event.properties.sessionID, \"Permission needs input\", \"permission\")\n  })"}],"edges":[{"source":"packages_tui_src_feature_plugins_system_notifications","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L1"}],"weight":1},{"source":"packages_tui_src_feature_plugins_system_notifications","target":"tui","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L2"}],"weight":1},{"source":"packages_tui_src_feature_plugins_system_notifications","target":"builtins","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L3"}],"weight":1},{"source":"packages_tui_src_feature_plugins_system_notifications","target":"packages_tui_src_feature_plugins_system_notifications_notify","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L9","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/notifications.ts","source_location":"L9"}],"weight":1},{"source":"packages_tui_src_feature_plugins_system_notifications","target":"packages_tui_