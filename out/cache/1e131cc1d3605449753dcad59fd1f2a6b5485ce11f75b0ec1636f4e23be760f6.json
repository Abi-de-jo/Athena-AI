cted)\n}"},{"id":"packages_llm_src_route_auth_credentialfromsecret","label":"credentialFromSecret()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/auth.ts","source_location":"L76-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/auth.ts","source_location":"L76"}],"snippet":"credentialFromSecret = (secret: Secret, source: string) => {\n  if (typeof secret === \"string\" || Redacted.isRedacted(secret)) return credential(secretEffect(secret, source))\n  return credential(\n    Effect.gen(function* () {\n      return yield* secretEffect(yield* secret, source)\n    }),\n  )\n}"},{"id":"packages_llm_src_route_auth_value","label":"value()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/auth.ts","source_location":"L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/auth.ts","source_location":"L85"}],"snippet":"value = (secret: string, source = \"value\") => credentialFromSecret(secret, source)"},{"id":"packages_llm_src_route_auth_optional","label":"optional()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/auth.ts","source_location":"L87-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/auth.ts","source_location":"L87"}],"snippet":"optional = (secret: Secret | undefined, source = \"optional value\") =>\n  secret === undefined\n    ? credential(Effect.fail(new MissingCredentialError(source)))\n    : credentialFromSecret(secret, source)"},{"id":"packages_llm_src_route_auth_config","label":"config()","file_type":"code","source_file":"/home/go