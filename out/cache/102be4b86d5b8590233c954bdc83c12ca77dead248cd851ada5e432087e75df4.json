{"__madarTsExtractorVersion":67,"__madarFileStem":"effect-flock.test","nodes":[{"id":"effect_flock_test","label":"effect-flock.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L1"}]},{"id":"effect_flock_test_lock","label":"lock()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L13-L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L13"}],"snippet":"function lock(dir: string, key: string) {\n  return path.join(dir, Hash.fast(key) + \".lock\")\n}"},{"id":"effect_flock_test_sleep","label":"sleep()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L17-L19","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L17"}],"snippet":"function sleep(ms: number) {\n  return new Promise<void>((resolve) => setTimeout(resolve, ms))\n}"},{"id":"effect_flock_test_exists","label":"exists()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L21-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L21"}],"snippet":"async function exists(file: string) {\n  return fs\n    .stat(file)\n    .then(() => true)\n    .catch(() => false)\n}"},{"id":"effect_flock_test_readjson","label":"readJson()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L28-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L28"}],"snippet":"async function readJson<T>(p: string): Promise<T> {\n  return JSON.parse(await fs.readFile(p, \"utf8\"))\n}"},{"id":"effect_flock_test_run","label":"run()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L48-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L48"}],"snippet":"function run(msg: Msg) {\n  return new Promise<{ code: number; stdout: Buffer; stderr: Buffer }>((resolve) => {\n    const proc = spawn(process.execPath, [worker, JSON.stringify(msg)], { cwd: root })\n    const stdout: Buffer[] = []\n    const stderr: Buffer[] = []\n    proc.stdout?.on(\"data\", (data) => stdout.push(Buffer.from(data)))\n    proc.stderr?.on(\"data\", (data) => stderr.push(Buffer.from(data)))\n    proc.on(\"close\", (code) => {\n      resolve({ code: code ?? 1, stdout: Buffer.concat(stdout), stderr: Buffer.concat(stderr) })\n    })\n  })\n}"},{"id":"effect_flock_test_spawnworker","label":"spawnWorker()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L61-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L61"}],"snippet":"function spawnWorker(msg: Msg) {\n  return spawn(process.execPath, [worker, JSON.stringify(msg)], {\n    cwd: root,\n    stdio: [\"ignore\", \"pipe\", \"pipe\"],\n  })\n}"},{"id":"effect_flock_test_stopworker","label":"stopWorker()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L68-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L68"}],"snippet":"async function stopWorker(proc: ReturnType<typeof spawnWorker>) {\n  if (proc.exitCode !== null || proc.signalCode !== null) return\n\n  const closed = new Promise<void>((resolve) => proc.once(\"close\", () => resolve()))\n\n  if (process.platform !== \"win32\" || !proc.pid) {\n    proc.kill()\n    await closed\n    return\n  }\n\n  await new Promise<void>((resolve) => {\n    const killProc = spawn(\"taskkill\", [\"/pid\", String(proc.pid), \"/T\", \"/F\"])\n    killProc.on(\"close\", () => {\n      proc.kill()\n      resolve()\n    })\n  })\n  await closed\n}"},{"id":"effect_flock_test_waitforfile","label":"waitForFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L89-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L89"}],"snippet":"async function waitForFile(file: string, timeout = 3_000) {\n  const stop = Date.now() + timeout\n  while (Date.now() < stop) {\n    if (await exists(file)) return\n    await sleep(20)\n  }\n  throw new Error(`Timed out waiting for file: ${file}`)\n}"}],"edges":[{"source":"effect_flock_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L1"}],"weight":1},{"source":"effect_flock_test","target":"child_process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L2"}],"weight":1},{"source":"effect_flock_test","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L3"}],"weight":1},{"source":"effect_flock_test","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/effect-flock.test.ts","source_location":"L4"}],"weight":1},{"source":"effect_flock_test","target":"os","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Proj