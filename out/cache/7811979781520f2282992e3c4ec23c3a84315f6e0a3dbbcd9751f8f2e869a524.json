{"__madarTsExtractorVersion":67,"__madarFileStem":"highlights","nodes":[{"id":"highlights","label":"highlights.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L1"}]},{"id":"highlights_isrecord","label":"isRecord()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L21-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L21"}],"snippet":"function isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value)\n}"},{"id":"highlights_gettext","label":"getText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L25-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L25"}],"snippet":"function getText(value: unknown): string | undefined {\n  if (typeof value === \"string\") {\n    const text = value.trim()\n    return text.length > 0 ? text : undefined\n  }\n\n  if (typeof value === \"number\") return String(value)\n  return\n}"},{"id":"highlights_normalizeversion","label":"normalizeVersion()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L35-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L35"}],"snippet":"function normalizeVersion(value: string | undefined) {\n  const text = value?.trim()\n  if (!text) return\n  return text.startsWith(\"v\") || text.startsWith(\"V\") ? text.slice(1) : text\n}"},{"id":"highlights_parsemedia","label":"parseMedia()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L41-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L41"}],"snippet":"function parseMedia(value: unknown, alt: string): Highlight[\"media\"] | undefined {\n  if (!isRecord(value)) return\n  const type = getText(value.type)?.toLowerCase()\n  const src = getText(value.src) ?? getText(value.url)\n  if (!src) return\n  if (type !== \"image\" && type !== \"video\") return\n\n  return { type, src, alt }\n}"},{"id":"highlights_parsehighlight","label":"parseHighlight()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L51-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L51"}],"snippet":"function parseHighlight(value: unknown): Highlight | undefined {\n  if (!isRecord(value)) return\n\n  const title = getText(value.title)\n  if (!title) return\n\n  const description = getText(value.description) ?? getText(value.shortDescription)\n  if (!description) return\n\n  const media = parseMedia(value.media, title)\n  return { title, description, media }\n}"},{"id":"highlights_parserelease","label":"parseRelease()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L64-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L64"}],"snippet":"function parseRelease(value: unknown): ParsedRelease | undefined {\n  if (!isRecord(value)) return\n  const tag = getText(value.tag) ?? getText(value.tag_name) ?? getText(value.name)\n\n  if (!Array.isArray(value.highlights)) {\n    return { tag, highlights: [] }\n  }\n\n  const highlights = value.highlights.flatMap((group) => {\n    if (!isRecord(group)) return []\n\n    const source = getText(group.source)\n    if (!source) return []\n    if (!source.toLowerCase().includes(\"desktop\")) return []\n\n    if (Array.isArray(group.items)) {\n      return group.items.map((item) => parseHighlight(item)).filter((item): item is Highlight => item !== undefined)\n    }\n\n    const item = parseHighlight(group)\n    if (!item) return []\n    return [item]\n  })\n\n  return { tag, highlights }"},{"id":"highlights_parsechangelog","label":"parseChangelog()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L91-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L91"}],"snippet":"function parseChangelog(value: unknown): ParsedRelease[] | undefined {\n  if (Array.isArray(value)) {\n    return value.map(parseRelease).filter((release): release is ParsedRelease => release !== undefined)\n  }\n\n  if (!isRecord(value)) return\n  if (!Array.isArray(value.releases)) return\n\n  return value.releases.map(parseRelease).filter((release): release is ParsedRelease => release !== undefined)\n}"},{"id":"highlights_slicehighlights","label":"sliceHighlights()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L102-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L102"}],"snippet":"function sliceHighlights(input: { releases: ParsedRelease[]; current?: string; previous?: string }) {\n  const current = normalizeVersion(input.current)\n  const previous = normalizeVersion(input.previous)\n  const releases = input.releases\n\n  const start = (() => {\n    if (!current) return 0\n    const index = releases.findIndex((release) => normalizeVersion(release.tag) === current)\n    return index === -1 ? 0 : index\n  })()\n\n  const end = (() => {\n    if (!previous) return releases.length\n    const index = releases.findIndex((release, i) => i >= start && normalizeVersion(release.tag) === previous)\n    return index === -1 ? releases.length : index\n  })()\n\n  const highlights = releases.slice(start, end).flatMap((release) => release.highlights)\n  const seen = new Set<string>()\n  const unique = highlights.filter((highlight) => {\n    const key = dedupeKey(highlight)\n    if (seen.has(key)) return false\n    seen.add(key)\n    return true\n  })"},{"id":"highlights_dedupekey","label":"dedupeKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L130-L132","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L130"}],"snippet":"function dedupeKey(highlight: Highlight) {\n  return [highlight.title, highlight.description, highlight.media?.type ?? \"\", highlight.media?.src ?? \"\"].join(\"\\n\")\n}"},{"id":"highlights_loadreleasehighlights","label":"loadReleaseHighlights()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L134-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L134"}],"snippet":"function loadReleaseHighlights(value: unknown, current?: string, previous?: string) {\n  const releases = parseChangelog(value)\n  if (!releases?.length) return []\n  return sliceHighlights({ releases, current, previous })\n}"}],"edges":[{"source":"highlights","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L1"}],"weight":1},{"source":"highlights","target":"store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L2"}],"weight":1},{"source":"highlights","target":"context","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlights.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/highlig