code_src_cli_ui_print","label":"print()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L36-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L36"}],"snippet":"export function print(...message: string[]) {\n  blank = false\n  process.stderr.write(message.join(\" \"))\n}"},{"id":"packages_opencode_src_cli_ui_empty","label":"empty()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L42-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L42"}],"snippet":"export function empty() {\n  if (blank) return\n  println(\"\" + Style.TEXT_NORMAL)\n  blank = true\n}"},{"id":"packages_opencode_src_cli_ui_logo","label":"logo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L48-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L48"}],"snippet":"export function logo(pad?: string) {\n  if (!process.stdout.isTTY && !process.stderr.isTTY) {\n    const result = []\n    for (const row of wordmark) {\n      if (pad) result.push(pad)\n      result.push(row)\n      result.push(EOL)\n    }\n    return result.join(\"\").trimEnd()\n  }\n\n  const result: string[] = []\n  const reset = \"\\x1b[0m\"\n  const left = {\n    fg: \"\\x1b[90m\",\n    shadow: \"\\x1b[38;5;235m\",\n    bg: \"\\x1b[48;5;235m\",\n  }\n  const right = {\n    fg: reset,\n    shadow: \"\\x1b[38;5;238m\",\n    bg: \"\\x1b[48;5;238m\",\n  }\n  const gap = \" \"\n  const draw = (line: string, fg: string, shadow: string, bg: string) => {"},{"id":"packages_opencode_src_cli_ui_logo_draw","label":"draw()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L72-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L72"}],"snippet":"draw = (line: string, fg: string, shadow: string, bg: string) => {\n    const parts: string[] = []\n    for (const char of line) {\n      if (char === \"_\") {\n        parts.push(bg, \" \", reset)\n        continue\n      }\n      if (char === \"^\") {\n        parts.push(fg, bg, \"▀\", reset)\n        continue\n      }\n      if (char === \"~\") {\n        parts.push(shadow, \"▀\", reset)\n        continue\n      }\n      if (char === \" \") {\n        parts.push(\" \")\n        continue\n      }\n      parts.push(fg, char, reset)\n    }\n    return parts.join(\"\")\n  }"},{"id":"packages_opencode_src_cli_ui_input","label":"input()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L106-L119","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L106"}],"snippet":"export async function input(prompt: string): Promise<string> {\n  const readline = require(\"readline\")\n  const rl = readline.createInterface({\n    input: process.stdin,\n    output: process.stdout,\n  })\n\n  return new Promise((resolve) => {\n    rl.question(prompt, (answer: string) => {\n      rl.close()\n      resolve(answer.trim())\n    })\n  })\n}"},{"id":"packages_opencode_src_cli_ui_error","label":"error()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L121-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L121"}],"snippet":"export function error(message: string) {\n  if (message.startsWith(\"Error: \")) {\n    message = message.slice(\"Error: \".length)\n  }\n  println(Style.TEXT_DANGER_BOLD + \"Error: \" + Style.TEXT_NORMAL + message)\n}"},{"id":"packages_opencode_src_cli_ui_markdown","label":"markdown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L128-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L128"}],"snippet":"export function markdown(text: string): string {\n  return text\n}"}],"edges":[{"source":"packages_opencode_src_cli_ui","target":"os","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_cli_ui","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/ui.ts","source_location":"L2"}],"weight":1},{"source":"packages_opencode_src_cli_ui","target":"log