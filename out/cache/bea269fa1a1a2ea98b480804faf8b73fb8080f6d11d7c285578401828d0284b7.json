{"__madarTsExtractorVersion":67,"__madarFileStem":"scrollback.surface.test","nodes":[{"id":"scrollback_surface_test","label":"scrollback.surface.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L1"}]},{"id":"scrollback_surface_test_claim","label":"claim()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L27-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L27"}],"snippet":"function claim(renderer: TestRenderer): ClaimedCommit[] {\n  const queue = Reflect.get(renderer, \"externalOutputQueue\")\n  if (!queue || typeof queue !== \"object\" || !(\"claim\" in queue) || typeof queue.claim !== \"function\") {\n    throw new Error(\"renderer missing external output queue\")\n  }\n\n  const commits = queue.claim()\n  if (!Array.isArray(commits)) {\n    throw new Error(\"renderer external output queue returned invalid commits\")\n  }\n\n  return commits as ClaimedCommit[]\n}"},{"id":"scrollback_surface_test_rendercommit","label":"renderCommit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L41-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L41"}],"snippet":"function renderCommit(commit: ClaimedCommit) {\n  return decoder.decode(commit.snapshot.getRealCharBytes(true)).replace(/ +\\n/g, \"\\n\")\n}"},{"id":"scrollback_surface_test_render","label":"render()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L45-L47","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L45"}],"snippet":"function render(commits: ClaimedCommit[]) {\n  return commits.map(renderCommit).join(\"\")\n}"},{"id":"scrollback_surface_test_renderrows","label":"renderRows()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L49-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L49"}],"snippet":"function renderRows(commit: ClaimedCommit, width = 80) {\n  const raw = decoder.decode(commit.snapshot.getRealCharBytes(true))\n  return Array.from({ length: commit.snapshot.height }, (_, index) =>\n    raw.slice(index * width, (index + 1) * width).trimEnd(),\n  )\n}"},{"id":"scrollback_surface_test_destroy","label":"destroy()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L56-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L56"}],"snippet":"function destroy(commits: ClaimedCommit[]) {\n  for (const commit of commits) {\n    commit.snapshot.destroy()\n  }\n}"},{"id":"scrollback_surface_test_setup","label":"setup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L62-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L62"}],"snippet":"async function setup(\n  input: {\n    width?: number\n    wrote?: boolean\n    theme?: RunTheme\n    onThemeRelease?: (theme: RunTheme) => void\n  } = {},\n) {\n  const out = await createTestRenderer({\n    width: input.width ?? 80,\n    screenMode: \"split-footer\",\n    footerHeight: 6,\n    externalOutputMode: \"capture-stdout\",\n    consoleMode: \"disabled\",\n  })\n  active.push(out.renderer)\n\n  const treeSitterClient = new MockTreeSitterClient({ autoResolveTimeout: 0 })\n  treeSitterClient.setMockResult({ highlights: [] })\n\n  return {\n    renderer: out.renderer,\n    scrollback: new RunScrollbackStream(out.renderer, input.theme ?? RUN_THEME_FALLBACK, {\n      treeSitterClient,\n      wrote: input.wrote ?? false,"},{"id":"scrollback_surface_test_assistant","label":"assistant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L92-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L92"}],"snippet":"function assistant(text: string, phase: StreamCommit[\"phase\"] = \"progress\"): StreamCommit {\n  return {\n    kind: \"assistant\",\n    text,\n    phase,\n    source: \"assistant\",\n    messageID: \"msg-1\",\n    partID: \"part-1\",\n  }\n}"},{"id":"scrollback_surface_test_reasoning","label":"reasoning()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L103-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L103"}],"snippet":"function reasoning(text: string, phase: StreamCommit[\"phase\"] = \"progress\"): StreamCommit {\n  return {\n    kind: \"reasoning\",\n    text,\n    phase,\n    source: \"reasoning\",\n    messageID: \"msg-r-1\",\n    partID: \"part-r-1\",\n  }\n}"},{"id":"scrollback_surface_test_activesyntax","label":"activeSyntax()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L170-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L170"}],"snippet":"function activeSyntax(scrollback: RunScrollbackStream) {\n  const entry = Reflect.get(scrollback, \"active\") as { renderable?: { syntaxStyle?: SyntaxStyle } } | undefined\n  return entry?.renderable?.syntaxStyle\n}"},{"id":"scrollback_surface_test_user","label":"user()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L204-L211","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L204"}],"snippet":"function user(text: string): StreamCommit {\n  return {\n    kind: \"user\",\n    text,\n    phase: \"start\",\n    source: \"system\",\n  }\n}"},{"id":"scrollback_surface_test_error","label":"error()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L213-L220","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L213"}],"snippet":"function error(text: string): StreamCommit {\n  return {\n    kind: \"error\",\n    text,\n    phase: \"start\",\n    source: \"system\",\n  }\n}"},{"id":"scrollback_surface_test_toolpart","label":"toolPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L222-L232","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L222"}],"snippet":"function toolPart(tool: string, state: Record<string, unknown>, id: string, messageID: string): ToolPart {\n  return {\n    id,\n    sessionID: \"session-1\",\n    messageID,\n    type: \"tool\",\n    callID: `call-${id}`,\n    tool,\n    state,\n  } as ToolPart\n}"},{"id":"scrollback_surface_test_toolcommit","label":"toolCommit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L234-L257","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/cli/run/scrollback.surface.test.ts","source_location":"L234"}],"snippet":"function toolCommit(input: {\n  tool: string\n  phase: StreamCommit[\"phase\"]\n  toolState?: StreamCommit[\"toolState\"]\n  text?: strin