{"__madarTsExtractorVersion":67,"__madarFileStem":"httpapi-ui.test","nodes":[{"id":"httpapi_ui_test","label":"httpapi-ui.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L1"}]},{"id":"httpapi_ui_test_restoreenv","label":"restoreEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L44-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L44"}],"snippet":"function restoreEnv(key: string, value: string | undefined) {\n  if (value === undefined) {\n    delete process.env[key]\n    return\n  }\n  process.env[key] = value\n}"},{"id":"httpapi_ui_test_app","label":"app()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L52-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L52"}],"snippet":"function app(input?: { password?: string; username?: string }) {\n  const handler = HttpRouter.toWebHandler(\n    HttpApiApp.routes.pipe(\n      Layer.provide(\n        ConfigProvider.layer(\n          ConfigProvider.fromUnknown({\n            RIMURU_SERVER_PASSWORD: input?.password,\n            RIMURU_SERVER_USERNAME: input?.username,\n          }),\n        ),\n      ),\n    ),\n    { disableLogger: true },\n  ).handler\n  return {\n    request(input: string | URL | Request, init?: RequestInit) {\n      return Effect.promise(() =>\n        Promise.resolve(\n          handler(\n            input instanceof Request ? input : new Request(new URL(input, \"http://localhost\"), init),\n            HttpApiApp.context,\n          ),\n        ),\n      )\n    },"},{"id":"httpapi_ui_test_uiapp","label":"uiApp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L80-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L80"}],"snippet":"function uiApp(input?: {\n  password?: string\n  username?: string\n  client?: Layer.Layer<HttpClient.HttpClient>\n  disableEmbeddedWebUi?: boolean\n}) {\n  const handler = HttpRouter.toWebHandler(\n    HttpRouter.use((router) =>\n      Effect.gen(function* () {\n        const fs = yield* FSUtil.Service\n        const client = yield* HttpClient.HttpClient\n        const flags = yield* RuntimeFlags.Service\n        yield* router.add(\"*\", \"/*\", (request) =>\n          serveUIEffect(request, { fs, client, disableEmbeddedWebUi: flags.disableEmbeddedWebUi }),\n        )\n      }),\n    ).pipe(\n      Layer.provide(authorizationRouterMiddleware.layer.pipe(Layer.provide(ServerAuth.Config.defaultLayer))),\n      Layer.provide([\n        FSUtil.defaultLayer,\n        input?.client ?? httpClient(new Response(\"ui\")),\n        RuntimeFlags.layer({ disableEmbeddedWebUi: input?.disableEmbeddedWebUi ?? false }),\n        HttpServer.layerServices,\n        ConfigProvider.layer(\n          ConfigProvider.fromUnknown({"},{"id":"httpapi_ui_test_routeorderingapp","label":"routeOrderingApp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L127-L167","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L127"}],"snippet":"function routeOrderingApp() {\n  let proxiedUrl: string | undefined\n  const handler = HttpRouter.toWebHandler(\n    HttpRouter.use((router) =>\n      Effect.gen(function* () {\n        const fs = yield* FSUtil.Service\n        const client = yield* HttpClient.HttpClient\n        const flags = yield* RuntimeFlags.Service\n        yield* router.add(\"GET\", \"/session/:sessionID\", () =>\n          Effect.succeed(HttpServerResponse.jsonUnsafe({ error: \"Not Found\" }, { status: 404 })),\n        )\n        yield* router.add(\"*\", \"/*\", (request) =>\n          serveUIEffect(request, { fs, client, disableEmbeddedWebUi: flags.disableEmbeddedWebUi }),\n        )\n      }),\n    ).pipe(\n      Layer.provide([\n        FSUtil.defaultLayer,\n        RuntimeFlags.layer({ disableEmbeddedWebUi: true }),\n        httpClient(new Response(\"ui\"), (request) => {\n          proxiedUrl = request.url\n        }),\n        HttpServer.layerServices,\n      ]),\n    ),"},{"id":"httpapi_ui_test_httpclient","label":"httpClient()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L169-L177","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-ui.test.ts","source_location":"L169"}],"snippet":"function httpClient(response: Response, onRequest?: (request: HttpClientRequest.HttpClientRequest) => void) {\n  return Layer.succeed(\n    HttpClient.HttpClient,\n    HttpClient.make((request) => {\n      onRequest?.(request)\n      return Effect.succeed(HttpClientResponse.fromWeb(request, response))\n    }),\n  )\n}"},{"id":"http