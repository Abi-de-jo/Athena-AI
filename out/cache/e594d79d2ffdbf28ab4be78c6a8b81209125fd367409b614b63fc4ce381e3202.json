{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_console_app_src_routes_bench_index","nodes":[{"id":"packages_console_app_src_routes_bench_index","label":"index.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/index.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/index.tsx","source_location":"L1"}]},{"id":"packages_console_app_src_routes_bench_index_benchmarkresult","label":"BenchmarkResult","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/index.tsx","source_location":"L8-L11","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/index.tsx","source_location":"L8"}],"snippet":"interface BenchmarkResult {\n  averageScore: number\n  tasks: { averageScore: number; task: { id: string } }[]\n}"},{"id":"packages_console_app_src_routes_bench_index_getbenchmarks","label":"getBenchmarks()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/index.tsx","source_location":"L13-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/index.tsx","source_location":"L13"}],"snippet":"async function getBenchmarks() {\n  \"use server\"\n  const rows = await Database.use((tx) =>\n    tx.select().from(BenchmarkTable).orderBy(desc(BenchmarkTable.timeCreated)).limit(100),\n  )\n  return rows.map((row) => {\n    const parsed = JSON.parse(row.result) as BenchmarkResult\n    const taskScores: Record<string, number> = {}\n    for (const t of parsed.tasks) {\n      taskScores[t.task.id] = t.averageScore\n    }\n    return {\n      id: row.id,\n      agent: row.agent,\n      model: row.model,\n      averageScore: parsed.averageScore,\n      taskScores,\n    }\n  })\n}"},{"id":"packages_console_app_src_routes_bench_index_bench","label":"Bench()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/index.tsx","source_location":"L36-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/index.tsx","source_location":"L36"}],"snippet":"export default function Bench() {\n  const i18n = useI18n()\n  const benchmarks = createAsync(() => queryBenchmarks())\n\n  const taskIds = createMemo(() => {\n    const ids = new Set<string>()\n    for (const row of benchmarks() ?? []) {\n      for (const id of Object.keys(row.taskScores)) {\n        ids.add(id)\n      }\n    }\n    return [...ids].sort()\n  })\n\n  return (\n    <main data-page=\"bench\" style={{ padding: \"2rem\" }}>\n      <Title>{i18n.t(\"bench.list.title\")}</Title>\n      <h1 style={{ \"margin-bottom\": \"1.5rem\" }}>{i18n.t(\"bench.list.heading\")}</h1>\n      <table style={{ \"border-collapse\": \"collapse\", width: \"100%\" }}>\n        <thead>\n          <tr>\n            <th style={{ \"text-align\": \"left\", padding: \"0.75rem\" }}>{i18n.t(\"bench.list.table.agent\")}</th>\n            <th style={{ \"text-align\": \"left\", padding: \"0.75rem\" }}>{i18n.t(\"bench.list.table.model\")}</th>\n            <th style={{ \"text-align\": \"left\", padding: \"0.75rem\" }}>{i18n.t(\"bench.list.table.score\")}</th>\n            <For each={taskIds()}>{(id) => <th style={{ \"text-align\": \"left\", padding: \"0.75rem\" }}>{id}</th>}</For>","node_kind":"component"}],"edges":[{"source":"packages_console_app_src_routes_bench_index","target":"meta","relation":"imports_from","conf