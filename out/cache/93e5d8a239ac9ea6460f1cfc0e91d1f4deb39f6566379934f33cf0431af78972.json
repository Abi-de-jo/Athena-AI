{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_llm_src_tool-runtime","nodes":[{"id":"packages_llm_src_tool_runtime","label":"tool-runtime.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L1"}]},{"id":"packages_llm_src_tool_runtime_toolsettlement","label":"ToolSettlement","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L13-L16","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L13"}],"snippet":"export interface ToolSettlement {\n  readonly result: ToolResultValueType\n  readonly output?: ToolOutputType\n}"},{"id":"packages_llm_src_tool_runtime_dispatchresult","label":"DispatchResult","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L18-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L18"}],"snippet":"export interface DispatchResult extends ToolSettlement {\n  readonly events: ReadonlyArray<LLMEvent>\n}"},{"id":"packages_llm_src_tool_runtime_dispatch","label":"dispatch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L23-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L23"}],"snippet":"dispatch = (tools: Tools, call: ToolCallPart): Effect.Effect<DispatchResult> => {\n  const tool = tools[call.name]\n  if (!tool) return Effect.succeed(result(call, { type: \"error\", value: `Unknown tool: ${call.name}` }))\n  if (!tool.execute)\n    return Effect.succeed(result(call, { type: \"error\", value: `Tool has no execute handler: ${call.name}` }))\n\n  return decodeAndExecute(tool, call).pipe(\n    Effect.map((value) => result(call, value)),\n    Effect.catchTag(\"LLM.ToolFailure\", (failure) =>\n      Effect.succeed(result(call, { type: \"error\", value: failure.message }, failure.error)),\n    ),\n  )\n}"},{"id":"packages_llm_src_tool_runtime_decodeandexecute","label":"decodeAndExecute()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L37-L61","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L37"}],"snippet":"decodeAndExecute = (tool: AnyTool, call: ToolCallPart): Effect.Effect<ToolSettlement, ToolFailure> =>\n  tool._decode(call.input).pipe(\n    Effect.mapError((error) => new ToolFailure({ message: `Invalid tool input: ${error.message}` })),\n    Effect.flatMap((decoded) =>\n      tool.execute!(decoded, { id: call.id, name: call.name }).pipe(\n        Effect.flatMap((value) =>\n          tool._encode(value).pipe(\n            Effect.mapError(\n              (error) =>\n                new ToolFailure({\n                  message: `Tool returned an invalid value for its success schema: ${error.message}`,\n                }),\n            ),\n          ),\n        ),\n        Effect.map((encoded) => {\n          if (tool._legacyResult && ToolResultValue.is(encoded))\n            return { result: encoded, output: ToolOutput.fromResultValue(encoded) }\n          const output = tool._project(decoded, call.id, encoded)\n          const result = ToolOutput.toResultValue(output)\n          return result.type === \"error\" ? { result } : { result, output }\n        }),\n      ),\n    ),\n  )"},{"id":"packages_llm_src_tool_runtime_result","label":"result()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L63-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L63"}],"snippet":"result = (call: ToolCallPart, value: ToolResultValueType | ToolSettlement, error?: unknown): DispatchResult => {\n  const settlement = ToolResultValue.is(value) ? { result: value } : value\n  return {\n    result: settlement.result,\n    output: settlement.output,\n    events:\n      settlement.result.type === \"error\"\n        ? [\n            LLMEvent.toolError({ id: call.id, name: call.name, message: String(settlement.result.value), error }),\n            LLMEvent.toolResult({ id: call.id, name: call.name, result: settlement.result }),\n          ]\n        : [LLMEvent.toolResult({ id: call.id, name: call.name, result: settlement.result, output: settlement.output })],\n  }\n}"}],"edges":[{"source":"packages_llm_src_tool_runtime","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L1"}],"weight":1},{"source":"packages_llm_src_tool_runtime","target":"schema","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/tool-runtime.ts","source_location":"L2","la