{"__madarTsExtractorVersion":67,"__madarFileStem":"proxy-util","nodes":[{"id":"proxy_util","label":"proxy-util.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L1"}]},{"id":"proxy_util_sanitize","label":"sanitize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L14-L19","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L14"}],"snippet":"function sanitize(out: Headers) {\n  for (const key of hop) out.delete(key)\n  out.delete(\"accept-encoding\")\n  out.delete(\"x-opencode-directory\")\n  out.delete(\"x-opencode-workspace\")\n}"},{"id":"proxy_util_headers","label":"headers()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L21-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L21"}],"snippet":"export function headers(input: Request | HeadersInit | Record<string, string>, extra?: HeadersInit) {\n  const raw = input instanceof Request ? input.headers : input\n  const out = new Headers(raw instanceof Headers ? raw : Object.entries(raw as Record<string, string>))\n  sanitize(out)\n  if (!extra) return out\n  for (const [key, value] of new Headers(extra).entries()) {\n    out.set(key, value)\n  }\n  return out\n}"},{"id":"proxy_util_websocketprotocols","label":"websocketProtocols()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L32-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L32"}],"snippet":"export function websocketProtocols(input: Request | Record<string, string | undefined>) {\n  const value = input instanceof Request ? input.headers.get(\"sec-websocket-protocol\") : input[\"sec-websocket-protocol\"]\n  if (!value) return []\n  return value\n    .split(\",\")\n    .map((item) => item.trim())\n    .filter(Boolean)\n}"},{"id":"proxy_util_websockettargeturl","label":"websocketTargetURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L41-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L41"}],"snippet":"export function websocketTargetURL(url: string | URL) {\n  const next = new URL(url)\n  if (next.protocol === \"http:\") next.protocol = \"ws:\"\n  if (next.protocol === \"https:\") next.protocol = \"wss:\"\n  return next.toString()\n}"}],"edges":[{"source":"proxy_util","target":"proxy_util_sanitize","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L14","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/proxy-util.ts","source_location":"L14"}],"weight":1},{"source":"proxy_util","target":"proxy_util_headers","relation":"contains","confidence":"EXTRACTE