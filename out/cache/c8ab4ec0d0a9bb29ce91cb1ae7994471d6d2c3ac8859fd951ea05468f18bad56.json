: Child {\n  if (cmd.length === 0) throw new Error(\"Command is required\")\n  opts.abort?.throwIfAborted()\n\n  const proc = launch(cmd[0], cmd.slice(1), {\n    cwd: opts.cwd,\n    shell: opts.shell,\n    env: opts.env === null ? {} : opts.env ? { ...process.env, ...opts.env } : undefined,\n    stdio: [opts.stdin ?? \"ignore\", opts.stdout ?? \"ignore\", opts.stderr ?? \"ignore\"],\n    windowsHide: process.platform === \"win32\",\n  })\n\n  let closed = false\n  let timer: ReturnType<typeof setTimeout> | undefined\n\n  const abort = () => {\n    if (closed) return\n    if (proc.exitCode !== null || proc.signalCode !== null) return\n    closed = true\n\n    proc.kill(opts.kill ?? \"SIGTERM\")\n\n    const ms = opts.timeout ?? 5_000\n    if (ms <= 0) return\n    timer = setTimeout(() => proc.kill(\"SIGKILL\"), ms)"},{"id":"packages_rimuru_src_util_process_spawn_abort","label":"abort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L74-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L74"}],"snippet":"abort = () => {\n    if (closed) return\n    if (proc.exitCode !== null || proc.signalCode !== null) return\n    closed = true\n\n    proc.kill(opts.kill ?? \"SIGTERM\")\n\n    const ms = opts.timeout ?? 5_000\n    if (ms <= 0) return\n    timer = setTimeout(() => proc.kill(\"SIGKILL\"), ms)\n  }"},{"id":"packages_rimuru_src_util_process_run","label":"run()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L114-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L114"}],"snippet":"export async function run(cmd: string[], opts: RunOptions = {}): Promise<Result> {\n  const proc = spawn(cmd, {\n    cwd: opts.cwd,\n    env: opts.env,\n    stdin: opts.stdin,\n    shell: opts.shell,\n    abort: opts.abort,\n    kill: opts.kill,\n    timeout: opts.timeout,\n    stdout: \"pipe\",\n    stderr: \"pipe\",\n  })\n\n  if (!proc.stdout || !proc.stderr) throw new Error(\"Process output not available\")\n\n  const out = await Promise.all([proc.exited, buffer(proc.stdout), buffer(proc.stderr)])\n    .then(([code, stdout, stderr]) => ({\n      code,\n      stdout,\n      stderr,\n    }))\n    .catch((err: unknown) => {\n      if (!opts.nothrow) throw err\n      return {\n        code: 1,"},{"id":"packages_rimuru_src_util_process_stop","label":"stop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L149-L163","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L149"}],"snippet":"export async function stop(proc: ChildProcess) {\n  if (proc.exitCode !== null || proc.signalCode !== null) return\n\n  if (process.platform !== \"win32\" || !proc.pid) {\n    proc.kill()\n    return\n  }\n\n  const out = await run([\"taskkill\", \"/pid\", String(proc.pid), \"/T\", \"/F\"], {\n    nothrow: true,\n  })\n\n  if (out.code === 0) return\n  proc.kill()\n}"},{"id":"packages_rimuru_src_util_process_text","label":"text()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L165-L171","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L165"}],"snippet":"export async function text(cmd: string[], opts: RunOptions = {}): Promise<TextResult> {\n  const out = await run(cmd, opts)\n  return {\n    ...out,\n    text: out.stdout.toString(),\n  }\n}"},{"id":"packages_rimuru_src_util_process_lines","label":"lines()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L173-L175","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L173"}],"snippet":"export async function lines(cmd: string[], opts: RunOptions = {}): Promise<string[]> {\n  return (await text(cmd, opts)).text.split(/\\r?\\n/).filter(Boolean)\n}"}],"edges":[{"source":"packages_rimuru_src_util_process","target":"child_process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_util_process","target":"stream","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L2"}],"weight":1},{"source":"packages_rimuru_src_util_process","target":"cross_spawn","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/process.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source