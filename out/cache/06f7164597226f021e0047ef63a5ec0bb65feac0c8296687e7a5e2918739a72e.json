{"__madarTsExtractorVersion":67,"__madarFileStem":"oauth-callback","nodes":[{"id":"oauth_callback","label":"oauth-callback.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L1"}]},{"id":"oauth_callback_html_error","label":"HTML_ERROR()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L30-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L30"}],"snippet":"HTML_ERROR = (error: string) => `<!DOCTYPE html>\n<html>\n<head>\n  <title>OpenCode - Authorization Failed</title>\n  <style>\n    body { font-family: system-ui, -apple-system, sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background: #1a1a2e; color: #eee; }\n    .container { text-align: center; padding: 2rem; }\n    h1 { color: #f87171; margin-bottom: 1rem; }\n    p { color: #aaa; }\n    .error { color: #fca5a5; font-family: monospace; margin-top: 1rem; padding: 1rem; background: rgba(248,113,113,0.1); border-radius: 0.5rem; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Authorization Failed</h1>\n    <p>An error occurred during authorization.</p>\n    <div class=\"error\">${escapeHtml(error)}</div>\n  </div>\n</body>\n</html>`"},{"id":"oauth_callback_pendingauth","label":"PendingAuth","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L51-L55","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L51"}],"snippet":"interface PendingAuth {\n  resolve: (code: string) => void\n  reject: (error: Error) => void\n  timeout: ReturnType<typeof setTimeout>\n}"},{"id":"oauth_callback_cleanupstateindex","label":"cleanupStateIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L65-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L65"}],"snippet":"function cleanupStateIndex(oauthState: string) {\n  for (const [name, state] of mcpNameToState) {\n    if (state === oauthState) {\n      mcpNameToState.delete(name)\n      break\n    }\n  }\n}"},{"id":"oauth_callback_stopifidle","label":"stopIfIdle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L74-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L74"}],"snippet":"function stopIfIdle() {\n  if (pendingAuths.size > 0 || !server) return\n\n  server.close()\n  server = undefined\n}"},{"id":"oauth_callback_handlerequest","label":"handleRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L81-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L81"}],"snippet":"function handleRequest(req: import(\"http\").IncomingMessage, res: import(\"http\").ServerResponse) {\n  const url = new URL(req.url || \"/\", `http://localhost:${currentPort}`)\n\n  if (url.pathname !== currentPath) {\n    res.writeHead(404)\n    res.end(\"Not found\")\n    return\n  }\n\n  const code = url.searchParams.get(\"code\")\n  const state = url.searchParams.get(\"state\")\n  const error = url.searchParams.get(\"error\")\n  const errorDescription = url.searchParams.get(\"error_description\")\n\n  // Enforce state parameter presence\n  if (!state) {\n    const errorMsg = \"Missing required state parameter - potential CSRF attack\"\n    res.writeHead(400, { \"Content-Type\": \"text/html; charset=utf-8\" })\n    res.end(HTML_ERROR(errorMsg))\n    return\n  }\n\n  if (error) {\n    const errorMsg = errorDescription || error\n    if (pendingAuths.has(state)) {"},{"id":"oauth_callback_ensurerunning","label":"ensureRunning()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L144-L170","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L144"}],"snippet":"export async function ensureRunning(redirectUri?: string): Promise<void> {\n  // Parse the redirect URI to get port and path (uses defaults if not provided)\n  const { port, path } = parseRedirectUri(redirectUri)\n\n  // If server is running on a different port/path, stop it first\n  if (server && (currentPort !== port || currentPath !== path)) {\n    await stop()\n  }\n\n  if (server) return\n\n  const running = await isPortInUse(port)\n  if (running) {\n    return\n  }\n\n  currentPort = port\n  currentPath = path\n\n  server = createServer(handleRequest)\n  await new Promise<void>((resolve, reject) => {\n    server!.listen(currentPort, () => {\n      resolve()\n    })\n    server!.on(\"error\", reject)"},{"id":"oauth_callback_waitforcallback","label":"waitForCallback()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L172-L186","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L172"}],"snippet":"export function waitForCallback(oauthState: string, mcpName?: string): Promise<string> {\n  if (mcpName) mcpNameToState.set(mcpName, oauthState)\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => {\n      if (pendingAuths.has(oauthState)) {\n        pendingAuths.delete(oauthState)\n        if (mcpName) mcpNameToState.delete(mcpName)\n        reject(new Error(\"OAuth callback timeout - authorization took too long\"))\n        stopIfIdle()\n      }\n    }, CALLBACK_TIMEOUT_MS)\n\n    pendingAuths.set(oauthState, { resolve, reject, timeout })\n  })\n}"},{"id":"oauth_callback_cancelpending","label":"cancelPending()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L188-L200","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L188"}],"snippet":"export function cancelPending(mcpName: string): void {\n  // Look up the oauthState for this mcpName via the reverse index\n  const oauthState = mcpNameToState.get(mcpName)\n  const key = oauthState ?? mcpName\n  const pending = pendingAuths.get(key)\n  if (pending) {\n    clearTimeout(pending.timeout)\n    pendingAuths.delete(key)\n    mcpNameToState.delete(mcpName)\n    pending.reject(new Error(\"Authorization cancelled\"))\n    stopIfIdle()\n  }\n}"},{"id":"oauth_callback_isportinuse","label":"isPortInUse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L202-L213","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L202"}],"snippet":"export async function isPortInUse(port: number = OAUTH_CALLBACK_PORT): Promise<boolean> {\n  return new Promise((resolve) => {\n    const socket = createConnection(port, \"127.0.0.1\")\n    socket.on(\"connect\", () => {\n      socket.destroy()\n      resolve(true)\n    })\n    socket.on(\"error\", () => {\n      resolve(false)\n    })\n  })\n}"},{"id":"oauth_callback_stop","label":"stop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L215-L227","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L215"}],"snippet":"export async function stop(): Promise<void> {\n  if (server) {\n    await new Promise<void>((resolve) => server!.close(() => resolve()))\n    server = undefined\n  }\n\n  for (const [_name, pending] of pendingAuths) {\n    clearTimeout(pending.timeout)\n    pending.reject(new Error(\"OAuth callback server stopped\"))\n  }\n  pendingAuths.clear()\n  mcpNameToState.clear()\n}"},{"id":"oauth_callback_isrunning","label":"isRunning()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L229-L231","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L229"}],"snippet":"export function isRunning(): boolean {\n  return server !== undefined\n}"}],"edges":[{"source":"oauth_callback","target":"net","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L1"}],"weight":1},{"source":"oauth_callback","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L2"}],"weight":1},{"source":"oauth_callback","target":"html","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L3"}],"weight":1},{"source":"oauth_callback","target":"oauth_provider","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/mcp/oauth-callback.ts","source_location":"L4"}],"weight":1},{"source":"oauth_callback","target":"oauth_callback_html_error","rel