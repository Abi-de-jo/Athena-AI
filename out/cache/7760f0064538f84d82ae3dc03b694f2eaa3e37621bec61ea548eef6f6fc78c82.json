{"__madarTsExtractorVersion":67,"__madarFileStem":"trace-imports","nodes":[{"id":"trace_imports","label":"trace-imports.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L1"}]},{"id":"trace_imports_resolveimport","label":"resolveImport()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L12-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L12"}],"snippet":"function resolveImport(importPath: string, fromFile: string): string | null {\n  if (importPath.startsWith(\"@/\")) {\n    return path.join(BASE_DIR, \"src\", importPath.slice(2))\n  }\n\n  if (importPath.startsWith(\"./\") || importPath.startsWith(\"../\")) {\n    const dir = path.dirname(fromFile)\n    return path.resolve(dir, importPath)\n  }\n\n  return null\n}"},{"id":"trace_imports_isinternalimport","label":"isInternalImport()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L25-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L25"}],"snippet":"function isInternalImport(importPath: string): boolean {\n  return importPath.startsWith(\"@/\") || importPath.startsWith(\"./\") || importPath.startsWith(\"../\")\n}"},{"id":"trace_imports_tryextensions","label":"tryExtensions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L29-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L29"}],"snippet":"async function tryExtensions(filePath: string): Promise<string | null> {\n  const extensions = [\".ts\", \".tsx\", \".js\", \".jsx\"]\n\n  try {\n    const file = Bun.file(filePath)\n    const stat = await file.stat()\n\n    if (stat?.isDirectory()) {\n      for (const ext of extensions) {\n        const indexPath = path.join(filePath, \"index\" + ext)\n        const indexFile = Bun.file(indexPath)\n        if (await indexFile.exists()) return indexPath\n      }\n      return null\n    }\n\n    // It's a file\n    return filePath\n  } catch {\n    // Path doesn't exist, try adding extensions\n    for (const ext of extensions) {\n      const withExt = filePath + ext\n      const extFile = Bun.file(withExt)\n      if (await extFile.exists()) return withExt\n    }"},{"id":"trace_imports_extractimports","label":"extractImports()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L58-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L58"}],"snippet":"function extractImports(sourceFile: ts.SourceFile): string[] {\n  const imports: string[] = []\n\n  function visit(node: ts.Node) {\n    // import x from \"path\" or import { x } from \"path\"\n    if (ts.isImportDeclaration(node)) {\n      // Skip type-only imports\n      if (node.importClause?.isTypeOnly) return\n\n      const moduleSpec = node.moduleSpecifier\n      if (ts.isStringLiteral(moduleSpec)) {\n        imports.push(moduleSpec.text)\n      }\n    }\n\n    // export { x } from \"path\"\n    if (ts.isExportDeclaration(node) && node.moduleSpecifier) {\n      if (ts.isStringLiteral(node.moduleSpecifier)) {\n        imports.push(node.moduleSpecifier.text)\n      }\n    }\n\n    // Dynamic import: import(\"path\")\n    if (ts.isCallExpression(node) && node.expression.kind === ts.SyntaxKind.ImportKeyword) {\n      const arg = node.arguments[0]"},{"id":"trace_imports_extractimports_visit","label":"visit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L61-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L61"}],"snippet":"function visit(node: ts.Node) {\n    // import x from \"path\" or import { x } from \"path\"\n    if (ts.isImportDeclaration(node)) {\n      // Skip type-only imports\n      if (node.importClause?.isTypeOnly) return\n\n      const moduleSpec = node.moduleSpecifier\n      if (ts.isStringLiteral(moduleSpec)) {\n        imports.push(moduleSpec.text)\n      }\n    }\n\n    // export { x } from \"path\"\n    if (ts.isExportDeclaration(node) && node.moduleSpecifier) {\n      if (ts.isStringLiteral(node.moduleSpecifier)) {\n        imports.push(node.moduleSpecifier.text)\n      }\n    }\n\n    // Dynamic import: import(\"path\")\n    if (ts.isCallExpression(node) && node.expression.kind === ts.SyntaxKind.ImportKeyword) {\n      const arg = node.arguments[0]\n      if (arg && ts.isStringLiteral(arg)) {\n        imports.push(arg.text)\n      }"},{"id":"trace_imports_tracefile","label":"traceFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L95-L137","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L95"}],"snippet":"async function traceFile(filePath: string, depth = 0): Promise<void> {\n  const normalizedPath = path.relative(BASE_DIR, filePath)\n\n  if (visited.has(filePath)) {\n    return\n  }\n\n  // Only trace TypeScript/JavaScript files\n  if (!filePath.match(/\\.(ts|tsx|js|jsx)$/)) {\n    return\n  }\n\n  visited.add(filePath)\n  console.log(\"\\t\".repeat(depth) + normalizedPath)\n\n  let content: string\n  try {\n    content = await Bun.file(filePath).text()\n  } catch {\n    return\n  }\n\n  const sourceFile = ts.createSourceFile(filePath, content, ts.ScriptTarget.Latest, true)\n\n  const imports = extractImports(sourceFile)"},{"id":"trace_imports_main","label":"main()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L139-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L139"}],"snippet":"async function main() {\n  const entryPath = path.join(BASE_DIR, ENTRY_FILE)\n\n  // Check if file exists\n  const file = Bun.file(entryPath)\n  if (!(await file.exists())) {\n    console.error(`File not found: ${ENTRY_FILE}`)\n    console.error(`Resolved to: ${entryPath}`)\n    process.exit(1)\n  }\n\n  await traceFile(entryPath)\n}"}],"edges":[{"source":"trace_imports","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/script/trace-imports.ts","source_location":"L2"}],"