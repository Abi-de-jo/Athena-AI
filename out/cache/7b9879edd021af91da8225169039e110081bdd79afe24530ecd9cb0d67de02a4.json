{"__madarTsExtractorVersion":67,"__madarFileStem":"header-timeout.test","nodes":[{"id":"header_timeout_test","label":"header-timeout.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L1"}]},{"id":"header_timeout_test_providerconfig","label":"providerConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L173-L184","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L173"}],"snippet":"function providerConfig(url: string, options: Record<string, unknown> = {}) {\n  const config = testProviderConfig(url)\n  return {\n    ...config,\n    provider: {\n      test: {\n        ...config.provider.test,\n        options: { ...config.provider.test.options, ...options },\n      },\n    },\n  }\n}"},{"id":"header_timeout_test_delayedheaderserver","label":"delayedHeaderServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L186-L197","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L186"}],"snippet":"async function delayedHeaderServer(delay: number): Promise<{ server: Server; url: string }> {\n  const server = createServer((_, res) => {\n    setTimeout(() => {\n      res.writeHead(200, { \"content-type\": \"text/event-stream\" })\n      res.end('data: {\"choices\":[{\"delta\":{\"content\":\"ok\"}}]}\\n\\ndata: [DONE]\\n\\n')\n    }, delay)\n  })\n  await new Promise<void>((resolve) => server.listen(0, \"127.0.0.1\", resolve))\n  const address = server.address()\n  if (!address || typeof address === \"string\") throw new Error(\"server did not bind to a TCP port\")\n  return { server, url: `http://127.0.0.1:${address.port}` }\n}"},{"id":"header_timeout_test_delayedbodyserver","label":"delayedBodyServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L199-L211","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L199"}],"snippet":"async function delayedBodyServer(delay: number): Promise<{ server: Server; url: string }> {\n  const server = createServer((_, res) => {\n    res.writeHead(200, { \"content-type\": \"text/event-stream\" })\n    res.flushHeaders()\n    setTimeout(() => {\n      res.end('data: {\"choices\":[{\"delta\":{\"content\":\"late\"}}]}\\n\\ndata: [DONE]\\n\\n')\n    }, delay)\n  })\n  await new Promise<void>((resolve) => server.listen(0, \"127.0.0.1\", resolve))\n  const address = server.address()\n  if (!address || typeof address === \"string\") throw new Error(\"server did not bind to a TCP port\")\n  return { server, url: `http://127.0.0.1:${address.port}` }\n}"},{"id":"header_timeout_test_withauthcontent","label":"withAuthContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L213-L227","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L213"}],"snippet":"function withAuthContent<A, E, R>(self: Effect.Effect<A, E, R>, value: Record<string, unknown> = defaultAuthContent()) {\n  return Effect.acquireUseRelease(\n    Effect.sync(() => {\n      const previous = process.env.OPENCODE_AUTH_CONTENT\n      process.env.OPENCODE_AUTH_CONTENT = JSON.stringify(value)\n      return previous\n    }),\n    () => self,\n    (previous) =>\n      Effect.sync(() => {\n        if (previous === undefined) delete process.env.OPENCODE_AUTH_CONTENT\n        else process.env.OPENCODE_AUTH_CONTENT = previous\n      }),\n  )\n}"},{"id":"header_timeout_test_defaultauthcontent","label":"defaultAuthContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L229-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L229"}],"snippet":"function defaultAuthContent() {\n  return {\n    openai: { type: \"oauth\", refresh: \"refresh\", access: \"access\", expires: Date.now() + 60_000 },\n  }\n}"}],"edges":[{"source":"header_timeout_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_location":"L1"}],"weight":1},{"source":"header_timeout_test","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/provider/header-timeout.test.ts","source_locat