{"__madarTsExtractorVersion":67,"__madarFileStem":"tui-migrate","nodes":[{"id":"tui_migrate","label":"tui-migrate.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L1"}]},{"id":"tui_migrate_migrateinput","label":"MigrateInput","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L19-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L19"}],"snippet":"interface MigrateInput {\n  cwd: string\n  directories: string[]\n}"},{"id":"tui_migrate_migratetuiconfig","label":"migrateTuiConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L29-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L29"}],"snippet":"export async function migrateTuiConfig(input: MigrateInput) {\n  const opencode = await opencodeFiles(input)\n  for (const file of opencode) {\n    const source = await Filesystem.readText(file).catch(() => undefined)\n    if (!source) continue\n    const errors: JsoncParseError[] = []\n    const data = parseJsonc(source, errors, { allowTrailingComma: true })\n    if (errors.length || !data || typeof data !== \"object\" || Array.isArray(data)) continue\n\n    const theme = decodeTheme(\"theme\" in data ? data.theme : undefined)\n    const keybinds = decodeRecord(\"keybinds\" in data ? data.keybinds : undefined)\n    const legacyTui = decodeRecord(\"tui\" in data ? data.tui : undefined)\n    const extracted = {\n      theme: Option.getOrUndefined(theme),\n      keybinds: Option.getOrUndefined(keybinds),\n      tui: Option.getOrUndefined(legacyTui),\n    }\n    const tui = extracted.tui ? normalizeTui(extracted.tui) : undefined\n    if (extracted.theme === undefined && extracted.keybinds === undefined && !tui) continue\n\n    const target = path.join(path.dirname(file), \"tui.json\")\n    const targetExists = await Filesystem.exists(target)\n    if (targetExists) continue\n\n    const payload: Record<string, unknown> = {"},{"id":"tui_migrate_normalizetui","label":"normalizeTui()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L70-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L70"}],"snippet":"function normalizeTui(data: Record<string, unknown>):\n  | {\n      scroll_speed: number | undefined\n      scroll_acceleration: { enabled: boolean } | undefined\n      diff_style: \"auto\" | \"stacked\" | undefined\n    }\n  | undefined {\n  const parsed = {\n    scroll_speed: Option.getOrUndefined(decodeScrollSpeed(data.scroll_speed)),\n    scroll_acceleration: Option.getOrUndefined(decodeScrollAcceleration(data.scroll_acceleration)),\n    diff_style: Option.getOrUndefined(decodeDiffStyle(data.diff_style)),\n  }\n  return parsed.scroll_speed === undefined &&\n    parsed.diff_style === undefined &&\n    parsed.scroll_acceleration === undefined\n    ? undefined\n    : parsed\n}"},{"id":"tui_migrate_backupandstriplegacy","label":"backupAndStripLegacy()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L89-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L89"}],"snippet":"async function backupAndStripLegacy(file: string, source: string) {\n  const backup = file + \".tui-migration.bak\"\n  const hasBackup = await Filesystem.exists(backup)\n  const backed = hasBackup\n    ? true\n    : await Filesystem.write(backup, source)\n        .then(() => true)\n        .catch(() => false)\n  if (!backed) return false\n\n  const text = [\"theme\", \"keybinds\", \"tui\"].reduce((acc, key) => {\n    const edits = modify(acc, [key], undefined, {\n      formattingOptions: {\n        insertSpaces: true,\n        tabSize: 2,\n      },\n    })\n    if (!edits.length) return acc\n    return applyEdits(acc, edits)\n  }, source)\n\n  return Filesystem.write(file, text)\n    .then(() => true)\n    .catch(() => false)\n}"},{"id":"tui_migrate_opencodefiles","label":"opencodeFiles()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L115-L132","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L115"}],"snippet":"async function opencodeFiles(input: { directories: string[]; cwd: string }) {\n  const files = [\n    ...ConfigPaths.fileInDirectory(Global.Path.config, \"rimuru-ai\"),\n    ...(await Filesystem.findUp([\"opencode.json\", \"opencode.jsonc\"], input.cwd, undefined, { rootFirst: true })),\n  ]\n  for (const dir of unique(input.directories)) {\n    files.push(...ConfigPaths.fileInDirectory(dir, \"rimuru-ai\"))\n  }\n  if (Flag.OPENCODE_CONFIG) files.push(Flag.OPENCODE_CONFIG)\n\n  const existing = await Promise.all(\n    unique(files).map(async (file) => {\n      const ok = await Filesystem.exists(file)\n      return ok ? file : undefined\n    }),\n  )\n  return existing.filter((file): file is string => !!file)\n}"}],"edges":[{"source":"tui_migrate","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L1"}],"weight":1},{"source":"tui_migrate","target":"jsonc_parser","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L2"}],"weight":1},{"source":"tui_migrate","target":"remeda","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L3"}],"weight":1},{"source":"tui_migrate","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/tui-migrate.ts","source_location":"L4"}],"weight"