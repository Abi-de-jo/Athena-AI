{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_config_plugin","nodes":[{"id":"packages_opencode_src_config_plugin","label":"plugin.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L1"}]},{"id":"packages_opencode_src_config_plugin_load","label":"load()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L18-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L18"}],"snippet":"export async function load(dir: string) {\n  const plugins: ConfigPluginV1.Spec[] = []\n\n  for (const item of await Glob.scan(\"{plugin,plugins}/*.{ts,js}\", {\n    cwd: dir,\n    absolute: true,\n    dot: true,\n    symlink: true,\n  })) {\n    plugins.push(pathToFileURL(item).href)\n  }\n  return plugins\n}"},{"id":"packages_opencode_src_config_plugin_pluginspecifier","label":"pluginSpecifier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L32-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L32"}],"snippet":"export function pluginSpecifier(plugin: ConfigPluginV1.Spec): string {\n  return Array.isArray(plugin) ? plugin[0] : plugin\n}"},{"id":"packages_opencode_src_config_plugin_pluginoptions","label":"pluginOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L36-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L36"}],"snippet":"export function pluginOptions(plugin: ConfigPluginV1.Spec): ConfigPluginV1.Options | undefined {\n  return Array.isArray(plugin) ? plugin[1] : undefined\n}"},{"id":"packages_opencode_src_config_plugin_resolvepluginspec","label":"resolvePluginSpec()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L42-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L42"}],"snippet":"export async function resolvePluginSpec(\n  plugin: ConfigPluginV1.Spec,\n  configFilepath: string,\n): Promise<ConfigPluginV1.Spec> {\n  const spec = pluginSpecifier(plugin)\n  if (!isPathPluginSpec(spec)) return plugin\n\n  const base = path.dirname(configFilepath)\n  const file = (() => {\n    if (spec.startsWith(\"file://\")) return spec\n    if (path.isAbsolute(spec) || /^[A-Za-z]:[\\\\/]/.test(spec)) return pathToFileURL(spec).href\n    return pathToFileURL(path.resolve(base, spec)).href\n  })()\n\n  const resolved = await resolvePathPluginTarget(file).catch(() => file)\n\n  if (Array.isArray(plugin)) return [resolved, plugin[1]]\n  return resolved\n}"},{"id":"packages_opencode_src_config_plugin_deduplicatepluginorigins","label":"deduplicatePluginOrigins()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L64-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L64"}],"snippet":"export function deduplicatePluginOrigins(plugins: Origin[]): Origin[] {\n  const seen = new Set<string>()\n  const list: Origin[] = []\n\n  for (const plugin of plugins.toReversed()) {\n    const spec = pluginSpecifier(plugin.spec)\n    const name = spec.startsWith(\"file://\") ? spec : parsePluginSpecifier(spec).pkg\n    if (seen.has(name)) continue\n    seen.add(name)\n    list.push(plugin)\n  }\n\n  return list.toReversed()\n}"}],"edges":[{"source":"packages_opencode_src_config_plugin","target":"glob","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_config_plugin","target":"plugin","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L2"}],"weight":1},{"source":"packages_opencode_src_config_plugin","target":"url","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/plugin.ts","source_location":"L3"}],"weight":1},{"source":"packages_opencode_src_config_plugin","target":"shared","relati