    <div class=\"text-[10px] leading-none font-black uppercase tracking-[0.04em] opacity-70\">{props.label}</div>\n        <div\n          classList={{\n            \"text-[13px] leading-none font-bold tabular-nums sm:text-[14px]\": true,\n            \"text-text-on-critical-base\": !!props.bad,\n            \"opacity-70\": !!props.dim,\n          }}\n        >\n          {props.value}\n        </div>\n      </div>\n    </Tooltip>\n  )\n}","node_kind":"component"},{"id":"debug_bar_debugbar","label":"DebugBar()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L78-L443","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L78"}],"snippet":"export function DebugBar() {\n  const language = useLanguage()\n  const location = useLocation()\n  const routing = useIsRouting()\n  const [state, setState] = createStore({\n    cls: undefined as number | undefined,\n    delay: undefined as number | undefined,\n    fps: undefined as number | undefined,\n    gap: undefined as number | undefined,\n    heap: {\n      limit: undefined as number | undefined,\n      used: undefined as number | undefined,\n    },\n    inp: undefined as number | undefined,\n    jank: undefined as number | undefined,\n    long: {\n      block: undefined as number | undefined,\n      count: undefined as number | undefined,\n      max: undefined as number | undefined,\n    },\n    nav: {\n      dur: undefined as number | undefined,\n      pending: false,\n    },\n  })","node_kind":"component"},{"id":"debug_bar_debugbar_na","label":"na()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L104"}],"snippet":"na = () => language.t(\"debugBar.na\")"},{"id":"debug_bar_debugbar_heap","label":"heap()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L105","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L105"}],"snippet":"heap = () => (state.heap.limit ? (state.heap.used ?? 0) / state.heap.limit : undefined)"},{"id":"debug_bar_debugbar_heapv","label":"heapv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L106-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L106"}],"snippet":"heapv = () => {\n    const value = heap()\n    if (value === undefined) return na()\n    return `${Math.round(value * 100)}%`\n  }"},{"id":"debug_bar_debugbar_longv","label":"longv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L111"}],"snippet":"longv = () => (state.long.count === undefined ? na() : `${time(state.long.block) ?? na()}/${state.long.count}`)"},{"id":"debug_bar_debugbar_navv","label":"navv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L112"}],"snippet":"navv = () => (state.nav.pending ? \"...\" : (time(state.nav.dur) ?? na()))"},{"id":"debug_bar_debugbar_trim","label":"trim()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L175-L177","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L175"}],"snippet":"trim = (list: Array<{ at: number; dur: number }>, span: number, at: number) => {\n      while (list[0] && at - list[0].at > span) list.shift()\n    }"},{"id":"debug_bar_debugbar_syncframe","label":"syncFrame()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L179-L189","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L179"}],"snippet":"syncFrame = (at: number) => {\n      trim(fps, span, at)\n      const total = fps.reduce((sum, entry) => sum + entry.dur, 0)\n      const gap = fps.reduce((max, entry) => Math.max(max, entry.dur), 0)\n      const jank = fps.filter((entry) => entry.dur > 32).length\n      batch(() => {\n        setState(\"fps\", total > 0 ? (fps.length * 1000) / total : undefined)\n        setState(\"gap\", gap > 0 ? gap : undefined)\n        setState(\"jank\", jank)\n      })\n    }"},{"id":"debug_bar_debugbar_synclong","label":"syncLong()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L191-L197","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L191"}],"snippet":"syncLong = (at = performance.now()) => {\n      if (!hasLong) return\n      trim(long, span, at)\n      const block = long.reduce((sum, entry) => sum + Math.max(0, entry.dur - 50), 0)\n      const max = long.reduce((hi, entry) => Math.max(hi, entry.dur), 0)\n      setState(\"long\", { block, count: long.length, max })\n    }"},{"id":"debug_bar_debugbar_syncinp","label":"syncInp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L199-L213","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L199"}],"snippet":"syncInp = (at = performance.now()) => {\n      for (const [key, entry] of seen) {\n        if (at - entry.at > span) seen.delete(key)\n      }\n      let delay = 0\n      let inp = 0\n      for (const entry of seen.values()) {\n        delay = Math.max(delay, entry.delay)\n        inp = Math.max(inp, entry.dur)\n      }\n      batch(() => {\n        setState(\"delay\", delay > 0 ? delay : undefined)\n        setState(\"inp\", inp > 0 ? inp : undefined)\n      })\n    }"},{"id":"debug_bar_debugbar_syncheap","label":"syncHeap()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L215-L219","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L215"}],"snippet":"syncHeap = () => {\n      const mem = (performance as Mem).memory\n      if (!mem) return\n      setState(\"heap\", { limit: mem.jsHeapSizeLimit, used: mem.usedJSHeapSize })\n    }"},{"id":"debug_bar_debugbar_reset","label":"reset()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L221-L235","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L221"}],"snippet":"reset = () => {\n      fps.length = 0\n      long.length = 0\n      seen.clear()\n      last = 0\n      snap = 0\n      batch(() => {\n        setState(\"fps\", undefined)\n        setState(\"gap\", undefined)\n        setState(\"jank\", undefined)\n        setState(\"delay\", undefined)\n        setState(\"inp\", undefined)\n        if (hasLong) setState(\"long\", { block: 0, count: 0, max: 0 })\n      })\n    }"},{"id":"debug_bar_debugbar_watch","label":"watch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L237-L249","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L237"}],"snippet":"watch = (type: string, init: Obs, fn: (entries: PerformanceEntry[]) => void) => {\n      if (typeof PerformanceObserver === \"undefined\") return false\n      if (!(PerformanceObserver.supportedEntryTypes ?? []).includes(type)) return false\n      const ob = new PerformanceObserver((list) => fn(list.getEntries()))\n      try {\n        ob.observe(init)\n        obs.push(ob)\n        return true\n      } catch {\n        ob.disconnect()\n        return false\n      }\n    }"},{"id":"debug_bar_debugbar_loop","label":"loop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L298-L319","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L298"}],"snippet":"loop = (at: number) => {\n      if (document.visibilityState !== \"visible\") {\n        raf = 0\n        return\n      }\n\n      if (last === 0) {\n        last = at\n        raf = requestAnimationFrame(loop)\n        return\n      }\n\n      fps.push({ at, dur: at - last })\n      last = at\n\n      if (at - snap >= 250) {\n        snap = at\n        syncFrame(at)\n      }\n\n      raf = requestAnimationFrame(loop)\n    }"},{"id":"debug_bar_debugbar_stop","label":"stop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L321-L327","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L321"}],"snippet":"stop = () => {\n      if (raf !== 0) cancelAnimationFrame(raf)\n      raf = 0\n      if (poll === undefined) return\n      clearInterval(poll)\n      poll = undefined\n    }"},{"id":"debug_bar_debugbar_start","label":"start()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L329-L340","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/debug-bar.tsx","source_location":"L329"}],"snippet":"start = () => {\n      if (document.visibilityState !== \"visible\") return\n      if (poll === undefined) {\n        poll = window.setInterval(() => {\n          syncLong()\n          syncInp()\n          syncHeap()\