_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L41-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L41"}],"snippet":"export interface Options {\n    dir?: string\n    signal?: AbortSignal\n    staleMs?: number\n    timeoutMs?: number\n    baseDelayMs?: number\n    maxDelayMs?: number\n    onWait?: Wait\n  }"},{"id":"flock_lease","label":"Lease","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L64-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L64"}],"snippet":"export interface Lease {\n    release: () => Promise<void>\n    [Symbol.asyncDispose]: () => Promise<void>\n  }"},{"id":"flock_code","label":"code()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L69-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L69"}],"snippet":"function code(err: unknown) {\n    if (typeof err !== \"object\" || err === null || !(\"code\" in err)) return\n    const value = err.code\n    if (typeof value !== \"string\") return\n    return value\n  }"},{"id":"flock_sleep","label":"sleep()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L76-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L76"}],"snippet":"function sleep(ms: number, signal?: AbortSignal) {\n    return new Promise<void>((resolve, reject) => {\n      if (signal?.aborted) {\n        reject(signal.reason ?? new Error(\"Aborted\"))\n        return\n      }\n\n      let timer: NodeJS.Timeout | undefined\n\n      const done = () => {\n        signal?.removeEventListener(\"abort\", abort)\n        resolve()\n      }\n\n      const abort = () => {\n        if (timer) {\n          clearTimeout(timer)\n        }\n        signal?.removeEventListener(\"abort\", abort)\n        reject(signal?.reason ?? new Error(\"Aborted\"))\n      }\n\n      signal?.addEventListener(\"abort\", abort, { once: true })\n      timer = setTimeout(done, ms)\n    })"},{"id":"flock_sleep_done","label":"done()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L85-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L85"}],"snippet":"done = () => {\n        signal?.removeEventListener(\"abort\", abort)\n        resolve()\n      }"},{"id":"flock_sleep_abort","label":"abort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L90-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L90"}],"snippet":"abort = () => {\n        if (timer) {\n          clearTimeout(timer)\n        }\n        signal?.removeEventListener(\"abort\", abort)\n        reject(signal?.reason ?? new Error(\"Aborted\"))\n      }"},{"id":"flock_jitter","label":"jitter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L103-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L103"}],"snippet":"function jitter(ms: number) {\n    const j = Math.floor(ms * 0.3)\n    const d = Math.floor(Math.random() * (2 * j + 1)) - j\n    return Math.max(0, ms + d)\n  }"},{"id":"flock_mono","label":"mono()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L109-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L109"}],"snippet":"function mono() {\n    return performance.now()\n  }"},{"id":"flock_wall","label":"wall()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L113-L115","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L113"}],"snippet":"function wall() {\n    return performance.timeOrigin + mono()\n  }"},{"id":"flock_stats","label":"stats()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L117-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L117"}],"snippet":"async function stats(file: string) {\n    try {\n      return await stat(file)\n    } catch (err) {\n      const errCode = code(err)\n      if (errCode === \"ENOENT\" || errCode === \"ENOTDIR\") return\n      throw err\n    }\n  }"},{"id":"flock_stale","label":"stale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L127-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L127"}],"snippet":"async function stale(lockDir: string, heartbeatPath: string, metaPath: string, staleMs: number) {\n    // Stale detection allows automatic recovery after crashed owners.\n    const now = wall()\n    const heartbeat = await stats(heartbeatPath)\n    if (heartbeat) {\n      return now - heartbeat.mtimeMs > staleMs\n    }\n\n    const meta = await stats(metaPath)\n    if (meta) {\n      return now - meta.mtimeMs > staleMs\n    }\n\n    const dir = await stats(lockDir)\n    if (!dir) {\n      return false\n    }\n\n    return now - dir.mtimeMs > staleMs\n  }"},{"id":"flock_tryacquirelockdir","label":"tryAcquireLockDir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L148-L272","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L148"}],"snippet":"async function tryAcquireLockDir(lockDir: string, opts: Opts): Promise<Owned | { acquired: false }> {\n    const token = randomUUID?.() ?? randomBytes(16).toString(\"hex\")\n    const metaPath = path.join(lockDir, \"meta.json\")\n    const heartbeatPath = path.join(lockDir, \"heartbeat\")\n\n    try {\n      await mkdir(lockDir, { mode: 0o700 })\n    } catch (err) {\n      if (code(err) !== \"EEXIST\") {\n        throw err\n      }\n\n      if (!(await stale(lockDir, heartbeatPath, metaPath, opts.staleMs))) {\n        return { acquired: false }\n      }\n\n      const breakerPath = lockDir + \".breaker\"\n      try {\n        await mkdir(breakerPath, { mode: 0o700 })\n      } catch (claimErr) {\n        const errCode = code(claimErr)\n        if (errCode === \"EEXIST\") {\n          const breaker = await stats(breakerPath)\n          if (breaker && wall() - breaker.mtimeMs > opts.staleMs) {\n            await rm(breakerPath, { recursive: true, force: true }).catch(() => undefined)"},{"id":"flock_tryacquirelockdir_startheartbeat","label":"startHeartbeat()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L225-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L225"}],"snippet":"startHeartbeat = (intervalMs = Math.max(100, Math.floor(opts.staleMs / 3))) => {\n      if (timer) return\n      // Heartbeat prevents long critical sections from being evicted as stale.\n      timer = setInterval(() => {\n        const t = new Date()\n        void utimes(heartbeatPath, t, t).catch(() => undefined)\n      }, intervalMs)\n      timer.unref?.()\n    }"},{"id":"flock_tryacquirelockdir_release","label":"release()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L235-L265","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L235"}],"snippet":"release = async () => {\n      if (timer) {\n        clearInterval(timer)\n        timer = undefined\n      }\n\n      const current = await readFile(metaPath, \"utf8\")\n        .then((raw) => {\n          const parsed = JSON.parse(raw)\n          if (!parsed || typeof parsed !== \"object\") return {}\n          return {\n            token: \"token\" in parsed && typeof parsed.token === \"string\" ? parsed.token : undefined,\n          }\n        })\n        .catch((err) => {\n          const errCode = code(err)\n          if (errCode === \"ENOENT\" || errCode === \"ENOTDIR\") {\n            throw new Error(\"Refusing to release: lock is compromised (metadata missing).\")\n          }\n          if (err instanceof SyntaxError) {\n            throw new Error(\"Refusing to release: lock is compromised (metadata invalid).\")\n          }\n          throw err\n        })\n      // Token check prevents deleting a lock that was re-acquired by another process."},{"id":"flock_acquirelockdir","label":"acquireLockDir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L274-L308","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L274"}],"snippet":"async function acquireLockDir(\n    lockDir: string,\n    input: { key: string; onWait?: Wait; signal?: AbortSignal },\n    opts: Opts,\n  ) {\n    const stop = mono() + opts.timeoutMs\n    let attempt = 0\n    let waited = 0\n    let delay = opts.baseDelayMs\n\n    while (true) {\n      input.signal?.throwIfAborted()\n\n      const res = await tryAcquireLockDir(lockDir, opts)\n      if (res.acquired) {\n        return res\n      }\n\n      if (mono() > stop) {\n        throw new Error(`Timed out waiting for lock: ${input.key}`)\n      }\n\n      attempt += 1\n      const ms = jitter(delay)\n      await input.onWait?.({"},{"id":"flock_acquire","label":"acquire()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L310-L340","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L310"}],"snippet":"export async function acquire(key: string, input: Options = {}): Promise<Lease> {\n    input.signal?.throwIfAborted()\n    const cfg: Opts = {\n      staleMs: input.staleMs ?? defaultOpts.staleMs,\n      timeoutMs: input.timeoutMs ?? defaultOpts.timeoutMs,\n      baseDelayMs: input.baseDelayMs ?? defaultOpts.baseDelayMs,\n      maxDelayMs: input.maxDelayMs ?? defaultOpts.maxDelayMs,\n    }\n    const dir = input.dir ?? root()\n\n    await mkdir(dir, { recursive: true })\n    const lockfile = path.join(dir, Hash.fast(key) + \".lock\")\n    const lock = await acquireLockDir(\n      lockfile,\n      {\n        key,\n        onWait: input.onWait,\n        signal: input.signal,\n      },\n      cfg,\n    )\n    lock.startHeartbeat()\n\n    const release = () => lock.release()\n    return {"},{"id":"flock_acquire_release","label":"release()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L333","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L333"}],"snippet":"release = () => lock.release()"},{"id":"flock_withlock","label":"withLock()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L342-L346","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/flock.ts","source_location":"L342"}],"snippet":"export async function withLock<T>(key: string, fn: () => Promise<T>, input: Options = {}) {\n    await using _ = await acquire(key, input)\n    input.signal?.throwIfAborted()\n    return await fn()\n  }"}],"edges":[{"source":"flock","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowda