ges/app/src/context/global-sync/eviction.ts","source_location":"L21"}],"snippet":"export function canDisposeDirectory(input: DisposeCheck) {\n  if (!input.directory) return false\n  if (!input.hasStore) return false\n  if (input.pinned) return false\n  if (input.booting) return false\n  if (input.loadingSessions) return false\n  return true\n}"}],"edges":[{"source":"eviction","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/eviction.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/eviction.ts","source_location":"L1"}],"weight":1},{"source":"eviction","target":"eviction_pickdirectoriestoevict","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/eviction.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/eviction.ts","source_location":"L3"}],"weight":1},{"source":"eviction","target":"eviction_candisposedirectory","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/eviction.ts","source_location":"L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/eviction.ts","source_location":"L21"}],"weight":1}]}