{"__madarTsExtractorVersion":67,"__madarFileStem":"uninstall","nodes":[{"id":"uninstall","label":"uninstall.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L1"}]},{"id":"uninstall_uninstallargs","label":"UninstallArgs","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L12-L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L12"}],"snippet":"interface UninstallArgs {\n  keepConfig: boolean\n  keepData: boolean\n  dryRun: boolean\n  force: boolean\n}"},{"id":"uninstall_removaltargets","label":"RemovalTargets","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L19-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L19"}],"snippet":"interface RemovalTargets {\n  directories: Array<{ path: string; label: string; keep: boolean }>\n  shellConfig: string | null\n  binary: string | null\n}"},{"id":"uninstall_collectremovaltargets","label":"collectRemovalTargets()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L90-L102","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L90"}],"snippet":"async function collectRemovalTargets(args: UninstallArgs, method: Installation.Method): Promise<RemovalTargets> {\n  const directories: RemovalTargets[\"directories\"] = [\n    { path: Global.Path.data, label: \"Data\", keep: args.keepData },\n    { path: Global.Path.cache, label: \"Cache\", keep: false },\n    { path: Global.Path.config, label: \"Config\", keep: args.keepConfig },\n    { path: Global.Path.state, label: \"State\", keep: false },\n  ]\n\n  const shellConfig = method === \"curl\" ? await getShellConfigFile() : null\n  const binary = method === \"curl\" ? process.execPath : null\n\n  return { directories, shellConfig, binary }\n}"},{"id":"uninstall_showremovalsummary","label":"showRemovalSummary()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L104-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L104"}],"snippet":"async function showRemovalSummary(targets: RemovalTargets, method: Installation.Method) {\n  prompts.log.message(\"The following will be removed:\")\n\n  for (const dir of targets.directories) {\n    const exists = await fs\n      .access(dir.path)\n      .then(() => true)\n      .catch(() => false)\n    if (!exists) continue\n\n    const size = await getDirectorySize(dir.path)\n    const sizeStr = formatSize(size)\n    const status = dir.keep ? UI.Style.TEXT_DIM + \"(keeping)\" : \"\"\n    const prefix = dir.keep ? \"○\" : \"✓\"\n\n    prompts.log.info(`  ${prefix} ${dir.label}: ${shortenPath(dir.path)} ${UI.Style.TEXT_DIM}(${sizeStr})${status}`)\n  }\n\n  if (targets.binary) {\n    prompts.log.info(`  ✓ Binary: ${shortenPath(targets.binary)}`)\n  }\n\n  if (targets.shellConfig) {\n    prompts.log.info(`  ✓ Shell PATH in ${shortenPath(targets.shellConfig)}`)\n  }"},{"id":"uninstall_executeuninstall","label":"executeUninstall()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L144-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L144"}],"snippet":"async function executeUninstall(method: Installation.Method, targets: RemovalTargets) {\n  const spinner = prompts.spinner()\n  const errors: string[] = []\n\n  for (const dir of targets.directories) {\n    if (dir.keep) {\n      prompts.log.step(`Skipping ${dir.label} (--keep-${dir.label.toLowerCase()})`)\n      continue\n    }\n\n    const exists = await fs\n      .access(dir.path)\n      .then(() => true)\n      .catch(() => false)\n    if (!exists) continue\n\n    spinner.start(`Removing ${dir.label}...`)\n    const err = await fs.rm(dir.path, { recursive: true, force: true }).catch((e) => e)\n    if (err) {\n      spinner.stop(`Failed to remove ${dir.label}`, 1)\n      errors.push(`${dir.label}: ${err.message}`)\n      continue\n    }\n    spinner.stop(`Removed ${dir.label}`)\n  }"},{"id":"uninstall_getshellconfigfile","label":"getShellConfigFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L235-L275","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L235"}],"snippet":"async function getShellConfigFile(): Promise<string | null> {\n  const shell = path.basename(process.env.SHELL || \"bash\")\n  const home = os.homedir()\n  const xdgConfig = process.env.XDG_CONFIG_HOME || path.join(home, \".config\")\n\n  const configFiles: Record<string, string[]> = {\n    fish: [path.join(xdgConfig, \"fish\", \"config.fish\")],\n    zsh: [\n      path.join(home, \".zshrc\"),\n      path.join(home, \".zshenv\"),\n      path.join(xdgConfig, \"zsh\", \".zshrc\"),\n      path.join(xdgConfig, \"zsh\", \".zshenv\"),\n    ],\n    bash: [\n      path.join(home, \".bashrc\"),\n      path.join(home, \".bash_profile\"),\n      path.join(home, \".profile\"),\n      path.join(xdgConfig, \"bash\", \".bashrc\"),\n      path.join(xdgConfig, \"bash\", \".bash_profile\"),\n    ],\n    ash: [path.join(home, \".ashrc\"), path.join(home, \".profile\")],\n    sh: [path.join(home, \".profile\")],\n  }\n\n  const candidates = configFiles[shell] || configFiles.bash"},{"id":"uninstall_cleanshellconfig","label":"cleanShellConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L277-L315","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L277"}],"snippet":"async function cleanShellConfig(file: string) {\n  const content = await Filesystem.readText(file)\n  const lines = content.split(\"\\n\")\n\n  const filtered: string[] = []\n  let skip = false\n\n  for (const line of lines) {\n    const trimmed = line.trim()\n\n    if (trimmed === \"# opencode\") {\n      skip = true\n      continue\n    }\n\n    if (skip) {\n      skip = false\n      if (trimmed.includes(\".opencode/bin\") || trimmed.includes(\"fish_add_path\")) {\n        continue\n      }\n    }\n\n    if (\n      (trimmed.startsWith(\"export PATH=\") && trimmed.includes(\".opencode/bin\")) ||\n      (trimmed.startsWith(\"fish_add_path\") && trimmed.includes(\".opencode\"))"},{"id":"uninstall_getdirectorysize","label":"getDirectorySize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L317-L338","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L317"}],"snippet":"async function getDirectorySize(dir: string): Promise<number> {\n  let total = 0\n\n  const walk = async (current: string) => {\n    const entries = await fs.readdir(current, { withFileTypes: true }).catch(() => [])\n\n    for (const entry of entries) {\n      const full = path.join(current, entry.name)\n      if (entry.isDirectory()) {\n        await walk(full)\n        continue\n      }\n      if (entry.isFile()) {\n        const stat = await fs.stat(full).catch(() => null)\n        if (stat) total += stat.size\n      }\n    }\n  }\n\n  await walk(dir)\n  return total\n}"},{"id":"uninstall_getdirectorysize_walk","label":"walk()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L320-L334","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L320"}],"snippet":"walk = async (current: string) => {\n    const entries = await fs.readdir(current, { withFileTypes: true }).catch(() => [])\n\n    for (const entry of entries) {\n      const full = path.join(current, entry.name)\n      if (entry.isDirectory()) {\n        await walk(full)\n        continue\n      }\n      if (entry.isFile()) {\n        const stat = await fs.stat(full).catch(() => null)\n        if (stat) total += stat.size\n      }\n    }\n  }"},{"id":"uninstall_formatsize","label":"formatSize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L340-L345","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L340"}],"snippet":"function formatSize(bytes: number): string {\n  if (bytes < 1024) return `${bytes} B`\n  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`\n  if (bytes < 1024 * 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(1)} MB`\n  return `${(bytes / (1024 * 1024 * 1024)).toFixed(1)} GB`\n}"},{"id":"uninstall_shortenpath","label":"shortenPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L347-L353","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L347"}],"snippet":"function shortenPath(p: string): string {\n  const home = os.homedir()\n  if (p.startsWith(home)) {\n    return p.replace(home, \"~\")\n  }\n  return p\n}"}],"edges":[{"source":"uninstall","target":"yargs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L1"}],"weight":1},{"source":"uninstall","target":"ui","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/uninstall.ts","sou