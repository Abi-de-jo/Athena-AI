{"__madarTsExtractorVersion":67,"__madarFileStem":"anthropic-messages","nodes":[{"id":"anthropic_messages","label":"anthropic-messages.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L1"}]},{"id":"anthropic_messages_parserstate","label":"ParserState","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L221-L225","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L221"}],"snippet":"interface ParserState {\n  readonly tools: ToolStream.State<number>\n  readonly usage?: Usage\n  readonly lifecycle: Lifecycle.State\n}"},{"id":"anthropic_messages_cachecontrol","label":"cacheControl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L241-L249","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L241"}],"snippet":"cacheControl = (breakpoints: Cache.Breakpoints, cache: CacheHint | undefined) => {\n  if (cache?.type !== \"ephemeral\" && cache?.type !== \"persistent\") return undefined\n  if (breakpoints.remaining <= 0) {\n    breakpoints.dropped += 1\n    return undefined\n  }\n  breakpoints.remaining -= 1\n  return Cache.ttlBucket(cache.ttlSeconds) === \"1h\" ? EPHEMERAL_1H : EPHEMERAL_5M\n}"},{"id":"anthropic_messages_anthropicmetadata","label":"anthropicMetadata()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L251","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L251"}],"snippet":"anthropicMetadata = (metadata: Record<string, unknown>): ProviderMetadata => ({ anthropic: metadata })"},{"id":"anthropic_messages_signaturefrommetadata","label":"signatureFromMetadata()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L253-L257","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L253"}],"snippet":"signatureFromMetadata = (metadata: ProviderMetadata | undefined): string | undefined => {\n  const anthropic = metadata?.anthropic\n  if (!ProviderShared.isRecord(anthropic)) return undefined\n  return typeof anthropic.signature === \"string\" ? anthropic.signature : undefined\n}"},{"id":"anthropic_messages_lowertool","label":"lowerTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L259-L264","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L259"}],"snippet":"lowerTool = (breakpoints: Cache.Breakpoints, tool: ToolDefinition): AnthropicTool => ({\n  name: tool.name,\n  description: tool.description,\n  input_schema: tool.inputSchema,\n  cache_control: cacheControl(breakpoints, tool.cache),\n})"},{"id":"anthropic_messages_lowertoolchoice","label":"lowerToolChoice()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L266-L272","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L266"}],"snippet":"lowerToolChoice = (toolChoice: NonNullable<LLMRequest[\"toolChoice\"]>) =>\n  ProviderShared.matchToolChoice(\"Anthropic Messages\", toolChoice, {\n    auto: () => ({ type: \"auto\" as const }),\n    none: () => undefined,\n    required: () => ({ type: \"any\" as const }),\n    tool: (name) => ({ type: \"tool\" as const, name }),\n  })"},{"id":"anthropic_messages_lowertoolcall","label":"lowerToolCall()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L274-L279","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L274"}],"snippet":"lowerToolCall = (part: ToolCallPart): AnthropicToolUseBlock => ({\n  type: \"tool_use\",\n  id: part.id,\n  name: part.name,\n  input: part.input,\n})"},{"id":"anthropic_messages_lowerservertoolcall","label":"lowerServerToolCall()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L281-L286","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L281"}],"snippet":"lowerServerToolCall = (part: ToolCallPart): AnthropicServerToolUseBlock => ({\n  type: \"server_tool_use\",\n  id: part.id,\n  name: part.name,\n  input: part.input,\n})"},{"id":"anthropic_messages_servertoolresulttype","label":"serverToolResultType()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L291-L296","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L291"}],"snippet":"serverToolResultType = (name: string): AnthropicServerToolResultType | undefined => {\n  if (name === \"web_search\") return \"web_search_tool_result\"\n  if (name === \"code_execution\") return \"code_execution_tool_result\"\n  if (name === \"web_fetch\") return \"web_fetch_tool_result\"\n  return undefined\n}"},{"id":"anthropic_messages_supportsnativesystemupdates","label":"supportsNativeSystemUpdates()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L354","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L354"}],"snippet":"supportsNativeSystemUpdates = (request: LLMRequest) => String(request.model.id) === \"claude-opus-4-8\""},{"id":"anthropic_messages_endsinservertooluse","label":"endsInServerToolUse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L356-L359","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L356"}],"snippet":"endsInServerToolUse = (message: LLMRequest[\"messages\"][number]) => {\n  const last = message.content.at(-1)\n  return message.role === \"assistant\" && last?.type === \"tool-call\" && last.providerExecuted === true\n}"},{"id":"anthropic_messages_canusenativesystemupdate","label":"canUseNativeSystemUpdate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L361-L371","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L361"}],"snippet":"canUseNativeSystemUpdate = (messages: LLMRequest[\"messages\"], index: number) => {\n  const previous = messages[index - 1]\n  const next = messages[index + 1]\n  return (\n    previous !== undefined &&\n    previous.role !== \"system\" &&\n    (previous.role === \"user\" || previous.role === \"tool\" || endsInServerToolUse(previous)) &&\n    next?.role !== \"system\" &&\n    (next === undefined || next.role === \"assistant\")\n  )\n}"},{"id":"anthropic_messages_splitslocaltoolresults","label":"splitsLocalToolResults()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L373-L383","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L373"}],"snippet":"splitsLocalToolResults = (messages: LLMRequest[\"messages\"], index: number) => {\n  const pending = new Set<string>()\n  for (const message of messages.slice(0, index)) {\n    for (const part of message.content) {\n      if (message.role === \"assistant\" && part.type === \"tool-call\" && part.providerExecuted !== true)\n        pending.add(part.id)\n      if (message.role === \"tool\" && part.type === \"tool-result\") pending.delete(part.id)\n    }\n  }\n  return pending.size > 0\n}"},{"id":"anthropic_messages_anthropicoptions","label":"anthropicOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L489","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L489"}],"snippet":"anthropicOptions = (request: LLMRequest) => request.providerOptions?.anthropic"},{"id":"anthropic_messages_mapfinishreason","label":"mapFinishReason()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L548-L554","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L548"}],"snippet":"mapFinishReason = (reason: string | null | undefined): FinishReason => {\n  if (reason === \"end_turn\" || reason === \"stop_sequence\" || reason === \"pause_turn\") return \"stop\"\n  if (reason === \"max_tokens\") return \"length\"\n  if (reason === \"tool_use\") return \"tool-calls\"\n  if (reason === \"refusal\") return \"content-filter\"\n  return \"unknown\"\n}"},{"id":"anthropic_messages_mapusage","label":"mapUsage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L563-L578","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L563"}],"snippet":"mapUsage = (usage: AnthropicUsage | undefined): Usage | undefined => {\n  if (!usage) return undefined\n  const nonCached = usage.input_tokens\n  const cacheRead = usage.cache_read_input_tokens ?? undefined\n  const cacheWrite = usage.cache_creation_input_tokens ?? undefined\n  const inputTokens = ProviderShared.sumTokens(nonCached, cacheRead, cacheWrite)\n  return new Usage({\n    inputTokens,\n    outputTokens: usage.output_tokens,\n    nonCachedInputTokens: nonCached,\n    cacheReadInputTokens: cacheRead,\n    cacheWriteInputTokens: cacheWrite,\n    totalTokens: ProviderShared.totalTokens(inputTokens, usage.output_tokens, undefined),\n    providerMetadata: { anthropic: usage },\n  })\n}"},{"id":"anthropic_messages_mergeusage","label":"mergeUsage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L585-L607","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L585"}],"snippet":"mergeUsage = (left: Usage | undefined, right: Usage | undefined) => {\n  if (!left) return right\n  if (!right) return left\n  const nonCachedInputTokens = right.nonCachedInputTokens ?? left.nonCachedInputTokens\n  const cacheReadInputTokens = right.cacheReadInputTokens ?? left.cacheReadInputTokens\n  const cacheWriteInputTokens = right.cacheWriteInputTokens ?? left.cacheWriteInputTokens\n  const inputTokens = ProviderShared.sumTokens(nonCachedInputTokens, cacheReadInputTokens, cacheWriteInputTokens)\n  const outputTokens = right.outputTokens ?? left.outputTokens\n  return new Usage({\n    inputTokens,\n    outputTokens,\n    nonCachedInputTokens,\n    cacheReadInputTokens,\n    cacheWriteInputTokens,\n    totalTokens: ProviderShared.totalTokens(inputTokens, outputTokens, undefined),\n    providerMetadata: {\n      anthropic: {\n        ...left.providerMetadata?.[\"anthropic\"],\n        ...right.providerMetadata?.[\"anthropic\"],\n      },\n    },\n  })\n}"},{"id":"anthropic_messages_isservertoolresulttype","label":"isServerToolResultType()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L620","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L620"}],"snippet":"isServerToolResultType = (type: string): type is AnthropicServerToolResultType => type in SERVER_TOOL_RESULT_NAMES"},{"id":"anthropic_messages_servertoolresultevent","label":"serverToolResultEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L622-L636","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L622"}],"snippet":"serverToolResultEvent = (block: NonNullable<AnthropicEvent[\"content_block\"]>): LLMEvent | undefined => {\n  if (!block.type || !isServerToolResultType(block.type)) return undefined\n  const errorPayload =\n    typeof block.content === \"object\" && block.content !== null && \"type\" in block.content\n      ? String((block.content as Record<string, unknown>).type)\n      : \"\"\n  const isError = errorPayload.endsWith(\"_tool_result_error\")\n  return LLMEvent.toolResult({\n    id: block.tool_use_id ?? \"\",\n    name: SERVER_TOOL_RESULT_NAMES[block.type],\n    result: isError ? { type: \"error\", value: block.content } : { type: \"json\", value: block.content },\n    providerExecuted: true,\n    providerMetadata: anthropicMetadata({ blockType: block.type }),\n  })\n}"},{"id":"anthropic_messages_onmessagestart","label":"onMessageStart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L642-L645","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L642"}],"snippet":"onMessageStart = (state: ParserState, event: AnthropicEvent): StepResult => {\n  const usage = mapUsage(event.message?.usage)\n  return [usage ? { ...state, usage: mergeUsage(state.usage, usage) } : state, NO_EVENTS]\n}"},{"id":"anthropic_messages_oncontentblockstart","label":"onContentBlockStart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L647-L691","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L647"}],"snippet":"onContentBlockStart = (state: ParserState, event: AnthropicEvent): StepResult => {\n  const block = event.content_block\n  if (!block) return [state, NO_EVENTS]\n\n  if ((block.type === \"tool_use\" || block.type === \"server_tool_use\") && event.index !== undefined) {\n    const events: LLMEvent[] = []\n    const lifecycle = Lifecycle.stepStart(state.lifecycle, events)\n    return [\n      {\n        ...state,\n        lifecycle,\n        tools: ToolStream.start(state.tools, event.index, {\n          id: block.id ?? String(event.index),\n          name: block.name ?? \"\",\n          providerExecuted: block.type === \"server_tool_use\",\n        }),\n      },\n      [...events, LLMEvent.toolInputStart({ id: block.id ?? String(event.index), name: block.name ?? \"\" })],\n    ]\n  }\n\n  if (block.type === \"text\" && block.text) {\n    const events: LLMEvent[] = []\n    return [\n      { ...state, lifecycle: Lifecycle.textDelta(state.lifecycle, events, `text-${event.index ?? 0}`, block.text) },"},{"id":"anthropic_messages_onmessagedelta","label":"onMessageDelta()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L772-L783","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L772"}],"snippet":"onMessageDelta = (state: ParserState, event: AnthropicEvent): StepResult => {\n  const usage = mergeUsage(state.usage, mapUsage(event.usage))\n  const events: LLMEvent[] = []\n  const lifecycle = Lifecycle.finish(state.lifecycle, events, {\n    reason: mapFinishReason(event.delta?.stop_reason),\n    usage,\n    providerMetadata: event.delta?.stop_sequence\n      ? anthropicMetadata({ stopSequence: event.delta.stop_sequence })\n      : undefined,\n  })\n  return [{ ...state, lifecycle, usage }, events]\n}"},{"id":"anthropic_messages_providererrormessage","label":"providerErrorMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L787-L792","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L787"}],"snippet":"providerErrorMessage = (event: AnthropicEvent): string => {\n  const type = event.error?.type\n  const message = event.error?.message\n  if (type && message) return `${type}: ${message}`\n  return message || type || \"Anthropic Messages stream error\"\n}"},{"id":"anthropic_messages_onerror","label":"onError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L794-L802","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L794"}],"snippet":"onError = (state: ParserState, event: AnthropicEvent): StepResult => [\n  state,\n  [\n    LLMEvent.providerError({\n      message: providerErrorMessage(event),\n      classification: isContextOverflow(event.error?.message ?? \"\") ? \"context-overflow\" : undefined,\n    }),\n  ],\n]"},{"id":"anthropic_messages_step","label":"step()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L804-L812","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L804"}],"snippet":"step = (state: ParserState, event: AnthropicEvent) => {\n  if (event.type === \"message_start\") return Effect.succeed(onMessageStart(state, event))\n  if (event.type === \"content_block_start\") return Effect.succeed(onContentBlockStart(state, event))\n  if (event.type === \"content_block_delta\") return onContentBlockDelta(state, event)\n  if (event.type === \"content_block_stop\") return onContentBlockStop(state, event)\n  if (event.type === \"message_delta\") return Effect.succeed(onMessageDelta(state, event))\n  if (event.type === \"error\") return Effect.succeed(onError(state, event))\n  return Effect.succeed<StepResult>([state, NO_EVENTS])\n}"}],"edges":[{"source":"anthropic_messages","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/anthropic-messages.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/pro