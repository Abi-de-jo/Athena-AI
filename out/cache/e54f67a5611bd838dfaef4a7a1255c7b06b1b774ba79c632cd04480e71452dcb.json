{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_context_file_path","nodes":[{"id":"packages_app_src_context_file_path","label":"path.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L1"}]},{"id":"packages_app_src_context_file_path_stripfileprotocol","label":"stripFileProtocol()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L1-L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L1"}],"snippet":"export function stripFileProtocol(input: string) {\n  if (!input.startsWith(\"file://\")) return input\n  return input.slice(\"file://\".length)\n}"},{"id":"packages_app_src_context_file_path_stripqueryandhash","label":"stripQueryAndHash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L6-L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L6"}],"snippet":"export function stripQueryAndHash(input: string) {\n  const hashIndex = input.indexOf(\"#\")\n  const queryIndex = input.indexOf(\"?\")\n\n  if (hashIndex !== -1 && queryIndex !== -1) {\n    return input.slice(0, Math.min(hashIndex, queryIndex))\n  }\n\n  if (hashIndex !== -1) return input.slice(0, hashIndex)\n  if (queryIndex !== -1) return input.slice(0, queryIndex)\n  return input\n}"},{"id":"packages_app_src_context_file_path_unquotegitpath","label":"unquoteGitPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L19-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L19"}],"snippet":"export function unquoteGitPath(input: string) {\n  if (!input.startsWith('\"')) return input\n  if (!input.endsWith('\"')) return input\n  const body = input.slice(1, -1)\n  const bytes: number[] = []\n\n  for (let i = 0; i < body.length; i++) {\n    const char = body[i]!\n    if (char !== \"\\\\\") {\n      bytes.push(char.charCodeAt(0))\n      continue\n    }\n\n    const next = body[i + 1]\n    if (!next) {\n      bytes.push(\"\\\\\".charCodeAt(0))\n      continue\n    }\n\n    if (next >= \"0\" && next <= \"7\") {\n      const chunk = body.slice(i + 1, i + 4)\n      const match = chunk.match(/^[0-7]{1,3}/)\n      if (!match) {\n        bytes.push(next.charCodeAt(0))\n        i++"},{"id":"packages_app_src_context_file_path_decodefilepath","label":"decodeFilePath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L75-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L75"}],"snippet":"export function decodeFilePath(input: string) {\n  try {\n    return decodeURIComponent(input)\n  } catch {\n    return input\n  }\n}"},{"id":"packages_app_src_context_file_path_encodefilepath","label":"encodeFilePath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L83-L102","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L83"}],"snippet":"export function encodeFilePath(filepath: string): string {\n  // Normalize Windows paths: convert backslashes to forward slashes\n  let normalized = filepath.replace(/\\\\/g, \"/\")\n\n  // Handle Windows absolute paths (D:/path -> /D:/path for proper file:// URLs)\n  if (/^[A-Za-z]:/.test(normalized)) {\n    normalized = \"/\" + normalized\n  }\n\n  // Encode each path segment (preserving forward slashes as path separators)\n  // Keep the colon in Windows drive letters (`/C:/...`) so downstream file URL parsers\n  // can reliably detect drives.\n  return normalized\n    .split(\"/\")\n    .map((segment, index) => {\n      if (index === 1 && /^[A-Za-z]:$/.test(segment)) return segment\n      return encodeURIComponent(segment)\n    })\n    .join(\"/\")\n}"},{"id":"packages_app_src_context_file_path_createpathhelpers","label":"createPathHelpers()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L104-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L104"}],"snippet":"export function createPathHelpers(scope: () => string) {\n  const normalize = (input: string) => {\n    const root = scope()\n\n    let path = unquoteGitPath(decodeFilePath(stripQueryAndHash(stripFileProtocol(input))))\n\n    // Separator-agnostic prefix stripping for Cygwin/native Windows compatibility\n    // Only case-insensitive on Windows (drive letter or UNC paths)\n    const windows = /^[A-Za-z]:/.test(root) || root.startsWith(\"\\\\\\\\\")\n    const canonRoot = windows ? root.replace(/\\\\/g, \"/\").toLowerCase() : root.replace(/\\\\/g, \"/\")\n    const canonPath = windows ? path.replace(/\\\\/g, \"/\").toLowerCase() : path.replace(/\\\\/g, \"/\")\n    if (\n      canonPath.startsWith(canonRoot) &&\n      (canonRoot.endsWith(\"/\") || canonPath === canonRoot || canonPath[canonRoot.length] === \"/\")\n    ) {\n      // Slice from original path to preserve native separators\n      path = path.slice(root.length)\n    }\n\n    if (path.startsWith(\"./\") || path.startsWith(\".\\\\\")) {\n      path = path.slice(2)\n    }\n\n    if (path.startsWith(\"/\") || path.startsWith(\"\\\\\")) {\n      path = path.slice(1)"},{"id":"packages_app_src_context_file_path_createpathhelpers_normalize","label":"normalize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L105-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L105"}],"snippet":"normalize = (input: string) => {\n    const root = scope()\n\n    let path = unquoteGitPath(decodeFilePath(stripQueryAndHash(stripFileProtocol(input))))\n\n    // Separator-agnostic prefix stripping for Cygwin/native Windows compatibility\n    // Only case-insensitive on Windows (drive letter or UNC paths)\n    const windows = /^[A-Za-z]:/.test(root) || root.startsWith(\"\\\\\\\\\")\n    const canonRoot = windows ? root.replace(/\\\\/g, \"/\").toLowerCase() : root.replace(/\\\\/g, \"/\")\n    const canonPath = windows ? path.replace(/\\\\/g, \"/\").toLowerCase() : path.replace(/\\\\/g, \"/\")\n    if (\n      canonPath.startsWith(canonRoot) &&\n      (canonRoot.endsWith(\"/\") || canonPath === canonRoot || canonPath[canonRoot.length] === \"/\")\n    ) {\n      // Slice from original path to preserve native separators\n      path = path.slice(root.length)\n    }\n\n    if (path.startsWith(\"./\") || path.startsWith(\".\\\\\")) {\n      path = path.slice(2)\n    }\n\n    if (path.startsWith(\"/\") || path.startsWith(\"\\\\\")) {\n      path = path.slice(1)\n    }"},{"id":"packages_app_src_context_file_path_createpathhelpers_tab","label":"tab()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L133-L136","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L133"}],"snippet":"tab = (input: string) => {\n    const path = normalize(input)\n    return `file://${encodeFilePath(path)}`\n  }"},{"id":"packages_app_src_context_file_path_createpathhelpers_pathfromtab","label":"pathFromTab()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L138-L141","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L138"}],"snippet":"pathFromTab = (tabValue: string) => {\n    if (!tabValue.startsWith(\"file://\")) return\n    return normalize(tabValue)\n  }"},{"id":"packages_app_src_context_file_path_createpathhelpers_normalizedir","label":"normalizeDir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/path.ts","source_location":"L143"}],"snippet":"normalizeDir = (input: string) => normalize(input).replace(/\\/+$/, \"\")"}],"edges":[{"source":"packages_app_src_context_file_path","target":"packages_app_src_context_file_path_stripfileprotocol","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/