{"__madarTsExtractorVersion":67,"__madarFileStem":"dialog-select-file","nodes":[{"id":"dialog_select_file","label":"dialog-select-file.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L1"}]},{"id":"dialog_select_file_uniqueentries","label":"uniqueEntries()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L58-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L58"}],"snippet":"uniqueEntries = (items: Entry[]) => {\n  const seen = new Set<string>()\n  const out: Entry[] = []\n  for (const item of items) {\n    if (seen.has(item.id)) continue\n    seen.add(item.id)\n    out.push(item)\n  }\n  return out\n}"},{"id":"dialog_select_file_createcommandentry","label":"createCommandEntry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L69-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L69"}],"snippet":"createCommandEntry = (option: CommandOption, category: string): Entry => ({\n  id: \"command:\" + option.id,\n  type: \"command\",\n  title: option.title,\n  description: option.description,\n  keybind: option.keybind,\n  category,\n  option,\n})"},{"id":"dialog_select_file_createfileentry","label":"createFileEntry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L79-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L79"}],"snippet":"createFileEntry = (path: string, category: string): Entry => ({\n  id: \"file:\" + path,\n  type: \"file\",\n  title: path,\n  category,\n  path,\n})"},{"id":"dialog_select_file_createsessionentry","label":"createSessionEntry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L87-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L87"}],"snippet":"createSessionEntry = (\n  input: {\n    directory: string\n    id: string\n    title: string\n    description: string\n    archived?: number\n    updated?: number\n  },\n  category: string,\n): Entry => ({\n  id: `session:${input.directory}:${input.id}`,\n  type: \"session\",\n  title: input.title,\n  description: input.description,\n  category,\n  directory: input.directory,\n  sessionID: input.id,\n  archived: input.archived,\n  updated: input.updated,\n})"},{"id":"dialog_select_file_createcommandentries","label":"createCommandEntries()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L109-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L109"}],"snippet":"function createCommandEntries(props: {\n  filesOnly: () => boolean\n  command: ReturnType<typeof useCommand>\n  language: ReturnType<typeof useLanguage>\n}) {\n  const allowed = createMemo(() => {\n    if (props.filesOnly()) return []\n    return props.command.options.filter(\n      (option) =>\n        !option.disabled && !option.hidden && !option.id.startsWith(\"suggested.\") && option.id !== \"file.open\",\n    )\n  })\n\n  const list = createMemo(() => {\n    const category = props.language.t(\"palette.group.commands\")\n    return allowed().map((option) => createCommandEntry(option, category))\n  })\n\n  const picks = createMemo(() => {\n    const all = allowed()\n    const order = new Map<string, number>(COMMON_COMMAND_IDS.map((id, index) => [id, index]))\n    const picked = all.filter((option) => order.has(option.id))\n    const base = picked.length ? picked : all.slice(0, ENTRY_LIMIT)\n    const sorted = picked.length ? [...base].sort((a, b) => (order.get(a.id) ?? 0) - (order.get(b.id) ?? 0)) : base\n    const category = props.language.t(\"palette.group.commands\")"},{"id":"dialog_select_file_createfileentries","label":"createFileEntries()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L140-L180","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L140"}],"snippet":"function createFileEntries(props: {\n  file: ReturnType<typeof useFile>\n  tabs: () => ReturnType<ReturnType<typeof useLayout>[\"tabs\"]>\n  language: ReturnType<typeof useLanguage>\n}) {\n  const tabState = createSessionTabs({\n    tabs: props.tabs,\n    pathFromTab: props.file.pathFromTab,\n    normalizeTab: (tab) => (tab.startsWith(\"file://\") ? props.file.tab(tab) : tab),\n  })\n  const recent = createMemo(() => {\n    const all = tabState.openedTabs()\n    const active = tabState.activeFileTab()\n    const order = active ? [active, ...all.filter((item) => item !== active)] : all\n    const seen = new Set<string>()\n    const category = props.language.t(\"palette.group.files\")\n    const items: Entry[] = []\n\n    for (const item of order) {\n      const path = props.file.pathFromTab(item)\n      if (!path) continue\n      if (seen.has(path)) continue\n      seen.add(path)\n      items.push(createFileEntry(path, category))\n    }"},{"id":"dialog_select_file_createsessionentries","label":"createSessionEntries()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L182-L269","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L182"}],"snippet":"function createSessionEntries(props: {\n  workspaces: () => string[]\n  label: (directory: string) => string\n  serverSDK: ServerSDK\n  language: ReturnType<typeof useLanguage>\n}) {\n  const state: {\n    token: number\n    inflight: Promise<Entry[]> | undefined\n    cached: Entry[] | undefined\n  } = {\n    token: 0,\n    inflight: undefined,\n    cached: undefined,\n  }\n\n  const sessions = (text: string) => {\n    const query = text.trim()\n    if (!query) {\n      state.token += 1\n      state.inflight = undefined\n      state.cached = undefined\n      return [] as Entry[]\n    }"},{"id":"dialog_select_file_createsessionentries_sessions","label":"sessions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L198-L266","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L198"}],"snippet":"sessions = (text: string) => {\n    const query = text.trim()\n    if (!query) {\n      state.token += 1\n      state.inflight = undefined\n      state.cached = undefined\n      return [] as Entry[]\n    }\n\n    if (state.cached) return state.cached\n    if (state.inflight) return state.inflight\n\n    const current = state.token\n    const dirs = props.workspaces()\n    if (dirs.length === 0) return [] as Entry[]\n\n    state.inflight = Promise.all(\n      dirs.map((directory) => {\n        const description = props.label(directory)\n        return props.serverSDK.client.session\n          .list({ directory, roots: true })\n          .then((x) =>\n            (x.data ?? [])\n              .filter((s) => !!s?.id)\n              .map((s) => ({"},{"id":"dialog_select_file_dialogselectfile","label":"DialogSelectFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L271-L494","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L271"}],"snippet":"export function DialogSelectFile(props: { mode?: DialogSelectFileMode; onOpenFile?: (path: string) => void }) {\n  const command = useCommand()\n  const language = useLanguage()\n  const platform = usePlatform()\n  const server = useServer()\n  const settings = useSettings()\n  const layout = useLayout()\n  const file = useFile()\n  const dialog = useDialog()\n  const navigate = useNavigate()\n  const serverSDK = useServerSDK()\n  const serverSync = useServerSync()\n  const { params, tabs, view } = useSessionLayout()\n  const filesOnly = () => props.mode === \"files\"\n  const state = { cleanup: undefined as (() => void) | void, committed: false }\n  const [grouped, setGrouped] = createSignal(false)\n  const commandEntries = createCommandEntries({ filesOnly, command, language })\n  const fileEntries = createFileEntries({ file, tabs, language })\n\n  const projectDirectory = createMemo(() => decode64(params.dir) ?? \"\")\n  const project = createMemo(() => {\n    const directory = projectDirectory()\n    if (!directory) return\n    return layout.projects.list().find((p) => p.worktree === directory || p.sandboxes?.includes(directory))\n  })","node_kind":"component"},{"id":"dialog_select_file_dialogselectfile_filesonly","label":"filesOnly()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L284","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L284"}],"snippet":"filesOnly = () => props.mode === \"files\""},{"id":"dialog_select_file_dialogselectfile_label","label":"label()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L306-L317","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L306"}],"snippet":"label = (directory: string) => {\n    const current = project()\n    const kind =\n      current && directory === current.worktree\n        ? language.t(\"workspace.type.local\")\n        : language.t(\"workspace.type.sandbox\")\n    const [store] = serverSync().child(directory, { bootstrap: false })\n    const home = homedir()\n    const path = home ? directory.replace(home, \"~\") : directory\n    const name = store.vcs?.branch ?? getFilename(directory)\n    return `${kind} : ${name || path}`\n  }"},{"id":"dialog_select_file_dialogselectfile_items","label":"items()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L321-L351","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L321"}],"snippet":"items = async (text: string) => {\n    const query = text.trim()\n    setGrouped(query.length > 0)\n\n    if (!query && filesOnly()) {\n      const loaded = file.tree.state(\"\")?.loaded\n      const pending = loaded ? Promise.resolve() : file.tree.list(\"\")\n      const next = uniqueEntries([...fileEntries.recent(), ...fileEntries.root()])\n\n      if (loaded || next.length > 0) {\n        void pending\n        return next\n      }\n\n      await pending\n      return uniqueEntries([...fileEntries.recent(), ...fileEntries.root()])\n    }\n\n    if (!query) return [...commandEntries.picks(), ...fileEntries.recent()]\n\n    if (filesOnly()) {\n      const files = await file.searchFiles(query)\n      const category = language.t(\"palette.group.files\")\n      return files.map((path) => createFileEntry(path, category))\n    }"},{"id":"dialog_select_file_dialogselectfile_handlemove","label":"handleMove()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L353-L358","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L353"}],"snippet":"handleMove = (item: Entry | undefined) => {\n    state.cleanup?.()\n    if (!item) return\n    if (item.type !== \"command\") return\n    state.cleanup = item.option?.onHighlight?.()\n  }"},{"id":"dialog_select_file_dialogselectfile_open","label":"open()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L360-L368","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L360"}],"snippet":"open = (path: string) => {\n    const value = file.tab(path)\n    void tabs().open(value)\n    void file.load(path)\n    if (!view().reviewPanel.opened()) view().reviewPanel.open()\n    layout.fileTree.setTab(\"all\")\n    props.onOpenFile?.(path)\n    tabs().setActive(value)\n  }"},{"id":"dialog_select_file_dialogselectfile_handleselect","label":"handleSelect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L370-L389","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L370"}],"snippet":"handleSelect = (item: Entry | undefined) => {\n    if (!item) return\n    state.committed = true\n    state.cleanup = undefined\n    dialog.close()\n\n    if (item.type === \"command\") {\n      item.option?.onSelect?.(\"palette\")\n      return\n    }\n\n    if (item.type === \"session\") {\n      if (!item.directory || !item.sessionID) return\n      navigate(`/${base64Encode(item.directory)}/session/${item.sessionID}`)\n      return\n    }\n\n    if (!item.path) return\n    open(item.path)\n  }"}],"edges":[{"source":"dialog_select_file","target":"dialog","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-file.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extr