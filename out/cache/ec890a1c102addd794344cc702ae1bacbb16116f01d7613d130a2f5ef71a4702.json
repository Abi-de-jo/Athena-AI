{"__madarTsExtractorVersion":67,"__madarFileStem":"diagnostic","nodes":[{"id":"diagnostic","label":"diagnostic.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L1"}]},{"id":"diagnostic_pretty","label":"pretty()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L5-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L5"}],"snippet":"export function pretty(diagnostic: LSPClient.Diagnostic) {\n  const severityMap = {\n    1: \"ERROR\",\n    2: \"WARN\",\n    3: \"INFO\",\n    4: \"HINT\",\n  }\n\n  const severity = severityMap[diagnostic.severity || 1]\n  const line = diagnostic.range.start.line + 1\n  const col = diagnostic.range.start.character + 1\n\n  return `${severity} [${line}:${col}] ${diagnostic.message}`\n}"},{"id":"diagnostic_report","label":"report()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L20-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L20"}],"snippet":"export function report(file: string, issues: LSPClient.Diagnostic[]) {\n  const errors = issues.filter((item) => item.severity === 1)\n  if (errors.length === 0) return \"\"\n  const limited = errors.slice(0, MAX_PER_FILE)\n  const more = errors.length - MAX_PER_FILE\n  const suffix = more > 0 ? `\\n... and ${more} more` : \"\"\n  return `<diagnostics file=\"${file}\">\\n${limited.map(pretty).join(\"\\n\")}${suffix}\\n</diagnostics>`\n}"}],"edges":[{"source":"diagnostic","target":"client","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L1"}],"weight":1},{"source":"diagnostic","target":"diagnostic_pretty","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L5","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L5"}],"weight":1},{"source":"diagnostic","target":"diagnostic_report","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L20"}],"weight":1},{"source":"diagnostic","target":"diagnostic","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L29","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/lsp/diagnostic.ts","source_location":"L29"}],"weight":1}]}