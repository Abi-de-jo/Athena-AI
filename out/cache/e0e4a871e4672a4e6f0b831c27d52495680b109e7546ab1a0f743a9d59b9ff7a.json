ntext/layout-helpers.ts","source_location":"L18-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-helpers.ts","source_location":"L18"}],"snippet":"export function pruneSessionKeys(input: {\n  keep?: string\n  max: number\n  used: Map<string, number>\n  view: string[]\n  tabs: string[]\n}) {\n  if (!input.keep) return []\n\n  const keys = new Set<string>([...input.view, ...input.tabs])\n  if (keys.size <= input.max) return []\n\n  const score = (key: string) => {\n    if (key === input.keep) return Number.MAX_SAFE_INTEGER\n    return input.used.get(key) ?? 0\n  }\n\n  return Array.from(keys)\n    .sort((a, b) => score(b) - score(a))\n    .slice(input.max)\n}"},{"id":"layout_helpers_prunesessionkeys_score","label":"score()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-helpers.ts","source_location":"L30-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-helpers.ts","source_location":"L30"}],"snippet":"score = (key: string) => {\n    if (key === input.keep) return Number.MAX_SAFE_INTEGER\n    return input.used.get(key) ?? 0\n  }"}],"edges":[{"source":"layout_helpers","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-helpers.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-helpers.ts","source_location":"L1"}],"weight":1},{"source":"layout_helpers","target":"layout_helpers_ensuresessionkey","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projec