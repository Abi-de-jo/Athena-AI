_location":"L41-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/cassette.ts","source_location":"L41"}],"snippet":"cassettePath = (directory: string, name: string) => {\n  if (!name || path.isAbsolute(name) || path.win32.isAbsolute(name) || name.split(/[\\\\/]/).includes(\"..\"))\n    throw new Error(`Invalid cassette name \"${name}\"`)\n  const root = path.resolve(directory)\n  const target = path.resolve(root, `${name}.json`)\n  const relative = path.relative(root, target)\n  if (!relative || relative.startsWith(\"..\") || path.isAbsolute(relative))\n    throw new Error(`Invalid cassette name \"${name}\"`)\n  return target\n}"},{"id":"cassette_hascassettesync","label":"hasCassetteSync()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/cassette.ts","source_location":"L52-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/cassette.ts","source_location":"L52"}],"snippet":"hasCassetteSync = (name: string, options: { readonly directory?: string } = {}) =>\n  fs.existsSync(cassettePath(options.directory ?? DEFAULT_RECORDINGS_DIR, name))"},{"id":"cassette_buildcassette","label":"buildCassette()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/cassette.ts","source_location":"L55-L63","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/cassette.ts","source_location":"L55"}],"snippet":"buildCassette = (\n  name: string,\n  interactions: ReadonlyArray<Interaction>,\n  metadata: CassetteMetadata | undefined,\n): Cassette => ({\n  version: 1,\n  metadata: { name, recordedAt: new Dat