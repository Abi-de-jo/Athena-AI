{"__madarTsExtractorVersion":67,"__madarFileStem":"graph-section","nodes":[{"id":"graph_section","label":"graph-section.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L1"}]},{"id":"graph_section_getcosts","label":"getCosts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L27-L102","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L27"}],"snippet":"async function getCosts(workspaceID: string, year: number, month: number, tzOffset: string) {\n  \"use server\"\n  return withActor(async () => {\n    const timezoneOffset = (() => {\n      const m = /^([+-])(\\d{2}):(\\d{2})$/.exec(tzOffset)\n      if (!m) return 0\n      const sign = m[1] === \"-\" ? -1 : 1\n      return sign * (Number(m[2]) * 60 + Number(m[3])) * 60_000\n    })()\n\n    const monthStartUTC = new Date(Date.UTC(year, month, 1, 0, 0, 0) - timezoneOffset)\n    const monthEndUTC = new Date(Date.UTC(year, month + 1, 1, 0, 0, 0) - timezoneOffset)\n    const dateExpr = sql<string>`DATE(CONVERT_TZ(${UsageTable.timeCreated}, '+00:00', ${tzOffset}))`\n    const usageData = await Database.use((tx) =>\n      tx\n        .select({\n          date: dateExpr,\n          model: UsageTable.model,\n          totalCost: sum(UsageTable.cost),\n          keyId: UsageTable.keyID,\n          plan: sql<string | null>`JSON_EXTRACT(${UsageTable.enrichment}, '$.plan')`,\n        })\n        .from(UsageTable)\n        .where(\n          and("},{"id":"graph_section_getmodelcolor","label":"getModelColor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L122-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L122"}],"snippet":"function getModelColor(model: string): string {\n  if (MODEL_COLORS[model]) return MODEL_COLORS[model]\n\n  const hash = model.split(\"\").reduce((acc, char) => char.charCodeAt(0) + ((acc << 5) - acc), 0)\n  const hue = Math.abs(hash) % 360\n  return `hsl(${hue}, 50%, 65%)`\n}"},{"id":"graph_section_formatdatelabel","label":"formatDateLabel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L130-L134","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L130"}],"snippet":"function formatDateLabel(dateStr: string): string {\n  const [, m, d] = dateStr.split(\"-\").map(Number)\n  const month = new Date(2000, m - 1, 1).toLocaleDateString(undefined, { month: \"short\" })\n  return `${month} ${d.toString().padStart(2, \"0\")}`\n}"},{"id":"graph_section_gettimezoneoffset","label":"getTimezoneOffset()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L138-L170","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L138"}],"snippet":"function getTimezoneOffset(timezone: string, at: Date): string {\n  const parts = new Intl.DateTimeFormat(\"en-US\", {\n    timeZone: timezone,\n    hourCycle: \"h23\",\n    year: \"numeric\",\n    month: \"2-digit\",\n    day: \"2-digit\",\n    hour: \"2-digit\",\n    minute: \"2-digit\",\n    second: \"2-digit\",\n  })\n    .formatToParts(at)\n    .reduce<Record<string, string>>((acc, p) => {\n      if (p.type !== \"literal\") acc[p.type] = p.value\n      return acc\n    }, {})\n  const asUTC = Date.UTC(\n    Number(parts.year),\n    Number(parts.month) - 1,\n    Number(parts.day),\n    Number(parts.hour),\n    Number(parts.minute),\n    Number(parts.second),\n  )\n  const diffMinutes = Math.round((asUTC - at.getTime()) / 60_000)"},{"id":"graph_section_addopacitytocolor","label":"addOpacityToColor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L172-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspace/[id]/usage/graph-section.tsx","source_location":"L172"}],"snippet":"function addOpacityToColor(color: string, opacity: number): string {\n  if (color.startsWith(\"#\")) {\n    const r = parseInt(color.slice(1, 3), 16)\n    const g = parseInt(color.slice(3, 5), 16)\n    const b = parseInt(color.slice(5, 7), 16)\n    return `rgba(${r}, ${g}, ${b}, ${opacity})`\n  }\n  if (color.startsWith(\"hsl\")) return color.replace(\")\", `, ${opacity})`).replace(\"hsl\", \"hsla\")\n  return color\n}"},{"id":"graph_section_graphsection","label":"GraphSection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/workspa