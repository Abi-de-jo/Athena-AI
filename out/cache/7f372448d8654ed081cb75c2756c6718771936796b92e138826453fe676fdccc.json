{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_core_src_tool_webfetch","nodes":[{"id":"packages_core_src_tool_webfetch","label":"webfetch.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L1"}]},{"id":"packages_core_src_tool_webfetch_acceptheader","label":"acceptHeader()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L42-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L42"}],"snippet":"acceptHeader = (format: Format) => {\n  switch (format) {\n    case \"markdown\":\n      return \"text/markdown;q=1.0, text/x-markdown;q=0.9, text/plain;q=0.8, text/html;q=0.7, */*;q=0.1\"\n    case \"text\":\n      return \"text/plain;q=1.0, text/markdown;q=0.9, text/html;q=0.8, */*;q=0.1\"\n    case \"html\":\n      return \"text/html;q=1.0, application/xhtml+xml;q=0.9, text/plain;q=0.8, text/markdown;q=0.7, */*;q=0.1\"\n  }\n  return \"*/*\"\n}"},{"id":"packages_core_src_tool_webfetch_headers","label":"headers()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L54-L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L54"}],"snippet":"headers = (format: Format, userAgent: string) => ({\n  \"User-Agent\": userAgent,\n  Accept: acceptHeader(format),\n  \"Accept-Language\": \"en-US,en;q=0.9\",\n})"},{"id":"packages_core_src_tool_webfetch_iscloudflarechallenge","label":"isCloudflareChallenge()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L63-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L63"}],"snippet":"isCloudflareChallenge = (error: unknown) => {\n  if (!error || typeof error !== \"object\" || !(\"reason\" in error)) return false\n  const reason = error.reason\n  if (\n    !reason ||\n    typeof reason !== \"object\" ||\n    !(\"_tag\" in reason) ||\n    reason._tag !== \"StatusCodeError\" ||\n    !(\"response\" in reason)\n  )\n    return false\n  const response = reason.response as HttpClientResponse.HttpClientResponse\n  return response.status === 403 && response.headers[\"cf-mitigated\"] === \"challenge\"\n}"},{"id":"packages_core_src_tool_webfetch_request","label":"request()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L78-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L78"}],"snippet":"request = (url: string, format: Format, userAgent = browserUserAgent) =>\n  HttpClientRequest.get(url).pipe(HttpClientRequest.setHeaders(headers(format, userAgent)))"},{"id":"packages_core_src_tool_webfetch_asserthttpurl","label":"assertHttpUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L81-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L81"}],"snippet":"assertHttpUrl = (url: URL) => {\n  if (url.protocol !== \"http:\" && url.protocol !== \"https:\") throw new Error(\"URL must use http:// or https://\")\n}"},{"id":"packages_core_src_tool_webfetch_execute","label":"execute()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L85-L86","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L85"}],"snippet":"execute = (http: HttpClient.HttpClient, url: string, format: Format, userAgent = browserUserAgent) =>\n  http.execute(request(url, format, userAgent)).pipe(Effect.flatMap(HttpClientResponse.filterStatusOk))"},{"id":"packages_core_src_tool_webfetch_collectbody","label":"collectBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L88-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L88"}],"snippet":"collectBody = (response: HttpClientResponse.HttpClientResponse) =>\n  Effect.gen(function* () {\n    const contentLength = response.headers[\"content-length\"]\n    if (contentLength && Number.parseInt(contentLength, 10) > MAX_RESPONSE_BYTES) {\n      return yield* Effect.fail(new Error(`Response too large (exceeds ${MAX_RESPONSE_BYTES} byte limit)`))\n    }\n    const chunks: Uint8Array[] = []\n    let size = 0\n    yield* Stream.runForEach(response.stream, (chunk) =>\n      Effect.gen(function* () {\n        size += chunk.byteLength\n        if (size > MAX_RESPONSE_BYTES)\n          return yield* Effect.fail(new Error(`Response too large (exceeds ${MAX_RESPONSE_BYTES} byte limit)`))\n        chunks.push(chunk)\n        return undefined\n      }),\n    )\n    return Buffer.concat(chunks, size)\n  })"},{"id":"packages_core_src_tool_webfetch_mimefrom","label":"mimeFrom()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L108"}],"snippet":"mimeFrom = (contentType: string) => contentType.split(\";\", 1)[0]?.trim().toLowerCase() ?? \"\""},{"id":"packages_core_src_tool_webfetch_isimageattachment","label":"isImageAttachment()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L109-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L109"}],"snippet":"isImageAttachment = (mime: string) =>\n  mime.startsWith(\"image/\") && mime !== \"image/svg+xml\" && mime !== \"image/vnd.fastbidsheet\""},{"id":"packages_core_src_tool_webfetch_istextualmime","label":"isTextualMime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L111-L119","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L111"}],"snippet":"isTextualMime = (mime: string) =>\n  !mime ||\n  mime.startsWith(\"text/\") ||\n  mime === \"application/json\" ||\n  mime.endsWith(\"+json\") ||\n  mime === \"application/xml\" ||\n  mime.endsWith(\"+xml\") ||\n  mime === \"application/javascript\" ||\n  mime === \"application/x-javascript\""},{"id":"packages_core_src_tool_webfetch_convert","label":"convert()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L120-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L120"}],"snippet":"convert = (content: string, contentType: string, format: Format) => {\n  if (!contentType.includes(\"text/html\")) return content\n  if (format === \"markdown\") return convertHTMLToMarkdown(content)\n  if (format === \"text\") return extractTextFromHTML(content)\n  return content\n}"},{"id":"packages_core_src_tool_webfetch_extracttextfromhtml","label":"extractTextFromHTML()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L188-L205","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L188"}],"snippet":"export function extractTextFromHTML(html: string) {\n  let text = \"\"\n  let skipDepth = 0\n  const parser = new Parser({\n    onopentag(name) {\n      if (skipDepth > 0 || [\"script\", \"style\", \"noscript\", \"iframe\", \"object\", \"embed\"].includes(name)) skipDepth++\n    },\n    ontext(input) {\n      if (skipDepth === 0) text += input\n    },\n    onclosetag() {\n      if (skipDepth > 0) skipDepth--\n    },\n  })\n  parser.write(html)\n  parser.end()\n  return text.trim()\n}"},{"id":"packages_core_src_tool_webfetch_converthtmltomarkdown","label":"convertHTMLToMarkdown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L207-L217","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L207"}],"snippet":"export function convertHTMLToMarkdown(html: string) {\n  const turndown = new TurndownService({\n    headingStyle: \"atx\",\n    hr: \"---\",\n    bulletListMarker: \"-\",\n    codeBlockStyle: \"fenced\",\n    emDelimiter: \"*\",\n  })\n  turndown.remove([\"script\", \"style\", \"meta\", \"link\"])\n  return turndown.turndown(html)\n}"}],"edges":[{"source":"packages_core_src_tool_webfetch","target":"webfetch","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_src_tool_webfetch","target":"llm","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L3"}],"weight":1},{"source":"packages_core_src_tool_webfetch","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webfetch.ts","source_location":"L4"}],"weight":1},{"source":"packages_core_src_tool_webfetch","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/webf