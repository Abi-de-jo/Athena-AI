{"__madarTsExtractorVersion":67,"__madarFileStem":"util","nodes":[{"id":"util","label":"util.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L1"}]},{"id":"util_waitevent","label":"waitEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L4-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L4"}],"snippet":"export function waitEvent(input: { timeout: number; signal?: AbortSignal; fn: (event: GlobalEvent) => boolean }) {\n  if (input.signal?.aborted) return Effect.fail(input.signal.reason ?? new Error(\"Request aborted\"))\n\n  return Effect.callback<void, unknown>((resume) => {\n    const abort = () => {\n      cleanup()\n      resume(Effect.fail(input.signal?.reason ?? new Error(\"Request aborted\")))\n    }\n\n    const handler = (event: GlobalEvent) => {\n      try {\n        if (!input.fn(event)) return\n        cleanup()\n        resume(Effect.void)\n      } catch (error) {\n        cleanup()\n        resume(Effect.fail(error))\n      }\n    }\n\n    const cleanup = () => {\n      clearTimeout(timeout)\n      GlobalBus.off(\"event\", handler)\n      input.signal?.removeEventListener(\"abort\", abort)\n    }"},{"id":"util_waitevent_abort","label":"abort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L8-L11","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L8"}],"snippet":"abort = () => {\n      cleanup()\n      resume(Effect.fail(input.signal?.reason ?? new Error(\"Request aborted\")))\n    }"},{"id":"util_waitevent_handler","label":"handler()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L13-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L13"}],"snippet":"handler = (event: GlobalEvent) => {\n      try {\n        if (!input.fn(event)) return\n        cleanup()\n        resume(Effect.void)\n      } catch (error) {\n        cleanup()\n        resume(Effect.fail(error))\n      }\n    }"},{"id":"util_waitevent_cleanup","label":"cleanup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L24-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L24"}],"snippet":"cleanup = () => {\n      clearTimeout(timeout)\n      GlobalBus.off(\"event\", handler)\n      input.signal?.removeEventListener(\"abort\", abort)\n    }"}],"edges":[{"source":"util","target":"global","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/util.ts","source_location":"L1"}],"weight":1},{"source":"util","targ