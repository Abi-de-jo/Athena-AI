{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_core_src_v1_config_agent","nodes":[{"id":"packages_core_src_v1_config_agent","label":"agent.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/agent.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/agent.ts","source_location":"L1"}]},{"id":"packages_core_src_v1_config_agent_normalize","label":"normalize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/agent.ts","source_location":"L62-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/agent.ts","source_location":"L62"}],"snippet":"normalize = (agent: Schema.Schema.Type<typeof AgentSchema>): Schema.Schema.Type<typeof AgentSchema> => {\n  const options: Record<string, unknown> = { ...agent.options }\n  for (const [key, value] of Object.entries(agent)) {\n    if (!KNOWN_KEYS.has(key)) options[key] = value\n  }\n\n  const permission: ConfigPermissionV1.Info = {}\n  for (const [tool, enabled] of Object.entries(agent.tools ?? {})) {\n    const action = enabled ? \"allow\" : \"deny\"\n    if (tool === \"write\" || tool === \"edit\" || tool === \"patch\") {\n      permission.edit = action\n      continue\n    }\n    permission[tool] = action\n  }\n  globalThis.Object.assign(permission, agent.permission)\n\n  const steps = agent.steps ?? agent.maxSteps\n  return { ...agent, options, permission, ...(steps !== undefined ? { steps } : {}) }\n}"}],"edges":[{"source":"packages_core_src_v1_config_agent","target":"agent","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/agent.ts","source_l