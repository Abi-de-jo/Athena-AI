{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_utils_id","nodes":[{"id":"packages_app_src_utils_id","label":"id.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L1"}]},{"id":"packages_app_src_utils_id_ascending","label":"ascending()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L16-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L16"}],"snippet":"export function ascending(prefix: Prefix, given?: string) {\n    return generateID(prefix, false, given)\n  }"},{"id":"packages_app_src_utils_id_descending","label":"descending()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L20-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L20"}],"snippet":"export function descending(prefix: Prefix, given?: string) {\n    return generateID(prefix, true, given)\n  }"},{"id":"packages_app_src_utils_id_generateid","label":"generateID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L25-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L25"}],"snippet":"function generateID(prefix: Prefix, descending: boolean, given?: string): string {\n  if (!given) {\n    return create(prefix, descending)\n  }\n\n  if (!given.startsWith(prefixes[prefix])) {\n    throw new Error(`ID ${given} does not start with ${prefixes[prefix]}`)\n  }\n\n  return given\n}"},{"id":"packages_app_src_utils_id_create","label":"create()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L37-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L37"}],"snippet":"function create(prefix: Prefix, descending: boolean, timestamp?: number): string {\n  const currentTimestamp = timestamp ?? Date.now()\n\n  if (currentTimestamp !== lastTimestamp) {\n    lastTimestamp = currentTimestamp\n    counter = 0\n  }\n\n  counter += 1\n\n  let now = BigInt(currentTimestamp) * BigInt(0x1000) + BigInt(counter)\n\n  if (descending) {\n    now = ~now\n  }\n\n  const timeBytes = new Uint8Array(6)\n  for (let i = 0; i < 6; i += 1) {\n    timeBytes[i] = Number((now >> BigInt(40 - 8 * i)) & BigInt(0xff))\n  }\n\n  return prefixes[prefix] + \"_\" + bytesToHex(timeBytes) + randomBase62(LENGTH - 12)\n}"},{"id":"packages_app_src_utils_id_bytestohex","label":"bytesToHex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L61-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L61"}],"snippet":"function bytesToHex(bytes: Uint8Array): string {\n  let hex = \"\"\n  for (let i = 0; i < bytes.length; i += 1) {\n    hex += bytes[i].toString(16).padStart(2, \"0\")\n  }\n  return hex\n}"},{"id":"packages_app_src_utils_id_randombase62","label":"randomBase62()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L69-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L69"}],"snippet":"function randomBase62(length: number): string {\n  const chars = \"0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz\"\n  const bytes = getRandomBytes(length)\n  let result = \"\"\n  for (let i = 0; i < length; i += 1) {\n    result += chars[bytes[i] % 62]\n  }\n  return result\n}"},{"id":"packages_app_src_utils_id_getrandombytes","label":"getRandomBytes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L79-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L79"}],"snippet":"function getRandomBytes(length: number): Uint8Array {\n  const bytes = new Uint8Array(length)\n  const cryptoObj = typeof globalThis !== \"undefined\" ? globalThis.crypto : undefined\n\n  if (cryptoObj && typeof cryptoObj.getRandomValues === \"function\") {\n    cryptoObj.getRandomValues(bytes)\n    return bytes\n  }\n\n  for (let i = 0; i < length; i += 1) {\n    bytes[i] = Math.floor(Math.random() * 256)\n  }\n\n  return bytes\n}"}],"edges":[{"source":"packages_app_src_utils_id","target":"packages_app_src_utils_id_ascending","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L16","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/id.ts","source_location":"L16"}],"weight":1},{"source":"packages_app_src_util