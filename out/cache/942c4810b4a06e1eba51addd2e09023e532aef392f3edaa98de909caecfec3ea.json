{"__madarTsExtractorVersion":67,"__madarFileStem":"layout-scroll","nodes":[{"id":"layout_scroll","label":"layout-scroll.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L1"}]},{"id":"layout_scroll_createscrollpersistence","label":"createScrollPersistence()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L16-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L16"}],"snippet":"export function createScrollPersistence(opts: Options) {\n  const wait = opts.debounceMs ?? 200\n  const [cache, setCache] = createStore<Record<string, ScrollMap>>({})\n  const dirty = new Set<string>()\n  const timers = new Map<string, ReturnType<typeof setTimeout>>()\n\n  function clone(input?: ScrollMap) {\n    const out: ScrollMap = {}\n    if (!input) return out\n\n    for (const key of Object.keys(input)) {\n      const pos = input[key]\n      if (!pos) continue\n      out[key] = { x: pos.x, y: pos.y }\n    }\n\n    return out\n  }\n\n  function seed(sessionKey: string) {\n    const next = clone(opts.getSnapshot(sessionKey))\n    const current = cache[sessionKey]\n    if (!current) {\n      setCache(sessionKey, next)\n      return"},{"id":"layout_scroll_createscrollpersistence_clone","label":"clone()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L22-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L22"}],"snippet":"function clone(input?: ScrollMap) {\n    const out: ScrollMap = {}\n    if (!input) return out\n\n    for (const key of Object.keys(input)) {\n      const pos = input[key]\n      if (!pos) continue\n      out[key] = { x: pos.x, y: pos.y }\n    }\n\n    return out\n  }"},{"id":"layout_scroll_createscrollpersistence_seed","label":"seed()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L35-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L35"}],"snippet":"function seed(sessionKey: string) {\n    const next = clone(opts.getSnapshot(sessionKey))\n    const current = cache[sessionKey]\n    if (!current) {\n      setCache(sessionKey, next)\n      return\n    }\n\n    if (Object.keys(current).length > 0) return\n    if (Object.keys(next).length === 0) return\n    setCache(sessionKey, next)\n  }"},{"id":"layout_scroll_createscrollpersistence_scroll","label":"scroll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L48-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L48"}],"snippet":"function scroll(sessionKey: string, tab: string) {\n    seed(sessionKey)\n    return cache[sessionKey]?.[tab] ?? opts.getSnapshot(sessionKey)?.[tab]\n  }"},{"id":"layout_scroll_createscrollpersistence_schedule","label":"schedule()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L53-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L53"}],"snippet":"function schedule(sessionKey: string) {\n    const prev = timers.get(sessionKey)\n    if (prev) clearTimeout(prev)\n    timers.set(\n      sessionKey,\n      setTimeout(() => flush(sessionKey), wait),\n    )\n  }"},{"id":"layout_scroll_createscrollpersistence_setscroll","label":"setScroll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L62-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L62"}],"snippet":"function setScroll(sessionKey: string, tab: string, pos: SessionScroll) {\n    seed(sessionKey)\n\n    const prev = cache[sessionKey]?.[tab]\n    if (prev?.x === pos.x && prev?.y === pos.y) return\n\n    setCache(sessionKey, tab, { x: pos.x, y: pos.y })\n    dirty.add(sessionKey)\n    schedule(sessionKey)\n  }"},{"id":"layout_scroll_createscrollpersistence_flush","label":"flush()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L73-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L73"}],"snippet":"function flush(sessionKey: string) {\n    const timer = timers.get(sessionKey)\n    if (timer) clearTimeout(timer)\n    timers.delete(sessionKey)\n\n    if (!dirty.has(sessionKey)) return\n    dirty.delete(sessionKey)\n\n    opts.onFlush(sessionKey, clone(cache[sessionKey]))\n  }"},{"id":"layout_scroll_createscrollpersistence_flushall","label":"flushAll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L84-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L84"}],"snippet":"function flushAll() {\n    const keys = Array.from(dirty)\n    if (keys.length === 0) return\n\n    for (const key of keys) {\n      flush(key)\n    }\n  }"},{"id":"layout_scroll_createscrollpersistence_drop","label":"drop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L93-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L93"}],"snippet":"function drop(keys: string[]) {\n    if (keys.length === 0) return\n\n    for (const key of keys) {\n      const timer = timers.get(key)\n      if (timer) clearTimeout(timer)\n      timers.delete(key)\n      dirty.delete(key)\n    }\n\n    setCache(\n      produce((draft) => {\n        for (const key of keys) {\n          delete draft[key]\n        }\n      }),\n    )\n  }"},{"id":"layout_scroll_createscrollpersistence_dispose","label":"dispose()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L112-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout-scroll.ts","source_location":"L112"}],"snippet":"function dispose() {\n    drop(Array.from(timers.keys()))\n  }"}],"edges":[{"source":"layout_scroll","target":"store"