{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_llm_test_lib_http","nodes":[{"id":"packages_llm_test_lib_http","label":"http.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L1"}]},{"id":"packages_llm_test_lib_http_handlerlayer","label":"handlerLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L19-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L19"}],"snippet":"handlerLayer = (handler: Handler): Layer.Layer<HttpClient.HttpClient> =>\n  Layer.succeed(\n    HttpClient.HttpClient,\n    HttpClient.make((request) =>\n      Effect.gen(function* () {\n        const web = yield* HttpClientRequest.toWeb(request).pipe(Effect.orDie)\n        const text = yield* Effect.promise(() => web.text())\n        return yield* handler({\n          request,\n          text,\n          respond: (body, init) => HttpClientResponse.fromWeb(request, new Response(body, init)),\n        })\n      }),\n    ),\n  )"},{"id":"packages_llm_test_lib_http_runtimelayer","label":"runtimeLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L37-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L37"}],"snippet":"runtimeLayer = (layer: Layer.Layer<HttpClient.HttpClient>): Layer.Layer<RuntimeEnv> => {\n  const requestExecutorLayer = RequestExecutor.layer.pipe(Layer.provide(layer))\n  const deps = Layer.mergeAll(requestExecutorLayer, WebSocketExecutor.layer)\n  const llmClientLayer = LLMClient.layer.pipe(Layer.provide(deps))\n  return Layer.mergeAll(deps, llmClientLayer)\n}"},{"id":"packages_llm_test_lib_http_fixedresponse","label":"fixedResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L52-L55","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L52"}],"snippet":"fixedResponse = (\n  body: ConstructorParameters<typeof Response>[0],\n  init: ResponseInit = { headers: SSE_HEADERS },\n) => runtimeLayer(handlerLayer((input) => Effect.succeed(input.respond(body, init))))"},{"id":"packages_llm_test_lib_http_dynamicresponse","label":"dynamicResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L60"}],"snippet":"dynamicResponse = (handler: Handler) => runtimeLayer(handlerLayer(handler))"},{"id":"packages_llm_test_lib_http_truncatedstream","label":"truncatedStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L66-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L66"}],"snippet":"truncatedStream = (chunks: ReadonlyArray<string>) =>\n  dynamicResponse((input) =>\n    Effect.sync(() => {\n      const encoder = new TextEncoder()\n      const stream = new ReadableStream({\n        start(controller) {\n          for (const chunk of chunks) controller.enqueue(encoder.encode(chunk))\n          controller.error(new Error(\"connection reset\"))\n        },\n      })\n      return input.respond(stream, { headers: SSE_HEADERS })\n    }),\n  )"},{"id":"packages_llm_test_lib_http_scriptedresponses","label":"scriptedResponses()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L85-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L85"}],"snippet":"scriptedResponses = (bodies: ReadonlyArray<string>, init: ResponseInit = { headers: SSE_HEADERS }) => {\n  if (bodies.length === 0) throw new Error(\"scriptedResponses requires at least one body\")\n  return Layer.unwrap(\n    Effect.gen(function* () {\n      const cursor = yield* Ref.make(0)\n      return dynamicResponse((input) =>\n        Effect.gen(function* () {\n          const index = yield* Ref.getAndUpdate(cursor, (n) => n + 1)\n          return input.respond(bodies[index] ?? bodies[bodies.length - 1], init)\n        }),\n      )\n    }),\n  )\n}"}],"edges":[{"source":"packages_llm_test_lib_http","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L1"}],"weight":1},{"source":"packages_llm_test_lib_http","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/lib/http.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"b