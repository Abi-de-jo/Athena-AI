{"__madarTsExtractorVersion":67,"__madarFileStem":"diff-viewer-file-tree-utils","nodes":[{"id":"diff_viewer_file_tree_utils","label":"diff-viewer-file-tree-utils.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L1"}]},{"id":"diff_viewer_file_tree_utils_buildfiletree","label":"buildFileTree()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L34-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L34"}],"snippet":"export function buildFileTree(files: readonly FileTreeItem[]): FileTree {\n  const roots: number[] = []\n  const nodes: FileTreeNode[] = []\n  const directoryByPath = new Map<string, number>()\n\n  files.forEach((file, fileIndex) => {\n    const segments = file.file.split(\"/\").filter(Boolean)\n    if (segments.length === 0) return\n\n    const parent = segments.slice(0, -1).reduce(\n      (state, segment) => {\n        const directoryPath = state.path ? `${state.path}/${segment}` : segment\n        const existing = directoryByPath.get(directoryPath)\n        if (existing !== undefined) return { id: existing, path: directoryPath, depth: state.depth + 1 }\n\n        const id = addFileTreeNode(nodes, roots, {\n          name: segment,\n          parent: state.id,\n          depth: state.depth,\n          kind: \"directory\",\n        })\n        directoryByPath.set(directoryPath, id)\n        return { id, path: directoryPath, depth: state.depth + 1 }\n      },\n      { id: undefined as number | undefined, path: \"\", depth: 0 },"},{"id":"diff_viewer_file_tree_utils_flattenfiletree","label":"flattenFileTree()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L76-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L76"}],"snippet":"export function flattenFileTree(tree: FileTree, expanded?: ReadonlySet<number>): FileTreeRow[] {\n  const rows: FileTreeRow[] = []\n  const visit = (id: number, depth: number) => {\n    const node = tree.nodes[id]!\n    if (node.kind === \"file\") {\n      rows.push({\n        id: node.id,\n        depth,\n        kind: node.kind,\n        name: node.name,\n        fileIndex: node.fileIndex,\n      })\n      return\n    }\n\n    const chain = collapsedFileTreeDirectoryChain(tree, node.id)\n    const last = chain[chain.length - 1]!\n    rows.push({\n      id: node.id,\n      depth,\n      kind: node.kind,\n      name: chain.map((item) => item.name).join(\"/\"),\n      fileIndex: node.fileIndex,\n    })\n    if (!expanded || expanded.has(node.id)) last.children.forEach((child) => visit(child, depth + 1))"},{"id":"diff_viewer_file_tree_utils_flattenfiletree_visit","label":"visit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L78-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L78"}],"snippet":"visit = (id: number, depth: number) => {\n    const node = tree.nodes[id]!\n    if (node.kind === \"file\") {\n      rows.push({\n        id: node.id,\n        depth,\n        kind: node.kind,\n        name: node.name,\n        fileIndex: node.fileIndex,\n      })\n      return\n    }\n\n    const chain = collapsedFileTreeDirectoryChain(tree, node.id)\n    const last = chain[chain.length - 1]!\n    rows.push({\n      id: node.id,\n      depth,\n      kind: node.kind,\n      name: chain.map((item) => item.name).join(\"/\"),\n      fileIndex: node.fileIndex,\n    })\n    if (!expanded || expanded.has(node.id)) last.children.forEach((child) => visit(child, depth + 1))\n  }"},{"id":"diff_viewer_file_tree_utils_collapsedfiletreedirectorychain","label":"collapsedFileTreeDirectoryChain()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L106-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L106"}],"snippet":"function collapsedFileTreeDirectoryChain(tree: FileTree, id: number): FileTreeNode[] {\n  const node = tree.nodes[id]!\n  const child = node.children.length === 1 ? tree.nodes[node.children[0]!] : undefined\n  if (child?.kind !== \"directory\") return [node]\n  return [node, ...collapsedFileTreeDirectoryChain(tree, child.id)]\n}"},{"id":"diff_viewer_file_tree_utils_comparefiletreenodes","label":"compareFileTreeNodes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L113-L120","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L113"}],"snippet":"export function compareFileTreeNodes(tree: FileTree, left: number, right: number) {\n  const leftNode = tree.nodes[left]!\n  const rightNode = tree.nodes[right]!\n  if (leftNode.kind !== rightNode.kind) return leftNode.kind === \"directory\" ? -1 : 1\n  if (leftNode.name < rightNode.name) return -1\n  if (leftNode.name > rightNode.name) return 1\n  return left - right\n}"},{"id":"diff_viewer_file_tree_utils_movefiletreeselection","label":"moveFileTreeSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L122-L127","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L122"}],"snippet":"export function moveFileTreeSelection(rows: readonly FileTreeRow[], selected: number | undefined, offset: number) {\n  if (rows.length === 0) return undefined\n  const index = selected === undefined ? -1 : rows.findIndex((row) => row.id === selected)\n  if (index === -1) return rows[0]!.id\n  return rows[Math.max(0, Math.min(rows.length - 1, index + offset))]!.id\n}"},{"id":"diff_viewer_file_tree_utils_movefiletreeselectiontofirstchild","label":"moveFileTreeSelectionToFirstChild()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L129-L135","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L129"}],"snippet":"export function moveFileTreeSelectionToFirstChild(rows: readonly FileTreeRow[], selected: number | undefined) {\n  const index = selected === undefined ? -1 : rows.findIndex((row) => row.id === selected)\n  const row = index === -1 ? undefined : rows[index]\n  if (row?.kind !== \"directory\") return selected\n  const child = rows[index + 1]\n  return child && child.depth > row.depth ? child.id : selected\n}"},{"id":"diff_viewer_file_tree_utils_movefiletreeselectiontoparent","label":"moveFileTreeSelectionToParent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L137-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L137"}],"snippet":"export function moveFileTreeSelectionToParent(rows: readonly FileTreeRow[], selected: number | undefined) {\n  const index = selected === undefined ? -1 : rows.findIndex((row) => row.id === selected)\n  const row = index === -1 ? undefined : rows[index]\n  if (!row || row.depth === 0) return selected\n  return rows.findLast((item, itemIndex) => itemIndex < index && item.depth < row.depth)?.id ?? selected\n}"},{"id":"diff_viewer_file_tree_utils_movefiletreeselectiontofile","label":"moveFileTreeSelectionToFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L144-L158","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L144"}],"snippet":"export function moveFileTreeSelectionToFile(\n  rows: readonly FileTreeRow[],\n  selected: number | undefined,\n  offset: number,\n) {\n  const fileRows = rows.filter((row) => row.fileIndex !== undefined)\n  if (fileRows.length === 0) return undefined\n  const selectedIndex = selected === undefined ? -1 : rows.findIndex((row) => row.id === selected)\n  if (selectedIndex === -1) return offset < 0 ? fileRows[fileRows.length - 1]!.id : fileRows[0]!.id\n  const next =\n    offset < 0\n      ? fileRows.findLast((row) => rows.findIndex((item) => item.id === row.id) < selectedIndex)\n      : fileRows.find((row) => rows.findIndex((item) => item.id === row.id) > selectedIndex)\n  return next?.id ?? (offset < 0 ? fileRows[0]!.id : fileRows[fileRows.length - 1]!.id)\n}"},{"id":"diff_viewer_file_tree_utils_filetreefileselection","label":"fileTreeFileSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L160-L167","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L160"}],"snippet":"export function fileTreeFileSelection(tree: FileTree, fileIndex: number) {\n  const node = tree.nodes.find((item) => item.kind === \"file\" && item.fileIndex === fileIndex)\n  if (!node) return undefined\n  return {\n    highlightedNode: node.id,\n    expandedNodes: fileTreeParentDirectories(tree, node.id),\n  }\n}"},{"id":"diff_viewer_file_tree_utils_singlepatchfileindex","label":"singlePatchFileIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L169-L176","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L169"}],"snippet":"export function singlePatchFileIndex(\n  selected: number | undefined,\n  active: number | undefined,\n  current: number | undefined,\n  first: number | undefined,\n) {\n  return selected ?? active ?? current ?? first\n}"},{"id":"diff_viewer_file_tree_utils_orderedpatchfileindexes","label":"orderedPatchFileIndexes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L178-L180","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L178"}],"snippet":"export function orderedPatchFileIndexes(rows: readonly FileTreeRow[]) {\n  return rows.flatMap((row) => (row.fileIndex === undefined ? [] : [row.fileIndex]))\n}"},{"id":"diff_viewer_file_tree_utils_showdiffviewerfiletree","label":"showDiffViewerFileTree()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L182-L184","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L182"}],"snippet":"export function showDiffViewerFileTree(showFileTree: boolean, fileCount: number) {\n  return showFileTree && fileCount > 0\n}"},{"id":"diff_viewer_file_tree_utils_movepatchfileindex","label":"movePatchFileIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L186-L191","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L186"}],"snippet":"export function movePatchFileIndex(fileIndexes: readonly number[], current: number | undefined, offset: number) {\n  if (fileIndexes.length === 0) return undefined\n  const index = current === undefined ? -1 : fileIndexes.indexOf(current)\n  if (index === -1) return fileIndexes[0]\n  return fileIndexes[Math.max(0, Math.min(fileIndexes.length - 1, index + offset))]\n}"},{"id":"diff_viewer_file_tree_utils_allexpandedfiletreedirectories","label":"allExpandedFileTreeDirectories()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L193-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L193"}],"snippet":"export function allExpandedFileTreeDirectories(tree: FileTree) {\n  return new Set(tree.nodes.filter((node) => node.kind === \"directory\").map((node) => node.id))\n}"},{"id":"diff_viewer_file_tree_utils_togglefiletreedirectory","label":"toggleFileTreeDirectory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L197-L203","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L197"}],"snippet":"export function toggleFileTreeDirectory(tree: FileTree, expanded: ReadonlySet<number>, selected: number | undefined) {\n  if (selected === undefined || tree.nodes[selected]?.kind !== \"directory\") return expanded\n  const next = new Set(expanded)\n  if (next.has(selected)) next.delete(selected)\n  else next.add(selected)\n  return next\n}"},{"id":"diff_viewer_file_tree_utils_setfiletreedirectoryexpanded","label":"setFileTreeDirectoryExpanded()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L205-L216","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L205"}],"snippet":"export function setFileTreeDirectoryExpanded(\n  tree: FileTree,\n  expanded: ReadonlySet<number>,\n  selected: number | undefined,\n  value: boolean,\n) {\n  if (selected === undefined || tree.nodes[selected]?.kind !== \"directory\") return expanded\n  const next = new Set(expanded)\n  if (value) next.add(selected)\n  else next.delete(selected)\n  return next\n}"},{"id":"diff_viewer_file_tree_utils_addfiletreenode","label":"addFileTreeNode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L218-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L218"}],"snippet":"function addFileTreeNode(nodes: FileTreeNode[], roots: number[], input: Omit<FileTreeNode, \"id\" | \"children\">) {\n  const id = nodes.length\n  nodes.push({ ...input, id, children: [] })\n  if (input.parent === undefined) roots.push(id)\n  else nodes[input.parent]!.children.push(id)\n  return id\n}"},{"id":"diff_viewer_file_tree_utils_filetreeparentdirectories","label":"fileTreeParentDirectories()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L226-L232","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L226"}],"snippet":"function fileTreeParentDirectories(tree: FileTree, id: number) {\n  const result = new Set<number>()\n  for (let parent = tree.nodes[id]?.parent; parent !== undefined; parent = tree.nodes[parent]?.parent) {\n    result.add(parent)\n  }\n  return result\n}"}],"edges":[{"source":"diff_viewer_file_tree_utils","target":"diff_viewer_file_tree_utils_buildfiletree","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L34"}],"weight":1},{"source":"diff_viewer_file_tree_utils","target":"diff_viewer_file_tree_utils_flattenfiletree","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree-utils.ts","source_location":"L76"}],"weight":1},{"source":"diff_viewer_file_tree_utils_flattenfiletree","target":"diff_viewer_file_tree_utils_flattenfiletree_visit","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/dif