{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_stats_core_src_domain_stat","nodes":[{"id":"packages_stats_core_src_domain_stat","label":"stat.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L1"}]},{"id":"packages_stats_core_src_domain_stat_tostatbaserow","label":"toStatBaseRow()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L64-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L64"}],"snippet":"export function toStatBaseRow(data: StatBaseAggregate) {\n  return {\n    grain: data.grain,\n    period_key: data.period_key,\n    dataset: data.dataset,\n    tier: data.tier,\n    client: \"all\",\n    source: \"all\",\n    sessions: data.sessions,\n    requests: data.requests,\n    input_tokens: data.input_tokens,\n    output_tokens: data.output_tokens,\n    reasoning_tokens: data.reasoning_tokens,\n    cache_read_tokens: data.cache_read_tokens,\n    total_tokens: data.total_tokens,\n    input_cost_microcents: data.input_cost_microcents,\n    output_cost_microcents: data.output_cost_microcents,\n    total_cost_microcents: data.total_cost_microcents,\n    avg_duration_ms: data.avg_duration_ms,\n    p50_duration_ms: data.p50_duration_ms,\n    p95_duration_ms: data.p95_duration_ms,\n    avg_ttfb_ms: data.avg_ttfb_ms,\n    p50_ttfb_ms: data.p50_ttfb_ms,\n    p95_ttfb_ms: data.p95_ttfb_ms,\n    avg_output_tps: data.avg_output_tps,"},{"id":"packages_stats_core_src_domain_stat_synthesizealltierrows","label":"synthesizeAllTierRows()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L95-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L95"}],"snippet":"export function synthesizeAllTierRows<T extends StatBaseRow>(rows: T[], dimensionKey: (row: T) => string) {\n  return [\n    ...rows,\n    ...Object.values(\n      rows.reduce<Record<string, T>>((result, row) => {\n        const key = [row.grain, row.period_key, row.dataset, row.client, row.source, dimensionKey(row)].join(\"\\u0000\")\n        result[key] = result[key] ? combineRows(result[key], row) : { ...row, tier: \"all\" }\n        return result\n      }, {}),\n    ),\n  ]\n}"},{"id":"packages_stats_core_src_domain_stat_collapserows","label":"collapseRows()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L108-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L108"}],"snippet":"export function collapseRows<T extends StatBaseRow>(rows: T[], dimensionKey: (row: T) => string) {\n  return Object.values(\n    rows.reduce<Record<string, T>>((result, row) => {\n      const key = [row.grain, row.period_key, row.dataset, row.tier, row.client, row.source, dimensionKey(row)].join(\n        \"\\u0000\",\n      )\n      result[key] = result[key] ? combineRows(result[key], row) : row\n      return result\n    }, {}),\n  )\n}"},{"id":"packages_stats_core_src_domain_stat_combinerows","label":"combineRows()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L120-L144","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L120"}],"snippet":"export function combineRows<T extends StatBaseRow>(left: T, right: T): T {\n  return {\n    ...left,\n    sessions: (left.sessions ?? 0) + (right.sessions ?? 0),\n    requests: (left.requests ?? 0) + (right.requests ?? 0),\n    input_tokens: (left.input_tokens ?? 0) + (right.input_tokens ?? 0),\n    output_tokens: (left.output_tokens ?? 0) + (right.output_tokens ?? 0),\n    reasoning_tokens: (left.reasoning_tokens ?? 0) + (right.reasoning_tokens ?? 0),\n    cache_read_tokens: (left.cache_read_tokens ?? 0) + (right.cache_read_tokens ?? 0),\n    total_tokens: (left.total_tokens ?? 0) + (right.total_tokens ?? 0),\n    input_cost_microcents: (left.input_cost_microcents ?? 0) + (right.input_cost_microcents ?? 0),\n    output_cost_microcents: (left.output_cost_microcents ?? 0) + (right.output_cost_microcents ?? 0),\n    total_cost_microcents: (left.total_cost_microcents ?? 0) + (right.total_cost_microcents ?? 0),\n    avg_duration_ms: weightedAverage(left.avg_duration_ms, left.requests, right.avg_duration_ms, right.requests),\n    p50_duration_ms: null,\n    p95_duration_ms: null,\n    avg_ttfb_ms: weightedAverage(left.avg_ttfb_ms, left.requests, right.avg_ttfb_ms, right.requests),\n    p50_ttfb_ms: null,\n    p95_ttfb_ms: null,\n    avg_output_tps: weightedAverage(left.avg_output_tps, left.requests, right.avg_output_tps, right.requests),\n    success_count: (left.success_count ?? 0) + (right.success_count ?? 0),\n    error_count: (left.error_count ?? 0) + (right.error_count ?? 0),\n    sample_count: (left.sample_count ?? 0) + (right.sample_count ?? 0),\n  }\n}"},{"id":"packages_stats_core_src_domain_stat_statperiodkey","label":"statPeriodKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L146-L148","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L146"}],"snippet":"export function statPeriodKey(row: StatBaseRow) {\n  return [row.grain, row.period_key, row.dataset, row.tier, row.client, row.source].join(\"\\u0000\")\n}"},{"id":"packages_stats_core_src_domain_stat_statrowscope","label":"statRowScope()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L150-L159","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L150"}],"snippet":"export function statRowScope(rows: StatBaseRow[]) {\n  if (rows.length === 0) return\n  return {\n    grains: unique(rows.map((row) => row.grain)),\n    periodKeys: unique(rows.map((row) => row.period_key)),\n    datasets: unique(rows.map((row) => row.dataset ?? \"all\")),\n    clients: unique(rows.map((row) => row.client ?? \"all\")),\n    sources: unique(rows.map((row) => row.source ?? \"all\")),\n  }\n}"},{"id":"packages_stats_core_src_domain_stat_periodkeyfor","label":"periodKeyFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L161-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L161"}],"snippet":"export function periodKeyFor(grain: StatGrain, periodStart: Date) {\n  if (grain === \"week\") return isoWeekId(periodStart)\n  return utcDateId(periodStart)\n}"},{"id":"packages_stats_core_src_domain_stat_startofutcday","label":"startOfUtcDay()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L166-L168","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L166"}],"snippet":"export function startOfUtcDay(value: Date) {\n  return new Date(Date.UTC(value.getUTCFullYear(), value.getUTCMonth(), value.getUTCDate()))\n}"},{"id":"packages_stats_core_src_domain_stat_startofisoweek","label":"startOfIsoWeek()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L170-L174","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L170"}],"snippet":"export function startOfIsoWeek(value: Date) {\n  return new Date(\n    Date.UTC(value.getUTCFullYear(), value.getUTCMonth(), value.getUTCDate() - (value.getUTCDay() || 7) + 1),\n  )\n}"},{"id":"packages_stats_core_src_domain_stat_isoweekid","label":"isoWeekId()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L176-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L176"}],"snippet":"export function isoWeekId(value: Date) {\n  const thursday = new Date(\n    Date.UTC(value.getUTCFullYear(), value.getUTCMonth(), value.getUTCDate() + 4 - (value.getUTCDay() || 7)),\n  )\n  return `${thursday.getUTCFullYear()}-W${String(Math.ceil(((thursday.getTime() - Date.UTC(thursday.getUTCFullYear(), 0, 1)) / DAY_MS + 1) / 7)).padStart(2, \"0\")}`\n}"},{"id":"packages_stats_core_src_domain_stat_utcdateid","label":"utcDateId()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L183-L185","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L183"}],"snippet":"function utcDateId(value: Date) {\n  return `${value.getUTCFullYear()}-${String(value.getUTCMonth() + 1).padStart(2, \"0\")}-${String(value.getUTCDate()).padStart(2, \"0\")}`\n}"},{"id":"packages_stats_core_src_domain_stat_rankby","label":"rankBy()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L187-L189","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L187"}],"snippet":"export function rankBy<T extends StatBaseRow>(rows: T[], value: (row: T) => number) {\n  return new Map(rows.toSorted((a, b) => value(b) - value(a)).map((row, index) => [row, index + 1]))\n}"},{"id":"packages_stats_core_src_domain_stat_rankrowswithmarketshare","label":"rankRowsWithMarketShare()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L191-L220","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L191"}],"snippet":"export function rankRowsWithMarketShare<T extends StatBaseRow>(\n  rows: T[],\n  groupKey: (row: T) => string = statPeriodKey,\n) {\n  return Object.values(\n    rows.reduce<Record<string, T[]>>((result, row) => {\n      const key = groupKey(row)\n      result[key] = [...(result[key] ?? []), row]\n      return result\n    }, {}),\n  ).flatMap((group) => {\n    const tokens = group.reduce((sum, row) => sum + (row.total_tokens ?? 0), 0)\n    const requests = group.reduce((sum, row) => sum + (row.requests ?? 0), 0)\n    const sessions = group.reduce((sum, row) => sum + (row.sessions ?? 0), 0)\n    const tokenRanks = rankBy(group, (row) => row.total_tokens ?? 0)\n    const requestRanks = rankBy(group, (row) => row.requests ?? 0)\n    const sessionRanks = rankBy(group, (row) => row.sessions ?? 0)\n    const costRanks = rankBy(group, (row) => row.total_cost_microcents ?? 0)\n    return group.map((row) => ({\n      ...row,\n      market_share_tokens: share(row.total_tokens, tokens),\n      market_share_requests: share(row.requests, requests),\n      market_share_sessions: share(row.sessions, sessions),\n      rank_by_tokens: tokenRanks.get(row) ?? null,\n      rank_by_requests: requestRanks.get(row) ?? null,"},{"id":"packages_stats_core_src_domain_stat_share","label":"share()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L222-L225","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L222"}],"snippet":"export function share(value: number | null | undefined, total: number) {\n  if (total <= 0) return null\n  return Number(((value ?? 0) / total).toFixed(6))\n}"},{"id":"packages_stats_core_src_domain_stat_chunks","label":"chunks()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L227-L231","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L227"}],"snippet":"export function chunks<T>(items: T[], size: number) {\n  return Array.from({ length: Math.ceil(items.length / size) }, (_, index) =>\n    items.slice(index * size, (index + 1) * size),\n  )\n}"},{"id":"packages_stats_core_src_domain_stat_unique","label":"unique()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L233-L235","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L233"}],"snippet":"function unique(values: string[]) {\n  return [...new Set(values)]\n}"},{"id":"packages_stats_core_src_domain_stat_inserted","label":"inserted()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L237-L239","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L237"}],"snippet":"export function inserted(column: string) {\n  return sql.raw(`values(\\`${column}\\`)`)\n}"},{"id":"packages_stats_core_src_domain_stat_weightedaverage","label":"weightedAverage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L241-L251","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L241"}],"snippet":"export function weightedAverage(\n  left: number | null | undefined,\n  leftWeight = 0,\n  right: number | null | undefined,\n  rightWeight = 0,\n) {\n  const totalWeight =\n    (left === null || left === undefined ? 0 : leftWeight) + (right === null || right === undefined ? 0 : rightWeight)\n  if (totalWeight === 0) return null\n  return Number((((left ?? 0) * leftWeight + (right ?? 0) * rightWeight) / totalWeight).toFixed(2))\n}"},{"id":"packages_stats_core_src_domain_stat_normalizetier","label":"normalizeTier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L253-L256","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L253"}],"snippet":"export function normalizeTier(value: string) {\n  if (value === \"Paid\") return \"Zen\"\n  return value\n}"},{"id":"packages_stats_core_src_domain_stat_normalizecountry","label":"normalizeCountry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L258-L261","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L258"}],"snippet":"export function normalizeCountry(value: string | undefined) {\n  if (!value || value.length !== 2) return \"ZZ\"\n  return value.toUpperCase()\n}"}],"edges":[{"source":"packages_stats_core_src_domain_stat","target":"drizzle_orm","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/stat.ts","source_location":"L1"}],"weight":1},{"source":"packages_stats_core_src_domain_stat","target":"packages_stats_core_src_domain_stat_tostatbaserow","relation":"contains","confidence":"EXTRACTED","s