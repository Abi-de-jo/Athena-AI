r({ message: \"Failed to start Athena stats query\", cause }),\n        })\n        const queryExecutionId = started.QueryExecutionId\n        if (!queryExecutionId)\n          return yield* new AthenaQueryError({ message: \"Athena did not return a query execution id\" })"},{"id":"athena_rowdata","label":"rowData()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/athena.ts","source_location":"L131-L139","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/athena.ts","source_location":"L131"}],"snippet":"function rowData(columns: string[], row: Row): AthenaData {\n  return Object.fromEntries(\n    columns.flatMap((column, index) => {\n      const value = row.Data?.[index]?.VarCharValue\n      if (!column || value === undefined) return []\n      return [[column, value]]\n    }),\n  )\n}"}],"edges":[{"source":"athena","target":"client_athena","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/athena.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/athena.ts","source_location":"L1"}],"weight":1},{"source":"athena","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/athena.ts","source_location":"L8","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/athena.ts","source_location":"L8"}],"weight":1},{"source":"athena","target":"context","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/