ai/packages/core/src/util/retry.ts","source_location":"L27-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/retry.ts","source_location":"L27"}],"snippet":"export async function retry<T>(fn: () => Promise<T>, options: RetryOptions = {}): Promise<T> {\n  const { attempts = 3, delay = 500, factor = 2, maxDelay = 10000, retryIf = isTransientError } = options\n\n  let lastError: unknown\n  for (let attempt = 0; attempt < attempts; attempt++) {\n    try {\n      return await fn()\n    } catch (error) {\n      lastError = error\n      if (attempt === attempts - 1 || !retryIf(error)) throw error\n      const wait = Math.min(delay * Math.pow(factor, attempt), maxDelay)\n      await new Promise((resolve) => setTimeout(resolve, wait))\n    }\n  }\n  throw lastError\n}"}],"edges":[{"source":"packages_core_src_util_retry","target":"packages_core_src_util_retry_retryoptions","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/retry.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/retry.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_src_util_retry","target":"packages_core_src_util_retry_istransienterror","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/retry.ts","source_location":"L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/util/retry.ts","source_location":"L20"}],"weight":1},{"source":"packages_core_src_util_retry","target":"packages_core_src_util_retry_retry","relation":"contains","confidence":"EXTRACTED