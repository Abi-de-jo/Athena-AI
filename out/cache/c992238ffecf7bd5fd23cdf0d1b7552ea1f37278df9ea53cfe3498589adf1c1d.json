{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_plugin_digitalocean","nodes":[{"id":"packages_rimuru_src_plugin_digitalocean","label":"digitalocean.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_plugin_digitalocean_implicittokenpayload","label":"ImplicitTokenPayload","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L18-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L18"}],"snippet":"interface ImplicitTokenPayload {\n  access_token: string\n  expires_in: number\n  state: string\n}"},{"id":"packages_rimuru_src_plugin_digitalocean_pendingoauth","label":"PendingOAuth","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L24-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L24"}],"snippet":"interface PendingOAuth {\n  state: string\n  resolve: (tokens: ImplicitTokenPayload) => void\n  reject: (error: Error) => void\n}"},{"id":"packages_rimuru_src_plugin_digitalocean_routerentry","label":"RouterEntry","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L30-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L30"}],"snippet":"interface RouterEntry {\n  name: string\n  uuid?: string\n  description?: string\n}"},{"id":"packages_rimuru_src_plugin_digitalocean_generatestate","label":"generateState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L39-L44","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L39"}],"snippet":"function generateState(): string {\n  const bytes = crypto.getRandomValues(new Uint8Array(32))\n  return Array.from(bytes)\n    .map((b) => b.toString(16).padStart(2, \"0\"))\n    .join(\"\")\n}"},{"id":"packages_rimuru_src_plugin_digitalocean_redirecturi","label":"redirectUri()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L46-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L46"}],"snippet":"function redirectUri(): string {\n  return `http://localhost:${OAUTH_PORT}${OAUTH_REDIRECT_PATH}`\n}"},{"id":"packages_rimuru_src_plugin_digitalocean_buildauthorizeurl","label":"buildAuthorizeUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L50-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L50"}],"snippet":"function buildAuthorizeUrl(state: string): string {\n  const params = new URLSearchParams({\n    response_type: \"token\",\n    client_id: DO_OAUTH_CLIENT_ID,\n    redirect_uri: redirectUri(),\n    scope: OAUTH_SCOPES,\n    state,\n  })\n  return `${DO_AUTHORIZE_URL}?${params.toString()}`\n}"},{"id":"packages_rimuru_src_plugin_digitalocean_startoauthserver","label":"startOAuthServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L120-L192","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L120"}],"snippet":"async function startOAuthServer(): Promise<void> {\n  if (oauthServer) return\n  oauthServer = createServer((req, res) => {\n    const url = new URL(req.url || \"/\", `http://localhost:${OAUTH_PORT}`)\n\n    if (req.method === \"GET\" && url.pathname === OAUTH_REDIRECT_PATH) {\n      res.writeHead(200, { \"Content-Type\": \"text/html\" })\n      res.end(HTML_CALLBACK)\n      return\n    }\n\n    if (req.method === \"POST\" && url.pathname === OAUTH_TOKEN_PATH) {\n      const chunks: Buffer[] = []\n      req.on(\"data\", (chunk: Buffer) => chunks.push(chunk))\n      req.on(\"end\", () => {\n        const raw = Buffer.concat(chunks).toString(\"utf8\")\n        let body: Record<string, string> = {}\n        try {\n          body = raw ? JSON.parse(raw) : {}\n        } catch {\n          body = {}\n        }\n        if (!pendingOAuth) {\n          res.writeHead(409, { \"Content-Type\": \"application/json\" })\n          res.end(JSON.stringify({ error: \"no_pending_oauth\" }))"},{"id":"packages_rimuru_src_plugin_digitalocean_stopoauthserver","label":"stopOAuthServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L194-L198","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L194"}],"snippet":"function stopOAuthServer() {\n  if (!oauthServer) return\n  oauthServer.close()\n  oauthServer = undefined\n}"},{"id":"packages_rimuru_src_plugin_digitalocean_waitforoauthcallback","label":"waitForOAuthCallback()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L200-L223","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L200"}],"snippet":"function waitForOAuthCallback(state: string): Promise<ImplicitTokenPayload> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(\n      () => {\n        if (pendingOAuth) {\n          pendingOAuth = undefined\n          reject(new Error(\"OAuth callback timeout - authorization took too long\"))\n        }\n      },\n      5 * 60 * 1000,\n    )\n    pendingOAuth = {\n      state,\n      resolve: (tokens) => {\n        clearTimeout(timeout)\n        resolve(tokens)\n      },\n      reject: (error) => {\n        clearTimeout(timeout)\n        reject(error)\n      },\n    }\n  })\n}"},{"id":"packages_rimuru_src_plugin_digitalocean_listrouters","label":"listRouters()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L225-L240","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L225"}],"snippet":"async function listRouters(\n  bearer: string,\n): Promise<{ ok: true; routers: RouterEntry[] } | { ok: false; status: number }> {\n  const res = await fetch(`${DO_GENAI_API}/models/routers`, {\n    headers: {\n      Authorization: `Bearer ${bearer}`,\n      Accept: \"application/json\",\n      \"User-Agent\": `rimuru-ai/${InstallationVersion}`,\n    },\n    signal: AbortSignal.timeout(10_000),\n  }).catch(() => undefined)\n  if (!res) return { ok: false, status: 0 }\n  if (!res.ok) return { ok: false, status: res.status }\n  const body = (await res.json().catch(() => undefined)) as { model_routers?: RouterEntry[] } | undefined\n  return { ok: true, routers: body?.model_routers ?? [] }\n}"},{"id":"packages_rimuru_src_plugin_digitalocean_routermodel","label":"routerModel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L242-L267","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L242"}],"snippet":"function routerModel(router: RouterEntry, providerID: string): Model {\n  const id = `router:${router.name}`\n  return {\n    id,\n    providerID,\n    name: router.name,\n    family: \"digitalocean-inference-routers\",\n    api: { id, url: DO_INFERENCE_BASE, npm: \"@ai-sdk/openai-compatible\" },\n    status: \"active\",\n    headers: {},\n    options: {},\n    cost: { input: 0, output: 0, cache: { read: 0, write: 0 } },\n    limit: { context: 128_000, output: 8_192 },\n    capabilities: {\n      temperature: true,\n      reasoning: false,\n      attachment: false,\n      toolcall: true,\n      input: { text: true, audio: false, image: false, video: false, pdf: false },\n      output: { text: true, audio: false, image: false, video: false, pdf: false },\n      interleaved: false,\n    },\n    release_date: \"\",\n    variants: {},\n  }"},{"id":"packages_rimuru_src_plugin_digitalocean_parseroutersjson","label":"parseRoutersJSON()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L269-L280","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L269"}],"snippet":"function parseRoutersJSON(raw: string | undefined): RouterEntry[] {\n  if (!raw) return []\n  try {\n    const parsed = JSON.parse(raw)\n    if (!Array.isArray(parsed)) return []\n    return parsed.flatMap((r) =>\n      r && typeof r.name === \"string\" ? [{ name: r.name, uuid: r.uuid, description: r.description }] : [],\n    )\n  } catch {\n    return []\n  }\n}"},{"id":"packages_rimuru_src_plugin_digitalocean_digitaloceanauthplugin","label":"DigitalOceanAuthPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L282-L383","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L282"}],"snippet":"export async function DigitalOceanAuthPlugin(input: PluginInput): Promise<Hooks> {\n  return {\n    provider: {\n      id: \"digitalocean\",\n      async models(provider, ctx) {\n        const baseModels = provider.models\n        if (ctx.auth?.type !== \"api\") return baseModels\n\n        const metadata = ctx.auth.metadata ?? {}\n        const oauthAccess = metadata[\"oauth_access\"]\n        const oauthExpires = parseInt(metadata[\"oauth_expires\"] || \"0\", 10)\n        const fetchedAt = parseInt(metadata[\"routers_fetched_at\"] || \"0\", 10)\n        const cached = parseRoutersJSON(metadata[\"routers\"])\n\n        let routers = cached\n        const stale = Date.now() - fetchedAt > ROUTER_REFRESH_INTERVAL_MS\n        const bearerValid = oauthAccess && oauthExpires > Date.now()\n\n        if (bearerValid && stale) {\n          const result = await listRouters(oauthAccess)\n          if (result.ok) {\n            routers = result.routers\n            const updated: Record<string, string> = {\n              ...metadata,\n              routers: JSON.stringify(routers.map((r) => ({ name: r.name, uuid: r.uuid, description: r.description }))),"}],"edges":[{"source":"packages_rimuru_src_plugin_digitalocean","target":"plugin","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_plugin_digitalocean","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L2"}],"weight":1},{"source":"packages_rimuru_src_plugin_digitalocean","target":"version","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/digitalocean.ts","source_location":"L3"}],"weight":1},{"source":"packages_rimuru_src_plugin_digitalocean","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gow