{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_components_prompt-input_history","nodes":[{"id":"packages_app_src_components_prompt_input_history","label":"history.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L1"}]},{"id":"packages_app_src_components_prompt_input_history_cannavigatehistoryatcursor","label":"canNavigateHistoryAtCursor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L25-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L25"}],"snippet":"export function canNavigateHistoryAtCursor(direction: \"up\" | \"down\", text: string, cursor: number, inHistory = false) {\n  const position = Math.max(0, Math.min(cursor, text.length))\n  const atStart = position === 0\n  const atEnd = position === text.length\n  if (inHistory) return atStart || atEnd\n  if (direction === \"up\") return position === 0 && text.length === 0\n  return position === text.length\n}"},{"id":"packages_app_src_components_prompt_input_history_clonepromptparts","label":"clonePromptParts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L34-L44","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L34"}],"snippet":"export function clonePromptParts(prompt: Prompt): Prompt {\n  return prompt.map((part) => {\n    if (part.type === \"text\") return { ...part }\n    if (part.type === \"image\") return { ...part }\n    if (part.type === \"agent\") return { ...part }\n    return {\n      ...part,\n      selection: part.selection ? { ...part.selection } : undefined,\n    }\n  })\n}"},{"id":"packages_app_src_components_prompt_input_history_cloneselection","label":"cloneSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L46-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L46"}],"snippet":"function cloneSelection(selection: SelectedLineRange): SelectedLineRange {\n  return {\n    start: selection.start,\n    end: selection.end,\n    ...(selection.side ? { side: selection.side } : {}),\n    ...(selection.endSide ? { endSide: selection.endSide } : {}),\n  }\n}"},{"id":"packages_app_src_components_prompt_input_history_cloneprompthistorycomments","label":"clonePromptHistoryComments()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L55-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L55"}],"snippet":"export function clonePromptHistoryComments(comments: PromptHistoryComment[]) {\n  return comments.map((comment) => ({\n    ...comment,\n    selection: cloneSelection(comment.selection),\n  }))\n}"},{"id":"packages_app_src_components_prompt_input_history_normalizeprompthistoryentry","label":"normalizePromptHistoryEntry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L62-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L62"}],"snippet":"export function normalizePromptHistoryEntry(entry: PromptHistoryStoredEntry): PromptHistoryEntry {\n  if (Array.isArray(entry)) {\n    return {\n      prompt: clonePromptParts(entry),\n      comments: [],\n    }\n  }\n  return {\n    prompt: clonePromptParts(entry.prompt),\n    comments: clonePromptHistoryComments(entry.comments),\n  }\n}"},{"id":"packages_app_src_components_prompt_input_history_promptlength","label":"promptLength()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L75-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L75"}],"snippet":"export function promptLength(prompt: Prompt) {\n  return prompt.reduce((len, part) => len + (\"content\" in part ? part.content.length : 0), 0)\n}"},{"id":"packages_app_src_components_prompt_input_history_prependhistoryentry","label":"prependHistoryEntry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L79-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L79"}],"snippet":"export function prependHistoryEntry(\n  entries: PromptHistoryStoredEntry[],\n  prompt: Prompt,\n  comments: PromptHistoryComment[] = [],\n  max = MAX_HISTORY,\n) {\n  const text = prompt\n    .map((part) => (\"content\" in part ? part.content : \"\"))\n    .join(\"\")\n    .trim()\n  const hasImages = prompt.some((part) => part.type === \"image\")\n  const hasComments = comments.some((comment) => !!comment.comment.trim())\n  if (!text && !hasImages && !hasComments) return entries\n\n  const entry = {\n    prompt: clonePromptParts(prompt),\n    comments: clonePromptHistoryComments(comments),\n  } satisfies PromptHistoryEntry\n  const last = entries[0]\n  if (last && isPromptEqual(last, entry)) return entries\n  return [entry, ...entries].slice(0, max)\n}"},{"id":"packages_app_src_components_prompt_input_history_iscommentequal","label":"isCommentEqual()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L102-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L102"}],"snippet":"function isCommentEqual(commentA: PromptHistoryComment, commentB: PromptHistoryComment) {\n  return (\n    commentA.path === commentB.path &&\n    commentA.comment === commentB.comment &&\n    commentA.origin === commentB.origin &&\n    commentA.preview === commentB.preview &&\n    commentA.selection.start === commentB.selection.start &&\n    commentA.selection.end === commentB.selection.end &&\n    commentA.selection.side === commentB.selection.side &&\n    commentA.selection.endSide === commentB.selection.endSide\n  )\n}"},{"id":"packages_app_src_components_prompt_input_history_ispromptequal","label":"isPromptEqual()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L115-L148","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L115"}],"snippet":"function isPromptEqual(promptA: PromptHistoryStoredEntry, promptB: PromptHistoryStoredEntry) {\n  const entryA = normalizePromptHistoryEntry(promptA)\n  const entryB = normalizePromptHistoryEntry(promptB)\n  if (entryA.prompt.length !== entryB.prompt.length) return false\n  for (let i = 0; i < entryA.prompt.length; i++) {\n    const partA = entryA.prompt[i]\n    const partB = entryB.prompt[i]\n    if (partA.type !== partB.type) return false\n    if (partA.type === \"text\" && partA.content !== (partB.type === \"text\" ? partB.content : \"\")) return false\n    if (partA.type === \"file\") {\n      if (partA.path !== (partB.type === \"file\" ? partB.path : \"\")) return false\n      const a = partA.selection\n      const b = partB.type === \"file\" ? partB.selection : undefined\n      const sameSelection =\n        (!a && !b) ||\n        (!!a &&\n          !!b &&\n          a.startLine === b.startLine &&\n          a.startChar === b.startChar &&\n          a.endLine === b.endLine &&\n          a.endChar === b.endChar)\n      if (!sameSelection) return false\n    }\n    if (partA.type === \"agent\" && partA.name !== (partB.type === \"agent\" ? partB.name : \"\")) return false\n    if (partA.type === \"image\" && partA.id !== (partB.type === \"image\" ? partB.id : \"\")) return false"},{"id":"packages_app_src_components_prompt_input_history_navigateprompthistory","label":"navigatePromptHistory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L173-L256","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L173"}],"snippet":"export function navigatePromptHistory(input: HistoryNavInput): HistoryNavResult {\n  if (input.direction === \"up\") {\n    if (input.entries.length === 0) {\n      return {\n        handled: false,\n        historyIndex: input.historyIndex,\n        savedPrompt: input.savedPrompt,\n      }\n    }\n\n    if (input.historyIndex === -1) {\n      const entry = normalizePromptHistoryEntry(input.entries[0])\n      return {\n        handled: true,\n        historyIndex: 0,\n        savedPrompt: {\n          prompt: clonePromptParts(input.currentPrompt),\n          comments: clonePromptHistoryComments(input.currentComments),\n        },\n        entry,\n        cursor: \"start\",\n      }\n    }\n\n    if (input.historyIndex < input.entries.length - 1) {"}],"edges":[{"source":"packages_app_src_components_prompt_input_history","target":"prompt","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L1"}],"weight":1},{"source":"packages_app_src_components_prompt_input_history","target":"file","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/history.ts","source_location":"L2"}],"weight":1},{"source":"packages_app_src_components_prompt_input_history","target":"packages_app_src_components_prompt_input_history_cannavigatehistoryatcursor","relation":"contains","confidence":"EXTRACTED","source_file":"/h