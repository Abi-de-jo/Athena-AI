{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_test_project_project.test","nodes":[{"id":"packages_rimuru_test_project_project_test","label":"project.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L1"}]},{"id":"packages_rimuru_test_project_project_test_remoteprojectid","label":"remoteProjectID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L32-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L32"}],"snippet":"function remoteProjectID(remote: string) {\n  return ProjectV2.ID.make(Hash.fast(`git-remote:${remote}`))\n}"},{"id":"packages_rimuru_test_project_project_test_mockgitfailure","label":"mockGitFailure()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L41-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L41"}],"snippet":"function mockGitFailure(failArg: string) {\n  return Layer.effect(\n    ChildProcessSpawner.ChildProcessSpawner,\n    Effect.gen(function* () {\n      const real = yield* ChildProcessSpawner.ChildProcessSpawner\n      return ChildProcessSpawner.make(\n        Effect.fnUntraced(function* (command) {\n          const std = ChildProcess.isStandardCommand(command) ? command : undefined\n          if (std?.command === \"git\" && std.args.some((a) => a === failArg)) {\n            return ChildProcessSpawner.makeHandle({\n              pid: ChildProcessSpawner.ProcessId(0),\n              exitCode: Effect.succeed(ChildProcessSpawner.ExitCode(128)),\n              isRunning: Effect.succeed(false),\n              kill: () => Effect.void,\n              stdin: { [Symbol.for(\"effect/Sink/TypeId\")]: Symbol.for(\"effect/Sink/TypeId\") } as any,\n              stdout: Stream.empty,\n              stderr: Stream.make(encoder.encode(\"fatal: simulated failure\\n\")),\n              all: Stream.empty,\n              getInputFd: () => ({ [Symbol.for(\"effect/Sink/TypeId\")]: Symbol.for(\"effect/Sink/TypeId\") }) as any,\n              getOutputFd: () => Stream.empty,\n              unref: Effect.succeed(Effect.void),\n            })\n          }\n          return yield* real.spawn(command)\n        }),"},{"id":"packages_rimuru_test_project_project_test_projectlayerwithfailure","label":"projectLayerWithFailure()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L71-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L71"}],"snippet":"function projectLayerWithFailure(failArg: string) {\n  return Project.layer.pipe(\n    Layer.provide(AppProcess.layer.pipe(Layer.provide(mockGitFailure(failArg)))),\n    Layer.provide(mockGitFailure(failArg)),\n    Layer.provide(ProjectV2.defaultLayer),\n    Layer.provide(ProjectDirectories.defaultLayer),\n    Layer.provide(EventV2Bridge.defaultLayer),\n    Layer.provide(FSUtil.defaultLayer),\n    Layer.provide(NodePath.layer),\n    Layer.provide(Database.defaultLayer),\n    Layer.provide(RuntimeFlags.defaultLayer),\n  )\n}"},{"id":"packages_rimuru_test_project_project_test_projectlayerwithruntimeflags","label":"projectLayerWithRuntimeFlags()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L85-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L85"}],"snippet":"function projectLayerWithRuntimeFlags(flags: Parameters<typeof RuntimeFlags.layer>[0]) {\n  return Project.layer.pipe(\n    Layer.provide(EventV2Bridge.defaultLayer),\n    Layer.provide(ProjectV2.defaultLayer),\n    Layer.provide(ProjectDirectories.defaultLayer),\n    Layer.provide(AppProcess.defaultLayer),\n    Layer.provide(FSUtil.defaultLayer),\n    Layer.provide(NodePath.layer),\n    Layer.provide(Database.defaultLayer),\n    Layer.provide(RuntimeFlags.layer(flags)),\n  )\n}"},{"id":"packages_rimuru_test_project_project_test_failureit","label":"failureIt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L98-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L98"}],"snippet":"failureIt = (failArg: string) =>\n  testEffect(Layer.mergeAll(projectLayerWithFailure(failArg), CrossSpawnSpawner.defaultLayer))"},{"id":"packages_rimuru_test_project_project_test_waitforprojecticon","label":"waitForProjectIcon()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L105-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L105"}],"snippet":"function waitForProjectIcon(id: ProjectV2.ID, attempts = 50): Effect.Effect<Project.Info, never, Project.Service> {\n  return Effect.gen(function* () {\n    const project = yield* Project.Service\n    const info = yield* project.get(id)\n    if (info?.icon?.url) return info\n    if (attempts <= 0) throw new Error(`Project icon was not discovered: ${id}`)\n    yield* Effect.sleep(\"10 millis\")\n    return yield* waitForProjectIcon(id, attempts - 1)\n  })\n}"}],"edges":[{"source":"packages_rimuru_test_project_project_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_test_project_project_test","target":"event_v2_bridge","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L2"}],"weight":1},{"source":"packages_rimuru_test_project_project_test","target":"project","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/project/project.test.ts","source_location":"L3"}],"weight":1},{"source":"packages_rimuru_test_p