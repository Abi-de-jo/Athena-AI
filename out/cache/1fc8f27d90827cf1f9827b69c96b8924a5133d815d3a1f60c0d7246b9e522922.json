{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_acp_event","nodes":[{"id":"packages_rimuru_src_acp_event","label":"event.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_acp_event_start","label":"start()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L33-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L33"}],"snippet":"export function start(input: { sdk: OpencodeClient; connection: Connection; session: ACPSession.Interface }) {\n  const subscription = new Subscription(input)\n  subscription.start()\n  return subscription\n}"},{"id":"packages_rimuru_src_acp_event_subscription","label":"Subscription","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L39-L340","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L39"}],"snippet":"export class Subscription {\n  private readonly abort = new AbortController()\n  private readonly shellSnapshots = new Map<string, string>()\n  private readonly toolStarts = new Set<string>()\n  private readonly permission: ACPPermission.Handler\n  private started = false\n\n  constructor(\n    private readonly input: {\n      sdk: OpencodeClient\n      connection: Connection\n      session: ACPSession.Interface\n    },\n  ) {\n    this.permission = new ACPPermission.Handler(input)\n  }\n\n  start() {\n    if (this.started) return\n    this.started = true\n    this.run().catch(() => {\n      if (this.abort.signal.aborted) return\n    })\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_constructor","label":".constructor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L46-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L46"}],"snippet":"constructor(\n    private readonly input: {\n      sdk: OpencodeClient\n      connection: Connection\n      session: ACPSession.Interface\n    },\n  ) {\n    this.permission = new ACPPermission.Handler(input)\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_start","label":".start()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L56-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L56"}],"snippet":"start() {\n    if (this.started) return\n    this.started = true\n    this.run().catch(() => {\n      if (this.abort.signal.aborted) return\n    })\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_stop","label":".stop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L64-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L64"}],"snippet":"stop() {\n    this.abort.abort()\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_handle","label":".handle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L68-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L68"}],"snippet":"async handle(event: Event) {\n    switch (event.type) {\n      case \"permission.asked\":\n        this.permission.handle(event)\n        return\n      case \"message.part.updated\":\n        return this.handlePartUpdated(event)\n      case \"message.part.delta\":\n        return this.handlePartDelta(event)\n    }\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_replaymessage","label":".replayMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L80-L92","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L80"}],"snippet":"async replayMessage(message: SessionMessageResponse) {\n    if (message.info.role !== \"assistant\" && message.info.role !== \"user\") return\n\n    const cwd = message.info.role === \"assistant\" ? message.info.path?.cwd : undefined\n    for (const part of message.parts) {\n      await this.recordFetchedPart(message.info.sessionID, message, part)\n      if (part.type === \"tool\") {\n        await this.handleToolPart(message.info.sessionID, part, cwd ?? process.cwd())\n        continue\n      }\n      await this.replayContentPart(message, part)\n    }\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_replaycontentpart","label":".replayContentPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L94-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L94"}],"snippet":"private async replayContentPart(message: SessionMessageResponse, part: Part) {\n    if (part.type !== \"text\" && part.type !== \"file\" && part.type !== \"reasoning\") return\n\n    const sessionUpdate =\n      part.type === \"reasoning\"\n        ? \"agent_thought_chunk\"\n        : message.info.role === \"user\"\n          ? \"user_message_chunk\"\n          : \"agent_message_chunk\"\n\n    for (const chunk of partsToContentChunks([part as ReplayPart])) {\n      await this.input.connection.sessionUpdate({\n        sessionId: message.info.sessionID,\n        update: {\n          sessionUpdate,\n          messageId: message.info.id,\n          ...chunk,\n        },\n      })\n    }\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_run","label":".run()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L116-L129","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L116"}],"snippet":"private async run() {\n    while (!this.abort.signal.aborted) {\n      const events = (await this.input.sdk.global.event({\n        signal: this.abort.signal,\n      })) as GlobalEventStream\n\n      for await (const event of events.stream) {\n        if (this.abort.signal.aborted) return\n        if (!event.payload) continue\n        await this.handle(event.payload).catch(() => {})\n      }\n      if (!this.abort.signal.aborted) await new Promise((resolve) => setTimeout(resolve, 1000))\n    }\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_handlepartupdated","label":".handlePartUpdated()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L131-L152","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L131"}],"snippet":"private async handlePartUpdated(event: EventMessagePartUpdated) {\n    const part = event.properties.part\n    const sessionId = part.sessionID || event.properties.sessionID\n    const session = await Effect.runPromise(this.input.session.tryGet(sessionId))\n    if (!session) return\n\n    await Effect.runPromise(\n      this.input.session.recordPartMetadata({\n        sessionId: session.id,\n        messageId: part.messageID,\n        partId: part.id,\n        partType: part.type,\n        role: part.type === \"reasoning\" ? \"assistant\" : undefined,\n        ignored: part.type === \"text\" ? part.ignored : undefined,\n        toolCallId: part.type === \"tool\" ? part.callID : undefined,\n        metadata: \"metadata\" in part ? part.metadata : undefined,\n      }),\n    )\n    if (part.type === \"tool\") {\n      await this.handleToolPart(session.id, part, session.cwd)\n    }\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_handlepartdelta","label":".handlePartDelta()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L154-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L154"}],"snippet":"private async handlePartDelta(event: EventMessagePartDelta) {\n    const props = event.properties\n    const session = await Effect.runPromise(this.input.session.tryGet(props.sessionID))\n    if (!session) return\n\n    const known = await Effect.runPromise(\n      this.input.session.tryGetPartMetadata({\n        sessionId: session.id,\n        messageId: props.messageID,\n        partId: props.partID,\n      }),\n    )\n    const metadata =\n      known?.role && known.partType\n        ? known\n        : await this.fetchPartMetadata(session.id, session.cwd, props.messageID, props.partID)\n    if (metadata?.role !== \"assistant\") return\n    if (metadata.partType === \"text\" && props.field === \"text\" && metadata.ignored !== true) {\n      await this.input.connection.sessionUpdate({\n        sessionId: session.id,\n        update: {\n          sessionUpdate: \"agent_message_chunk\",\n          messageId: props.messageID,\n          content: {\n            type: \"text\","},{"id":"packages_rimuru_src_acp_event_subscription_fetchpartmetadata","label":".fetchPartMetadata()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L201-L218","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L201"}],"snippet":"private async fetchPartMetadata(sessionId: string, cwd: string, messageId: string, partId: string) {\n    const message = await this.input.sdk.session\n      .message(\n        {\n          sessionID: sessionId,\n          messageID: messageId,\n          directory: cwd,\n        },\n        { throwOnError: true },\n      )\n      .then((response) => response.data)\n      .catch(() => undefined)\n    if (!message) return\n\n    const part = message.parts.find((item) => item.id === partId)\n    if (!part) return\n    return await this.recordFetchedPart(sessionId, message, part)\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_recordfetchedpart","label":".recordFetchedPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L220-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L220"}],"snippet":"private async recordFetchedPart(sessionId: string, message: SessionMessageResponse, part: Part) {\n    return await Effect.runPromise(\n      this.input.session.recordPartMetadata({\n        sessionId,\n        messageId: part.messageID,\n        partId: part.id,\n        partType: part.type,\n        role: message.info.role,\n        ignored: part.type === \"text\" ? part.ignored : undefined,\n        toolCallId: part.type === \"tool\" ? part.callID : undefined,\n        metadata: \"metadata\" in part ? part.metadata : undefined,\n      }),\n    )\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_handletoolpart","label":".handleToolPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L235-L279","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L235"}],"snippet":"private async handleToolPart(sessionId: string, part: ToolPart, cwd: string) {\n    await this.toolStart(sessionId, part, cwd)\n\n    switch (part.state.status) {\n      case \"pending\":\n        this.shellSnapshots.delete(part.callID)\n        return\n\n      case \"running\":\n        await this.runningTool(sessionId, part, cwd)\n        return\n\n      case \"completed\":\n        this.clearTool(part.callID)\n        await this.input.connection.sessionUpdate({\n          sessionId,\n          update: {\n            sessionUpdate: \"tool_call_update\",\n            ...completedToolUpdate({\n              toolCallId: part.callID,\n              toolName: part.tool,\n              state: part.state,\n              cwd,\n            }),\n          },"},{"id":"packages_rimuru_src_acp_event_subscription_runningtool","label":".runningTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L281-L317","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L281"}],"snippet":"private async runningTool(sessionId: string, part: ToolPart, cwd: string) {\n    if (part.state.status !== \"running\") return\n\n    const output = part.tool === \"bash\" ? shellOutputSnapshot(part.state) : undefined\n    if (output !== undefined) {\n      if (this.shellSnapshots.get(part.callID) === output) {\n        await this.input.connection.sessionUpdate({\n          sessionId,\n          update: {\n            sessionUpdate: \"tool_call_update\",\n            ...duplicateRunningToolUpdate({\n              toolCallId: part.callID,\n              toolName: part.tool,\n              state: part.state,\n              cwd,\n            }),\n          },\n        })\n        return\n      }\n      this.shellSnapshots.set(part.callID, output)\n    }\n\n    await this.input.connection.sessionUpdate({\n      sessionId,"},{"id":"packages_rimuru_src_acp_event_subscription_toolstart","label":".toolStart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L319-L334","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L319"}],"snippet":"private async toolStart(sessionId: string, part: ToolPart, cwd: string) {\n    if (this.toolStarts.has(part.callID)) return\n    this.toolStarts.add(part.callID)\n    await this.input.connection.sessionUpdate({\n      sessionId,\n      update: {\n        sessionUpdate: \"tool_call\",\n        ...pendingToolCall({\n          toolCallId: part.callID,\n          toolName: part.tool,\n          state: part.state,\n          cwd,\n        }),\n      },\n    })\n  }"},{"id":"packages_rimuru_src_acp_event_subscription_cleartool","label":".clearTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L336-L339","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L336"}],"snippet":"private clearTool(toolCallId: string) {\n    this.toolStarts.delete(toolCallId)\n    this.shellSnapshots.delete(toolCallId)\n  }"}],"edges":[{"source":"packages_rimuru_src_acp_event","target":"sdk","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_acp_event","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L2"}],"weight":1},{"source":"packages_rimuru_src_acp_event","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/acp/event.ts","source_location":"L11","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai