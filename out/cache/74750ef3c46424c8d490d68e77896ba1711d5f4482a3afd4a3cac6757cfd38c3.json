{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_test_storage_storage.test","nodes":[{"id":"packages_rimuru_test_storage_storage_test","label":"storage.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L1"}]},{"id":"packages_rimuru_test_storage_storage_test_remap","label":"remap()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L31-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L31"}],"snippet":"function remap(root: string, file: string) {\n  if (file === Global.Path.data) return root\n  if (file.startsWith(Global.Path.data + path.sep)) return path.join(root, path.relative(Global.Path.data, file))\n  return file\n}"},{"id":"packages_rimuru_test_storage_storage_test_remappedfs","label":"remappedFs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L37-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L37"}],"snippet":"function remappedFs(root: string) {\n  return Layer.effect(\n    FSUtil.Service,\n    Effect.gen(function* () {\n      const fs = yield* FSUtil.Service\n      return FSUtil.Service.of({\n        ...fs,\n        isDir: (file) => fs.isDir(remap(root, file)),\n        readJson: (file) => fs.readJson(remap(root, file)),\n        writeWithDirs: (file, content, mode) => fs.writeWithDirs(remap(root, file), content, mode),\n        readFileString: (file) => fs.readFileString(remap(root, file)),\n        remove: (file) => fs.remove(remap(root, file)),\n        glob: (pattern, options) =>\n          fs.glob(pattern, options?.cwd ? { ...options, cwd: remap(root, options.cwd) } : options),\n      })\n    }),\n  ).pipe(Layer.provide(FSUtil.defaultLayer))\n}"},{"id":"packages_rimuru_test_storage_storage_test_remappedstorage","label":"remappedStorage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L59-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L59"}],"snippet":"remappedStorage = (root: string) =>\n  Layer.fresh(Storage.layer.pipe(Layer.provide(remappedFs(root)), Layer.provide(Git.defaultLayer)))"}],"edges":[{"source":"packages_rimuru_test_storage_storage_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_test_storage_storage_test","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage/storage.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/storage