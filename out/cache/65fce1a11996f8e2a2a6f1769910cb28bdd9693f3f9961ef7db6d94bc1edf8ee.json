{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_desktop_scripts_utils","nodes":[{"id":"packages_desktop_scripts_utils","label":"utils.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L1"}]},{"id":"packages_desktop_scripts_utils_resolvechannel","label":"resolveChannel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L5-L9","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L5"}],"snippet":"export function resolveChannel(): Channel {\n  const raw = Bun.env.OPENCODE_CHANNEL\n  if (raw === \"dev\" || raw === \"beta\" || raw === \"prod\") return raw\n  return \"dev\"\n}"},{"id":"packages_desktop_scripts_utils_nativetarget","label":"nativeTarget()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L46-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L46"}],"snippet":"function nativeTarget() {\n  const { platform, arch } = process\n  if (platform === \"darwin\") return arch === \"arm64\" ? \"aarch64-apple-darwin\" : \"x86_64-apple-darwin\"\n  if (platform === \"win32\") return arch === \"arm64\" ? \"aarch64-pc-windows-msvc\" : \"x86_64-pc-windows-msvc\"\n  if (platform === \"linux\") return arch === \"arm64\" ? \"aarch64-unknown-linux-gnu\" : \"x86_64-unknown-linux-gnu\"\n  throw new Error(`Unsupported platform: ${platform}/${arch}`)\n}"},{"id":"packages_desktop_scripts_utils_getcurrentsidecar","label":"getCurrentSidecar()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L54-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L54"}],"snippet":"export function getCurrentSidecar(target = RUST_TARGET ?? nativeTarget()) {\n  const binaryConfig = SIDECAR_BINARIES.find((b) => b.rustTarget === target)\n  if (!binaryConfig) throw new Error(`Sidecar configuration not available for Rust target '${target}'`)\n\n  return binaryConfig\n}"},{"id":"packages_desktop_scripts_utils_copybinarytosidecarfolder","label":"copyBinaryToSidecarFolder()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L61-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L61"}],"snippet":"export async function copyBinaryToSidecarFolder(source: string) {\n  const dir = `resources`\n  await $`mkdir -p ${dir}`\n  const dest = windowsify(`${dir}/opencode-cli`)\n  await $`cp ${source} ${dest}`\n  if (process.platform === \"win32\" && process.env.GITHUB_ACTIONS === \"true\") {\n    await $`pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ../../script/sign-windows.ps1 ${dest}`\n  }\n  if (process.platform === \"darwin\") await $`codesign --force --sign - ${dest}`\n\n  console.log(`Copied ${source} to ${dest}`)\n}"},{"id":"packages_desktop_scripts_utils_windowsify","label":"windowsify()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/utils.ts","source_location":"L74-L77","layer"