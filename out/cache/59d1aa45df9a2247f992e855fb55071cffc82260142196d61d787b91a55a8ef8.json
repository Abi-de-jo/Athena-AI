{"__madarTsExtractorVersion":67,"__madarFileStem":"provider-helper","nodes":[{"id":"provider_helper","label":"provider-helper.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L1"}]},{"id":"provider_helper_provider","label":"provider()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L86-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L86"}],"snippet":"export function provider(providerID: string, options?: ProviderInput) {\n  return new ProviderV2.Info({\n    ...ProviderV2.Info.empty(ProviderV2.ID.make(providerID)),\n    api: options?.api ?? {\n      type: \"aisdk\",\n      package: \"test-provider\",\n    },\n    ...options,\n    request: {\n      headers: {},\n      body: {},\n      ...options?.request,\n    },\n  })\n}"},{"id":"provider_helper_model","label":"model()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L102-L121","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L102"}],"snippet":"export function model(providerID: string, modelID: string, options?: ModelInput) {\n  return new ModelV2.Info({\n    ...ModelV2.Info.empty(ProviderV2.ID.make(providerID), ModelV2.ID.make(modelID)),\n    ...options,\n    api:\n      options?.api && \"type\" in options.api\n        ? { id: ModelV2.ID.make(modelID), ...options.api }\n        : {\n            id: ModelV2.ID.make(modelID),\n            ...options?.api,\n            type: \"aisdk\",\n            package: \"test-provider\",\n          },\n    request: {\n      headers: {},\n      body: {},\n      ...options?.request,\n    },\n  })\n}"},{"id":"provider_helper_withenv","label":"withEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L123-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L123"}],"snippet":"export function withEnv<A, E, R>(vars: Record<string, string | undefined>, fx: () => Effect.Effect<A, E, R>) {\n  return Effect.acquireUseRelease(\n    Effect.sync(() => {\n      const previous = Object.fromEntries(Object.keys(vars).map((key) => [key, process.env[key]]))\n      for (const [key, value] of Object.entries(vars)) {\n        if (value === undefined) delete process.env[key]\n        else process.env[key] = value\n      }\n      return previous\n    }),\n    () => fx(),\n    (previous) =>\n      Effect.sync(() => {\n        for (const [key, value] of Object.entries(previous)) {\n          if (value === undefined) delete process.env[key]\n          else process.env[key] = value\n        }\n      }),\n  )\n}"},{"id":"provider_helper_fakeselectorsdk","label":"fakeSelectorSdk()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L144-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L144"}],"snippet":"export function fakeSelectorSdk(calls: string[]) {\n  const make = (method: string) => (id: string) => {\n    calls.push(`${method}:${id}`)\n    return { modelId: id, provider: method, specificationVersion: \"v3\" } as unknown as LanguageModelV3\n  }\n  return {\n    responses: make(\"responses\"),\n    messages: make(\"messages\"),\n    chat: make(\"chat\"),\n    languageModel: make(\"languageModel\"),\n  }\n}"},{"id":"provider_helper_fakeselectorsdk_make","label":"make()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L145-L148","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L145"}],"snippet":"make = (method: string) => (id: string) => {\n    calls.push(`${method}:${id}`)\n    return { modelId: id, provider: method, specificationVersion: \"v3\" } as unknown as LanguageModelV3\n  }"},{"id":"provider_helper_expectpluginregistered","label":"expectPluginRegistered()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L157-L159","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L157"}],"snippet":"export function expectPluginRegistered(ids: string[], id: string) {\n  expect(ids).toContain(PluginV2.ID.make(id))\n}"}],"edges":[{"source":"provider_helper","target":"npm","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/plugin/provider-helper.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/person