{"__madarTsExtractorVersion":67,"__madarFileStem":"httpapi-promptasync-context.test","nodes":[{"id":"httpapi_promptasync_context_test","label":"httpapi-promptasync-context.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-promptasync-context.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-promptasync-context.test.ts","source_location":"L1"}]},{"id":"httpapi_promptasync_context_test_localadapter","label":"localAdapter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-promptasync-context.test.ts","source_location":"L70-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-promptasync-context.test.ts","source_location":"L70"}],"snippet":"localAdapter = (directory: string): WorkspaceAdapter => ({\n  name: \"Local Test\",\n  description: \"Create a local test workspace\",\n  configure: (info) => ({ ...info, name: \"local-test\", directory }),\n  create: async () => {\n    await mkdir(directory, { recursive: true })\n  },\n  async remove() {},\n  target: () => ({ type: \"local\" as const, directory }),\n})"},{"id":"httpapi_promptasync_context_test_setupworkspace","label":"setupWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-promptasync-context.test.ts","source_location":"L81-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-promptasync-context.test.ts","source_location":"L81"}],"snippet":"setupWorkspace = (kind: string) =>\n  Effect.gen(function* () {\n    const dir = yield* tmpdirScoped({ git: true })\n    yield* Project.use.fromDirectory(dir)\n    const projectID = yield* Project.Service.use((svc) => svc.fromDirectory(dir).pipe(Effect.map((p) => p.project.id)))\n    registerAdapter(projectID, kind, localAdapter(dir))\n    const workspace = yield* Workspace.Service.use((svc) =>\n      svc.create({ type: kind, branch: null, extra: null, projectID }),\n    )\n    return { dir, workspace }\n  })"},{"id":"httpapi_promptasync_context_test_serveprobes","label":"serveProbes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-promptasync-context.test.ts","source_location":"L118-L139","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-promptasync-context.test.ts","source_location":"L118"}],"snippet":"serveProbes = (input: {\n  fork?: Effect.Effect<boolean, never, Scope.Scope>\n  streamWithout?: Effect.Effect<HttpServerResponse.HttpServerResponse>\n  streamWith?: Effect.Effect<HttpServerResponse.HttpServerResponse>\n}) =>\n  HttpApiBuilder.layer(ProbeApi).pipe(\n    Layer.provide(\n      HttpApiBuilder.group(ProbeApi, \"probe\", (handlers) =>\n        handlers\n          .handle(\"fork\", () => input.fork ?? Effect.succeed(false))\n          .handleRaw(\n            \"streamWithout\",\n            () => input.streamWithout ?? Effect.succeed(HttpServerResponse.empty({ status: 404 })),\n          )\n          .handleRaw(\"streamWith\", () => input.streamWith ?? Effect.succeed(HttpServerResponse.empty({ status: 404 }))),\n      ),\n    ),\n    Layer.provide(instanceContextTestLayer),\n    Layer.provide(Layer.mock(Session.Service)({})),\n    HttpRouter.serve,\n    Layer.build,\n  )"}],"edges":[{"source":"httpapi_promptasync_context_test","target":"platform_node","relation":"imports_from","confid