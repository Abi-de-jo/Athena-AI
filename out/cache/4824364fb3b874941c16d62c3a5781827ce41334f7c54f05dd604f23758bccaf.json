{"__madarTsExtractorVersion":67,"__madarFileStem":"finalize-latest-yml","nodes":[{"id":"finalize_latest_yml","label":"finalize-latest-yml.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L1"}]},{"id":"finalize_latest_yml_parse","label":"parse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L28-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L28"}],"snippet":"function parse(content: string): LatestYml {\n  const lines = content.split(\"\\n\")\n  let version = \"\"\n  let releaseDate = \"\"\n  const files: FileEntry[] = []\n  let current: Partial<FileEntry> | undefined\n\n  const flush = () => {\n    if (current?.url && current.sha512 && current.size) files.push(current as FileEntry)\n    current = undefined\n  }\n\n  for (const line of lines) {\n    const indented = line.startsWith(\"    \") || line.startsWith(\"  -\")\n    if (line.startsWith(\"version:\")) version = line.slice(\"version:\".length).trim()\n    else if (line.startsWith(\"releaseDate:\"))\n      releaseDate = line.slice(\"releaseDate:\".length).trim().replace(/^'|'$/g, \"\")\n    else if (line.trim().startsWith(\"- url:\")) {\n      flush()\n      current = { url: line.trim().slice(\"- url:\".length).trim() }\n    } else if (indented && current && line.trim().startsWith(\"sha512:\"))\n      current.sha512 = line.trim().slice(\"sha512:\".length).trim()\n    else if (indented && current && line.trim().startsWith(\"size:\"))\n      current.size = Number(line.trim().slice(\"size:\".length).trim())\n    else if (indented && current && line.trim().startsWith(\"blockMapSize:\"))"},{"id":"finalize_latest_yml_parse_flush","label":"flush()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L35-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L35"}],"snippet":"flush = () => {\n    if (current?.url && current.sha512 && current.size) files.push(current as FileEntry)\n    current = undefined\n  }"},{"id":"finalize_latest_yml_serialize","label":"serialize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L61-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L61"}],"snippet":"function serialize(data: LatestYml) {\n  const lines = [`version: ${data.version}`, \"files:\"]\n  for (const file of data.files) {\n    lines.push(`  - url: ${file.url}`)\n    lines.push(`    sha512: ${file.sha512}`)\n    lines.push(`    size: ${file.size}`)\n    if (file.blockMapSize) lines.push(`    blockMapSize: ${file.blockMapSize}`)\n  }\n  lines.push(`releaseDate: '${data.releaseDate}'`)\n  return lines.join(\"\\n\") + \"\\n\"\n}"},{"id":"finalize_latest_yml_read","label":"read()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L73-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L73"}],"snippet":"async function read(subdir: string, filename: string): Promise<LatestYml | undefined> {\n  const file = Bun.file(path.join(dir, subdir, filename))\n  if (!(await file.exists())) return undefined\n  return parse(await file.text())\n}"}],"edges":[{"source":"finalize_latest_yml","target":"bun","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L3"}],"weight":1},{"source":"finalize_latest_yml","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L4"}],"weight":1},{"source":"finalize_latest_yml","target":"finalize_latest_yml_parse","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":"L28"}],"weight":1},{"source":"finalize_latest_yml_parse","target":"finalize_latest_yml_parse_flush","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-yml.ts","source_location":