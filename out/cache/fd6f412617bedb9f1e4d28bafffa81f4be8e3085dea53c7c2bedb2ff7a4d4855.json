{"__madarTsExtractorVersion":67,"__madarFileStem":"dialog-move-session","nodes":[{"id":"dialog_move_session","label":"dialog-move-session.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L1"}]},{"id":"dialog_move_session_dialogmovesession","label":"DialogMoveSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L34-L347","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L34"}],"snippet":"export function DialogMoveSession(props: DialogMoveSessionProps) {\n  const dialog = useDialog()\n  const sdk = useSDK()\n  const dimensions = useTerminalDimensions()\n  const { theme } = useTheme()\n  const sync = useSync()\n  const projectContext = useProject()\n  const route = useRoute()\n  const toast = useToast()\n  const paths = useTuiPaths()\n  const [working, setWorking] = createSignal(Boolean(props.initialRemoving))\n  const [toDelete, setToDelete] = createSignal<string>()\n  const [removing, setRemoving] = createSignal(props.initialRemoving)\n  const [replacementCurrent, setReplacementCurrent] = createSignal<string>()\n  const [loadError, setLoadError] = createSignal<unknown>()\n  const deleteHint = useCommandShortcut(\"dialog.move_session.delete\")\n  onMount(() => dialog.setSize(\"xlarge\"))\n\n  function reopen(initialRemoving?: string) {\n    dialog.replace(() => (\n      <DialogMoveSession {...props} initialDirectories={directoryData()} initialRemoving={initialRemoving} />\n    ))\n  }\n\n  // A failed current-checkout lookup only affects which row is highlighted, so","node_kind":"component"},{"id":"dialog_move_session_dialogmovesession_reopen","label":"reopen()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L52-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L52"}],"snippet":"function reopen(initialRemoving?: string) {\n    dialog.replace(() => (\n      <DialogMoveSession {...props} initialDirectories={directoryData()} initialRemoving={initialRemoving} />\n    ))\n  }"},{"id":"dialog_move_session_dialogmovesession_removedcurrent","label":"removedCurrent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L193-L208","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L193"}],"snippet":"async function removedCurrent(current: boolean) {\n    if (!current) return false\n    const fallback = projectContext.data.project.mainDir\n    if (fallback) setReplacementCurrent(fallback)\n    if (route.data.type === \"session\") {\n      route.navigate({ type: \"home\" })\n      dialog.clear()\n      return true\n    }\n    if (fallback) {\n      props.onCurrentChange?.({ type: \"directory\", directory: fallback, subdirectory: false })\n      return true\n    }\n    dialog.clear()\n    return true\n  }"},{"id":"dialog_move_session_dialogmovesession_remove","label":"remove()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L210-L280","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L210"}],"snippet":"async function remove(option: DialogSelectOption<MoveSessionSelection | undefined>) {\n    if (!option.value || option.value.type !== \"directory\" || option.value.subdirectory || removing()) return\n    const data = directoryData()\n    const selected = option.value\n    const root = data?.find((item) => item.directory === selected.directory)\n    if (!root?.strategy) return\n    const deletingCurrent = selected.directory === currentRoot()?.directory\n    if (toDelete() !== selected.directory) {\n      setToDelete(selected.directory)\n      return\n    }\n    setToDelete(undefined)\n    setRemoving(selected.directory)\n    setWorking(true)\n    const result = await sdk.client.v2.projectCopy\n      .remove({\n        projectID: props.projectID,\n        location: { directory: sdk.directory },\n        directory: selected.directory,\n        force: false,\n      })\n      .catch((error) => ({ error }))\n    if (result.error) {\n      setRemoving(undefined)\n      setWorking(false)"},{"id":"dialog_move_session_contains","label":"contains()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L349-L353","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-move-session.tsx","source_location":"L349"}],"snippet":"function contains(root: string, directory: string) {\n  if (root === directory) return true\n  const relative = path.relative(root, directory)\n  return relative && relative !== \"..\" && !relative.startsWith(\"..\" + path.sep) && !path.isAbsolute(relative)\n}"}],"edges":[{"source