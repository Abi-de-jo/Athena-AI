{"__madarTsExtractorVersion":67,"__madarFileStem":"generate-sitemap","nodes":[{"id":"generate_sitemap","label":"generate-sitemap.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L1"}]},{"id":"generate_sitemap_sitemapentry","label":"SitemapEntry","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L13-L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L13"}],"snippet":"interface SitemapEntry {\n  url: string\n  priority: number\n  changefreq: string\n}"},{"id":"generate_sitemap_getmainroutes","label":"getMainRoutes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L19-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L19"}],"snippet":"async function getMainRoutes(): Promise<SitemapEntry[]> {\n  const routes: SitemapEntry[] = []\n\n  // Add main static routes\n  const staticRoutes = [\n    { path: \"/\", priority: 1.0, changefreq: \"daily\" },\n    { path: \"/enterprise\", priority: 0.8, changefreq: \"weekly\" },\n    { path: \"/brand\", priority: 0.6, changefreq: \"monthly\" },\n    { path: \"/zen\", priority: 0.8, changefreq: \"weekly\" },\n    { path: \"/go\", priority: 0.8, changefreq: \"weekly\" },\n  ]\n\n  for (const item of staticRoutes) {\n    for (const locale of LOCALES) {\n      routes.push({\n        url: `${BASE_URL}${route(locale, item.path)}`,\n        priority: item.priority,\n        changefreq: item.changefreq,\n      })\n    }\n  }\n\n  return routes\n}"},{"id":"generate_sitemap_getdocsroutes","label":"getDocsRoutes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L44-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L44"}],"snippet":"async function getDocsRoutes(): Promise<SitemapEntry[]> {\n  const routes: SitemapEntry[] = []\n\n  try {\n    const files = await readdir(DOCS_DIR)\n\n    for (const file of files) {\n      if (!file.endsWith(\".mdx\")) continue\n\n      const slug = file.replace(\".mdx\", \"\")\n      const path = slug === \"index\" ? \"/docs/\" : `/docs/${slug}`\n\n      for (const locale of LOCALES) {\n        routes.push({\n          url: `${BASE_URL}${route(locale, path)}`,\n          priority: slug === \"index\" ? 0.9 : 0.7,\n          changefreq: \"weekly\",\n        })\n      }\n    }\n  } catch (error) {\n    console.error(\"Error reading docs directory:\", error)\n  }\n\n  return routes"},{"id":"generate_sitemap_generatesitemapxml","label":"generateSitemapXML()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L71-L86","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L71"}],"snippet":"function generateSitemapXML(entries: SitemapEntry[]): string {\n  const urls = entries\n    .map(\n      (entry) => `  <url>\n    <loc>${entry.url}</loc>\n    <changefreq>${entry.changefreq}</changefreq>\n    <priority>${entry.priority}</priority>\n  </url>`,\n    )\n    .join(\"\\n\")\n\n  return `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n${urls}\n</urlset>`\n}"},{"id":"generate_sitemap_main","label":"main()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L88-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L88"}],"snippet":"async function main() {\n  console.log(\"Generating sitemap...\")\n\n  const mainRoutes = await getMainRoutes()\n  const docsRoutes = await getDocsRoutes()\n\n  const allRoutes = [...mainRoutes, ...docsRoutes]\n\n  console.log(`Found ${mainRoutes.length} main routes`)\n  console.log(`Found ${docsRoutes.length} docs routes`)\n  console.log(`Total: ${allRoutes.length} routes`)\n\n  const xml = generateSitemapXML(allRoutes)\n\n  const outputPath = join(PUBLIC_DIR, \"sitemap.xml\")\n  await writeFile(outputPath, xml, \"utf-8\")\n\n  console.log(`✓ Sitemap generated at ${outputPath}`)\n}"}],"edges":[{"source":"generate_sitemap","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/generate-sitemap.ts","source_location":"L2"}],"weight":1},{"source":"generate_sitemap","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/script/genera