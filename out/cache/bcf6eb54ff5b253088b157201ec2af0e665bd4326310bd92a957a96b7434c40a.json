{"__madarTsExtractorVersion":67,"__madarFileStem":"raw-changelog","nodes":[{"id":"raw_changelog","label":"raw-changelog.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L1"}]},{"id":"raw_changelog_ref","label":"ref()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L46-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L46"}],"snippet":"function ref(input: string) {\n  if (input === \"HEAD\") return input\n  if (input.startsWith(\"v\")) return input\n  if (input.match(/^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$/)) return `v${input}`\n  return input\n}"},{"id":"raw_changelog_latest","label":"latest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L53-L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L53"}],"snippet":"async function latest() {\n  const data = await $`gh api \"/repos/${repo}/releases?per_page=100\"`.json()\n  const release = (data as Release[]).find((item) => !item.draft)\n  if (!release) throw new Error(\"No releases found\")\n  return release.tag_name.replace(/^v/, \"\")\n}"},{"id":"raw_changelog_diff","label":"diff()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L60-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L60"}],"snippet":"async function diff(base: string, head: string) {\n  const list: Diff[] = []\n  for (let page = 1; ; page++) {\n    const text =\n      await $`gh api \"/repos/${repo}/compare/${base}...${head}?per_page=100&page=${page}\" --jq '.commits[] | {sha: .sha, login: .author.login, message: .commit.message}'`.text()\n    const batch = text\n      .split(\"\\n\")\n      .filter(Boolean)\n      .map((line) => JSON.parse(line) as Diff)\n    if (batch.length === 0) break\n    list.push(...batch)\n    if (batch.length < 100) break\n  }\n  return list\n}"},{"id":"raw_changelog_section","label":"section()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L76-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L76"}],"snippet":"function section(areas: Set<string>) {\n  const priority = [\"core\", \"tui\", \"app\", \"tauri\", \"sdk\", \"plugin\", \"extensions/vscode\", \"github\"]\n  for (const area of priority) {\n    if (areas.has(area)) return sections[area as keyof typeof sections]\n  }\n  return \"Core\"\n}"},{"id":"raw_changelog_type","label":"type()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L84-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L84"}],"snippet":"function type(message: string) {\n  if (message.match(/fix/i)) return \"Bugfixes\"\n  return \"Improvements\"\n}"},{"id":"raw_changelog_reverted","label":"reverted()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L89-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L89"}],"snippet":"function reverted(commits: Commit[]) {\n  const seen = new Map<string, Commit>()\n\n  for (const commit of commits) {\n    const match = commit.message.match(/^Revert \"(.+)\"$/)\n    if (match) {\n      const msg = match[1]!\n      if (seen.has(msg)) seen.delete(msg)\n      else seen.set(commit.message, commit)\n      continue\n    }\n\n    const revert = `Revert \"${commit.message}\"`\n    if (seen.has(revert)) {\n      seen.delete(revert)\n      continue\n    }\n\n    seen.set(commit.message, commit)\n  }\n\n  return [...seen.values()]\n}"},{"id":"raw_changelog_commits","label":"commits()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L113-L154","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L113"}],"snippet":"async function commits(from: string, to: string) {\n  const base = ref(from)\n  const head = ref(to)\n\n  const data = new Map<string, { login: string | null; message: string }>()\n  for (const item of await diff(base, head)) {\n    data.set(item.sha, { login: item.login, message: item.message.split(\"\\n\")[0] ?? \"\" })\n  }\n\n  const log =\n    await $`git log ${base}..${head} --format=%H -- packages/opencode packages/sdk packages/plugin packages/desktop packages/app sdks/vscode packages/extensions github`.text()\n\n  const list: Commit[] = []\n  for (const hash of log.split(\"\\n\").filter(Boolean)) {\n    const item = data.get(hash)\n    if (!item) continue\n    if (item.message.match(/^(ignore:|test:|chore:|ci:|release:)/i)) continue\n\n    const diff = await $`git diff-tree --no-commit-id --name-only -r ${hash}`.text()\n    const areas = new Set<string>()\n\n    for (const file of diff.split(\"\\n\").filter(Boolean)) {\n      if (file.startsWith(\"packages/opencode/src/cli/cmd/\")) areas.add(\"tui\")\n      else if (file.startsWith(\"packages/opencode/\")) areas.add(\"core\")\n      else if (file.startsWith(\"packages/desktop/src-tauri/\")) areas.add(\"tauri\")"},{"id":"raw_changelog_contributors","label":"contributors()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L156-L170","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L156"}],"snippet":"async function contributors(from: string, to: string) {\n  const base = ref(from)\n  const head = ref(to)\n\n  const users: User = new Map()\n  for (const item of await diff(base, head)) {\n    const title = item.message.split(\"\\n\")[0] ?? \"\"\n    if (!item.login || team.includes(item.login)) continue\n    if (title.match(/^(ignore:|test:|chore:|ci:|release:)/i)) continue\n    if (!users.has(item.login)) users.set(item.login, new Set())\n    users.get(item.login)!.add(title)\n  }\n\n  return users\n}"},{"id":"raw_changelog_published","label":"published()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L172-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L172"}],"snippet":"async function published(to: string) {\n  if (to === \"HEAD\") return\n  const body = await $`gh release view ${ref(to)} --repo ${repo} --json body --jq .body`.text().catch(() => \"\")\n  if (!body) return\n\n  const lines = body.split(/\\r?\\n/)\n  const start = lines.findIndex((line) => line.startsWith(\"**Thank you to \"))\n  if (start < 0) return\n  return lines.slice(start).join(\"\\n\").trim()\n}"},{"id":"raw_changelog_thanks","label":"thanks()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L183-L196","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L183"}],"snippet":"async function thanks(from: string, to: string, reuse: boolean) {\n  const release = reuse ? await published(to) : undefined\n  if (release) return release.split(/\\r?\\n/)\n\n  const users = await contributors(from, to)\n  if (users.size === 0) return []\n\n  const lines = [`**Thank you to ${users.size} community contributor${users.size > 1 ? \"s\" : \"\"}:**`]\n  for (const [name, commits] of users) {\n    lines.push(`- @${name}:`)\n    for (const commit of commits) lines.push(`  - ${commit}`)\n  }\n  return lines\n}"},{"id":"raw_changelog_format","label":"format()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L198-L250","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L198"}],"snippet":"function format(from: string, to: string, list: Commit[], thanks: string[]) {\n  const grouped = new Map<string, Map<string, string[]>>()\n  for (const title of order) {\n    grouped.set(\n      title,\n      new Map([\n        [\"Improvements\", []],\n        [\"Bugfixes\", []],\n      ]),\n    )\n  }\n\n  for (const commit of list) {\n    const attr = commit.author && !team.includes(commit.author) ? ` (@${commit.author})` : \"\"\n    grouped.get(section(commit.areas))!.get(type(commit.message))!.push(`- \\`${commit.hash}\\` ${commit.message}${attr}`)\n  }\n\n  const lines = [`Last release: ${ref(from)}`, `Target ref: ${to}`, \"\"]\n\n  if (list.length === 0) {\n    lines.push(\"No notable changes.\")\n  }\n\n  for (const title of order) {\n    const groups = grouped.get(title)"}],"edges":[{"source":"raw_changelog","target":"bun","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L3"}],"weight":1},{"source":"raw_changelog","target":"util","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L4"}],"weight":1},{"source":"raw_changelog","target":"raw_changelog_ref","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L46"}],"weight":1},{"source":"raw_changelog","target":"raw_changelog_latest","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/script/raw-changelog.ts","source_location":"L53"}],"weight":1},{"source":"raw_changelog","target":"raw_changelog_diff","relation":"contains","confidence":"EXTRACTED