rrors","label":"showErrors()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L71-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L71"}],"snippet":"function showErrors(input: {\n  errors: unknown[]\n  title: string\n  translate: (key: string, vars?: Record<string, string | number>) => string\n  formatMoreCount: (count: number) => string\n}) {\n  if (input.errors.length === 0) return\n  const message = formatServerError(input.errors[0], input.translate)\n  const more = input.errors.length > 1 ? input.formatMoreCount(input.errors.length - 1) : \"\"\n  showToast({\n    variant: \"error\",\n    title: input.title,\n    description: message + more,\n  })\n}"},{"id":"packages_app_src_context_global_sync_bootstrap_loadglobalconfigquery","label":"loadGlobalConfigQuery()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L87-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L87"}],"snippet":"loadGlobalConfigQuery = (scope: ServerScope, sdk: OpencodeClient) =>\n  queryOptions({\n    queryKey: [scope, \"config\"],\n    queryFn: () => retry(() => sdk.global.config.get().then((x) => x.data!)),\n  })"},{"id":"packages_app_src_context_global_sync_bootstrap_loadprojectsquery","label":"loadProjectsQuery()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L93-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L93"}],"snippet":"loadProjectsQuery = (scope: ServerScope, sdk: OpencodeClient) =>\n  queryOptions({\n    queryKey: [scope, \"project\"],\n    queryFn: () =>\n      retry(() =>\n        sdk.project.list().then((x) => {\n          return (x.data ?? [])\n            .filter((p) => !!p?.id)\n            .filter((p) => !!p.worktree && !p.worktree.includes(\"opencode-test\"))\n            .slice()\n            .sort((a, b) => cmp(a.id, b.id))\n        }),\n      ),\n  })"},{"id":"packages_app_src_context_global_sync_bootstrap_bootstrapglobal","label":"bootstrapGlobal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L108-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L108"}],"snippet":"export async function bootstrapGlobal(input: {\n  serverSDK: OpencodeClient\n  scope: ServerScope\n  requestFailedTitle: string\n  translate: (key: string, vars?: Record<string, string | number>) => string\n  formatMoreCount: (count: number) => string\n  setGlobalStore: SetStoreFunction<GlobalStore>\n  queryClient: QueryClient\n}) {\n  const slow = [\n    () => input.queryClient.fetchQuery(loadGlobalConfigQuery(input.scope, input.serverSDK)),\n    () => input.queryClient.fetchQuery(loadProvidersQuery(input.scope, null, input.serverSDK)),\n    () => input.queryClient.fetchQuery(loadPathQuery(input.scope, null, input.serverSDK)),\n    () =>\n      input.queryClient\n        .fetchQuery(loadProjectsQuery(input.scope, input.serverSDK))\n        .then((data) => input.setGlobalStore(\"project\", data)),\n  ]\n  await runAll(slow)\n  // showErrors({\n  //   errors: errors(),\n  //   title: input.requestFailedTitle,\n  //   translate: input.translate,\n  //   formatMoreCount: input.formatMoreCount,\n  // })"},{"id":"packages_app_src_context_global_sync_bootstrap_groupbysession","label":"groupBySession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L135-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L135"}],"snippet":"function groupBySession<T extends { id: string; sessionID: string }>(input: T[]) {\n  return input.reduce<Record<string, T[]>>((acc, item) => {\n    if (!item?.id || !item.sessionID) return acc\n    const list = acc[item.sessionID]\n    if (list) list.push(item)\n    if (!list) acc[item.sessionID] = [item]\n    return acc\n  }, {})\n}"},{"id":"packages_app_src_context_global_sync_bootstrap_projectid","label":"projectID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L145-L147","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L145"}],"snippet":"function projectID(directory: string, projects: Project[]) {\n  return projects.find((project) => project.worktree === directory || project.sandboxes?.includes(directory))?.id\n}"},{"id":"packages_app_src_context_global_sync_bootstrap_mergesession","label":"mergeSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L149-L161","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L149"}],"snippet":"function mergeSession(setStore: SetStoreFunction<State>, session: Session) {\n  setStore(\"session\", (list) => {\n    const next = list.slice()\n    const idx = next.findIndex((item) => item.id >= session.id)\n    if (idx === -1) return [...next, session]\n    if (next[idx]?.id === session.id) {\n      next[idx] = session\n      return next\n    }\n    next.splice(idx, 0, session)\n    return next\n  })\n}"},{"id":"packages_app_src_context_global_sync_bootstrap_warmsessions","label":"warmSessions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L163-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L163"}],"snippet":"function warmSessions(input: {\n  ids: string[]\n  store: Store<State>\n  setStore: SetStoreFunction<State>\n  sdk: OpencodeClient\n}) {\n  const known = new Set(input.store.session.map((item) => item.id))\n  const ids = [...new Set(input.ids)].filter((id) => !!id && !known.has(id))\n  if (ids.length === 0) return Promise.resolve()\n  return Promise.all(\n    ids.map((sessionID) =>\n      retry(() => input.sdk.session.get({ sessionID })).then((x) => {\n        const session = x.data\n        if (!session?.id) return\n        mergeSession(input.setStore, session)\n      }),\n    ),\n  ).then(() => undefined)\n}"},{"id":"packages_app_src_context_global_sync_bootstrap_loadprovidersquery","label":"loadProvidersQuery()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L183-L187","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L183"}],"snippet":"loadProvidersQuery = (scope: ServerScope, directory: string | null, sdk: OpencodeClient) =>\n  queryOptions({\n    queryKey: [scope, directory, \"providers\"],\n    queryFn: () => retry(() => sdk.provider.list().then((x) => normalizeProviderList(x.data!))),\n  })"},{"id":"packages_app_src_context_global_sync_bootstrap_loadagentsquery","label":"loadAgentsQuery()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L189-L193","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L189"}],"snippet":"loadAgentsQuery = (scope: ServerScope, directory: string | null, sdk: OpencodeClient) =>\n  queryOptions({\n    queryKey: [scope, directory, \"agents\"],\n    queryFn: () => retry(() => sdk.app.agents().then((x) => normalizeAgentList(x.data))),\n  })"},{"id":"packages_app_src_context_global_sync_bootstrap_loadpathquery","label":"loadPathQuery()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L195-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L195"}],"snippet":"loadPathQuery = (scope: ServerScope, directory: string | null, sdk: OpencodeClient) =>\n  queryOptions<Path>({\n    queryKey: [scope, directory, \"path\"],\n    queryFn: () => retry(() => sdk.path.get().then((x) => x.data!)),\n  })"},{"id":"packages_app_src_context_global_sync_bootstrap_bootstrapdirectory","label":"bootstrapDirectory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L201-L338","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L201"}],"snippet":"export async function bootstrapDirectory(input: {\n  directory: string\n  scope: ServerScope\n  mcp: boolean\n  sdk: OpencodeClient\n  store: Store<State>\n  setStore: SetStoreFunction<State>\n  vcsCache: VcsCache\n  loadSessions: (directory: string) => Promise<void> | void\n  translate: (key: string, vars?: Record<string, string | number>) => string\n  global: {\n    config: Config\n    path: Path\n    project: Project[]\n    provider: NormalizedProviderListResponse\n  }\n  queryClient: QueryClient\n}) {\n  const loading = input.store.status !== \"complete\"\n  const seededProject = projectID(input.directory, input.global.project)\n  const seededPath = input.global.path.directory === input.directory ? input.global.path : undefined\n  if (seededProject) input.setStore(\"project\", seededProject)\n  if (seededPath) input.setStore(\"path\", seededPath)\n  if (Object.keys(input.store.config).length === 0 && Object.keys(input.global.config).length > 0) {\n    input.setStore(\"config\", reconcile(input.global.config, { merge: false }))"}],"edges":[{"source":"packages_app_src_context_global_sync_bootstrap","target":"client","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/bootstrap.ts","source_location":"L1"}],"weight":1},{"source":"packages_app_src_context_global_sync_bootst