xtract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L126"}],"snippet":"function loadDict(locale: Locale) {\n  const hit = dicts.get(locale)\n  if (hit) return Promise.resolve(hit)\n  if (locale === \"en\") return Promise.resolve(base)\n  const load = loaders[locale]\n  return load().then((next: Dictionary) => {\n    dicts.set(locale, next)\n    return next\n  })\n}"},{"id":"packages_app_src_context_language_loadlocaledict","label":"loadLocaleDict()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L137-L139","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L137"}],"snippet":"export function loadLocaleDict(locale: Locale) {\n  return loadDict(locale).then(() => undefined)\n}"},{"id":"packages_app_src_context_language_detectlocale","label":"detectLocale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L165-L177","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L165"}],"snippet":"function detectLocale(): Locale {\n  if (typeof navigator !== \"object\") return \"en\"\n\n  const languages = navigator.languages?.length ? navigator.languages : [navigator.language]\n  for (const language of languages) {\n    if (!language) continue\n    const normalized = language.toLowerCase()\n    const match = localeMatchers.find((entry) => entry.match(normalized))\n    if (match) return match.locale\n  }\n\n  return \"en\"\n}"},{"id":"packages_app_src_context_language_normalizelocale","label":"normalizeLocale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L179-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L179"}],"snippet":"export function normalizeLocale(value: string): Locale {\n  return LOCALES.includes(value as Locale) ? (value as Locale) : \"en\"\n}"},{"id":"packages_app_src_context_language_readstoredlocale","label":"readStoredLocale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L183-L194","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L183"}],"snippet":"function readStoredLocale() {\n  if (typeof localStorage !== \"object\") return\n  try {\n    const raw = localStorage.getItem(\"opencode.global.dat:language\")\n    if (!raw) return\n    const next = JSON.parse(raw) as { locale?: string }\n    if (typeof next?.locale !== \"string\") return\n    return normalizeLocale(next.locale)\n  } catch {\n    return\n  }\n}"}],"edges":[{"source":"packages_app_src_context_language","target":"i18n","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.tsx","source_location":"L1"}],"weight":1},{"source":"packages_app_src_context_language","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/language.