{"__madarTsExtractorVersion":67,"__madarFileStem":"tool-status-title","nodes":[{"id":"tool_status_title","label":"tool-status-title.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L1"}]},{"id":"tool_status_title_common","label":"common()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L5-L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L5"}],"snippet":"function common(active: string, done: string) {\n  const a = Array.from(active)\n  const b = Array.from(done)\n  let i = 0\n  while (i < a.length && i < b.length && a[i] === b[i]) i++\n  return {\n    prefix: a.slice(0, i).join(\"\"),\n    active: a.slice(i).join(\"\"),\n    done: b.slice(i).join(\"\"),\n  }\n}"},{"id":"tool_status_title_contentwidth","label":"contentWidth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L17-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L17"}],"snippet":"function contentWidth(el: HTMLSpanElement | undefined) {\n  if (!el) return\n  return `${Math.ceil(el.getBoundingClientRect().width)}px`\n}"},{"id":"tool_status_title_toolstatustitle","label":"ToolStatusTitle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L22-L136","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L22"}],"snippet":"export function ToolStatusTitle(props: {\n  active: boolean\n  activeText: string\n  doneText: string\n  class?: string\n  split?: boolean\n}) {\n  const split = createMemo(() => common(props.activeText, props.doneText))\n  const suffix = createMemo(\n    () => (props.split ?? true) && split().prefix.length >= 2 && split().active.length > 0 && split().done.length > 0,\n  )\n  const prefixLen = createMemo(() => Array.from(split().prefix).length)\n  const activeTail = createMemo(() => (suffix() ? split().active : props.activeText))\n  const doneTail = createMemo(() => (suffix() ? split().done : props.doneText))\n\n  const [state, setState] = createStore({\n    active: props.active,\n    animating: false,\n    width: undefined as string | undefined,\n  })\n  const width = () => state.width\n  const active = () => state.active\n  const animating = () => state.animating\n  let activeRef: HTMLSpanElement | undefined\n  let doneRef: HTMLSpanElement | undefined","node_kind":"component"},{"id":"tool_status_title_toolstatustitle_width","label":"width()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L42"}],"snippet":"width = () => state.width"},{"id":"tool_status_title_toolstatustitle_active","label":"active()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L43"}],"snippet":"active = () => state.active"},{"id":"tool_status_title_toolstatustitle_animating","label":"animating()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L44","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L44"}],"snippet":"animating = () => state.animating"},{"id":"tool_status_title_toolstatustitle_finish","label":"finish()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L51-L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L51"}],"snippet":"finish = () => {\n    if (frame !== undefined) cancelAnimationFrame(frame)\n    if (finishTimer !== undefined) clearTimeout(finishTimer)\n    frame = undefined\n    finishTimer = undefined\n    setState(\"animating\", false)\n    setState(\"width\", undefined)\n  }"},{"id":"tool_status_title_toolstatustitle_animate","label":"animate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L60-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L60"}],"snippet":"animate = () => {\n    const first = contentWidth(widthRef)\n    finish()\n    setState(\"animating\", true)\n    setState(\"active\", props.active)\n    const last = contentWidth(props.active ? activeRef : doneRef)\n    if (!first || !last) {\n      finish()\n      return\n    }\n\n    setState(\"width\", first)\n    if (first === last) {\n      finishTimer = setTimeout(finish, 600)\n      return\n    }\n\n    frame = requestAnimationFrame(() => {\n      frame = undefined\n      setState(\"width\", last)\n      finishTimer = setTimeout(finish, 600)\n    })\n  }"}],"edges":[{"source":"tool_status_title","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L1"}],"weight":1},{"source":"tool_status_title","target":"store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L2"}],"weight":1},{"source":"tool_status_title","target":"text_shimmer","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/tool-status-title.tsx","source_location":"L3"}],"weight":1},{"source":"tool_st