{"__madarTsExtractorVersion":67,"__madarFileStem":"run-service","nodes":[{"id":"run_service","label":"run-service.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/effect/run-service.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/effect/run-service.ts","source_location":"L1"}]},{"id":"run_service_attachwith","label":"attachWith()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/effect/run-service.ts","source_location":"L14-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/effect/run-service.ts","source_location":"L14"}],"snippet":"export function attachWith<A, E, R>(effect: Effect.Effect<A, E, R>, refs: Refs): Effect.Effect<A, E, R> {\n  if (!refs.instance && !refs.workspace) return effect\n  if (!refs.instance) return effect.pipe(Effect.provideService(WorkspaceRef, refs.workspace))\n  if (!refs.workspace) return effect.pipe(Effect.provideService(InstanceRef, refs.instance))\n  return effect.pipe(\n    Effect.provideService(InstanceRef, refs.instance),\n    Effect.provideService(WorkspaceRef, refs.workspace),\n  )\n}"},{"id":"run_service_attach","label":"attach()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/effect/run-service.ts","source_location":"L24-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/effect/run-service.ts","source_location":"L24"}],"snippet":"export function attach<A, E, R>(effect: Effect.Effect<A, E, R>): Effect.Effect<A, E, R> {\n  const workspace = WorkspaceContext.workspaceID\n  const fiber = Fiber.getCurrent()\n  return attachWith(effect, {\n    instance: fiber ? Context.getReferenceUnsafe(fiber.context, InstanceRef) : undefined,\n    workspace: workspace ?? (fiber ? Context.getReferenceUnsafe(fiber.context, WorkspaceRef) : undefined),\n  })\n}"},{"id":"run_service_makeruntime","label":"makeRuntime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/effect/run-service.ts","source_location":"L33-L47","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/effect/run-service.ts","source_location":"L33"}],"snippet":"export function makeRuntime<I, S, E>(service: Context.Service<I, S>, layer: Layer.Layer<I, E>) {\n  let rt: ManagedRuntime.ManagedRuntime<I, E> | undefined\n  const getRuntime = () => (rt ??= ManagedRuntime.make(Layer.provideMerge(layer, Observability.layer), { memoMap }))\n\n  return {\n    runSync: <A, Err>(fn: (svc: S) => Effect.Effect<A, Err, I>) => getRuntime().runSync(attach(service.use(fn))),\n    runPromiseExit: <A, Err>(fn: (svc: S) => Effect.Effect<A, Err, I>, options?: Effect.RunOptions) =>\n      getRuntime().runPromiseExit(attach(service.use(fn)), options),\n    runPromise: <A, Err>(fn: (svc: S) => Effect.Effect<A, Err, I>, options?: Effect.RunOptions) =>\n      getRuntime().runPromise(attach(service.use(fn)), options),\n    runFork: <A, Err>(fn: (svc: S) => Effect.Effect<A, Err, I>) => getRuntime().runFork(attach(service.use(fn))),\n    runCallback: <A, Err>(fn: (svc: S) => Effect.Effect<A, Err, I>) =>\n      getRuntime().runCallback(attach(service.use(fn))),\n  }\n}"},{"id":"run_service_makeruntime_getruntime","label":"getRuntime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/effect/run-service.ts","source_location":"L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"e