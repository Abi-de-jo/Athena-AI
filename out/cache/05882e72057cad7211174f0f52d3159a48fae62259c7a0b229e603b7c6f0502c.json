{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_test_cli_acp_helpers","nodes":[{"id":"packages_rimuru_test_cli_acp_helpers","label":"helpers.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L1"}]},{"id":"packages_rimuru_test_cli_acp_helpers_createacpclient","label":"createAcpClient()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L14-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L14"}],"snippet":"export function createAcpClient(input: Pick<CliFixture, \"rimuru-ai\">, env?: Record<string, string>) {\n  return Effect.gen(function* () {\n    return createJsonRpcAcpClient(yield* input.opencode.acp(env ? { env } : undefined))\n  })\n}"},{"id":"packages_rimuru_test_cli_acp_helpers_initialize","label":"initialize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L20-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L20"}],"snippet":"export function initialize(acp: AcpClient) {\n  return Effect.gen(function* () {\n    return expectOk(\n      yield* acp.request<InitializeResponse>(\"initialize\", {\n        protocolVersion: 1,\n        clientCapabilities: { _meta: { \"terminal-auth\": true } },\n        clientInfo: { name: \"opencode-local-acp\", version: \"0.1.0\" },\n      }),\n    )\n  })\n}"},{"id":"packages_rimuru_test_cli_acp_helpers_newsession","label":"newSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L32-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L32"}],"snippet":"export function newSession(acp: AcpClient, cwd: string) {\n  return Effect.gen(function* () {\n    return expectOk(yield* acp.request<NewSessionResponse>(\"session/new\", { cwd, mcpServers: [] }))\n  })\n}"},{"id":"packages_rimuru_test_cli_acp_helpers_verifierconfig","label":"verifierConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L38-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L38"}],"snippet":"export function verifierConfig(llmUrl: string, skills?: string) {\n  const config = testProviderConfig(llmUrl)\n  return {\n    ...config,\n    model: \"test/test-model\",\n    ...(skills ? { skills: { paths: [skills] } } : {}),\n    provider: {\n      test: {\n        ...config.provider.test,\n        models: {\n          \"test-model\": {\n            ...config.provider.test.models[\"test-model\"],\n            variants: {\n              low: {},\n              high: {},\n            },\n          },\n          \"second-model\": {\n            ...config.provider.test.models[\"test-model\"],\n            id: \"second-model\",\n            name: \"Second Test Model\",\n            variants: {\n              medium: {},\n              max: {},\n            },"},{"id":"packages_rimuru_test_cli_acp_helpers_expecterrorcode","label":"expectErrorCode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L70-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L70"}],"snippet":"export function expectErrorCode(error: unknown, code: number) {\n  if (!error || typeof error !== \"object\" || !(\"code\" in error)) {\n    expect(error).toEqual({ code })\n    return\n  }\n  expect(error.code).toBe(code)\n}"},{"id":"packages_rimuru_test_cli_acp_helpers_expectselectoption","label":"expectSelectOption()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L78-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L78"}],"snippet":"export function expectSelectOption(options: SessionConfigOption[] | null | undefined, id: string) {\n  const option = selectConfigOption(options, id)\n  expect(option).toBeDefined()\n  return option!\n}"},{"id":"packages_rimuru_test_cli_acp_helpers_expectalternatevalue","label":"expectAlternateValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L84-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L84"}],"snippet":"export function expectAlternateValue(option: ReturnType<typeof expectSelectOption>) {\n  const value = flattenSelectOptions(option).find((item) => item.value !== option.currentValue)?.value\n  expect(value).toBeDefined()\n  return value!\n}"}],"edges":[{"source":"packages_rimuru_test_cli_acp_helpers","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_test_cli_acp_helpers","target":"sdk","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L2"}],"weight":1},{"source":"packages_rimuru_test_cli_acp_helpers","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L3"}],"weight":1},{"source":"packages_rimuru_test_cli_acp_helpers","target":"cli_process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/helpers.ts","source_location":"L4"}],"weight":1},{"source":"packages_rimuru_test_cli_acp_helpers","target":"test_provider","relati