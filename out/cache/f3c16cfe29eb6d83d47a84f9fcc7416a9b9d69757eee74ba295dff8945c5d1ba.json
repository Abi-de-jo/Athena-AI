 },\n  }\n}"},{"id":"session_timeline_context_resize_spec_base64encode","label":"base64Encode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L266-L268","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L266"}],"snippet":"function base64Encode(value: string) {\n  return Buffer.from(value, \"utf8\").toString(\"base64\").replace(/\\+/g, \"-\").replace(/\\//g, \"_\").replace(/=/g, \"\")\n}"}],"edges":[{"source":"session_timeline_context_resize_spec","target":"test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L1"}],"weight":1},{"source":"session_timeline_context_resize_spec","target":"mock_server","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L2"}],"weight":1},{"source":"session_timeline_context_resize_spec","target":"waits","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.s