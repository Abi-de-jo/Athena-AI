{"__madarTsExtractorVersion":67,"__madarFileStem":"session-timeline-context-resize.spec","nodes":[{"id":"session_timeline_context_resize_spec","label":"session-timeline-context-resize.spec.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L1"}]},{"id":"session_timeline_context_resize_spec_configurepage","label":"configurePage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L43-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L43"}],"snippet":"async function configurePage(page: Page) {\n  await page.addInitScript(() => {\n    localStorage.setItem(\n      \"settings.v3\",\n      JSON.stringify({\n        general: {\n          editToolPartsExpanded: true,\n          shellToolPartsExpanded: true,\n          showReasoningSummaries: true,\n          showSessionProgressBar: true,\n        },\n      }),\n    )\n  })\n}"},{"id":"session_timeline_context_resize_spec_sampleexpansion","label":"sampleExpansion()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L59-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L59"}],"snippet":"async function sampleExpansion(page: Page) {\n  return page.evaluate(\n    ({ contextIDs, followingTextID }) =>\n      new Promise<\n        {\n          frame: number\n          label: string\n          scrollTop: number\n          scrollHeight: number\n          contextBottom: number\n          textTop: number\n          overlap: number\n          gap: number\n          expanded: string | null\n        }[]\n      >((resolve) => {\n        const context = document.querySelector<HTMLElement>(`[data-timeline-part-ids=\"${contextIDs.join(\",\")}\"]`)\n        const text = document.querySelector<HTMLElement>(`[data-timeline-part-id=\"${followingTextID}\"]`)\n        const scroller = context?.closest<HTMLElement>(\".scroll-view__viewport\")\n        const trigger = context?.querySelector<HTMLElement>('[data-slot=\"collapsible-trigger\"]')\n        const contextRow = context?.closest<HTMLElement>('[data-timeline-row=\"AssistantPart\"]')\n        const textRow = text?.closest<HTMLElement>('[data-timeline-row=\"AssistantPart\"]')\n        if (!context || !text || !scroller || !trigger || !contextRow || !textRow)\n          throw new Error(\"missing regression nodes\")"},{"id":"session_timeline_context_resize_spec_sampleexpansion_capture","label":"capture()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L96-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L96"}],"snippet":"capture = (frame: number, label: string) => {\n          const contextRect = contextRow.getBoundingClientRect()\n          const textRect = textRow.getBoundingClientRect()\n          samples.push({\n            frame,\n            label,\n            scrollTop: Math.round(scroller.scrollTop * 10) / 10,\n            scrollHeight: Math.round(scroller.scrollHeight * 10) / 10,\n            contextBottom: Math.round(contextRect.bottom * 10) / 10,\n            textTop: Math.round(textRect.top * 10) / 10,\n            overlap: Math.max(0, Math.round((contextRect.bottom - textRect.top) * 10) / 10),\n            gap: Math.max(0, Math.round((textRect.top - contextRect.bottom) * 10) / 10),\n            expanded: trigger.getAttribute(\"aria-expanded\"),\n          })\n        }"},{"id":"session_timeline_context_resize_spec_sampleexpansion_tick","label":"tick()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L117-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L117"}],"snippet":"tick = () => {\n          capture(frame, \"raf\")\n          frame += 1\n          if (frame > 8) {\n            resolve(samples)\n            return\n          }\n          requestAnimationFrame(tick)\n        }"},{"id":"session_timeline_context_resize_spec_turn","label":"turn()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L132-L190","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L132"}],"snippet":"function turn(index: number, target: boolean): Message[] {\n  const userID = id(\"msg_user\", index)\n  const assistantID = id(\"msg_assistant\", index)\n  return [\n    {\n      info: {\n        id: userID,\n        sessionID,\n        role: \"user\",\n        time: { created: 1700000000000 + index * 10_000 },\n        summary: { diffs: [] },\n        agent: \"build\",\n        model,\n      },\n      parts: [{ id: id(\"prt_user\", index), sessionID, messageID: userID, type: \"text\", text: `User message ${index}` }],\n    },\n    {\n      info: {\n        id: assistantID,\n        sessionID,\n        role: \"assistant\",\n        time: { created: 1700000000000 + index * 10_000 + 1_000, completed: 1700000000000 + index * 10_000 + 2_000 },\n        parentID: userID,\n        modelID: model.modelID,\n        providerID: model.providerID,"},{"id":"session_timeline_context_resize_spec_contexttool","label":"contextTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L192-L209","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L192"}],"snippet":"function contextTool(partID: string, messageID: string, tool: string, input: Record<string, unknown>) {\n  return {\n    id: partID,\n    sessionID,\n    messageID,\n    type: \"tool\",\n    callID: `call_${partID}`,\n    tool,\n    state: {\n      status: \"completed\",\n      input,\n      output: `Completed ${tool}.\\n${\"detail line\\n\".repeat(8)}`,\n      title: input.filePath || input.path || input.pattern || \"completed\",\n      metadata: {},\n      time: { start: 1700000000000, end: 1700000000100 },\n    },\n  }\n}"},{"id":"session_timeline_context_resize_spec_mockserver","label":"mockServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L211-L219","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L211"}],"snippet":"async function mockServer(page: Page) {\n  await mockOpenCodeServer(page, {\n    directory,\n    project: project(),\n    provider: provider(),\n    sessions: [session()],\n    pageMessages: () => ({ items: messages }),\n  })\n}"},{"id":"session_timeline_context_resize_spec_settle","label":"settle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L221-L223","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L221"}],"snippet":"async function settle(page: Page) {\n  await page.evaluate(() => new Promise((resolve) => requestAnimationFrame(() => requestAnimationFrame(resolve))))\n}"},{"id":"session_timeline_context_resize_spec_id","label":"id()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L225-L227","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L225"}],"snippet":"function id(prefix: string, index: number) {\n  return `${prefix}_${String(index).padStart(4, \"0\")}`\n}"},{"id":"session_timeline_context_resize_spec_project","label":"project()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/e2e/regression/session-timeline-context-resize.spec.ts","source_location":"L229-L238","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_fi