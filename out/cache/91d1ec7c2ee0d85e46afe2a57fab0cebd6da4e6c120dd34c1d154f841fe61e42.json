e/script/lookup-user.ts","source_location":"L291-L294","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/lookup-user.ts","source_location":"L291"}],"snippet":"function formatMicroCents(value: number | null | undefined) {\n  if (value === null || value === undefined) return null\n  return `$${(value / 100000000).toFixed(2)}`\n}"},{"id":"lookup_user_formatdate","label":"formatDate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/lookup-user.ts","source_location":"L296-L299","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/lookup-user.ts","source_location":"L296"}],"snippet":"function formatDate(value: Date | null | undefined) {\n  if (!value) return null\n  return value.toISOString().split(\"T\")[0]\n}"},{"id":"lookup_user_formatmonthlyusage","label":"formatMonthlyUsage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/lookup-user.ts","source_location":"L301-L305","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/lookup-user.ts","source_location":"L301"}],"snippet":"function formatMonthlyUsage(usage: number | null | undefined, limit: number | null | undefined) {\n  const usageText = formatMicroCents(usage) ?? \"$0.00\"\n  if (limit === null || limit === undefined) return `${usageText} / no limit`\n  return `${usageText} / $${limit.toFixed(2)}`\n}"},{"id":"lookup_user_formatretrytime","label":"formatRetryTime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/lookup-user.ts","source_location":"L307-L314","layer"