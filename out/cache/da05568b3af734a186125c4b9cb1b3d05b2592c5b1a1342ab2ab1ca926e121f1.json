{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_core_src_plugin_provider_cloudflare-ai-gateway","nodes":[{"id":"packages_core_src_plugin_provider_cloudflare_ai_gateway","label":"cloudflare-ai-gateway.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L1"}]},{"id":"packages_core_src_plugin_provider_cloudflare_ai_gateway_gatewayconfig","label":"gatewayConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L46-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L46"}],"snippet":"function gatewayConfig(options: Record<string, unknown>): GatewayConfig | undefined {\n  const accountId = process.env.CLOUDFLARE_ACCOUNT_ID ?? stringOption(options, \"accountId\")\n  // Credential projection copies key metadata into options. The prompt stores the\n  // gateway as gatewayId, while older config examples may use gateway.\n  const gatewayId =\n    process.env.CLOUDFLARE_GATEWAY_ID ?? stringOption(options, \"gatewayId\") ?? stringOption(options, \"gateway\")\n  const apiKey = process.env.CLOUDFLARE_API_TOKEN ?? process.env.CF_AIG_TOKEN ?? stringOption(options, \"apiKey\")\n  if (!accountId || !gatewayId || !apiKey) return undefined\n\n  return { accountId, gatewayId, apiKey }\n}"},{"id":"packages_core_src_plugin_provider_cloudflare_ai_gateway_gatewaymetadata","label":"gatewayMetadata()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L58-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L58"}],"snippet":"function gatewayMetadata(options: Record<string, unknown>) {\n  // Preserve the legacy cf-aig-metadata header escape hatch for gateway logging\n  // metadata, but prefer the typed metadata option when present.\n  if (options.metadata !== undefined) return options.metadata\n  const raw = (options.headers as Record<string, string> | undefined)?.[\"cf-aig-metadata\"]\n  return raw ? Option.getOrUndefined(decodeJson(raw)) : undefined\n}"},{"id":"packages_core_src_plugin_provider_cloudflare_ai_gateway_gatewayoptions","label":"gatewayOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L66-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L66"}],"snippet":"function gatewayOptions(options: Record<string, unknown>, metadata: unknown) {\n  return {\n    metadata,\n    cacheTtl: options.cacheTtl,\n    cacheKey: options.cacheKey,\n    skipCache: options.skipCache,\n    collectLog: options.collectLog,\n    headers: {\n      \"User-Agent\": `opencode/${InstallationVersion} cloudflare-ai-gateway (${os.platform()} ${os.release()}; ${os.arch()})`,\n    },\n  }\n}"},{"id":"packages_core_src_plugin_provider_cloudflare_ai_gateway_stringoption","label":"stringOption()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L79-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L79"}],"snippet":"function stringOption(options: Record<string, unknown>, key: string) {\n  return typeof options[key] === \"string\" ? options[key] : undefined\n}"}],"edges":[{"source":"packages_core_src_plugin_provider_cloudflare_ai_gateway","target":"os","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_src_plugin_provider_cloudflare_ai_gateway","target":"version","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L2"}],"weight":1},{"source":"packages_core_src_plugin_provider_cloudflare_ai_gateway","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/cloudflare-ai-gateway.ts","source_location":"L3"}],"weight":1},{"source":"packages_core_src_plug