id === props.provider : true)),\n  )\n\n  return (\n    <List\n      class={`flex-1 px-3 min-h-0 [&_[data-slot=list-scroll]]:flex-1 [&_[data-slot=list-scroll]]:min-h-0 ${props.class ?? \"\"}`}\n      search={{ placeholder: language.t(\"dialog.model.search.placeholder\"), autofocus: true, action: props.action }}\n      emptyMessage={language.t(\"dialog.model.empty\")}\n      key={(x) => `${x.provider.id}:${x.id}`}\n      items={models}\n      current={model.current()}","node_kind":"component"},{"id":"dialog_select_model_modelselectorpopover","label":"ModelSelectorPopover()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-model.tsx","source_location":"L91-L197","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-model.tsx","source_location":"L91"}],"snippet":"export function ModelSelectorPopover(props: {\n  provider?: string\n  model?: ModelState\n  children?: JSX.Element\n  triggerAs?: ValidComponent\n  triggerProps?: ModelSelectorTriggerProps\n  onClose?: (cause: \"escape\" | \"select\") => void\n}) {\n  const [store, setStore] = createStore<{\n    open: boolean\n    dismiss: Dismiss | null\n  }>({\n    open: false,\n    dismiss: null,\n  })\n  const dialog = useDialog()\n\n  const close = (dismiss: Dismiss) => {\n    setStore(\"dismiss\", dismiss)\n    setStore(\"open\", false)\n  }\n\n  const handleManage = () => {\n    close(\"manage\")\n    void import(\"./dialog-manage-models\").then((x) => {","node_kind":"component"},{"id":"dialog_select_model_modelselectorpopover_close","label":"close()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-model.tsx","source_location":"L108-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"