{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_pages_layout_helpers","nodes":[{"id":"packages_app_src_pages_layout_helpers","label":"helpers.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L1"}]},{"id":"packages_app_src_pages_layout_helpers_sortsessions","label":"sortSessions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L11-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L11"}],"snippet":"function sortSessions(now: number) {\n  const oneMinuteAgo = now - 60 * 1000\n  return (a: Session, b: Session) => {\n    const aUpdated = a.time.updated ?? a.time.created\n    const bUpdated = b.time.updated ?? b.time.created\n    const aRecent = aUpdated > oneMinuteAgo\n    const bRecent = bUpdated > oneMinuteAgo\n    if (aRecent && bRecent) return a.id < b.id ? -1 : a.id > b.id ? 1 : 0\n    if (aRecent && !bRecent) return -1\n    if (!aRecent && bRecent) return 1\n    return bUpdated - aUpdated\n  }\n}"},{"id":"packages_app_src_pages_layout_helpers_isrootvisiblesession","label":"isRootVisibleSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L25-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L25"}],"snippet":"isRootVisibleSession = (session: Session, directory: string) =>\n  pathKey(session.directory) === pathKey(directory) && !session.parentID && !session.time?.archived"},{"id":"packages_app_src_pages_layout_helpers_roots","label":"roots()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L28-L29","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L28"}],"snippet":"roots = (store: SessionStore) =>\n  (store.session ?? []).filter((session) => isRootVisibleSession(session, store.path.directory))"},{"id":"packages_app_src_pages_layout_helpers_sortedrootsessions","label":"sortedRootSessions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L31"}],"snippet":"sortedRootSessions = (store: SessionStore, now: number) => roots(store).sort(sortSessions(now))"},{"id":"packages_app_src_pages_layout_helpers_latestrootsession","label":"latestRootSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L33-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L33"}],"snippet":"latestRootSession = (stores: SessionStore[], now: number) =>\n  stores.flatMap(roots).sort(sortSessions(now))[0]"},{"id":"packages_app_src_pages_layout_helpers_hasprojectpermissions","label":"hasProjectPermissions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L36-L41","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L36"}],"snippet":"export function hasProjectPermissions<T>(\n  request: Record<string, T[] | undefined> | undefined,\n  include: (item: T) => boolean = () => true,\n) {\n  return Object.values(request ?? {}).some((list) => list?.some(include))\n}"},{"id":"packages_app_src_pages_layout_helpers_childsessiononpath","label":"childSessionOnPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L43-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L43"}],"snippet":"childSessionOnPath = (sessions: Session[] | undefined, rootID: string, activeID?: string) => {\n  if (!activeID || activeID === rootID) return\n  const map = new Map((sessions ?? []).map((session) => [session.id, session]))\n  let id = activeID\n\n  while (id) {\n    const session = map.get(id)\n    if (!session?.parentID) return\n    if (session.parentID === rootID) return session\n    id = session.parentID\n  }\n}"},{"id":"packages_app_src_pages_layout_helpers_displayname","label":"displayName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L56-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L56"}],"snippet":"displayName = (project: { name?: string; worktree: string }) =>\n  project.name || getFilename(project.worktree) || project.worktree"},{"id":"packages_app_src_pages_layout_helpers_togglehomeprojectselection","label":"toggleHomeProjectSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L61-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L61"}],"snippet":"export function toggleHomeProjectSelection(\n  current: HomeProjectSelection | undefined,\n  server: ServerConnection.Key,\n  directory: string,\n): HomeProjectSelection {\n  if (current?.server === server && current.directory === directory) return { server }\n  return { server, directory }\n}"},{"id":"packages_app_src_pages_layout_helpers_closehomeproject","label":"closeHomeProject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L70-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L70"}],"snippet":"export function closeHomeProject(\n  selected: HomeProjectSelection | undefined,\n  server: ServerConnection.Key,\n  projects: { close: (directory: string) => void },\n  directory: string,\n) {\n  projects.close(directory)\n  if (selected?.server === server && selected.directory === directory) return { server }\n  return selected\n}"},{"id":"packages_app_src_pages_layout_helpers_homeprojectnavigation","label":"homeProjectNavigation()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L81-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L81"}],"snippet":"export function homeProjectNavigation(active: ServerConnection.Key, server: ServerConnection.Key, href: string) {\n  if (active === server) return { href }\n  return { server, href }\n}"},{"id":"packages_app_src_pages_layout_helpers_homeprojectdirectories","label":"homeProjectDirectories()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L86-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L86"}],"snippet":"export function homeProjectDirectories(result: string | string[] | null) {\n  if (!result) return []\n  return Array.isArray(result) ? result : [result]\n}"},{"id":"packages_app_src_pages_layout_helpers_homesessionserverstatus","label":"homeSessionServerStatus()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L91-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L91"}],"snippet":"export function homeSessionServerStatus(active: boolean, status: () => { working: boolean; tint?: string }) {\n  if (!active) return { working: false, tint: undefined }\n  return status()\n}"},{"id":"packages_app_src_pages_layout_helpers_getprojectavatarsource","label":"getProjectAvatarSource()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L98-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L98"}],"snippet":"export function getProjectAvatarSource(id?: string, icon?: { color?: string; url?: string; override?: string }) {\n  if (id === OPENCODE_PROJECT_ID) return \"https://opencode.ai/favicon.svg\"\n  if (icon?.override) return icon.override\n  if (icon?.color) return undefined\n  return icon?.url\n}"},{"id":"packages_app_src_pages_layout_helpers_projectforsession","label":"projectForSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L105-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L105"}],"snippet":"export function projectForSession<T extends { id?: string; worktree: string; sandboxes?: string[] }>(\n  session: Session,\n  projects: T[],\n  byID: Map<string, T> = new Map(projects.flatMap((project) => (project.id ? [[project.id, project] as const] : []))),\n) {\n  const direct = byID.get(session.projectID)\n  if (direct) return direct\n  const directory = pathKey(session.directory)\n  return projects.find(\n    (project) =>\n      pathKey(project.worktree) === directory || project.sandboxes?.some((sandbox) => pathKey(sandbox) === directory),\n  )\n}"},{"id":"packages_app_src_pages_layout_helpers_errormessage","label":"errorMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L119-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L119"}],"snippet":"errorMessage = (err: unknown, fallback: string) => {\n  if (err && typeof err === \"object\" && \"data\" in err) {\n    const data = (err as { data?: { message?: string } }).data\n    if (data?.message) return data.message\n  }\n  if (err instanceof Error) return err.message\n  return fallback\n}"},{"id":"packages_app_src_pages_layout_helpers_effectiveworkspaceorder","label":"effectiveWorkspaceOrder()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L128-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L128"}],"snippet":"effectiveWorkspaceOrder = (local: string, dirs: string[], persisted?: string[]) => {\n  const root = pathKey(local)\n  const live = new Map<string, string>()\n\n  for (const dir of dirs) {\n    const key = pathKey(dir)\n    if (key === root) continue\n    if (!live.has(key)) live.set(key, dir)\n  }\n\n  if (!persisted?.length) return [local, ...live.values()]\n\n  const result = [local]\n  for (const dir of persisted) {\n    const key = pathKey(dir)\n    if (key === root) continue\n    const match = live.get(key)\n    if (!match) continue\n    result.push(match)\n    live.delete(key)\n  }\n\n  return [...result, ...live.values()]\n}"}],"edges":[{"source":"packages_app_src_pages_layout_helpers","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/helpers.ts","source_location":"L1"}],"weight":1},{"source":"packages_app_src_pages_layout_helpers","target":"client","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/pe