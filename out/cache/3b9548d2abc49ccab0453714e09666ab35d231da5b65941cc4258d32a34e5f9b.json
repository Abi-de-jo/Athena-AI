{"__madarTsExtractorVersion":67,"__madarFileStem":"scrollback.surface","nodes":[{"id":"scrollback_surface","label":"scrollback.surface.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L1"}]},{"id":"scrollback_surface_commitmarkdownblocks","label":"commitMarkdownBlocks()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L37-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L37"}],"snippet":"function commitMarkdownBlocks(input: {\n  surface: ScrollbackSurface\n  renderable: MarkdownRenderable\n  startBlock: number\n  endBlockExclusive: number\n  trailingNewline: boolean\n  beforeCommit?: () => void\n}) {\n  if (input.endBlockExclusive <= input.startBlock) {\n    return false\n  }\n\n  const first = input.renderable._blockStates[input.startBlock]\n  const last = input.renderable._blockStates[input.endBlockExclusive - 1]\n  if (!first || !last) {\n    return false\n  }\n\n  const next = input.renderable._blockStates[input.endBlockExclusive]\n  const start = first.renderable.y\n  const end = next ? next.renderable.y : last.renderable.y + last.renderable.height\n\n  input.beforeCommit?.()\n  input.surface.commitRows(start, end, {\n    trailingNewline: input.trailingNewline,"},{"id":"scrollback_surface_staticbody","label":"staticBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L66-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L66"}],"snippet":"function staticBody(commit: StreamCommit, body: RunEntryBody, spaced: number): RunEntryBody {\n  if (spaced === 0 || body.type !== \"text\") {\n    return body\n  }\n\n  if (commit.kind !== \"tool\" || commit.phase !== \"progress\" || commit.toolState !== \"completed\") {\n    return body\n  }\n\n  if (!body.content.startsWith(\"\\n\")) {\n    return body\n  }\n\n  return {\n    ...body,\n    content: body.content.replace(/^\\n/, \"\"),\n  }\n}"},{"id":"scrollback_surface_runscrollbackstream","label":"RunScrollbackStream","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L85-L431","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L85"}],"snippet":"export class RunScrollbackStream {\n  private tail: StreamCommit | undefined\n  private rendered: StreamCommit | undefined\n  private active: ActiveEntry | undefined\n  private diffStyle: RunDiffStyle | undefined\n  private sessionID?: () => string | undefined\n  private treeSitterClient: TreeSitterClient | undefined\n  private wrote: boolean\n  private pendingThemes: RunTheme[] = []\n\n  constructor(\n    private renderer: CliRenderer,\n    private theme: RunTheme,\n    options: {\n      wrote?: boolean\n      diffStyle?: RunDiffStyle\n      sessionID?: () => string | undefined\n      treeSitterClient?: TreeSitterClient\n      onThemeRelease?: (theme: RunTheme) => void\n    } = {},\n  ) {\n    this.diffStyle = options.diffStyle\n    this.sessionID = options.sessionID\n    this.treeSitterClient = options.treeSitterClient ?? getTreeSitterClient()\n    this.wrote = options.wrote ?? false"},{"id":"scrollback_surface_runscrollbackstream_constructor","label":".constructor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L95-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L95"}],"snippet":"constructor(\n    private renderer: CliRenderer,\n    private theme: RunTheme,\n    options: {\n      wrote?: boolean\n      diffStyle?: RunDiffStyle\n      sessionID?: () => string | undefined\n      treeSitterClient?: TreeSitterClient\n      onThemeRelease?: (theme: RunTheme) => void\n    } = {},\n  ) {\n    this.diffStyle = options.diffStyle\n    this.sessionID = options.sessionID\n    this.treeSitterClient = options.treeSitterClient ?? getTreeSitterClient()\n    this.wrote = options.wrote ?? false\n    this.onThemeRelease = options.onThemeRelease\n  }"},{"id":"scrollback_surface_runscrollbackstream_releasependingthemes","label":".releasePendingThemes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L115-L121","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L115"}],"snippet":"private releasePendingThemes(): void {\n    if (this.pendingThemes.length === 0) {\n      return\n    }\n\n    for (const theme of this.pendingThemes.splice(0)) this.onThemeRelease?.(theme)\n  }"},{"id":"scrollback_surface_runscrollbackstream_settheme","label":".setTheme()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L123-L147","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L123"}],"snippet":"public setTheme(theme: RunTheme): void {\n    if (this.theme === theme) {\n      return\n    }\n\n    const previous = this.theme\n    this.theme = theme\n    const active = this.active\n    if (!active) {\n      this.onThemeRelease?.(previous)\n      return\n    }\n\n    this.pendingThemes.push(previous)\n\n    const style = entryLook(active.commit, theme.entry)\n    if (active.renderable instanceof TextRenderable) {\n      active.renderable.fg = style.fg\n      active.renderable.attributes = style.attrs ?? 0\n      return\n    }\n\n    active.renderable.fg = entryColor(active.commit, theme)\n    active.renderable.syntaxStyle = entrySyntax(active.commit, theme)\n  }"},{"id":"scrollback_surface_runscrollbackstream_createentry","label":".createEntry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L149-L201","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L149"}],"snippet":"private createEntry(commit: StreamCommit, body: ActiveBody): ActiveEntry {\n    const surface = this.renderer.createScrollbackSurface({\n      startOnNewLine: entryFlags(commit).startOnNewLine,\n    })\n    const style = entryLook(commit, this.theme.entry)\n    const renderable =\n      body.type === \"text\"\n        ? new TextRenderable(surface.renderContext, {\n            content: \"\",\n            width: \"100%\",\n            wrapMode: \"word\",\n            fg: style.fg,\n            attributes: style.attrs,\n          })\n        : body.type === \"code\"\n          ? new CodeRenderable(surface.renderContext, {\n              content: \"\",\n              filetype: body.filetype,\n              syntaxStyle: entrySyntax(commit, this.theme),\n              width: \"100%\",\n              wrapMode: \"word\",\n              drawUnstyledText: false,\n              streaming: true,\n              fg: entryColor(commit, this.theme),\n              treeSitterClient: this.treeSitterClient,"},{"id":"scrollback_surface_runscrollbackstream_markrendered","label":".markRendered()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L203-L209","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L203"}],"snippet":"private markRendered(commit: StreamCommit | undefined): void {\n    if (!commit) {\n      return\n    }\n\n    this.rendered = commit\n  }"},{"id":"scrollback_surface_runscrollbackstream_writespacer","label":".writeSpacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L211-L218","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L211"}],"snippet":"private writeSpacer(rows: number): void {\n    if (rows === 0) {\n      return\n    }\n\n    this.renderer.writeToScrollback(spacerWriter())\n    this.wrote = false\n  }"},{"id":"scrollback_surface_runscrollbackstream_flushpendingspacer","label":".flushPendingSpacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L220-L223","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L220"}],"snippet":"private flushPendingSpacer(active: ActiveEntry): void {\n    this.writeSpacer(active.pendingSpacerRows)\n    active.pendingSpacerRows = 0\n  }"},{"id":"scrollback_surface_runscrollbackstream_flushactive","label":".flushActive()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L225-L308","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L225"}],"snippet":"private async flushActive(done: boolean, trailingNewline: boolean): Promise<boolean> {\n    const active = this.active\n    if (!active) {\n      return false\n    }\n\n    if (active.body.type === \"text\") {\n      if (!(active.renderable instanceof TextRenderable)) {\n        return false\n      }\n\n      const renderable = active.renderable\n      renderable.content = active.content\n      active.surface.render()\n      this.releasePendingThemes()\n      const targetRows = done ? active.surface.height : Math.max(active.committedRows, active.surface.height - 1)\n      if (targetRows <= active.committedRows) {\n        return false\n      }\n\n      this.flushPendingSpacer(active)\n      active.surface.commitRows(active.committedRows, targetRows, {\n        trailingNewline: done && targetRows === active.surface.height ? trailingNewline : false,\n      })\n      active.committedRows = targetRows"},{"id":"scrollback_surface_runscrollbackstream_finishactive","label":".finishActive()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L310-L331","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L310"}],"snippet":"private async finishActive(trailingNewline: boolean): Promise<StreamCommit | undefined> {\n    if (!this.active) {\n      return undefined\n    }\n\n    const active = this.active\n\n    try {\n      await this.flushActive(true, trailingNewline)\n    } finally {\n      if (this.active === active) {\n        this.active = undefined\n      }\n\n      if (!active.surface.isDestroyed) {\n        active.surface.destroy()\n      }\n      this.releasePendingThemes()\n    }\n\n    return active.rendered ? active.commit : undefined\n  }"},{"id":"scrollback_surface_runscrollbackstream_writestreaming","label":".writeStreaming()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L333-L346","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.surface.ts","source_location":"L333"}],"snippet":"private async writeStreaming(commit: StreamCommit, body: ActiveBody): Promise<void> {\n    if (!this.active || !sameEntryGroup(this.active.commit, commit) || this.active.body.type !== body.type) {\n      this.markRendered(await this.finishActive(false))\n      this.active = this.createEntry(commit, body)\n    }\n\n    this.active.body = body\n    this.active.commit = commit\n    this.active.content += body.content\n    await this.flushActive(false, false)\n    if (this.active.rendered) {\n      this.markRendered(this.active.commit)\n    }\n  }"},{"i