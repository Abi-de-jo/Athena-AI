cAbortedError>()(\"WorkspaceSyncAbortedError\", {\n  message: Schema.String,\n  cause: Schema.optional(Schema.Defect),\n}) {}"},{"id":"packages_opencode_src_control_plane_workspace_interface","label":"Interface","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L147-L163","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L147"}],"snippet":"export interface Interface {\n  readonly create: (input: CreateInput) => Effect.Effect<Info, CreateError>\n  readonly sessionWarp: (input: SessionWarpInput) => Effect.Effect<void, SessionWarpError>\n  readonly list: (project: Project.Info) => Effect.Effect<Info[]>\n  readonly syncList: (project: Project.Info) => Effect.Effect<void>\n  readonly get: (id: WorkspaceV2.ID) => Effect.Effect<Info | undefined>\n  readonly remove: (id: WorkspaceV2.ID) => Effect.Effect<Info | undefined>\n  readonly status: () => Effect.Effect<ConnectionStatus[]>\n  readonly isSyncing: (workspaceID: WorkspaceV2.ID) => Effect.Effect<boolean>\n  readonly waitForSync: (\n    workspaceID: WorkspaceV2.ID,\n    state: Record<string, number>,\n    signal?: AbortSignal,\n    timeout?: number,\n  ) => Effect.Effect<void, WaitForSyncError>\n  readonly startWorkspaceSyncing: (projectID: ProjectV2.ID) => Effect.Effect<void>\n}"},{"id":"packages_opencode_src_control_plane_workspace_service","label":"Service","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L165","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L165"}],"snippet":"export class Service extends Context.Service<Service, Interface>()(\"@opencode/Workspace\") {}"},{"id":"packages_opencode_src_control_plane_workspace_waituntilsynced","label":"waitUntilSynced()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L927-L946","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L927"}],"snippet":"function waitUntilSynced(input: {\n  db: Database.Interface[\"db\"]\n  workspaceID: WorkspaceV2.ID\n  state: Record<string, number>\n  signal?: AbortSignal\n  timeout: number\n}): Effect.Effect<void, unknown> {\n  return Effect.suspend(() =>\n    waitEvent({\n      timeout: input.timeout,\n      signal: input.signal,\n      fn(event) {\n        return event.workspace === input.workspaceID || event.payload.type === \"sync\"\n      },\n    }).pipe(\n      Effect.andThen(synced(input.db, input.state)),\n      Effect.flatMap((done): Effect.Effect<void, unknown> => (done ? Effect.void : waitUntilSynced(input))),\n    ),\n  )\n}"},{"id":"packages_opencode_src_control_plane_workspace_synced","label":"synced()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L948-L967","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L948"}],"snippet":"function synced(db: Database.Interface[\"db\"], state: Record<string, number>): Effect.Effect<boolean> {\n  const ids = Object.keys(state)\n  if (ids.length === 0) return Effect.succeed(true)\n\n  return db\n    .select({\n      id: EventSequenceTable.aggregate_id,\n      seq: EventSequenceTable.seq,\n    })\n    .from(EventSequenceTable)\n    .where(inArray(EventSequenceTable.aggregate_id, ids))\n    .all()\n    .pipe(\n      Effect.orDie,\n      Effect.map((rows) => {\n        const done = Object.fromEntries(rows.map((row) => [row.id, row.seq])) as Record<string, number>\n        return ids.every((id) => (done[id] ?? -1) >= state[id])\n      }),\n    )\n}"},{"id":"packages_opencode_src_control_plane_workspace_route","label":"route()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L969-L975","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L969"}],"snippet":"function route(url: string | URL, path: string) {\n  const next = new URL(url)\n  next.pathname = `${next.pathname.replace(/\\/$/, \"\")}${path}`\n  next.search = \"\"\n  next.hash = \"\"\n  return next\n}"}],"edges":[{"source":"packages_opencode_src_control_plane_workspace","target":"layer_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_control_plane_workspace","target":"layer_node_platform","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/workspace.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane