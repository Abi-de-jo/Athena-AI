{"__madarTsExtractorVersion":67,"__madarFileStem":"entry","nodes":[{"id":"entry","label":"entry.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/entry.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/entry.tsx","source_location":"L1"}]},{"id":"entry_getlocale","label":"getLocale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/entry.tsx","source_location":"L16-L24","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/entry.tsx","source_location":"L16"}],"snippet":"getLocale = () => {\n  if (typeof navigator !== \"object\") return \"en\" as const\n  const languages = navigator.languages?.length ? navigator.languages : [navigator.language]\n  for (const language of languages) {\n    if (!language) continue\n    if (language.toLowerCase().startsWith(\"zh\")) return \"zh\" as const\n  }\n  return \"en\" as const\n}"},{"id":"entry_getrootnotfounderror","label":"getRootNotFoundError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/entry.tsx","source_location":"L26-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/entry.tsx","source_location":"L26"}],"snippet":"getRootNotFoundError = () => {\n  const key = \"error.dev.rootNotFound\" as const\n  const locale = getLocale()\n  return locale === \"zh\" ? (zh[key] ?? en[key]) : en[key]\n}"},{"id":"entry_getstorage","label":"getStorage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/entry.tsx","source_location":"L32-L39","layer":"base","provenance":[{"capabili