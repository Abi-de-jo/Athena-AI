{"__madarTsExtractorVersion":67,"__madarFileStem":"dialog-select-directory","nodes":[{"id":"dialog_select_directory","label":"dialog-select-directory.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L1"}]},{"id":"dialog_select_directory_dialogselectdirectoryprops","label":"DialogSelectDirectoryProps","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L13-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L13"}],"snippet":"interface DialogSelectDirectoryProps {\n  title?: string\n  multiple?: boolean\n  onSelect: (result: string | string[] | null) => void\n  server: ServerConnection.Any\n}"},{"id":"dialog_select_directory_torow","label":"toRow()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L26-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L26"}],"snippet":"function toRow(absolute: string, home: string, group: Row[\"group\"]): Row {\n  const full = displayPickerPath(absolute, \"\", \"\")\n  const tilde = displayPickerPath(full, \"~\", home)\n  const withSlash = (value: string) => {\n    if (!value) return \"\"\n    if (value.endsWith(\"/\")) return value\n    return value + \"/\"\n  }\n\n  const search = Array.from(\n    new Set([full, withSlash(full), tilde, withSlash(tilde), getFilename(full)].filter(Boolean)),\n  ).join(\"\\n\")\n  return { absolute: full, search, group }\n}"},{"id":"dialog_select_directory_torow_withslash","label":"withSlash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L29-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L29"}],"snippet":"withSlash = (value: string) => {\n    if (!value) return \"\"\n    if (value.endsWith(\"/\")) return value\n    return value + \"/\"\n  }"},{"id":"dialog_select_directory_uniquerows","label":"uniqueRows()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L41-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L41"}],"snippet":"function uniqueRows(rows: Row[]) {\n  const seen = new Set<string>()\n  return rows.filter((row) => {\n    if (seen.has(row.absolute)) return false\n    seen.add(row.absolute)\n    return true\n  })\n}"},{"id":"dialog_select_directory_dialogselectdirectory","label":"DialogSelectDirectory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L50-L194","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L50"}],"snippet":"export function DialogSelectDirectory(props: DialogSelectDirectoryProps) {\n  const global = useGlobal()\n  const { sync, sdk, ...serverCtx } = global.createServerCtx(props.server)\n  const dialog = useDialog()\n  const language = useLanguage()\n\n  const [filter, setFilter] = createSignal(\"\")\n  let list: ListRef | undefined\n\n  const missingBase = createMemo(() => !(sync.data.path.home || sync.data.path.directory))\n  const [fallbackPath] = createResource(\n    () => (missingBase() ? true : undefined),\n    async () => {\n      return sdk.client.path\n        .get()\n        .then((x) => x.data)\n        .catch(() => undefined)\n    },\n    { initialValue: undefined },\n  )\n\n  const home = createMemo(() => sync.data.path.home || fallbackPath()?.home || \"\")\n  const start = createMemo(\n    () => sync.data.path.home || sync.data.path.directory || fallbackPath()?.home || fallbackPath()?.directory,\n  )","node_kind":"component"},{"id":"dialog_select_directory_dialogselectdirectory_items","label":"items()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L114-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L114"}],"snippet":"items = async (value: string) => {\n    const results = await directories(value)\n    const directoryRows = results.map((absolute) => toRow(absolute, home(), \"folders\"))\n    return uniqueRows([...recentProjects(), ...directoryRows])\n  }"},{"id":"dialog_select_directory_dialogselectdirectory_resolve","label":"resolve()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/dialog-select-directory.tsx","source_location":"L120-L123","layer":"base","provenance":[{"capability_id":"builtin:extract:type