 = async (input: RequestInfo | URL, init?: RequestInit): Promise<Response> => {\n    const request = new Request(input, init)\n    const body = request.body ? await request.text() : undefined\n    const result = await client.call(\"fetch\", {\n      url: request.url,\n      method: request.method,\n      headers: Object.fromEntries(request.headers.entries()),\n      body,\n    })\n    return new Response(result.body, {\n      status: result.status,\n      headers: result.headers,\n    })\n  }"},{"id":"packages_rimuru_src_cli_cmd_tui_createeventsource","label":"createEventSource()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/tui.ts","source_location":"L41-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/tui.ts","source_location":"L41"}],"snippet":"function createEventSource(client: RpcClient): EventSource {\n  return {\n    subscribe: async (handler) => {\n      return client.on<GlobalEvent>(\"global.event\", (e) => {\n        handler(e)\n      })\n    },\n  }\n}"},{"id":"packages_rimuru_src_cli_cmd_tui_target","label":"target()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/tui.ts","source_location":"L51-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/tui.ts","source_location":"L51"}],"snippet":"async function target() {\n  if (typeof OPENCODE_WORKER_PATH !== \"undefined\") return OPENCODE_WORKER_PATH\n  const dist = new URL(\"./cli/tui/worker.js\", import.meta.url)\n  if (await Filesystem.exists(fileURLToPath(dist))) return dist\n  return new URL(\"../tui/worker.ts\", import.meta.url)\n}"},{"id":"packages_rimuru_src_cli_cmd_tui_input","label":"input()","file_type":"code","source_fi