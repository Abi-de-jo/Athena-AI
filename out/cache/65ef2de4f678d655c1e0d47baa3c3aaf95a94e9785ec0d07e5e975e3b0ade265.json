{"__madarTsExtractorVersion":67,"__madarFileStem":"flock.test","nodes":[{"id":"flock_test","label":"flock.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L1"}]},{"id":"flock_test_tmpdir","label":"tmpdir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L25-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L25"}],"snippet":"async function tmpdir() {\n  const dir = await fs.mkdtemp(path.join(os.tmpdir(), \"flock-test-\"))\n  return {\n    path: dir,\n    async [Symbol.asyncDispose]() {\n      await fs.rm(dir, { recursive: true, force: true })\n    },\n  }\n}"},{"id":"flock_test_lock","label":"lock()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L35-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L35"}],"snippet":"function lock(dir: string, key: string) {\n  return path.join(dir, Hash.fast(key) + \".lock\")\n}"},{"id":"flock_test_sleep","label":"sleep()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L39-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L39"}],"snippet":"function sleep(ms: number) {\n  return new Promise<void>((resolve) => {\n    setTimeout(resolve, ms)\n  })\n}"},{"id":"flock_test_exists","label":"exists()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L45-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L45"}],"snippet":"async function exists(file: string) {\n  return fs\n    .stat(file)\n    .then(() => true)\n    .catch(() => false)\n}"},{"id":"flock_test_wait","label":"wait()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L52-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L52"}],"snippet":"async function wait(file: string, timeout = 3_000) {\n  const stop = Date.now() + timeout\n  while (Date.now() < stop) {\n    if (await exists(file)) return\n    await sleep(20)\n  }\n\n  throw new Error(`Timed out waiting for file: ${file}`)\n}"},{"id":"flock_test_run","label":"run()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L62-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L62"}],"snippet":"function run(msg: Msg) {\n  return new Promise<{ code: number; stdout: Buffer; stderr: Buffer }>((resolve) => {\n    const proc = spawn(process.execPath, [worker, JSON.stringify(msg)], {\n      cwd: root,\n    })\n\n    const stdout: Buffer[] = []\n    const stderr: Buffer[] = []\n\n    proc.stdout?.on(\"data\", (data) => stdout.push(Buffer.from(data)))\n    proc.stderr?.on(\"data\", (data) => stderr.push(Buffer.from(data)))\n\n    proc.on(\"close\", (code) => {\n      resolve({\n        code: code ?? 1,\n        stdout: Buffer.concat(stdout),\n        stderr: Buffer.concat(stderr),\n      })\n    })\n  })\n}"},{"id":"flock_test_spawnworker","label":"spawnWorker()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L84-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L84"}],"snippet":"function spawnWorker(msg: Msg) {\n  return spawn(process.execPath, [worker, JSON.stringify(msg)], {\n    cwd: root,\n    stdio: [\"ignore\", \"pipe\", \"pipe\"],\n  })\n}"},{"id":"flock_test_stopworker","label":"stopWorker()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L91-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L91"}],"snippet":"async function stopWorker(proc: ReturnType<typeof spawnWorker>) {\n  if (proc.exitCode !== null || proc.signalCode !== null) return\n\n  const closed = new Promise<void>((resolve) => proc.once(\"close\", () => resolve()))\n\n  if (process.platform !== \"win32\" || !proc.pid) {\n    proc.kill()\n    await closed\n    return\n  }\n\n  await new Promise<void>((resolve) => {\n    const killProc = spawn(\"taskkill\", [\"/pid\", String(proc.pid), \"/T\", \"/F\"])\n    killProc.on(\"close\", () => {\n      proc.kill()\n      resolve()\n    })\n  })\n  await closed\n}"},{"id":"flock_test_readjson","label":"readJson()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L112-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L112"}],"snippet":"async function readJson<T>(p: string): Promise<T> {\n  return JSON.parse(await fs.readFile(p, \"utf8\"))\n}"}],"edges":[{"source":"flock_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L1"}],"weight":1},{"source":"flock_test","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L2"}],"weight":1},{"source":"flock_test","target":"child_process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/util/flock.test.ts","source_location":"L3"}],"weight":1},{"source":"flock_test","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-a