{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_test_session_prompt.test","nodes":[{"id":"packages_opencode_test_session_prompt_test","label":"prompt.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L1"}]},{"id":"packages_opencode_test_session_prompt_test_withsh","label":"withSh()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L74-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L74"}],"snippet":"function withSh<A, E, R>(fx: () => Effect.Effect<A, E, R>) {\n  return Effect.acquireUseRelease(\n    Effect.sync(() => {\n      const prev = process.env.SHELL\n      process.env.SHELL = \"/bin/sh\"\n      Shell.preferred.reset()\n      return prev\n    }),\n    () => fx(),\n    (prev) =>\n      Effect.sync(() => {\n        if (prev === undefined) delete process.env.SHELL\n        else process.env.SHELL = prev\n        Shell.preferred.reset()\n      }),\n  )\n}"},{"id":"packages_opencode_test_session_prompt_test_toolpart","label":"toolPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L92-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L92"}],"snippet":"function toolPart(parts: SessionV1.Part[]) {\n  return parts.find((part): part is SessionV1.ToolPart => part.type === \"tool\")\n}"},{"id":"packages_opencode_test_session_prompt_test_completedtool","label":"completedTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L99-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L99"}],"snippet":"function completedTool(parts: SessionV1.Part[]) {\n  const part = toolPart(parts)\n  expect(part?.state.status).toBe(\"completed\")\n  return part?.state.status === \"completed\" ? (part as CompletedToolPart) : undefined\n}"},{"id":"packages_opencode_test_session_prompt_test_errortool","label":"errorTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L105-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L105"}],"snippet":"function errorTool(parts: SessionV1.Part[]) {\n  const part = toolPart(parts)\n  expect(part?.state.status).toBe(\"error\")\n  return part?.state.status === \"error\" ? (part as ErrorToolPart) : undefined\n}"},{"id":"packages_opencode_test_session_prompt_test_makeprompt","label":"makePrompt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L166-L230","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L166"}],"snippet":"function makePrompt(input?: { processor?: \"blocking\" }) {\n  const deps = Layer.mergeAll(\n    Session.defaultLayer,\n    Snapshot.defaultLayer,\n    LLM.defaultLayer,\n    Env.defaultLayer,\n    AgentSvc.defaultLayer,\n    Command.defaultLayer,\n    Permission.defaultLayer,\n    Plugin.defaultLayer,\n    Config.defaultLayer,\n    ProviderSvc.defaultLayer,\n    lsp,\n    mcp,\n    FSUtil.defaultLayer,\n    BackgroundJob.defaultLayer,\n    status,\n    Database.defaultLayer,\n    EventV2Bridge.defaultLayer,\n  ).pipe(Layer.provideMerge(infra))\n  const question = Question.layer.pipe(Layer.provideMerge(deps))\n  const todo = Todo.layer.pipe(Layer.provideMerge(deps))\n  const registry = ToolRegistry.layer.pipe(\n    Layer.provide(Skill.defaultLayer),\n    Layer.provide(FetchHttpClient.layer),"},{"id":"packages_opencode_test_session_prompt_test_makehttp","label":"makeHttp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L232-L234","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L232"}],"snippet":"function makeHttp(input?: { processor?: \"blocking\" }) {\n  return Layer.mergeAll(TestLLMServer.layer, makePrompt(input))\n}"},{"id":"packages_opencode_test_session_prompt_test_makehttpnollmserver","label":"makeHttpNoLLMServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L236-L238","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L236"}],"snippet":"function makeHttpNoLLMServer(input?: { processor?: \"blocking\" }) {\n  return makePrompt(input)\n}"},{"id":"packages_opencode_test_session_prompt_test_providercfg","label":"providerCfg()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L277-L291","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L277"}],"snippet":"function providerCfg(url: string) {\n  return {\n    ...cfg,\n    provider: {\n      ...cfg.provider,\n      test: {\n        ...cfg.provider.test,\n        options: {\n          ...cfg.provider.test.options,\n          baseURL: url,\n        },\n      },\n    },\n  }\n}"},{"id":"packages_opencode_test_session_prompt_test_waitforbusy","label":"waitForBusy()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L320-L329","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L320"}],"snippet":"waitForBusy = (sessionID: SessionID, duration: Duration.Input = \"2 seconds\") =>\n  pollWithTimeout(\n    Effect.gen(function* () {\n      const status = yield* SessionStatus.Service\n      const s = yield* status.get(sessionID)\n      return s.type === \"busy\" ? (true as const) : undefined\n    }),\n    `session ${sessionID} never became busy`,\n    duration,\n  )"},{"id":"packages_opencode_test_session_prompt_test_deferredaspromise","label":"deferredAsPromise()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L333-L349","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L333"}],"snippet":"deferredAsPromise = <A>(deferred: Deferred.Deferred<A>): PromiseLike<A> => ({\n  then: (onfulfilled, onrejected) => {\n    Effect.runFork(\n      Deferred.await(deferred).pipe(\n        Effect.match({\n          onFailure: (error) => {\n            onrejected?.(error)\n          },\n          onSuccess: (value) => {\n            onfulfilled?.(value)\n          },\n        }),\n      ),\n    )\n    return deferredAsPromise(deferred) as PromiseLike<never>\n  },\n})"},{"id":"packages_opencode_test_session_prompt_test_defer","label":"defer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L351-L357","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L351"}],"snippet":"function defer<T>() {\n  let resolve!: (value: T | PromiseLike<T>) => void\n  const promise = new Promise<T>((done) => {\n    resolve = done\n  })\n  return { promise, resolve }\n}"},{"id":"packages_opencode_test_session_prompt_test_succeedvoid","label":"succeedVoid()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L359-L361","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L359"}],"snippet":"succeedVoid = (deferred: Deferred.Deferred<void>) => {\n  Effect.runSync(Deferred.succeed(deferred, void 0).pipe(Effect.ignore))\n}"},{"id":"packages_opencode_test_session_prompt_test_addsubtask","label":"addSubtask()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L412-L425","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L412"}],"snippet":"addSubtask = (sessionID: SessionID, messageID: MessageID, model = ref) =>\n  Effect.gen(function* () {\n    const session = yield* Session.Service\n    yield* session.updatePart({\n      id: PartID.ascending(),\n      messageID,\n      sessionID,\n      type: \"subtask\",\n      prompt: \"look into the cache key path\",\n      description: \"inspect bug\",\n      agent: \"general\",\n      model,\n    })\n  })"},{"id":"packages_opencode_test_session_prompt_test_hanguntilaborted","label":"hangUntilAborted()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L1896-L1910","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/prompt.test.ts","source_location":"L1896"}],"snippet":"function hangUntilAborted(tool: { execute: (...args: any[]) => any }) {\n  return Effect.gen(function* () {\n    const ready = yield* Deferred.make<void>()\n    const aborted = yield* Deferred.make<void>()\n    const original = tool.execute\n    tool.execute = (_args: any, ctx: any) => {\n      ctx.abort.addEventListener(\"abort\", () => succeedVoid(aborted), { once: true })\n      if (ctx.abort.aborted) succeedVoid(aborted)\n      succeedVoid(ready)\n      return Effect.callback<never>(() => Effect.sync(() => succeedVoid(aborted)))\n    }\n    const restore = Effect.addFinalizer(() => Effect.sync(() => void (tool.execute = original)))\n    return { ready, aborted, restore }\n  })\n}"}],"edges":[{"source":"packages_opencode_test_session_prompt_test","target":"platform_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/hom