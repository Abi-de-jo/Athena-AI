t(match[1]) ? match[1] + \"\\\\\" : match[1]\n    return join(normalizePath(dir), \"*\")\n  }"},{"id":"fs_util_resolve","label":"resolve()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/fs-util.ts","source_location":"L225-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/fs-util.ts","source_location":"L225"}],"snippet":"export function resolve(p: string): string {\n    const resolved = pathResolve(windowsPath(p))\n    try {\n      return normalizePath(realpathSync(resolved))\n    } catch (e: any) {\n      if (e?.code === \"ENOENT\") return normalizePath(resolved)\n      throw e\n    }\n  }"},{"id":"fs_util_windowspath","label":"windowsPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/fs-util.ts","source_location":"L235-L242","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/fs-util.ts","source_location":"L235"}],"snippet":"export function windowsPath(p: string): string {\n    if (process.platform !== \"win32\") return p\n    return p\n      .replace(/^\\/([a-zA-Z]):(?:[\\\\/]|$)/, (_, drive) => `${drive.toUpperCase()}:/`)\n      .replace(/^\\/([a-zA-Z])(?:\\/|$)/, (_, drive) => `${drive.toUpperCase()}:/`)\n      .replace(/^\\/cygdrive\\/([a-zA-Z])(?:\\/|$)/, (_, drive) => `${drive.toUpperCase()}:/`)\n      .replace(/^\\/mnt\\/([a-zA-Z])(?:\\/|$)/, (_, drive) => `${drive.toUpperCase()}:/`)\n  }"},{"id":"fs_util_overlaps","label":"overlaps()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/fs-util.ts","source_location":"L244-L246","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/pac