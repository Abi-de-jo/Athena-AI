{"__madarTsExtractorVersion":67,"__madarFileStem":"usageBatcher","nodes":[{"id":"usagebatcher","label":"usageBatcher.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/usageBatcher.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/usageBatcher.ts","source_location":"L1"}]},{"id":"usagebatcher_accumulateusage","label":"accumulateUsage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/usageBatcher.ts","source_location":"L14-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/util/usageBatcher.ts","source_location":"L14"}],"snippet":"export async function accumulateUsage(workspaceID: string, userID: string, workspaceCost: number, userCost: number) {\n  const redis = getRedis()\n  const wKey = `${Resource.App.stage}:usage:wrk:${workspaceID}`\n  const uKey = `${Resource.App.stage}:usage:usr:${workspaceID}:${userID}`\n\n  await Promise.all([redis.incrby(wKey, workspaceCost), redis.incrby(uKey, userCost)])\n\n  if (Math.random() > FLUSH_PROBABILITY) return null\n\n  // Atomically take the current totals and reset to 0\n  const [workspaceTotal, userTotal] = await Promise.all([redis.getdel<number>(wKey), redis.getdel<number>(uKey)])\n\n  const workspaceFlush = Number(workspaceTotal ?? 0)\n  const userFlush = Number(userTotal ?? 0)\n  if (workspaceFlush === 0 && userFlush === 0) return null\n\n  return { workspaceCost: workspaceFlush, userCost: userFlush }\n}"}],"edges":[{"source":"usagebatcher","target":"console_resource","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/pac