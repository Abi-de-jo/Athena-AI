","source_location":"L79-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/[id].tsx","source_location":"L79"}],"snippet":"async function getTaskDetail(benchmarkId: string, taskId: string) {\n  \"use server\"\n  const rows = await Database.use((tx) =>\n    tx.select().from(BenchmarkTable).where(eq(BenchmarkTable.id, benchmarkId)).limit(1),\n  )\n  if (!rows[0]) return null\n  const parsed = JSON.parse(rows[0].result) as BenchmarkResult\n  const task = parsed.tasks.find((t) => t.task.id === taskId)\n  return task ?? null\n}"},{"id":"packages_console_app_src_routes_bench_id_formatduration","label":"formatDuration()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/[id].tsx","source_location":"L92-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/[id].tsx","source_location":"L92"}],"snippet":"function formatDuration(ms: number): string {\n  const seconds = Math.floor(ms / 1000)\n  const minutes = Math.floor(seconds / 60)\n  const remainingSeconds = seconds % 60\n  if (minutes > 0) {\n    return `${minutes}m ${remainingSeconds}s`\n  }\n  return `${remainingSeconds}s`\n}"},{"id":"packages_console_app_src_routes_bench_id_benchdetail","label":"BenchDetail()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/[id].tsx","source_location":"L102-L375","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/bench/[id].tsx","source_location":"L102"}],"snippet":"export default function BenchDetail() {\n  const params = useParams()\n  const i18n 