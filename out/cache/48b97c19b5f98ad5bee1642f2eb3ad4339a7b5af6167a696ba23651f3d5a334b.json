{"__madarTsExtractorVersion":67,"__madarFileStem":"recorded-utils","nodes":[{"id":"recorded_utils","label":"recorded-utils.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L1"}]},{"id":"recorded_utils_kebab","label":"kebab()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L1-L7","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L1"}],"snippet":"kebab = (value: string) =>\n  value\n    .trim()\n    .replace(/['\"]/g, \"\")\n    .replace(/[^a-zA-Z0-9]+/g, \"-\")\n    .replace(/^-|-$/g, \"\")\n    .toLowerCase()"},{"id":"recorded_utils_missingenv","label":"missingEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L9","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L9"}],"snippet":"missingEnv = (names: ReadonlyArray<string>) => names.filter((name) => !process.env[name])"},{"id":"recorded_utils_envlist","label":"envList()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L11-L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L11"}],"snippet":"envList = (name: string) =>\n  (process.env[name] ?? \"\")\n    .split(\",\")\n    .map((item) => item.trim().toLowerCase())\n    .filter((item) => item !== \"\")"},{"id":"recorded_utils_unique","label":"unique()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L17"}],"snippet":"unique = (items: ReadonlyArray<string>) => Array.from(new Set(items))"},{"id":"recorded_utils_classifiedtags","label":"classifiedTags()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L19-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L19"}],"snippet":"classifiedTags = (input: {\n  readonly prefix?: string\n  readonly provider?: string\n  readonly protocol?: string\n  readonly tags?: ReadonlyArray<string>\n}) =>\n  unique([\n    ...(input.prefix ? [`prefix:${input.prefix}`] : []),\n    ...(input.provider ? [`provider:${input.provider}`] : []),\n    ...(input.protocol ? [`protocol:${input.protocol}`] : []),\n    ...(input.tags ?? []),\n  ])"},{"id":"recorded_utils_matchesselected","label":"matchesSelected()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L32-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L32"}],"snippet":"matchesSelected = (input: {\n  readonly prefix: string\n  readonly name: string\n  readonly cassette: string\n  readonly tags: ReadonlyArray<string>\n}) => {\n  const prefixes = envList(\"RECORDED_PREFIX\")\n  const providers = envList(\"RECORDED_PROVIDER\")\n  const requiredTags = envList(\"RECORDED_TAGS\")\n  const tests = envList(\"RECORDED_TEST\")\n  const tags = input.tags.map((tag) => tag.toLowerCase())\n  const names = [input.name, kebab(input.name), input.cassette].map((item) => item.toLowerCase())\n\n  if (prefixes.length > 0 && !prefixes.includes(input.prefix.toLowerCase())) return false\n  if (providers.length > 0 && !providers.some((provider) => tags.includes(`provider:${provider}`))) return false\n  if (requiredTags.length > 0 && !requiredTags.every((tag) => tags.includes(tag))) return false\n  if (tests.length > 0 && !tests.some((test) => names.some((name) => name.includes(test)))) return false\n  return true\n}"},{"id":"recorded_utils_cassettename","label":"cassetteName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L52-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L52"}],"snippet":"cassetteName = (\n  prefix: string,\n  name: string,\n  options: { readonly cassette?: string; readonly id?: string },\n) => options.cassette ?? `${prefix}/${options.id ?? kebab(name)}`"}],"edges":[{"source":"recorded_utils","target":"recorded_utils_kebab","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/test/recorded-utils.ts","source_location":"L1"}],"weight":1},{"source":"recorded_utils","target":"recorded_utils_missingenv","relation":"contains