ription>${skill.description}</description>`,\n          `    <location>${pathToFileURL(skill.location).href}</location>`,\n          \"  </skill>\",\n        ]),\n      \"</available_skills>\",\n    ].join(\"\\n\")\n  }\n\n  return [\n    \"## Available Skills\",\n    ...described\n      .toSorted((a, b) => a.name.localeCompare(b.name))\n      .map((skill) => `- **${skill.name}**: ${skill.description}`),\n  ].join(\"\\n\")"}],"edges":[{"source":"packages_opencode_src_skill_index","target":"layer_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/skill/index.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/skill/index.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_skill_index","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/skill/index.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/skill/index.ts","source_location":"L2"}],"weight":1},{"source":"packages_opencode_src_skill_index","target":"url","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/skill/index.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/skill/index.ts","source_location":"L3"}],"weight":1},{"source":"packages_opencode_src_skill_index","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/