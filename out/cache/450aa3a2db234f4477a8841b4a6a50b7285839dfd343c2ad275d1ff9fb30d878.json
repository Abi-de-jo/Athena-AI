{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_console_app_src_lib_salesforce","nodes":[{"id":"packages_console_app_src_lib_salesforce","label":"salesforce.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/salesforce.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/salesforce.ts","source_location":"L1"}]},{"id":"packages_console_app_src_lib_salesforce_login","label":"login()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/salesforce.ts","source_location":"L3-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/salesforce.ts","source_location":"L3"}],"snippet":"async function login() {\n  const url = Resource.SALESFORCE_INSTANCE_URL.value.replace(/\\/$/, \"\")\n  const clientId = Resource.SALESFORCE_CLIENT_ID.value\n  const clientSecret = Resource.SALESFORCE_CLIENT_SECRET.value\n\n  const params = new URLSearchParams({\n    grant_type: \"client_credentials\",\n    client_id: clientId,\n    client_secret: clientSecret,\n  })\n\n  const res = await fetch(`${url}/services/oauth2/token`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/x-www-form-urlencoded\" },\n    body: params.toString(),\n  }).catch((err) => {\n    console.error(\"Failed to fetch Salesforce access token:\", err)\n  })\n\n  if (!res) return\n\n  if (!res.ok) {\n    console.error(\"Failed to fetch Salesforce access token:\", res.status, await res.text())\n    return\n  }"},{"id":"packages_console_app_src_lib_salesforce_salesforceleadinput","label":"SalesforceLeadInput","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/salesforce.ts","source_location":"L41-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/salesforce.ts","source_location":"L41"}],"snippet":"export interface SalesforceLeadInput {\n  name: string\n  role: string\n  company?: string\n  email: string\n  phone?: string\n  message: string\n}"},{"id":"packages_console_app_src_lib_salesforce_createlead","label":"createLead()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/salesforce.ts","source_location":"L50-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/salesforce.ts","source_location":"L50"}],"snippet":"export async function createLead(input: SalesforceLeadInput): Promise<boolean> {\n  const auth = await login()\n  if (!auth) return false\n\n  const res = await fetch(`${auth.url}/services/data/v59.0/sobjects/Lead`, {\n    method: \"POST\",\n    headers: {\n      Authorization: `Bearer ${auth.token}`,\n      \"Content-Type\": \"application/json\",\n    },\n    body: JSON.stringify({\n      LastName: input.name,\n      Company: input.company?.trim() || \"Website\",\n      Email: input.email,\n      Phone: input.phone ?? null,\n      Title: input.role,\n      Description: input.message,\n      LeadSource: \"Website\",\n    }),\n  }).catch((err) => {\n    console.error(\"Failed to create Salesforce lead:\", err)\n  })\n\n  if (!res) return false"}],"edges":[{"source":"packages_console_app_src_lib_salesforce","target":"console_resource","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/salesforce.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage"