{"__madarTsExtractorVersion":67,"__madarFileStem":"aim","nodes":[{"id":"aim","label":"aim.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L1"}]},{"id":"aim_createaim","label":"createAim()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L3-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L3"}],"snippet":"export function createAim(props: {\n  enabled: () => boolean\n  active: () => string | undefined\n  el: () => HTMLElement | undefined\n  onActivate: (id: string) => void\n  delay?: number\n  max?: number\n  tolerance?: number\n  edge?: number\n}) {\n  const state = {\n    locs: [] as Point[],\n    timer: undefined as number | undefined,\n    pending: undefined as string | undefined,\n    over: undefined as string | undefined,\n    last: undefined as Point | undefined,\n  }\n\n  const delay = props.delay ?? 250\n  const max = props.max ?? 4\n  const tolerance = props.tolerance ?? 80\n  const edge = props.edge ?? 18\n\n  const cancel = () => {\n    if (state.timer !== undefined) clearTimeout(state.timer)"},{"id":"aim_createaim_cancel","label":"cancel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L26-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L26"}],"snippet":"cancel = () => {\n    if (state.timer !== undefined) clearTimeout(state.timer)\n    state.timer = undefined\n    state.pending = undefined\n  }"},{"id":"aim_createaim_reset","label":"reset()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L32-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L32"}],"snippet":"reset = () => {\n    cancel()\n    state.over = undefined\n    state.last = undefined\n    state.locs.length = 0\n  }"},{"id":"aim_createaim_move","label":"move()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L39-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L39"}],"snippet":"move = (event: MouseEvent) => {\n    if (!props.enabled()) return\n    const el = props.el()\n    if (!el) return\n\n    const rect = el.getBoundingClientRect()\n    const x = event.clientX\n    const y = event.clientY\n    if (x < rect.left || x > rect.right || y < rect.top || y > rect.bottom) return\n\n    state.locs.push({ x, y })\n    if (state.locs.length > max) state.locs.shift()\n  }"},{"id":"aim_createaim_wait","label":"wait()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L53-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L53"}],"snippet":"wait = () => {\n    if (!props.enabled()) return 0\n    if (!props.active()) return 0\n\n    const el = props.el()\n    if (!el) return 0\n    if (state.locs.length < 2) return 0\n\n    const rect = el.getBoundingClientRect()\n    const loc = state.locs[state.locs.length - 1]\n    if (!loc) return 0\n\n    const prev = state.locs[0] ?? loc\n    if (prev.x < rect.left || prev.x > rect.right || prev.y < rect.top || prev.y > rect.bottom) return 0\n    if (state.last && loc.x === state.last.x && loc.y === state.last.y) return 0\n\n    if (rect.right - loc.x <= edge) {\n      state.last = loc\n      return delay\n    }\n\n    const upper = { x: rect.right, y: rect.top - tolerance }\n    const lower = { x: rect.right, y: rect.bottom + tolerance }\n    const slope = (a: Point, b: Point) => (b.y - a.y) / (b.x - a.x)"},{"id":"aim_createaim_wait_slope","label":"slope()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L76"}],"snippet":"slope = (a: Point, b: Point) => (b.y - a.y) / (b.x - a.x)"},{"id":"aim_createaim_activate","label":"activate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L92-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L92"}],"snippet":"activate = (id: string) => {\n    cancel()\n    props.onActivate(id)\n  }"},{"id":"aim_createaim_request","label":"request()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L97-L123","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L97"}],"snippet":"request = (id: string) => {\n    if (!id) return\n    if (props.active() === id) return\n\n    if (!props.active()) {\n      activate(id)\n      return\n    }\n\n    const ms = wait()\n    if (ms === 0) {\n      activate(id)\n      return\n    }\n\n    cancel()\n    state.pending = id\n    state.timer = window.setTimeout(() => {\n      state.timer = undefined\n      if (state.pending !== id) return\n      state.pending = undefined\n      if (!props.enabled()) return\n      if (!props.active()) return\n      if (state.over !== id) return\n      props.onActivate(id)"},{"id":"aim_createaim_enter","label":"enter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L125-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L125"}],"snippet":"enter = (id: string, event: MouseEvent) => {\n    if (!props.enabled()) return\n    state.over = id\n    move(event)\n    request(id)\n  }"},{"id":"aim_createaim_leave","label":"leave()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L132-L135","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L132"}],"snippet":"leave = (id: string) => {\n    if (state.over === id) state.over = undefined\n    if (state.pending === id) cancel()\n  }"}],"edges":[{"source":"aim","target":"aim_createaim","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/aim.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ap