omponents/list.tsx","source_location":"L99-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L99"}],"snippet":"applyFilter = (value: string, options?: { ref?: boolean }) => {\n    const prev = filter()\n    setInternalFilter(value)\n    onInput(value)\n    props.onFilter?.(value)\n\n    if (!options?.ref) return\n\n    // Force a refetch even if the value is unchanged.\n    // This is important for programmatic changes like Tab completion.\n    if (prev === value) {\n      void refetch()\n      return\n    }\n    queueMicrotask(() => refetch())\n  }"},{"id":"packages_ui_src_components_list_list_handleselect","label":"handleSelect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L168-L170","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L168"}],"snippet":"handleSelect = (item: T | undefined, index: number) => {\n    props.onSelect?.(item, index)\n  }"},{"id":"packages_ui_src_components_list_list_handlekey","label":"handleKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L172-L197","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L172"}],"snippet":"handleKey = (e: KeyboardEvent) => {\n    setStore(\"mouseActive\", false)\n    if (e.key === \"Escape\") return\n\n    const all = flat()\n    const selected = all.find((x) => props.key(x) === active())\n    const index = selected ? all.indexOf(selected) : -1\n    props.onKeyEvent?.(e, selected)\n\n    if (e.defaultPrevented) return\n\n    if (e.key === \"Enter\" && !e.isComposing) {\n      e.preventDefault()\n      if (selected) handleSelect(selected, index)\n    } else if (props.search) {\n      if (e.ctrlKey && !e.metaKey && !e.altKey && !e.shiftKey && (e.key === \"n\" || e.key === \"p\")) {\n        onKeyDown(e)\n        return\n      }\n      if (e.key === \"ArrowDown\" || e.key === \"ArrowUp\") {\n        onKeyDown(e)\n      }\n    } else {\n      onKeyDown(e)\n    }"},{"id":"packages_ui_src_components_list_list_renderadd","label":"renderAdd()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L205-L213","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L205"}],"snippet":"renderAdd = () => {\n    const add = addProps()\n    if (!add) return null\n    return (\n      <div data-slot=\"list-item-add\" classList={{ [add.class ?? \"\"]: !!add.class }}>\n        {add.render()}\n      </div>\n    )\n  }"},{"id":"packages_ui_src_components_list_list_groupheader","label":"GroupHeader()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L215-L241","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L215"}],"snippet":"function GroupHeader(groupProps: { group: { category: string; items: T[] } }): JSX.Element {\n    const [state, setState] = createStore({\n      stuck: false,\n      header: undefined as HTMLDivElement | undefined,\n    })\n\n    createEffect(() => {\n      const scroll = scrollRef()\n      const node = state.header\n      if (!scroll || !node) return\n\n      const handler = () => {\n        const rect = node.getBoundingClientRect()\n        const scrollRect = scroll.getBoundingClientRect()\n        setState(\"stuck\", rect.top <= scrollRect.top + 1 && scroll.scrollTop > 0)\n      }\n\n      makeEventListener(scroll, \"scroll\", handler, { passive: true })\n      handler()\n    })\n\n    return (\n      <div data-slot=\"list-header\" data-stuck={state.stuck} ref={(el) => setState(\"header\", el)}>\n        {props.groupHeader?.(groupProps.group) ?? groupProps.group.category}\n      </div>"},{"id":"packages_ui_src_components_list_list_groupheader_handler","label":"handler()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L226-L230","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L226"}],"snippet":"handler = () => {\n        const rect = node.getBoundingClientRect()\n        const scrollRect = scroll.getBoundingClientRect()\n        setState(\"stuck\", rect.top <= scrollRect.top + 1 && scroll.scrollTop > 0)\n      }"},{"id":"packages_ui_src_components_list_list_emptymessage","label":"emptyMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L243-L260","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L243"}],"snippet":"emptyMessage = () => {\n    if (grouped.loading) return props.loadingMessage ?? i18n.t(\"ui.list.loading\")\n    if (props.emptyMessage) return props.emptyMessage\n\n    const query = filter()\n    if (!query) return i18n.t(\"ui.list.empty\")\n\n    const suffix = i18n.t(\"ui.list.emptyWithFilter.suffix\")\n    return (\n      <>\n        <span>{i18n.t(\"ui.list.emptyWithFilter.prefix\")}</span>\n        <span data-slot=\"list-filter\">&quot;{query}&quot;</span>\n        <Show when={suffix}>\n          <span>{suffix}</span>\n        </Show>\n      </>\n    )\n  }"},{"id":"packages_ui_src_components_list_list_islastgroup","label":"isLastGroup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L329","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L329"}],"snippet":"isLastGroup = () => groupIndex() === grouped.latest.length - 1"}],"edges":[{"source":"packages_ui_src_components_list","target":"hooks","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L1"}],"weight":1},{"source":"packages_ui_src_components_list","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L2"}],"weight":1},{"source":"packages_ui_src_components_list","target":"store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/list.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract",