{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_cli_error","nodes":[{"id":"packages_rimuru_src_cli_error","label":"error.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_cli_error_istaggederror","label":"isTaggedError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L7-L9","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L7"}],"snippet":"function isTaggedError(error: unknown, tag: string): error is Record<string, unknown> {\n  return isRecord(error) && error._tag === tag\n}"},{"id":"packages_rimuru_src_cli_error_configdata","label":"configData()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L11-L16","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L11"}],"snippet":"function configData(input: unknown, tag: string): Record<string, unknown> | undefined {\n  if (!isRecord(input)) return undefined\n  if (input.name === tag && isRecord(input.data)) return input.data\n  if (input._tag === tag) return input\n  return undefined\n}"},{"id":"packages_rimuru_src_cli_error_stringfield","label":"stringField()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L18-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L18"}],"snippet":"function stringField(input: Record<string, unknown>, key: string): string | undefined {\n  return typeof input[key] === \"string\" ? input[key] : undefined\n}"},{"id":"packages_rimuru_src_cli_error_configissues","label":"configIssues()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L22-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L22"}],"snippet":"function configIssues(input: Record<string, unknown>): ConfigIssue[] {\n  return Array.isArray(input.issues)\n    ? input.issues.filter((issue): issue is ConfigIssue => {\n        if (!isRecord(issue)) return false\n        return (\n          typeof issue.message === \"string\" &&\n          Array.isArray(issue.path) &&\n          issue.path.every((x) => typeof x === \"string\")\n        )\n      })\n    : []\n}"},{"id":"packages_rimuru_src_cli_error_formaterror","label":"FormatError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L35-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L35"}],"snippet":"export function FormatError(input: unknown): string | undefined {\n  if (input instanceof Error && isRecord(input.cause) && \"body\" in input.cause) {\n    const formatted = FormatError(input.cause.body)\n    if (formatted) return formatted\n  }\n\n  // CliError: domain failure surfaced from an effectCmd handler via fail(\"...\")\n  if (isTaggedError(input, \"CliError\")) {\n    if (typeof input.exitCode === \"number\") process.exitCode = input.exitCode\n    return stringField(input, \"message\") ?? \"\"\n  }\n\n  // MCPFailed: { name: string }\n  if (NamedError.hasName(input, \"MCPFailed\")) {\n    const data = isRecord(input) && isRecord(input.data) ? stringField(input.data, \"name\") : undefined\n    return `MCP server \"${data}\" failed. Note, rimuru-ai does not support MCP authentication yet.`\n  }\n\n  // AccountServiceError, AccountTransportError: TaggedErrorClass\n  if (isTaggedError(input, \"AccountServiceError\") || isTaggedError(input, \"AccountTransportError\")) {\n    return stringField(input, \"message\") ?? \"\"\n  }\n\n  // ProviderModelNotFoundError: { providerID: string, modelID: string, suggestions?: string[] }\n  const providerModelNotFound = configData(input, \"ProviderModelNotFoundError\")"},{"id":"packages_rimuru_src_cli_error_formatunknownerror","label":"FormatUnknownError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L128-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L128"}],"snippet":"export function FormatUnknownError(input: unknown): string {\n  return errorFormat(input)\n}"}],"edges":[{"source":"packages_rimuru_src_cli_error","target":"error","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/error.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_cli_error","target":"record","relation":"imports_from","confidence":"EXTRACTE