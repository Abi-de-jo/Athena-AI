{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_desktop_src_main_logging","nodes":[{"id":"packages_desktop_src_main_logging","label":"logging.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L1"}]},{"id":"packages_desktop_src_main_logging_getlogger","label":"getLogger()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L20"}],"snippet":"getLogger = () => logger"},{"id":"packages_desktop_src_main_logging_initlogging","label":"initLogging()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L22-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L22"}],"snippet":"export function initLogging() {\n  initRunDirectory()\n  log.transports.file.maxSize = 5 * 1024 * 1024\n  log.transports.file.resolvePathFn = (_vars, message) =>\n    join(\n      run,\n      `${safeLogName(message?.scope ?? (message?.variables?.processType === \"renderer\" ? \"renderer\" : \"main\"))}.log`,\n    )\n  log.initialize({ preload: false, spyRendererConsole: true })\n  initConsoleTransport()\n  cleanup()\n  return (logger = log)\n}"},{"id":"packages_desktop_src_main_logging_initcrashreporter","label":"initCrashReporter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L36-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L36"}],"snippet":"export function initCrashReporter() {\n  const dir = join(app.getPath(\"userData\"), \"Crashpad\")\n  mkdirSync(dir, { recursive: true })\n  app.setPath(\"crashDumps\", dir)\n  crashReporter.start({ uploadToServer: false, compress: true })\n  write(\"crash\", \"crash reporter started\", { path: dir })\n}"},{"id":"packages_desktop_src_main_logging_startnetlog","label":"startNetLog()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L44-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L44"}],"snippet":"export async function startNetLog() {\n  if (netLog.currentlyLogging) return\n  netLogPath = join(run, \"network.netlog\")\n  await netLog.startLogging(netLogPath, { captureMode: \"default\", maxFileSize: NET_LOG_SIZE })\n  write(\"network\", \"net log started\", { path: netLogPath })\n}"},{"id":"packages_desktop_src_main_logging_exportdebuglogs","label":"exportDebugLogs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L51-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L51"}],"snippet":"export async function exportDebugLogs() {\n  const restartNetLog = netLog.currentlyLogging\n  if (restartNetLog) {\n    await netLog.stopLogging().catch((error) => write(\"network\", \"failed to stop net log\", { error }))\n  }\n\n  const output = join(app.getPath(\"downloads\"), `opencode-debug-${stamp()}.zip`)\n  try {\n    write(\"main\", \"exporting debug logs\", { output })\n    await writeZip(output, [\n      { name: \"manifest.json\", data: Buffer.from(JSON.stringify(manifest(), null, 2)) },\n      ...collect(root, \"desktop\"),\n      ...serverLogRoots().flatMap((dir, i) => collect(dir, `server-${i + 1}`)),\n      ...collect(app.getPath(\"crashDumps\"), \"crashpad\"),\n    ])\n    shell.showItemInFolder(output)\n    return output\n  } finally {\n    if (restartNetLog) {\n      await startNetLog().catch((error) => write(\"network\", \"failed to restart net log\", { error }))\n    }\n  }\n}"},{"id":"packages_desktop_src_main_logging_write","label":"write()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L75-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L75"}],"snippet":"export function write(\n  name: string,\n  message: string,\n  extra?: Record<string, unknown>,\n  level: \"info\" | \"warn\" | \"error\" = \"info\",\n) {\n  if (!run) return\n  const scoped = log.scope(safeLogName(name))\n  if (extra !== undefined) {\n    scoped[level](message, extra)\n    return\n  }\n  scoped[level](message)\n}"},{"id":"packages_desktop_src_main_logging_tail","label":"tail()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L90-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L90"}],"snippet":"export function tail(): string {\n  try {\n    const path = log.transports.file.getFile().path\n    const contents = readFileSync(path, \"utf8\")\n    const lines = contents.split(\"\\n\")\n    return lines.slice(Math.max(0, lines.length - TAIL_LINES)).join(\"\\n\")\n  } catch {\n    return \"\"\n  }\n}"},{"id":"packages_desktop_src_main_logging_initrundirectory","label":"initRunDirectory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L101-L105","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L101"}],"snippet":"function initRunDirectory() {\n  root = join(app.getPath(\"userData\"), \"logs\")\n  run = join(root, stamp())\n  mkdirSync(run, { recursive: true })\n}"},{"id":"packages_desktop_src_main_logging_stamp","label":"stamp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L107-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L107"}],"snippet":"function stamp() {\n  return new Date()\n    .toISOString()\n    .replace(/[-:]/g, \"\")\n    .replace(/\\.\\d+Z$/, \"\")\n}"},{"id":"packages_desktop_src_main_logging_safelogname","label":"safeLogName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L114-L116","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L114"}],"snippet":"function safeLogName(name: string) {\n  return name.replace(/[^a-z0-9_.-]/gi, \"_\") || \"main\"\n}"},{"id":"packages_desktop_src_main_logging_cleanup","label":"cleanup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L118-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L118"}],"snippet":"function cleanup() {\n  const dir = root || dirname(log.transports.file.getFile().path)\n  const cutoff = Date.now() - MAX_LOG_AGE_DAYS * 24 * 60 * 60 * 1000\n\n  for (const entry of readdirSync(dir)) {\n    const file = join(dir, entry)\n    try {\n      const info = statSync(file)\n      if (info.mtimeMs < cutoff) rmSync(file, { recursive: true, force: true })\n    } catch {\n      continue\n    }\n  }\n}"},{"id":"packages_desktop_src_main_logging_manifest","label":"manifest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L133-L150","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L133"}],"snippet":"function manifest() {\n  return {\n    generated: new Date().toISOString(),\n    version: app.getVersion(),\n    name: app.getName(),\n    packaged: app.isPackaged,\n    platform: process.platform,\n    arch: process.arch,\n    versions: process.versions,\n    uptime: process.uptime(),\n    userData: app.getPath(\"userData\"),\n    logs: root,\n    currentRun: run,\n    crashDumps: app.getPath(\"crashDumps\"),\n    serverLogs: serverLogRoots(),\n    netLog: netLogPath,\n  }\n}"},{"id":"packages_desktop_src_main_logging_serverlogroots","label":"serverLogRoots()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L152-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L152"}],"snippet":"function serverLogRoots() {\n  const xdgData = process.env.XDG_DATA_HOME || join(homedir(), \".local\", \"share\")\n  return [...new Set([join(xdgData, \"rimuru-ai\", \"log\"), join(app.getPath(\"userData\"), \"rimuru-ai\", \"log\")])]\n}"},{"id":"packages_desktop_src_main_logging_collect","label":"collect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L159-L179","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L159"}],"snippet":"function collect(dir: string, prefix: string): Entry[] {\n  if (!existsSync(dir)) return []\n  const cutoff = Date.now() - EXPORT_WINDOW\n  const result: Entry[] = []\n  const walk = (current: string) => {\n    for (const entry of readdirSync(current)) {\n      const file = join(current, entry)\n      const info = statSync(file)\n      if (info.isDirectory()) {\n        walk(file)\n        continue\n      }\n      if (info.mtimeMs < cutoff) continue\n      if (info.size > MAX_EXPORT_FILE_SIZE) continue\n      if (file.endsWith(\".heapsnapshot\")) continue\n      result.push({ name: join(prefix, file.slice(dir.length + 1)).replace(/\\\\/g, \"/\"), path: file })\n    }\n  }\n  walk(dir)\n  return result\n}"},{"id":"packages_desktop_src_main_logging_collect_walk","label":"walk()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L163-L176","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L163"}],"snippet":"walk = (current: string) => {\n    for (const entry of readdirSync(current)) {\n      const file = join(current, entry)\n      const info = statSync(file)\n      if (info.isDirectory()) {\n        walk(file)\n        continue\n      }\n      if (info.mtimeMs < cutoff) continue\n      if (info.size > MAX_EXPORT_FILE_SIZE) continue\n      if (file.endsWith(\".heapsnapshot\")) continue\n      result.push({ name: join(prefix, file.slice(dir.length + 1)).replace(/\\\\/g, \"/\"), path: file })\n    }\n  }"},{"id":"packages_desktop_src_main_logging_writezip","label":"writeZip()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L181-L189","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L181"}],"snippet":"async function writeZip(output: string, entries: Entry[]) {\n  const writer = new ZipWriter(new BlobWriter(\"application/zip\"))\n  for (const entry of entries) {\n    const data = entry.data ?? readFileSync(entry.path!)\n    await writer.add(entry.name, new BlobReader(new Blob([new Uint8Array(data)])))\n  }\n  const zip = await writer.close()\n  writeFileSync(output, Buffer.from(await zip.arrayBuffer()))\n}"},{"id":"packages_desktop_src_main_logging_initconsoletransport","label":"initConsoleTransport()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L191-L201","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L191"}],"snippet":"function initConsoleTransport() {\n  const write = log.transports.console.writeFn.bind(log.transports.console)\n  log.transports.console.writeFn = (options) => {\n    try {\n      write(options)\n    } catch (err) {\n      if (!isBrokenPipe(err)) throw err\n      log.transports.console.level = false\n    }\n  }\n}"},{"id":"packages_desktop_src_main_logging_isbrokenpipe","label":"isBrokenPipe()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L203-L205","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L203"}],"snippet":"function isBrokenPipe(err: unknown) {\n  return typeof err === \"object\" && err !== null && \"code\" in err && err.code === \"EPIPE\"\n}"}],"edges":[{"source":"packages_desktop_src_main_logging","target":"electron_log","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L1"}],"weight":1},{"source":"packages_desktop_src_main_logging","target":"main","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L2"}],"weight":1},{"source":"packages_desktop_src_main_logging","target":"electron","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/logging.ts","source_location":"L3","layer":"base","p