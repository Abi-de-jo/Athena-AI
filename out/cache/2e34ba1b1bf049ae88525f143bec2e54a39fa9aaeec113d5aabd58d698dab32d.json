unction isAllowedEditableKeybind(id: string | undefined) {\n  if (!id) return false\n  return EDITABLE_KEYBIND_IDS.has(actionId(id))\n}"},{"id":"packages_app_src_context_command_keybind","label":"Keybind","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L67-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L67"}],"snippet":"export interface Keybind {\n  key: string\n  ctrl: boolean\n  meta: boolean\n  shift: boolean\n  alt: boolean\n}"},{"id":"packages_app_src_context_command_commandoption","label":"CommandOption","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L75-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L75"}],"snippet":"export interface CommandOption {\n  id: string\n  title: string\n  description?: string\n  category?: string\n  keybind?: KeybindConfig\n  slash?: string\n  suggested?: boolean\n  disabled?: boolean\n  hidden?: boolean\n  onSelect?: (source?: \"palette\" | \"keybind\" | \"slash\") => void\n  onHighlight?: () => (() => void) | void\n}"},{"id":"packages_app_src_context_command_upsertcommandregistration","label":"upsertCommandRegistration()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L105-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L105"}],"snippet":"export function upsertCommandRegistration(registrations: CommandRegistration[], entry: CommandRegistration) {\n  if (entry.key === undefined) return [entry, ...registrations]\n  return [entry, ...registrations.filter((x) => x.key !== entry.key)]\n}"},{"id":"packages_app_src_context_command_parsekeybind","label":"parseKeybind()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L110-L153","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L110"}],"snippet":"export function parseKeybind(config: string): Keybind[] {\n  if (!config || config === \"none\") return []\n\n  return config.split(\",\").map((combo) => {\n    const parts = combo.trim().toLowerCase().split(\"+\")\n    const keybind: Keybind = {\n      key: \"\",\n      ctrl: false,\n      meta: false,\n      shift: false,\n      alt: false,\n    }\n\n    for (const part of parts) {\n      switch (part) {\n        case \"ctrl\":\n        case \"control\":\n          keybind.ctrl = true\n          break\n        case \"meta\":\n        case \"cmd\":\n        case \"command\":\n          keybind.meta = true\n          break\n        case \"mod\":"},{"id":"packages_app_src_context_command_matchkeybind","label":"matchKeybind()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L155-L171","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L155"}],"snippet":"export function matchKeybind(keybinds: Keybind[], event: KeyboardEvent): boolean {\n  const eventKey = normalizeKey(event.key)\n\n  for (const kb of keybinds) {\n    const keyMatch = kb.key === eventKey\n    const ctrlMatch = kb.ctrl === (event.ctrlKey || false)\n    const metaMatch = kb.meta === (event.metaKey || false)\n    const shiftMatch = kb.shift === (event.shiftKey || false)\n    const altMatch = kb.alt === (event.altKey || false)\n\n    if (keyMatch && ctrlMatch && metaMatch && shiftMatch && altMatch) {\n      return true\n    }\n  }\n\n  return false\n}"},{"id":"packages_app_src_context_command_formatkeybind","label":"formatKeybind()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L173-L222","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L173"}],"snippet":"export function formatKeybind(config: string, t?: (key: KeyLabel) => string): string {\n  if (!config || config === \"none\") return \"\"\n\n  const keybinds = parseKeybind(config)\n  if (keybinds.length === 0) return \"\"\n\n  const kb = keybinds[0]\n  const parts: string[] = []\n\n  if (kb.ctrl) parts.push(IS_MAC ? \"⌃\" : keyText(\"common.key.ctrl\", t))\n  if (kb.alt) parts.push(IS_MAC ? \"⌥\" : keyText(\"common.key.alt\", t))\n  if (kb.shift) parts.push(IS_MAC ? \"⇧\" : keyText(\"common.key.shift\", t))\n  if (kb.meta) parts.push(IS_MAC ? \"⌘\" : keyText(\"common.key.meta\", t))\n\n  if (kb.key) {\n    const keys: Record<string, string> = {\n      arrowup: \"↑\",\n      arrowdown: \"↓\",\n      arrowleft: \"←\",\n      arrowright: \"→\",\n      comma: \",\",\n      plus: \"+\",\n    }\n    const named: Record<string, KeyLabel> = {\n      backspace: \"common.key.backspace\","},{"id":"packages_app_src_context_command_iseditabletarget","label":"isEditableTarget()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/command.tsx","source_location":"L224-L230","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extr