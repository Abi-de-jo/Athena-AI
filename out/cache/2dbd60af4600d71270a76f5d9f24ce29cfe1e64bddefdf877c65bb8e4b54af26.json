(!list.length) return list\n  const order = new Map(list.map((url, index) => [url, index] as const))\n  const rank = (value?: ServerHealth) => {\n    if (value?.healthy === true) return 0\n    if (value?.healthy === false) return 2\n    return 1\n  }\n\n  return list.slice().sort((a, b) => {\n    if (ServerConnection.key(a) === active) return -1\n    if (ServerConnection.key(b) === active) return 1\n    const diff = rank(status[ServerConnection.key(a)]) - rank(status[ServerConnection.key(b)])\n    if (diff !== 0) return diff\n    return (order.get(a) ?? 0) - (order.get(b) ?? 0)\n  })\n}"},{"id":"status_popover_body_listserversbyhealth_rank","label":"rank()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/status-popover-body.tsx","source_location":"L39-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/status-popover-body.tsx","source_location":"L39"}],"snippet":"rank = (value?: ServerHealth) => {\n    if (value?.healthy === true) return 0\n    if (value?.healthy === false) return 2\n    return 1\n  }"},{"id":"status_popover_body_usedefaultserverkey","label":"useDefaultServerKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/status-popover-body.tsx","source_location":"L54-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/status-popover-body.tsx","source_location":"L54"}],"snippet":"useDefaultServerKey = (\n  get: (() => string | Promise<string | null | undefined> | null | undefined) | undefined,\n) => {\n  const [state, setState] = createStore({\n    key: undefined as ServerConnection.Key | undefined,\n    tick: 0,\n  })\n\n  createEffect(() => {\n    state.tick\n    let dead = false\n    const result = get?.()\n    if (!result) {\n      setState(\"key\", undefined)\n      onCleanup(() => {\n        dead = true\n      })\n      return\n    }\n\n    if (result instanceof Promise) {\n      void result.then((next) => {\n        if (dead) return\n        setState(\"key\", next ?? undefined)\n      })"},{"id":"status_popover_body_statuspopoverserverbody","label":"StatusPopoverServerBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/status-popover-body.tsx","source_location":"L118-L170","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/status-popover-body.tsx","source_location":"L118"}],"snippet":"export function StatusPopoverServerBody() {\n  const global = useGlobal()\n  const server = useServer()\n  const platform = usePlatform()\n  const dialog = useDialog()\n  const language = useLanguage()\n  const navigate = useNavigate()\n  let dialogRun = 0\n  let dialogDead = false\n  onCleanup(() => {\n    dialogDead = true\n    dialogRun += 1\n  })\n\n  const sortedServers = createMemo(() => listServersByHealth(global.servers.list(), server.key, global.servers.health))\n  const defaultServer = useDefaultServerKey(platform.getDefaultServer)\n  const serverItems = createMemo(() =>\n    sortedServers().map((conn) => {\n      const key = ServerConnection.key(conn)\n      return {\n        key,\n        conn,\n        health: global.servers.health[key],\n        blocked: global.servers.health[key]?.healthy === false,\n        active: !!server.current && key === ServerConnection.key(server.current),","node_kind":"component"},{"id":"status_popover_body_serverstatuspopoverview","label":"ServerStatusPopoverView()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/status-popover-body.tsx","source_location":"L172-L195","layer":"ba