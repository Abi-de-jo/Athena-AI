{"__madarTsExtractorVersion":67,"__madarFileStem":"footer.permission","nodes":[{"id":"footer_permission","label":"footer.permission.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L1"}]},{"id":"footer_permission_buttons","label":"buttons()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L37-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L37"}],"snippet":"function buttons(\n  list: PermissionOption[],\n  selected: PermissionOption,\n  theme: RunFooterTheme,\n  disabled: boolean,\n  onHover: (option: PermissionOption) => void,\n  onSelect: (option: PermissionOption) => void,\n) {\n  return (\n    <box flexDirection=\"row\" gap={1} flexShrink={0}>\n      <For each={list}>\n        {(option) => (\n          <box\n            paddingLeft={1}\n            paddingRight={1}\n            backgroundColor={option === selected ? theme.highlight : transparent}\n            onMouseOver={() => {\n              if (!disabled) onHover(option)\n            }}\n            onMouseUp={() => {\n              if (!disabled) onSelect(option)\n            }}\n          >\n            <text fg={option === selected ? theme.surface : theme.muted}>{permissionLabel(option)}</text>\n          </box>"},{"id":"footer_permission_rejectfield","label":"RejectField()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L69-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L69"}],"snippet":"export function RejectField(props: {\n  theme: RunFooterTheme\n  text: string\n  disabled: boolean\n  onChange: (text: string) => void\n  onConfirm: () => void\n  onCancel: () => void\n}) {\n  let area: TextareaRenderable | undefined\n\n  createEffect(() => {\n    if (!area || area.isDestroyed) {\n      return\n    }\n\n    if (area.plainText !== props.text) {\n      area.setText(props.text)\n      area.cursorOffset = props.text.length\n    }\n\n    queueMicrotask(() => {\n      if (!area || area.isDestroyed || props.disabled) {\n        return\n      }\n      area.focus()","node_kind":"component"},{"id":"footer_permission_runpermissionbody","label":"RunPermissionBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L132-L472","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L132"}],"snippet":"export function RunPermissionBody(props: {\n  request: PermissionRequest\n  theme: RunFooterTheme\n  block: RunBlockTheme\n  diffStyle?: RunDiffStyle\n  onReply: (input: PermissionReply) => void | Promise<void>\n}) {\n  const dims = useTerminalDimensions()\n  const [state, setState] = createSignal(createPermissionBodyState(props.request.id))\n  const info = createMemo(() => permissionInfo(props.request))\n  const ft = createMemo(() => toolFiletype(info().file))\n  const narrow = createMemo(() => footerWidthPolicy(dims().width).dialog.narrow)\n  const opts = createMemo(() => permissionOptions(state().stage))\n  const busy = createMemo(() => state().submitting)\n  const title = createMemo(() => {\n    if (state().stage === \"always\") {\n      return \"Always allow\"\n    }\n\n    if (state().stage === \"reject\") {\n      return \"Reject permission\"\n    }\n\n    return \"Permission required\"\n  })","node_kind":"component"},{"id":"footer_permission_runpermissionbody_shift","label":"shift()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L167-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L167"}],"snippet":"shift = (dir: -1 | 1) => {\n    setState((prev) => permissionShift(prev, dir))\n  }"},{"id":"footer_permission_runpermissionbody_submit","label":"submit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L171-L185","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L171"}],"snippet":"submit = async (next: PermissionReply) => {\n    setState((prev) => ({\n      ...prev,\n      submitting: true,\n    }))\n\n    try {\n      await props.onReply(next)\n    } catch {\n      setState((prev) => ({\n        ...prev,\n        submitting: false,\n      }))\n    }\n  }"},{"id":"footer_permission_runpermissionbody_run","label":"run()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L187-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L187"}],"snippet":"run = (option: PermissionOption) => {\n    const cur = state()\n    const next = permissionRun(cur, props.request.id, option)\n    if (next.state !== cur) {\n      setState(next.state)\n    }\n\n    if (!next.reply) {\n      return\n    }\n\n    void submit(next.reply)\n  }"},{"id":"footer_permission_runpermissionbody_reject","label":"reject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L201-L208","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L201"}],"snippet":"reject = () => {\n    const next = permissionReject(state(), props.request.id)\n    if (!next) {\n      return\n    }\n\n    void submit(next)\n  }"},{"id":"footer_permission_runpermissionbody_cancelreject","label":"cancelReject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L210-L212","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L210"}],"snippet":"cancelReject = () => {\n    setState((prev) => permissionCancel(prev))\n  }"}],"edges":[{"source":"footer_permission","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.permission.tsx","source_location":"L14","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/footer.per