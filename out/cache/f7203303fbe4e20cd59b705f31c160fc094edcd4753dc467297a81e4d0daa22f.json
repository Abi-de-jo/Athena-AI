{"__madarTsExtractorVersion":67,"__madarFileStem":"plugins","nodes":[{"id":"plugins","label":"plugins.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L1"}]},{"id":"plugins_state","label":"state()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L11-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L11"}],"snippet":"function state(api: TuiPluginApi, item: TuiPluginStatus) {\n  if (!item.enabled) {\n    return <span style={{ fg: api.theme.current.textMuted }}>disabled</span>\n  }\n\n  return (\n    <span style={{ fg: item.active ? api.theme.current.success : api.theme.current.error }}>\n      {item.active ? \"active\" : \"inactive\"}\n    </span>\n  )\n}"},{"id":"plugins_source","label":"source()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L23-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L23"}],"snippet":"function source(spec: string) {\n  if (!spec.startsWith(\"file://\")) return\n  return fileURLToPath(spec)\n}"},{"id":"plugins_meta","label":"meta()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L28-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L28"}],"snippet":"function meta(item: TuiPluginStatus, width: number) {\n  if (item.source === \"internal\") {\n    if (width >= 120) return \"Built-in plugin\"\n    return \"Built-in\"\n  }\n  const next = source(item.spec)\n  if (next) return next\n  return item.spec\n}"},{"id":"plugins_install","label":"Install()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L38-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L38"}],"snippet":"function Install(props: { api: TuiPluginApi }) {\n  const [global, setGlobal] = createSignal(false)\n  const [busy, setBusy] = createSignal(false)\n\n  useBindings(() => ({\n    enabled: !busy(),\n    bindings: [{ key: \"tab\", desc: \"Toggle install scope\", group: \"Plugins\", cmd: () => setGlobal((value) => !value) }],\n  }))\n\n  return (\n    <props.api.ui.DialogPrompt\n      title=\"Install plugin\"\n      placeholder=\"npm package name\"\n      busy={busy()}\n      busyText=\"Installing plugin...\"\n      description={() => (\n        <box flexDirection=\"row\" gap={1}>\n          <text fg={props.api.theme.current.textMuted}>scope:</text>\n          <text fg={busy() ? props.api.theme.current.textMuted : props.api.theme.current.text}>\n            {global() ? \"global\" : \"local\"}\n          </text>\n          <Show when={!busy()}>\n            <text fg={props.api.theme.current.textMuted}>(tab toggle)</text>\n          </Show>\n        </box>","node_kind":"component"},{"id":"plugins_row","label":"row()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L135-L144","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L135"}],"snippet":"function row(api: TuiPluginApi, item: TuiPluginStatus, width: number): DialogSelectOption<string> {\n  return {\n    title: item.id,\n    value: item.id,\n    category: item.source === \"internal\" ? \"Internal\" : \"External\",\n    description: meta(item, width),\n    footer: state(api, item),\n    disabled: item.id === id,\n  }\n}"},{"id":"plugins_showinstall","label":"showInstall()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L146-L148","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L146"}],"snippet":"function showInstall(api: TuiPluginApi) {\n  api.ui.dialog.replace(() => <Install api={api} />)\n}"},{"id":"plugins_view","label":"View()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L150-L232","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L150"}],"snippet":"function View(props: { api: TuiPluginApi }) {\n  const size = useTerminalDimensions()\n  const [list, setList] = createSignal(props.api.plugins.list())\n  const [cur, setCur] = createSignal<string | undefined>()\n  const [lock, setLock] = createSignal(false)\n\n  createEffect(() => {\n    const width = size().width\n    if (width >= 128) {\n      props.api.ui.dialog.setSize(\"xlarge\")\n      return\n    }\n    if (width >= 96) {\n      props.api.ui.dialog.setSize(\"large\")\n      return\n    }\n    props.api.ui.dialog.setSize(\"medium\")\n  })\n\n  const rows = createMemo(() =>\n    [...list()]\n      .sort((a, b) => {\n        const x = a.source === \"internal\" ? 1 : 0\n        const y = b.source === \"internal\" ? 1 : 0\n        if (x !== y) return x - y","node_kind":"component"},{"id":"plugins_view_flip","label":"flip()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L180-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L180"}],"snippet":"flip = (x: string) => {\n    if (lock()) return\n    const item = list().find((entry) => entry.id === x)\n    if (!item) return\n    setLock(true)\n    const task = item.active ? props.api.plugins.deactivate(x) : props.api.plugins.activate(x)\n    void task\n      .then((ok) => {\n        if (!ok) {\n          props.api.ui.toast({\n            variant: \"error\",\n            message: `Failed to update plugin ${item.id}`,\n          })\n        }\n        setList(props.api.plugins.list())\n      })\n      .finally(() => {\n        setLock(false)\n      })\n  }"},{"id":"plugins_show","label":"show()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L234-L236","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L234"}],"snippet":"function show(api: TuiPluginApi) {\n  api.ui.dialog.replace(() => <View api={api} />)\n}"},{"id":"plugins_tui","label":"tui()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L238-L262","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L238"}],"snippet":"tui: TuiPlugin = async (api) => {\n  api.keymap.registerLayer({\n    commands: [\n      {\n        name: \"plugins.list\",\n        title: \"Plugins\",\n        category: \"System\",\n        namespace: \"palette\",\n        run() {\n          show(api)\n        },\n      },\n      {\n        name: \"plugins.install\",\n        title: \"Install plugin\",\n        category: \"System\",\n        namespace: \"palette\",\n        run() {\n          showInstall(api)\n        },\n      },\n    ],\n    bindings: api.tuiConfig.keybinds.gather(\"plugins.palette\", [\"plugins.list\", \"plugins.install\"]),\n  })\n}"}],"edges":[{"source":"plugins","target":"tui","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L1"}],"weight":1},{"source":"plugins","target":"builtins","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/plugins.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugin