{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_tui_src_clipboard","nodes":[{"id":"packages_tui_src_clipboard","label":"clipboard.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L1"}]},{"id":"packages_tui_src_clipboard_command","label":"command()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L9-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L9"}],"snippet":"function command(command: string, args: string[] = [], input?: string) {\n  return new Promise<Buffer>((resolve, reject) => {\n    const child = spawn(command, args, { stdio: [input === undefined ? \"ignore\" : \"pipe\", \"pipe\", \"ignore\"] })\n    const output: Buffer[] = []\n    child.on(\"error\", reject)\n    child.stdout?.on(\"data\", (chunk: Buffer) => output.push(chunk))\n    child.on(\"close\", (code) => {\n      if (code === 0) return resolve(Buffer.concat(output))\n      reject(new Error(`${command} exited with code ${code}`))\n    })\n    if (input !== undefined) child.stdin?.end(input)\n  })\n}"},{"id":"packages_tui_src_clipboard_writeosc52","label":"writeOsc52()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L23-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L23"}],"snippet":"function writeOsc52(text: string) {\n  if (!process.stdout.isTTY) return\n  const sequence = `\\x1b]52;c;${Buffer.from(text).toString(\"base64\")}\\x07`\n  process.stdout.write(process.env.TMUX || process.env.STY ? `\\x1bPtmux;\\x1b${sequence}\\x1b\\\\` : sequence)\n}"},{"id":"packages_tui_src_clipboard_read","label":"read()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L29-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L29"}],"snippet":"export async function read() {\n  if (platform() === \"darwin\") {\n    const file = path.join(tmpdir(), \"opencode-clipboard.png\")\n    try {\n      await exec(\"osascript\", [\n        \"-e\",\n        'set imageData to the clipboard as \"PNGf\"',\n        \"-e\",\n        `set fileRef to open for access POSIX file \"${file}\" with write permission`,\n        \"-e\",\n        \"set eof fileRef to 0\",\n        \"-e\",\n        \"write imageData to fileRef\",\n        \"-e\",\n        \"close access fileRef\",\n      ])\n      return { data: (await readFile(file)).toString(\"base64\"), mime: \"image/png\" }\n    } catch {\n      // Fall through to text clipboard.\n    } finally {\n      await rm(file, { force: true }).catch(() => {})\n    }\n  }\n\n  if (platform() === \"win32\" || release().includes(\"WSL\")) {"},{"id":"packages_tui_src_clipboard_copycommand","label":"copyCommand()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L76-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L76"}],"snippet":"export function copyCommand(\n  os: NodeJS.Platform,\n  wayland: boolean,\n  has: (name: string) => boolean,\n): string[] | undefined {\n  if (os === \"darwin\" && has(\"osascript\")) return [\"osascript\"]\n  if (os === \"linux\" && wayland && has(\"wl-copy\")) return [\"wl-copy\"]\n  if (os === \"linux\" && has(\"xclip\")) return [\"xclip\", \"-selection\", \"clipboard\"]\n  if (os === \"linux\" && has(\"xsel\")) return [\"xsel\", \"--clipboard\", \"--input\"]\n  if (os === \"win32\" && has(\"powershell.exe\")) {\n    return [\n      \"powershell.exe\",\n      \"-NonInteractive\",\n      \"-NoProfile\",\n      \"-Command\",\n      \"[Console]::InputEncoding = [System.Text.Encoding]::UTF8; Set-Clipboard -Value ([Console]::In.ReadToEnd())\",\n    ]\n  }\n}"},{"id":"packages_tui_src_clipboard_getcopymethod","label":"getCopyMethod()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L98-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L98"}],"snippet":"function getCopyMethod() {\n  return (copyMethod ??= (async () => {\n    const { which } = await import(\"@rimuru-ai/core/util/which\")\n    const native = copyCommand(platform(), Boolean(process.env.WAYLAND_DISPLAY), (name) => Boolean(which(name)))\n    if (native?.[0] === \"osascript\") {\n      return async (text: string) => {\n        const escaped = text.replace(/\\\\/g, \"\\\\\\\\\").replace(/\"/g, '\\\\\"')\n        await command(\"osascript\", [\"-e\", `set the clipboard to \"${escaped}\"`]).catch(() => undefined)\n      }\n    }\n    if (native) {\n      return async (text: string) => {\n        await command(native[0], native.slice(1), text).catch(() => undefined)\n      }\n    }\n    return async (text: string) => {\n      const { default: clipboardy } = await import(\"clipboardy\")\n      await clipboardy.write(text).catch(() => undefined)\n    }\n  })())\n}"},{"id":"packages_tui_src_clipboard_write","label":"write()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L120-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L120"}],"snippet":"export async function write(text: string) {\n  writeOsc52(text)\n  const method = await getCopyMethod()\n  await method(text)\n}"}],"edges":[{"source":"packages_tui_src_clipboard","target":"child_process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L1"}],"weight":1},{"source":"packages_tui_src_clipboard","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L2"}],"weight":1},{"source":"packages_tui_src_clipboard","target":"os","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/clipboard.ts","source_location":"L3"}],"weight":1},{"source":"packages_tui_src_clipboard","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/r