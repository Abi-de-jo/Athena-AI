{"__madarTsExtractorVersion":67,"__madarFileStem":"models.test","nodes":[{"id":"models_test","label":"models.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L1"}]},{"id":"models_test_mockstate","label":"MockState","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L71-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L71"}],"snippet":"interface MockState {\n  body: string\n  status: number\n  calls: Array<{ url: string; userAgent: string | null }>\n}"},{"id":"models_test_makemockclient","label":"makeMockClient()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L77-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L77"}],"snippet":"makeMockClient = (state: Ref.Ref<MockState>) =>\n  HttpClient.make((request) =>\n    Effect.gen(function* () {\n      yield* Ref.update(state, (s) => ({\n        ...s,\n        calls: [...s.calls, { url: request.url, userAgent: request.headers[\"user-agent\"] ?? null }],\n      }))\n      const s = yield* Ref.get(state)\n      return HttpClientResponse.fromWeb(request, new Response(s.body, { status: s.status }))\n    }),\n  )"},{"id":"models_test_buildlayer","label":"buildLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L89-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L89"}],"snippet":"buildLayer = (state: Ref.Ref<MockState>) =>\n  // Layer.fresh is required: ModelsDev.layer is a module-level Layer constant,\n  // and Effect.provide uses a process-global MemoMap by default — without fresh,\n  // every test would reuse the cachedInvalidateWithTTL state from the first run.\n  Layer.fresh(ModelsDev.layer).pipe(\n    Layer.provide(Layer.succeed(HttpClient.HttpClient, makeMockClient(state))),\n    Layer.provide(FSUtil.defaultLayer),\n    Layer.provide(EventV2.defaultLayer),\n  )"},{"id":"models_test_writecachetext","label":"writeCacheText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L99-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L99"}],"snippet":"writeCacheText = (text: string, mtimeMs?: number) =>\n  Effect.promise(async () => {\n    await mkdir(Global.Path.cache, { recursive: true })\n    await writeFile(cacheFile, text)\n    if (mtimeMs !== undefined) {\n      const t = mtimeMs / 1000\n      await utimes(cacheFile, t, t)\n    }\n  })"},{"id":"models_test_writecache","label":"writeCache()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L109"}],"snippet":"writeCache = (data: object, mtimeMs?: number) => writeCacheText(JSON.stringify(data), mtimeMs)"},{"id":"models_test_provided","label":"provided()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L111-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L111"}],"snippet":"provided = <A, E>(state: Ref.Ref<MockState>, eff: Effect.Effect<A, E, ModelsDev.Service>) =>\n  eff.pipe(Effect.provide(buildLayer(state)))"}],"edges":[{"source":"models_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L1"}],"weight":1},{"source":"models_test","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L2"}],"weight":1},{"source":"models_test","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/models.test.ts","source_location":"L3"}],"weight":1},{"source":"models_test","target":"fs_util","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Proj