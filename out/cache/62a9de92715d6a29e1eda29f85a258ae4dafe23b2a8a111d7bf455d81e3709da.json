{"__madarTsExtractorVersion":67,"__madarFileStem":"model-catalog","nodes":[{"id":"model_catalog","label":"model-catalog.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L1"}]},{"id":"model_catalog_findmodelcatalogentry","label":"findModelCatalogEntry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L65-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L65"}],"snippet":"export function findModelCatalogEntry(catalog: ModelCatalog, model: string, lab?: string) {\n  const normalizedId = lab ? `${catalogSlug(lab)}/${catalogSlug(model)}` : model.trim().toLowerCase()\n  const leaf = catalogSlug(model)\n  return (\n    catalog.models.find((entry) => entry.id.toLowerCase() === normalizedId) ??\n    catalog.models.find((entry) => (lab ? entry.lab === catalogSlug(lab) : true) && entry.slug === leaf) ??\n    catalog.models.find((entry) => entry.slug === leaf)\n  )\n}"},{"id":"model_catalog_findmodelcataloglab","label":"findModelCatalogLab()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L75-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L75"}],"snippet":"export function findModelCatalogLab(catalog: ModelCatalog, lab: string) {\n  const id = catalogSlug(lab)\n  return catalog.labs.find((entry) => entry.id === id)\n}"},{"id":"model_catalog_formatcataloglabname","label":"formatCatalogLabName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L80-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L80"}],"snippet":"export function formatCatalogLabName(lab: string) {\n  const known: Record<string, string> = {\n    alibaba: \"Alibaba\",\n    anthropic: \"Anthropic\",\n    cohere: \"Cohere\",\n    deepseek: \"DeepSeek\",\n    google: \"Google\",\n    meta: \"Meta\",\n    minimax: \"MiniMax\",\n    mistral: \"Mistral\",\n    moonshotai: \"Moonshot\",\n    openai: \"OpenAI\",\n    perplexity: \"Perplexity\",\n    stepfun: \"StepFun\",\n    tencent: \"Tencent\",\n    xai: \"xAI\",\n    xiaomi: \"Xiaomi\",\n    zai: \"Z.ai\",\n    zhipuai: \"Zhipu\",\n  }\n  return known[catalogSlug(lab)] ?? lab.replace(/[-_]/g, \" \").replace(/\\b\\w/g, (letter) => letter.toUpperCase())\n}"},{"id":"model_catalog_catalogslug","label":"catalogSlug()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L103-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L103"}],"snippet":"export function catalogSlug(value: string) {\n  return value\n    .trim()\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, \"-\")\n    .replace(/^-+|-+$/g, \"\")\n    .replace(/-{2,}/g, \"-\")\n}"},{"id":"model_catalog_buildmodelcatalog","label":"buildModelCatalog()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L112-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L112"}],"snippet":"function buildModelCatalog(payload: unknown, pricingPayload?: unknown): ModelCatalog {\n  const costs = readCatalogCosts(pricingPayload)\n  const models = (Array.isArray(payload) ? payload : isRecord(payload) ? Object.values(payload) : [])\n    .flatMap(readModelCatalogEntry)\n    .map((model) => ({\n      ...model,\n      cost:\n        costs.get(catalogIdKey(model.id)) ??\n        costs.get(`${model.lab}/${model.slug}`) ??\n        costs.get(model.slug) ??\n        model.cost,\n    }))\n    .toSorted((a, b) => a.lab.localeCompare(b.lab) || displayDateTime(b.releaseDate) - displayDateTime(a.releaseDate))\n  return {\n    models,\n    labs: Object.values(\n      models.reduce<Record<string, ModelCatalogLab>>((result, model) => {\n        result[model.lab] = {\n          id: model.lab,\n          name: formatCatalogLabName(model.lab),\n          models: [...(result[model.lab]?.models ?? []), model],\n        }\n        return result\n      }, {}),\n    ).toSorted((a, b) => a.name.localeCompare(b.name)),"},{"id":"model_catalog_readmodelcatalogentry","label":"readModelCatalogEntry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L140-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L140"}],"snippet":"function readModelCatalogEntry(value: unknown): ModelCatalogEntry[] {\n  if (!isRecord(value)) return []\n  const id = stringValue(value.id)\n  const name = stringValue(value.name)\n  const lab = id?.split(\"/\")[0]\n  const slug = id?.split(\"/\").slice(1).join(\"/\")\n  if (!id || !name || !lab || !slug) return []\n  return [\n    {\n      id,\n      lab: catalogSlug(lab),\n      slug: catalogSlug(slug),\n      name,\n      family: stringValue(value.family),\n      knowledge: stringValue(value.knowledge),\n      releaseDate: stringValue(value.release_date),\n      lastUpdated: stringValue(value.last_updated),\n      limit: readCatalogLimit(value.limit),\n      modalities: readCatalogModalities(value.modalities),\n      openWeights: booleanValue(value.open_weights),\n      reasoning: booleanValue(value.reasoning),\n      toolCall: booleanValue(value.tool_call),\n      attachment: booleanValue(value.attachment),\n      temperature: booleanValue(value.temperature),\n      cost: readCatalogCost(value.cost),"},{"id":"model_catalog_fetchcatalogpayload","label":"fetchCatalogPayload()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L171-L175","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L171"}],"snippet":"async function fetchCatalogPayload(url: string) {\n  return fetch(url)\n    .then((response): Promise<unknown> => (response.ok ? (response.json() as Promise<unknown>) : Promise.resolve()))\n    .catch(() => undefined)\n}"},{"id":"model_catalog_readcatalogcosts","label":"readCatalogCosts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L177-L204","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L177"}],"snippet":"function readCatalogCosts(payload: unknown) {\n  const costs = new Map<string, ModelCatalogCost>()\n  const add = (model: unknown, provider?: string) => {\n    if (!isRecord(model)) return\n    const id = stringValue(model.id)\n    const cost = readCatalogCost(model.cost)\n    if (!id || !cost) return\n    costs.set(catalogIdKey(id), cost)\n    costs.set(catalogSlug(id), cost)\n    if (provider && !id.includes(\"/\")) costs.set(`${catalogSlug(provider)}/${catalogSlug(id)}`, cost)\n  }\n\n  if (Array.isArray(payload)) {\n    payload.forEach((model) => add(model))\n    return costs\n  }\n  if (!isRecord(payload)) return costs\n\n  Object.entries(payload).forEach(([key, value]) => {\n    if (!isRecord(value)) return\n    if (isRecord(value.models)) {\n      Object.values(value.models).forEach((model) => add(model, stringValue(value.id) ?? key))\n      return\n    }\n    add(value)"},{"id":"model_catalog_readcatalogcosts_add","label":"add()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L179-L187","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L179"}],"snippet":"add = (model: unknown, provider?: string) => {\n    if (!isRecord(model)) return\n    const id = stringValue(model.id)\n    const cost = readCatalogCost(model.cost)\n    if (!id || !cost) return\n    costs.set(catalogIdKey(id), cost)\n    costs.set(catalogSlug(id), cost)\n    if (provider && !id.includes(\"/\")) costs.set(`${catalogSlug(provider)}/${catalogSlug(id)}`, cost)\n  }"},{"id":"model_catalog_readcatalogcost","label":"readCatalogCost()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L206-L217","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L206"}],"snippet":"function readCatalogCost(value: unknown): ModelCatalogCost | undefined {\n  if (!isRecord(value)) return undefined\n  const input = numberValue(value.input)\n  const output = numberValue(value.output)\n  if (input === undefined || output === undefined) return undefined\n  return {\n    input,\n    output,\n    cacheRead: numberValue(value.cache_read),\n    cacheWrite: numberValue(value.cache_write),\n  }\n}"},{"id":"model_catalog_readcataloglimit","label":"readCatalogLimit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L219-L225","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L219"}],"snippet":"function readCatalogLimit(value: unknown) {\n  if (!isRecord(value)) return undefined\n  return {\n    context: numberValue(value.context),\n    output: numberValue(value.output),\n  }\n}"},{"id":"model_catalog_readcatalogmodalities","label":"readCatalogModalities()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L227-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L227"}],"snippet":"function readCatalogModalities(value: unknown) {\n  if (!isRecord(value)) return { input: [], output: [] }\n  return {\n    input: stringArrayValue(value.input),\n    output: stringArrayValue(value.output),\n  }\n}"},{"id":"model_catalog_readcatalogweights","label":"readCatalogWeights()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L235-L243","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L235"}],"snippet":"function readCatalogWeights(value: unknown) {\n  if (!Array.isArray(value)) return []\n  return value.flatMap((item) => {\n    if (!isRecord(item)) return []\n    const label = stringValue(item.label)\n    const url = stringValue(item.url)\n    return label && url ? [{ label, url }] : []\n  })\n}"},{"id":"model_catalog_readcatalogbenchmarks","label":"readCatalogBenchmarks()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L245-L266","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L245"}],"snippet":"function readCatalogBenchmarks(value: unknown) {\n  if (!Array.isArray(value)) return []\n  return value.flatMap((item) => {\n    if (!isRecord(item)) return []\n    const name = stringValue(item.name)\n    const score = numberValue(item.score)\n    return name && score !== undefined\n      ? [\n          {\n            name,\n            score,\n            metric: stringValue(item.metric),\n            harness: stringValue(item.harness),\n            variant: stringValue(item.variant),\n            dataset: stringValue(item.dataset),\n            version: stringValue(item.version),\n            source: stringValue(item.source),\n          },\n        ]\n      : []\n  })\n}"},{"id":"model_catalog_displaydatetime","label":"displayDateTime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L268-L270","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L268"}],"snippet":"function displayDateTime(value: string | undefined) {\n  return value ? new Date(value).getTime() || 0 : 0\n}"},{"id":"model_catalog_catalogidkey","label":"catalogIdKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L272-L274","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L272"}],"snippet":"function catalogIdKey(value: string) {\n  return value.split(\"/\").map(catalogSlug).join(\"/\")\n}"},{"id":"model_catalog_isrecord","label":"isRecord()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L276-L278","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L276"}],"snippet":"function isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value)\n}"},{"id":"model_catalog_stringvalue","label":"stringValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L280-L282","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L280"}],"snippet":"function stringValue(value: unknown) {\n  return typeof value === \"string\" && value.trim() ? value : undefined\n}"},{"id":"model_catalog_numbervalue","label":"numberValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L284-L286","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L284"}],"snippet":"function numberValue(value: unknown) {\n  return typeof value === \"number\" && Number.isFinite(value) ? value : undefined\n}"},{"id":"model_catalog_booleanvalue","label":"booleanValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L288-L290","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L288"}],"snippet":"function booleanValue(value: unknown) {\n  return value === true\n}"},{"id":"model_catalog_stringarrayvalue","label":"stringArrayValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L292-L296","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L292"}],"snippet":"function stringArrayValue(value: unknown) {\n  return Array.isArray(value)\n    ? value.filter((item): item is string => typeof item === \"string\" && item.trim() !== \"\")\n    : []\n}"}],"edges":[{"source":"model_catalog","target":"router","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L1"}],"weight":1},{"source":"model_catalog","target":"model_catalog_findmodelcatalogentry","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L65"}],"weight":1},{"source":"model_catalog","target":"model_catalog_findmodelcataloglab","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L75"}],"weight":1},{"source":"model_catalog","target":"model_catalog_formatcataloglabname","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/model-catalog.ts","source_location":"L80"}],"weight":1},{"source":"model_catalog","target":"model_catalog_catalogslug","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sta