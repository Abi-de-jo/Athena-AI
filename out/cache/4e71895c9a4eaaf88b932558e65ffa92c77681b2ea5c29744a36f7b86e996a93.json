og-add-server.tsx","source_location":"L24"}],"snippet":"export function DialogAddWslServer(props: DialogWslServerProps = {}) {\n  const language = useLanguage()\n  const platform = usePlatform()\n  const dialog = useDialog()\n  const wslServers = useWslServers()\n  const api = platform.wslServers!\n  const [store, setStore] = createStore({\n    step: undefined as WslServerStep | undefined,\n    selectedDistro: null as string | null,\n    installTarget: undefined as string | undefined,\n    adding: false,\n  })\n  const current = () => wslServers.data\n  let disposed = false\n  onCleanup(() => {\n    disposed = true\n  })\n  const busy = createMemo(() => !!current()?.job || store.adding)\n  const visibleInstalledDistros = createMemo(() =>\n    (current()?.installed ?? []).filter((item) => !isHiddenDistro(item.name)),\n  )\n  const visibleOnlineDistros = createMemo(() => (current()?.online ?? []).filter((item) => !isHiddenDistro(item.name)))\n  const defaultInstalledDistro = createMemo(() => visibleInstalledDistros().find((item) => item.isDefault) ?? null)\n  const existingServerDistros = createMemo(() => new Set((current()?.servers ?? []).map((item) => item.config.distro)))\n  const addableInstalledDistros = createMemo(() => {","node_kind":"component"},{"id":"dialog_add_server_dialogaddwslserver_current","label":"current()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/wsl/dialog-add-server.tsx","source_location":"L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/wsl/dialog-add-server.tsx","source_location":"L36"}],"snippet":"current = () => wslServers.data"},{"id":"dialog_add_server_dialogaddwslserver_run","label":"run()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/wsl/dialog-add-server.tsx","source_location":"L230-L236","layer":"base","provenance":