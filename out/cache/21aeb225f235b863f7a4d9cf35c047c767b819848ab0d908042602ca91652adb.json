{"__madarTsExtractorVersion":67,"__madarFileStem":"path-key","nodes":[{"id":"path_key","label":"path-key.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/path-key.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/path-key.ts","source_location":"L1"}]},{"id":"path_key_isdrive","label":"isDrive()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/path-key.ts","source_location":"L3-L7","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/path-key.ts","source_location":"L3"}],"snippet":"isDrive = (value: string) => {\n  if (value.length !== 2) return false\n  const code = value.charCodeAt(0)\n  return value[1] === \":\" && ((code >= 65 && code <= 90) || (code >= 97 && code <= 122))\n}"},{"id":"path_key_trimtrailingslashes","label":"trimTrailingSlashes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/path-key.ts","source_location":"L9-L14","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/path-key.ts","source_location":"L9"}],"snippet":"trimTrailingSlashes = (value: string) => {\n  for (let i = value.length - 1; i >= 0; i--) {\n    if (value[i] !== \"/\") return value.slice(0, i + 1)\n  }\n  return \"\"\n}"},{"id":"path_key_iswindowspath","label":"isWindowsPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/path-key.ts","source_location":"L16","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Project