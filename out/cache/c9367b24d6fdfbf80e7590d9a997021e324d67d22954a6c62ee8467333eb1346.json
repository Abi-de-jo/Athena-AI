,"provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/assertions.ts","source_location":"L16"}],"snippet":"export function stable(value: unknown): string {\n  return JSON.stringify(sort(value))\n}"},{"id":"assertions_sort","label":"sort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/assertions.ts","source_location":"L20-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/assertions.ts","source_location":"L20"}],"snippet":"function sort(value: unknown): unknown {\n  if (Array.isArray(value)) return value.map(sort)\n  if (!value || typeof value !== \"object\") return value\n  return Object.fromEntries(\n    Object.entries(value)\n      .sort(([left], [right]) => left.localeCompare(right))\n      .map(([key, item]) => [key, sort(item)]),\n  )\n}"},{"id":"assertions_array","label":"array()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/assertions.ts","source_location":"L30-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/assertions.ts","source_location":"L30"}],"snippet":"export function array(value: unknown): asserts value is unknown[] {\n  if (!Array.isArray(value)) throw new Error(\"expected array\")\n}"},{"id":"assertions_object","label":"object()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/assertions.ts","source_location":"L34-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"ex