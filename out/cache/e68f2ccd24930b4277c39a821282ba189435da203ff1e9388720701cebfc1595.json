action()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/review-tab.tsx","source_location":"L65-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/review-tab.tsx","source_location":"L65"}],"snippet":"handleInteraction = () => {\n    userInteracted = true\n\n    if (restoreFrame !== undefined) {\n      cancelAnimationFrame(restoreFrame)\n      restoreFrame = undefined\n    }\n  }"},{"id":"review_tab_sessionreviewtab_dorestore","label":"doRestore()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/review-tab.tsx","source_location":"L74-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/review-tab.tsx","source_location":"L74"}],"snippet":"doRestore = () => {\n    restoreFrame = undefined\n    const el = scroll\n    if (!el || !layout.ready() || userInteracted) return\n    if (el.clientHeight === 0 || el.clientWidth === 0) return\n\n    const s = props.view().scroll(\"review\")\n    if (!s || (s.x === 0 && s.y === 0)) return\n\n    const maxY = Math.max(0, el.scrollHeight - el.clientHeight)\n    const maxX = Math.max(0, el.scrollWidth - el.clientWidth)\n\n    const targetY = Math.min(s.y, maxY)\n    const targetX = Math.min(s.x, maxX)\n\n    if (el.scrollTop === targetY && el.scrollLeft === targetX) return\n\n    if (el.scrollTop !== targetY) el.scrollTop = targetY\n    if (el.scrollLeft !== targetX) el.scrollLeft = targetX\n    restored = { x: el.scrollLeft, y: el.scrollTop }\n  }"},{"id":"review_tab_sessionreviewtab_queuerestore","label":"queueRestore()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/review-tab.tsx","source_location":"L96-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/review-tab.tsx","source_location":"L96"}],"snippet":"queueRestore = () => {\n    if (userInteracted || restoreFrame !== undefined) return\n    restoreFrame = requestAnimationFrame(doRestore)\n  }"},{"id":"review_tab_sessionreviewtab_handlescroll","label":"handleScroll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/review-tab.tsx","source_location":"L101-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/review-tab.tsx","source_location":"L101"}],"snippet":"handleScroll = (event: Event & { currentTarget: HTMLDivElement }) => {\n    const el = event.currentTarget\n    const prev = restored\n    if (prev && el.scrollTop === prev.y && el.scrollLeft === prev.x) {\n      restored = undefined\n      return\n    }\n\n    restored = undefined\n    handleInteraction()\n    if (!layout.ready()) return\n    if (el.clientHeight === 0 || el.clientWidth === 0) return\n\n    props.view().setScroll(\"review\", {\n      x: el.scrollLeft,\n      y: el.scrollTop,\n    })\n  }"}],"edges":[{"source":"review_tab","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/review-tab.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/review-tab.tsx","source_location":"L1"}],"weight":1},{"source":"review_tab","target":"event_listener","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-a