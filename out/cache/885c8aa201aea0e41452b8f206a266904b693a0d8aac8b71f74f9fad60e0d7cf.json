<{ plugin?: Array<string | [string, Record<string, unknown>]> }>,\n    )\n    const plugins = config.plugin ?? []\n    return yield* Effect.gen(function* () {\n      const plugin = yield* Plugin.Service\n      yield* plugin.list()\n    }).pipe(\n      Effect.provide(\n        Plugin.layer.pipe(\n          Layer.provide(EventV2Bridge.defaultLayer),\n          Layer.provide(RuntimeFlags.layer({ disableDefaultPlugins: true, ...flags })),\n          Layer.provide(\n            TestConfig.layer({\n              get: () =>\n                Effect.succeed({\n                  plugin: plugins,\n                  plugin_origins: plugins.map((plugin) => ({ spec: plugin, source, scope: \"local\" as const })),\n                }),\n              directories: () => Effect.succeed([dir]),\n            }),\n          ),"}],"edges":[{"source":"loader_shared_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/plugin/loader-shared.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/plugin/loader-shared.test.ts","source_location":"L1"}],"weight":1},{"source":"loader_shared_test","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/plugin/loader-shared.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/plugin/loader-shared.test.ts","source_location":"L2"}],"weight":1},{"source":"loader_shared_test","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/plugin/loader-shared.test.ts","source_location