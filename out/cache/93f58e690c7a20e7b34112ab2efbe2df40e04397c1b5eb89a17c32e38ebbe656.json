) return\n\n    const control = root.querySelector(CONTROL_SELECTOR) as HTMLInputElement | HTMLTextAreaElement | null\n    if (!control) return\n\n    const shell = control.closest(\n      \"[data-component='text-input-v2'], [data-component='textarea-v2'], [data-component='inline-input-v2']\",\n    ) as HTMLElement | null\n\n    control.id = controlId\n    control.setAttribute(\"aria-labelledby\", labelId)\n\n    const describedBy = ctx.getDescribedBy()\n    if (describedBy) {\n      control.setAttribute(\"aria-describedby\", describedBy)\n    } else {\n      control.removeAttribute(\"aria-describedby\")\n    }\n\n    if (ctx.invalid()) {\n      control.setAttribute(\"aria-invalid\", \"true\")\n      shell?.setAttribute(\"data-invalid\", \"\")\n    } else {"},{"id":"field_v2_fieldlabelinfoicon","label":"FieldLabelInfoIcon()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/field-v2.tsx","source_location":"L140-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/field-v2.tsx","source_location":"L140"}],"snippet":"function FieldLabelInfoIcon() {\n  return (\n    <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n      <path\n        fill-rule=\"evenodd\"\n        clip-rule=\"evenodd\"\n        d=\"M13 13H3V3H13V13ZM6.46777 6.81641V7.81641H7.5791V11.3721H8.5791V6.81641H6.46777ZM7.30078 4.62891V5.62891H8.85645V4.62891H7.30078Z\"\n        fill=\"currentColor\"\n      />\n    </svg>\n  )\n}","node_kind":"component"},{"id":"field_v2_fieldlabelprops","label":"FieldLabelProps","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/v2/components/field-v2.tsx","source_location":"L153-L156","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"ex