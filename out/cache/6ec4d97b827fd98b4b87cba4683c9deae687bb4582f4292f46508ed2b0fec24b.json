iltin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L34"}],"snippet":"encodeEvent = (direction: \"client\" | \"server\", message: Frame): WebSocketEvent =>\n  typeof message === \"string\"\n    ? { direction, kind: \"text\", body: message }\n    : { direction, kind: \"binary\", body: Buffer.from(message).toString(\"base64\"), bodyEncoding: \"base64\" }"},{"id":"socket_decodeevent","label":"decodeEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L39-L40","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L39"}],"snippet":"decodeEvent = (event: WebSocketEvent): Frame =>\n  event.kind === \"text\" ? event.body : new Uint8Array(Buffer.from(event.body, \"base64\"))"},{"id":"socket_redactevent","label":"redactEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L42-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L42"}],"snippet":"redactEvent = (event: WebSocketEvent, redactor: Redactor): WebSocketEvent => {\n  if (event.kind === \"binary\") return event\n  const body =\n    event.direction === \"client\"\n      ? redactor.request({ method: \"WEBSOCKET\", url: \"\", headers: {}, body: event.body }).body\n      : redactor.response({ status: 101, headers: {}, body: event.body }).body\n  return { ...event, body }\n}"},{"id":"socket_comparable","label":"comparable()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L51-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L51"}],"snippet":"comparable = (event: WebSocketEvent, asJson: boolean) => {\n  if (!asJson || event.kind === \"binary\") return JSON.stringify(canonicalizeJson(event))\n  const decoded = decodeJson(event.body)\n  return JSON.stringify(\n    canonicalizeJson({\n      ...event,\n      body: decoded._tag === \"None\" ? event.body : canonicalizeJson(decoded.value),\n    }),\n  )\n}"},{"id":"socket_assertevent","label":"assertEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L62-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L62"}],"snippet":"assertEvent = (actual: WebSocketEvent, expected: WebSocketEvent | undefined, index: number, asJson: boolean) =>\n  Effect.sync(() => {\n    if (expected && comparable(actual, asJson) === comparable(expected, asJson)) return\n    throw new Error(`WebSocket event ${index + 1}: expected ${safeText(expected)}, received ${safeText(actual)}`)\n  })"},{"id":"socket_runhandler","label":"runHandler()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L68-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L68"}],"snippet":"runHandler = <A, E, R>(handler: (value: A) => Effect.Effect<unknown, E, R> | void, value: A) =>\n  Effect.suspend(() => {\n    const result = handler(value)\n    return Effect.isEffect(result) ? Effect.asVoid(result) : Effect.void\n  })"},{"id":"socket_runreplay","label":"runReplay()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L74-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L74"}],"snippet":"runReplay = <A, E, R>(\n  state: ActiveReplay,\n  handler: (value: A) => Effect.Effect<unknown, E, R> | void,\n  decode: (event: WebSocketEvent) => A,\n  onOpen: Effect.Effect<void> | undefined,\n) =>\n  Effect.scoped(\n    Effect.gen(function* () {\n      const handlers = yield* FiberSet.make<unknown, E>()\n      const run = yield* FiberSet.runtime(handlers)<R>()\n      if (onOpen) yield* onOpen\n\n      const drive = Effect.gen(function* () {\n        while (true) {\n          const current = yield* Ref.get(state.progress)\n          const event = state.interaction.events[current.position]\n          if (!event) return\n          if (yield* Ref.get(state.closed))\n            return yield* Effect.die(\n              new Error(\n                `WebSocket closed with unconsumed events: used ${current.position} of ${state.interaction.events.length}`,\n              ),\n            )\n          if (event.direction === \"server\") {\n            yield* Ref.set(state.progress, {"},{"id":"socket_opensnapshot","label":"openSnapshot()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L114-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L114"}],"snippet":"openSnapshot = (request: WebSocketRequest, redactor: Redactor) => {\n  const snapshot = redactor.request({ method: \"GET\", url: request.url, headers: request.headers ?? {}, body: \"\" })\n  return { url: snapshot.url, headers: snapshot.headers }\n}"},{"id":"socket_makerecordingsocket","label":"makeRecordingSocket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L119-L200","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L119"}],"snippet":"makeRecordingSocket = (\n  upstream: Socket.Socket,\n  cassette: CassetteService.Interface,\n  name: string,\n  request: WebSocketRequest,\n  options: WebSocketRecorderOptions,\n  redactor: Redactor,\n) =>\n  Effect.gen(function* () {\n    const active = yield* Ref.make<ActiveRecording | undefined>(undefined)\n    const writeLock = yield* Semaphore.make(1)\n\n    return Socket.make({\n      runRaw: (handler, runOptions) =>\n        Effect.gen(function* () {\n          const state: ActiveRecording = {\n            events: [],\n            eventLock: yield* Semaphore.make(1),\n            accepting: yield* Ref.make(true),\n            opened: false,\n            valid: true,\n          }\n          const occupied = yield* Ref.modify(active, (current) => [current !== undefined, current ?? state])\n          if (occupied) return yield* Effect.die(\"Concurrent runs of a recorded WebSocket are not supported\")\n          yield* upstream"},{"id":"socket_makereplaysocket","label":"makeReplaySocket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L202-L281","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L202"}],"snippet":"makeReplaySocket = (\n  cassette: CassetteService.Interface,\n  name: string,\n  request: WebSocketRequest,\n  options: WebSocketRecorderOptions,\n  redactor: Redactor,\n): Effect.Effect<Socket.Socket, never, Scope.Scope> =>\n  Effect.gen(function* () {\n    const replay = yield* makeReplayState(cassette, name, webSocketInteractions)\n    const active = yield* Ref.make<ActiveReplay | undefined>(undefined)\n\n    return Socket.make({\n      runRaw: (handler, runOptions) =>\n        Effect.gen(function* () {\n          const claimed = yield* replay\n            .claim((interaction, index) =>\n              Effect.sync(() => {\n                const incoming = openSnapshot(request, redactor)\n                if (\n                  interaction &&\n                  JSON.stringify(canonicalizeJson(incoming)) === JSON.stringify(canonicalizeJson(interaction.open))\n                )\n                  return\n                throw new Error(\n                  `WebSocket open ${index + 1}: expected ${safeText(interaction?.open)}, received ${safeText(incoming)}`,"},{"id":"socket_recordinglayer","label":"recordingLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L283-L299","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L283"}],"snippet":"recordingLayer = (\n  name: string,\n  request: WebSocketRequest,\n  options: WebSocketRecorderOptions,\n  forcedMode?: \"record\" | \"replay\",\n): Layer.Layer<Socket.Socket, never, Socket.Socket | CassetteService.Service> =>\n  Layer.effect(\n    Socket.Socket,\n    Effect.gen(function* () {\n      const upstream = yield* Socket.Socket\n      const cassette = yield* CassetteService.Service\n      const redactor = make(options.redact)\n      if ((forcedMode ?? (yield* resolveAutoMode(cassette, name))) === \"record\")\n        return yield* makeRecordingSocket(upstream, cassette, name, request, options, redactor)\n      return yield* makeReplaySocket(cassette, name, request, options, redactor)\n    }),\n  )"},{"id":"socket_socket","label":"socket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L308-L309","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L308"}],"snippet":"socket = (name: string, options: RecorderOptions = {}): Layer.Layer<Socket.Socket, never, Socket.Socket> =>\n  provideCassette(recordingLayer(name, { url: \"\" }, { ...options, compareClientMessagesAsJson: true }), options)"},{"id":"socket_socketlayer","label":"socketLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L312-L317","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L312"}],"snippet":"socketLayer = (\n  name: string,\n  request: WebSocketRequest,\n  options: WebSocketRecorderOptions & { readonly mode: \"record\" | \"replay\" },\n): Layer.Layer<Socket.Socket, never, Socket.Socket> =>\n  provideCassette(recordingLayer(name, request, options, options.mode), options)"},{"id":"socket_providecassette","label":"provideCassette()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L319-L326","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/socket.ts","source_location":"L319"}],"snippet":"provideCassette = (\n  layer: Layer.Layer<So