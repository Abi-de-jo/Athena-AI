{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_sdk_js_src_client","nodes":[{"id":"packages_sdk_js_src_client","label":"client.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L1"}]},{"id":"packages_sdk_js_src_client_pick","label":"pick()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L9-L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L9"}],"snippet":"function pick(value: string | null, fallback?: string) {\n  if (!value) return\n  if (!fallback) return value\n  if (value === fallback) return fallback\n  if (value === encodeURIComponent(fallback)) return fallback\n  return value\n}"},{"id":"packages_sdk_js_src_client_rewrite","label":"rewrite()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L17-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L17"}],"snippet":"function rewrite(request: Request, directory?: string) {\n  if (request.method !== \"GET\" && request.method !== \"HEAD\") return request\n\n  const value = pick(request.headers.get(\"x-rimuru-directory\"), directory)\n  if (!value) return request\n\n  const url = new URL(request.url)\n  if (!url.searchParams.has(\"directory\")) {\n    url.searchParams.set(\"directory\", value)\n  }\n\n  const next = new Request(url, request)\n  next.headers.delete(\"x-rimuru-directory\")\n  return next\n}"},{"id":"packages_sdk_js_src_client_createopencodeclient","label":"createOpencodeClient()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L33-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L33"}],"snippet":"export function createOpencodeClient(config?: Config & { directory?: string }) {\n  if (!config?.fetch) {\n    const customFetch: any = (req: any) => {\n      // @ts-ignore\n      req.timeout = false\n      return fetch(req)\n    }\n    config = {\n      ...config,\n      fetch: customFetch,\n    }\n  }\n\n  if (config?.directory) {\n    config.headers = {\n      ...config.headers,\n      \"x-rimuru-directory\": encodeURIComponent(config.directory),\n    }\n  }\n\n  const client = createClient(config)\n  client.interceptors.request.use((request) => rewrite(request, config?.directory))\n  client.interceptors.error.use(wrapClientError)\n  return new OpencodeClient({ client })\n}"},{"id":"packages_sdk_js_src_client_createopencodeclient_customfetch","label":"customFetch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L35-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L35"}],"snippet":"customFetch: any = (req: any) => {\n      // @ts-ignore\n      req.timeout = false\n      return fetch(req)\n    }"}],"edges":[{"source":"packages_sdk_js_src_client","target":"types_gen","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/client.ts","source_location":"L1","layer":"base","provenance"