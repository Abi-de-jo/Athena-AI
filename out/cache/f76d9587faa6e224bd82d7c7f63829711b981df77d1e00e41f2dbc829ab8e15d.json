{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_cli_cmd_mcp","nodes":[{"id":"packages_opencode_src_cli_cmd_mcp","label":"mcp.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L1"}]},{"id":"packages_opencode_src_cli_cmd_mcp_getauthstatusicon","label":"getAuthStatusIcon()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L26-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L26"}],"snippet":"function getAuthStatusIcon(status: MCP.AuthStatus): string {\n  switch (status) {\n    case \"authenticated\":\n      return \"✓\"\n    case \"expired\":\n      return \"⚠\"\n    case \"not_authenticated\":\n      return \"✗\"\n  }\n}"},{"id":"packages_opencode_src_cli_cmd_mcp_getauthstatustext","label":"getAuthStatusText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L37-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L37"}],"snippet":"function getAuthStatusText(status: MCP.AuthStatus): string {\n  switch (status) {\n    case \"authenticated\":\n      return \"authenticated\"\n    case \"expired\":\n      return \"expired\"\n    case \"not_authenticated\":\n      return \"not authenticated\"\n  }\n}"},{"id":"packages_opencode_src_cli_cmd_mcp_ismcpconfigured","label":"isMcpConfigured()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L51-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L51"}],"snippet":"function isMcpConfigured(config: McpEntry): config is McpConfigured {\n  return typeof config === \"object\" && config !== null && \"type\" in config\n}"},{"id":"packages_opencode_src_cli_cmd_mcp_ismcpremote","label":"isMcpRemote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L56-L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L56"}],"snippet":"function isMcpRemote(config: McpEntry): config is McpRemote {\n  return isMcpConfigured(config) && config.type === \"remote\"\n}"},{"id":"packages_opencode_src_cli_cmd_mcp_configuredservers","label":"configuredServers()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L60-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L60"}],"snippet":"function configuredServers(config: ConfigV1.Info) {\n  return Object.entries(config.mcp ?? {}).filter((entry): entry is [string, McpConfigured] => isMcpConfigured(entry[1]))\n}"},{"id":"packages_opencode_src_cli_cmd_mcp_oauthservers","label":"oauthServers()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L64-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L64"}],"snippet":"function oauthServers(config: ConfigV1.Info) {\n  return configuredServers(config).filter(\n    (entry): entry is [string, McpRemote] => isMcpRemote(entry[1]) && entry[1].oauth !== false,\n  )\n}"},{"id":"packages_opencode_src_cli_cmd_mcp_liststate","label":"listState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L70-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L70"}],"snippet":"function listState() {\n  return Effect.gen(function* () {\n    const cfg = yield* Config.Service\n    const mcp = yield* MCP.Service\n    const config = yield* cfg.get()\n    const statuses = yield* mcp.status()\n    const stored = yield* Effect.all(\n      Object.fromEntries(configuredServers(config).map(([name]) => [name, mcp.hasStoredTokens(name)])),\n      { concurrency: \"unbounded\" },\n    )\n    return { config, statuses, stored }\n  })\n}"},{"id":"packages_opencode_src_cli_cmd_mcp_authstate","label":"authState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L84-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L84"}],"snippet":"function authState() {\n  return Effect.gen(function* () {\n    const cfg = yield* Config.Service\n    const mcp = yield* MCP.Service\n    const config = yield* cfg.get()\n    const auth = yield* Effect.all(\n      Object.fromEntries(oauthServers(config).map(([name]) => [name, mcp.getAuthStatus(name)])),\n      { concurrency: \"unbounded\" },\n    )\n    return { config, auth }\n  })\n}"},{"id":"packages_opencode_src_cli_cmd_mcp_resolveconfigpath","label":"resolveConfigPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L405-L421","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L405"}],"snippet":"async function resolveConfigPath(baseDir: string, global = false) {\n  // Check for existing config files (prefer .jsonc over .json, check .opencode/ subdirectory too)\n  const candidates = [path.join(baseDir, \"opencode.json\"), path.join(baseDir, \"opencode.jsonc\")]\n\n  if (!global) {\n    candidates.push(path.join(baseDir, \".opencode\", \"opencode.json\"), path.join(baseDir, \".opencode\", \"opencode.jsonc\"))\n  }\n\n  for (const candidate of candidates) {\n    if (await Filesystem.exists(candidate)) {\n      return candidate\n    }\n  }\n\n  // Default to opencode.json if none exist\n  return candidates[0]\n}"},{"id":"packages_opencode_src_cli_cmd_mcp_addmcptoconfig","label":"addMcpToConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L423-L438","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L423"}],"snippet":"async function addMcpToConfig(name: string, mcpConfig: ConfigMCPV1.Info, configPath: string) {\n  let text = \"{}\"\n  if (await Filesystem.exists(configPath)) {\n    text = await Filesystem.readText(configPath)\n  }\n\n  // Use jsonc-parser to modify while preserving comments\n  const edits = modify(text, [\"mcp\", name], mcpConfig, {\n    formattingOptions: { tabSize: 2, insertSpaces: true },\n  })\n  const result = applyEdits(text, edits)\n\n  await Filesystem.write(configPath, result)\n\n  return configPath\n}"}],"edges":[{"source":"packages_opencode_src_cli_cmd_mcp","target":"cmd","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_cli_cmd_mcp","target":"config","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L2"}],"weight":1},{"source":"packages_opencode_src_cli_cmd_mcp","target":"effect_cmd","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L3"}],"weight":1},{"source":"packages_opencode_src_cli_cmd_mcp","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/mcp.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/