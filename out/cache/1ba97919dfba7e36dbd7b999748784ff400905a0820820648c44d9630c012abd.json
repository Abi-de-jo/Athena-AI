{"__madarTsExtractorVersion":67,"__madarFileStem":"black-stats","nodes":[{"id":"black_stats","label":"black-stats.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L1"}]},{"id":"black_stats_formatmicrocents","label":"formatMicroCents()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L274-L276","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L274"}],"snippet":"function formatMicroCents(value: number) {\n  return `$${(value / 100000000).toFixed(2)}`\n}"},{"id":"black_stats_formatdate","label":"formatDate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L278-L281","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L278"}],"snippet":"function formatDate(value: Date | null | undefined) {\n  if (!value) return null\n  return value.toISOString().split(\"T\")[0]\n}"},{"id":"black_stats_formatweek","label":"formatWeek()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L283-L285","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L283"}],"snippet":"function formatWeek(value: number) {\n  return formatDate(isoWeekStart(value)) ?? \"\"\n}"},{"id":"black_stats_startofmonth","label":"startOfMonth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L287-L289","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L287"}],"snippet":"function startOfMonth(value: Date) {\n  return new Date(Date.UTC(value.getUTCFullYear(), value.getUTCMonth(), 1))\n}"},{"id":"black_stats_isoweekstart","label":"isoWeekStart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L291-L299","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L291"}],"snippet":"function isoWeekStart(value: number) {\n  const year = Math.floor(value / 100)\n  const weekNumber = value % 100\n  const jan4 = new Date(Date.UTC(year, 0, 4))\n  const day = jan4.getUTCDay() || 7\n  const weekStart = new Date(Date.UTC(year, 0, 4 - (day - 1)))\n  weekStart.setUTCDate(weekStart.getUTCDate() + (weekNumber - 1) * 7)\n  return weekStart\n}"},{"id":"black_stats_tonumber","label":"toNumber()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L301-L306","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L301"}],"snippet":"function toNumber(value: unknown) {\n  if (typeof value === \"number\") return value\n  if (typeof value === \"bigint\") return Number(value)\n  if (typeof value === \"string\") return Number(value)\n  return 0\n}"},{"id":"black_stats_csvcell","label":"csvCell()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L308-L312","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L308"}],"snippet":"function csvCell(value: string | number) {\n  const text = String(value)\n  if (!/[\",\\n]/.test(text)) return text\n  return `\"${text.replace(/\"/g, '\"\"')}\"`\n}"}],"edges":[{"source":"black_stats","target":"index","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L1"}],"weight":1},{"source":"black_stats","target":"billing_sql","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L2"}],"weight":1},{"source":"black_stats","target":"black_stats_formatmicrocents","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/script/black-stats.ts","source_location":"L274","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extra