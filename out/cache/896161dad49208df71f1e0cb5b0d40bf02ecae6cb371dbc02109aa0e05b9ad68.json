{"__madarTsExtractorVersion":67,"__madarFileStem":"editor-zed","nodes":[{"id":"editor_zed","label":"editor-zed.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L1"}]},{"id":"editor_zed_resolvezedselection","label":"resolveZedSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L41-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L41"}],"snippet":"export async function resolveZedSelection(dbPath: string, cwd = process.cwd()): Promise<ZedSelectionResult> {\n  const active = queryZedActiveEditor(dbPath, cwd)\n  if (active.type !== \"row\") return active\n\n  const row = active.row\n  if (!row.buffer_path) return { type: \"empty\" }\n\n  const selections = queryZedEditorSelections(dbPath, row)\n  if (selections.type !== \"selections\") return selections\n  const byteRanges = selections.selections\n    .flatMap((selection) => {\n      if (selection.selection_start == null || selection.selection_end == null) return []\n      return [\n        {\n          start: Math.min(selection.selection_start, selection.selection_end),\n          end: Math.max(selection.selection_start, selection.selection_end),\n        },\n      ]\n    })\n    .sort((left, right) => left.start - right.start || left.end - right.end)\n  if (byteRanges.length === 0) return { type: \"unavailable\" }\n\n  const contents = queryZedEditorContents(dbPath, row)\n  const text =\n    contents.type === \"contents\" && contents.contents != null"},{"id":"editor_zed_queryzedactiveeditor","label":"queryZedActiveEditor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L89-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L89"}],"snippet":"function queryZedActiveEditor(dbPath: string, cwd: string) {\n  let db: Database | undefined\n  try {\n    db = new Database(dbPath, { readonly: true })\n    const raw = db\n      .query(\n        `select\n          i.kind as item_kind,\n          e.item_id as editor_id,\n          i.workspace_id as workspace_id,\n          w.paths as workspace_paths,\n          w.timestamp as timestamp,\n          e.buffer_path as buffer_path\n        from items i\n        join panes p on p.pane_id = i.pane_id and p.workspace_id = i.workspace_id\n        join workspaces w on w.workspace_id = i.workspace_id\n        left join editors e on e.item_id = i.item_id and e.workspace_id = i.workspace_id\n        where i.active = 1 and p.active = 1\n        order by w.timestamp desc`,\n      )\n      .all()\n\n    const rows = raw.flatMap((row) => {\n      const parsed = decodeZedEditorRow(row)\n      return Option.isSome(parsed) ? [parsed.value] : []"},{"id":"editor_zed_queryzededitorselections","label":"queryZedEditorSelections()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L133-L159","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L133"}],"snippet":"function queryZedEditorSelections(dbPath: string, row: ZedActiveEditorRow) {\n  let db: Database | undefined\n  try {\n    db = new Database(dbPath, { readonly: true })\n    const raw = db\n      .query(\n        `select\n          start as selection_start,\n          end as selection_end\n        from editor_selections\n        where editor_id = $editorID and workspace_id = $workspaceID`,\n      )\n      .all({ $editorID: row.editor_id, $workspaceID: row.workspace_id })\n\n    const selections = raw.flatMap((selection) => {\n      const parsed = decodeZedSelectionRow(selection)\n      return Option.isSome(parsed) ? [parsed.value] : []\n    })\n\n    if (raw.length > 0 && selections.length === 0) return { type: \"unavailable\" as const }\n    return { type: \"selections\" as const, selections }\n  } catch {\n    return { type: \"unavailable\" as const }\n  } finally {\n    db?.close()"},{"id":"editor_zed_queryzededitorcontents","label":"queryZedEditorContents()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L161-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L161"}],"snippet":"function queryZedEditorContents(dbPath: string, row: ZedActiveEditorRow) {\n  let db: Database | undefined\n  try {\n    db = new Database(dbPath, { readonly: true })\n    const parsed = decodeZedEditorContents(\n      db\n        .query(\n          `select contents\n        from editors\n        where item_id = $editorID and workspace_id = $workspaceID`,\n        )\n        .get({ $editorID: row.editor_id, $workspaceID: row.workspace_id }),\n    )\n    if (Option.isNone(parsed)) return { type: \"unavailable\" as const }\n    return { type: \"contents\" as const, contents: parsed.value.contents }\n  } catch {\n    return { type: \"unavailable\" as const }\n  } finally {\n    db?.close()\n  }\n}"},{"id":"editor_zed_iszedactiveeditorrow","label":"isZedActiveEditorRow()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L183-L185","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L183"}],"snippet":"function isZedActiveEditorRow(row: ZedEditorRow): row is ZedActiveEditorRow {\n  return row.item_kind === \"Editor\" && row.editor_id != null\n}"},{"id":"editor_zed_resolvezeddbpath","label":"resolveZedDbPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L187-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L187"}],"snippet":"export function resolveZedDbPath() {\n  const candidates = [\n    process.env.OPENCODE_ZED_DB,\n    path.join(os.homedir(), \"Library\", \"Application Support\", \"Zed\", \"db\", \"0-stable\", \"db.sqlite\"),\n    path.join(os.homedir(), \".local\", \"share\", \"zed\", \"db\", \"0-stable\", \"db.sqlite\"),\n  ].filter((item): item is string => Boolean(item))\n\n  return candidates.find((item) => isFile(item))\n}"},{"id":"editor_zed_iszedterminal","label":"isZedTerminal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L197-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L197"}],"snippet":"export function isZedTerminal() {\n  return process.env.ZED_TERM === \"true\" || process.env.TERM_PROGRAM?.toLowerCase() === \"zed\"\n}"},{"id":"editor_zed_isfile","label":"isFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L201-L207","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L201"}],"snippet":"function isFile(item: string) {\n  try {\n    return statSync(item).isFile()\n  } catch {\n    return false\n  }\n}"},{"id":"editor_zed_scorezedworkspace","label":"scoreZedWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L209-L214","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L209"}],"snippet":"function scoreZedWorkspace(workspacePaths: string | null, cwd: string) {\n  return zedWorkspacePaths(workspacePaths).reduce((score, item) => {\n    if (pathContains(item, cwd)) return Math.max(score, path.resolve(item).length)\n    return score\n  }, 0)\n}"},{"id":"editor_zed_zedworkspacepaths","label":"zedWorkspacePaths()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L216-L221","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L216"}],"snippet":"function zedWorkspacePaths(value: string | null) {\n  if (!value) return []\n  const parsed = parseJson(value)\n  if (Array.isArray(parsed)) return parsed.filter((item): item is string => typeof item === \"string\")\n  return value.split(/\\r?\\n/).filter(Boolean)\n}"},{"id":"editor_zed_offsettoposition","label":"offsetToPosition()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L223-L226","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L223"}],"snippet":"export function offsetToPosition(text: string, offset: number) {\n  const stringOffset = utf8ByteOffsetToStringIndex(text, offset)\n  return offsetsToSelection(text, stringOffset, stringOffset).start\n}"},{"id":"editor_zed_utf8byteoffsettostringindex","label":"utf8ByteOffsetToStringIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L228-L243","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L228"}],"snippet":"function utf8ByteOffsetToStringIndex(text: string, byteOffset: number) {\n  if (byteOffset <= 0) return 0\n\n  let bytes = 0\n  for (let index = 0; index < text.length; ) {\n    const codePoint = text.codePointAt(index)\n    if (codePoint === undefined) return text.length\n\n    const nextIndex = index + (codePoint > 0xffff ? 2 : 1)\n    bytes += utf8.encode(text.slice(index, nextIndex)).length\n    if (bytes >= byteOffset) return nextIndex\n    index = nextIndex\n  }\n\n  return text.length\n}"},{"id":"editor_zed_offsetstoselection","label":"offsetsToSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L245-L266","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L245"}],"snippet":"function offsetsToSelection(text: string, startOffset: number, endOffset: number) {\n  const start = Math.max(0, Math.min(startOffset, text.length))\n  const end = Math.max(0, Math.min(endOffset, text.length))\n  let line = 1\n  let lineStart = 0\n  let startPosition = position(line, lineStart, start)\n  let endPosition = position(line, lineStart, end)\n\n  for (let index = 0; index <= end; index++) {\n    if (index === start) startPosition = position(line, lineStart, index)\n    if (index === end) {\n      endPosition = position(line, lineStart, index)\n      break\n    }\n    if (text[index] === \"\\n\") {\n      line += 1\n      lineStart = index + 1\n    }\n  }\n\n  return { start: startPosition, end: endPosition }\n}"},{"id":"editor_zed_position","label":"position()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L268-L273","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L268"}],"snippet":"function position(line: number, lineStart: number, offset: number) {\n  return {\n    line,\n    character: offset - lineStart + 1,\n  }\n}"},{"id":"editor_zed_pathcontains","label":"pathContains()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L275-L278","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L275"}],"snippet":"function pathContains(parent: string, child: string) {\n  const relative = path.relative(path.resolve(parent), path.resolve(child))\n  return relative === \"\" || (!relative.startsWith(\"..\") && !path.isAbsolute(relative))\n}"},{"id":"editor_zed_parsejson","label":"parseJson()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L280-L286","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L280"}],"snippet":"function parseJson(value: string) {\n  try {\n    return JSON.parse(value) as unknown\n  } catch {\n    return\n  }\n}"}],"edges":[{"source":"editor_zed","target":"bun_sqlite","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L1"}],"weight":1},{"source":"editor_zed","target":"fs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L2"}],"weight":1},{"source":"editor_zed","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L3"}],"weight":1},{"source":"editor_zed","target":"os","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor-zed.ts","source_location":"L4"}],"weight":1},{"source":"editor_zed","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman