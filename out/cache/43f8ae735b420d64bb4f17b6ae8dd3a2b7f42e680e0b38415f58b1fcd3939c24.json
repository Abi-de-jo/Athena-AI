{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_plugin_loader","nodes":[{"id":"packages_opencode_src_plugin_loader","label":"loader.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L1"}]},{"id":"packages_opencode_src_plugin_loader_errormessage","label":"errorMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L65-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L65"}],"snippet":"function errorMessage(error: unknown) {\n    if (!error || typeof error !== \"object\") return \"\"\n    const message = \"message\" in error && typeof error.message === \"string\" ? error.message : \"\"\n    return message\n  }"},{"id":"packages_opencode_src_plugin_loader_isretryableresolveerror","label":"isRetryableResolveError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L71-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L71"}],"snippet":"function isRetryableResolveError(stage: \"install\" | \"entry\" | \"compatibility\", error: unknown) {\n    if (stage !== \"install\") return false\n    return errorMessage(error).includes(\"missing package.json or index file\")\n  }"},{"id":"packages_opencode_src_plugin_loader_plan","label":"plan()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L77-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L77"}],"snippet":"function plan(item: ConfigPluginV1.Spec): Plan {\n    const spec = ConfigPlugin.pluginSpecifier(item)\n    return { spec, options: ConfigPlugin.pluginOptions(item), deprecated: isDeprecatedPlugin(spec) }\n  }"},{"id":"packages_opencode_src_plugin_loader_resolve","label":"resolve()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L86-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L86"}],"snippet":"export async function resolve(\n    plan: Plan,\n    kind: PluginKind,\n  ): Promise<\n    | { ok: true; value: Resolved }\n    | { ok: false; stage: \"missing\"; value: Missing }\n    | { ok: false; stage: \"install\" | \"entry\" | \"compatibility\"; error: unknown }\n  > {\n    // First make sure the plugin exists locally, installing npm plugins on demand.\n    let target = \"\"\n    try {\n      target = await resolvePluginTarget(plan.spec)\n    } catch (error) {\n      return { ok: false, stage: \"install\", error }\n    }\n    if (!target) return { ok: false, stage: \"install\", error: new Error(`Plugin ${plan.spec} target is empty`) }\n\n    // Then inspect the target for the requested server/tui entrypoint.\n    let base\n    try {\n      base = await createPluginEntry(plan.spec, target, kind)\n    } catch (error) {\n      return { ok: false, stage: \"entry\", error }\n    }\n    if (!base.entry)"},{"id":"packages_opencode_src_plugin_loader_load","label":"load()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L136-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L136"}],"snippet":"export async function load(row: Resolved): Promise<{ ok: true; value: Loaded } | { ok: false; error: unknown }> {\n    let mod\n    try {\n      mod = await import(row.entry)\n    } catch (error) {\n      return { ok: false, error }\n    }\n    if (!mod) return { ok: false, error: new Error(`Plugin ${row.spec} module is empty`) }\n    return { ok: true, value: { ...row, mod } }\n  }"},{"id":"packages_opencode_src_plugin_loader_attempt","label":"attempt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L149-L192","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L149"}],"snippet":"async function attempt<R>(\n    candidate: Candidate,\n    kind: PluginKind,\n    retry: boolean,\n    finish: ((load: Loaded, origin: ConfigPlugin.Origin, retry: boolean) => Promise<R | undefined>) | undefined,\n    missing: ((value: Missing, origin: ConfigPlugin.Origin, retry: boolean) => Promise<R | undefined>) | undefined,\n    report: Report | undefined,\n  ): Promise<AttemptResult<R>> {\n    const plan = candidate.plan\n    const filePlugin = pluginSource(plan.spec) === \"file\"\n\n    // Deprecated plugin packages are silently ignored because they are now built in.\n    if (plan.deprecated) return { retry: false }\n\n    report?.start?.(candidate, retry)\n\n    const resolved = await resolve(plan, kind)\n    if (!resolved.ok) {\n      if (resolved.stage === \"missing\") {\n        // Missing entrypoints are handled separately so callers can still inspect package metadata,\n        // for example to load theme files from a tui plugin package that has no code entrypoint.\n        if (missing) {\n          const value = await missing(resolved.value, candidate.origin, retry)\n          if (value !== undefined) return { value, retry: false }\n        }"},{"id":"packages_opencode_src_plugin_loader_loadexternal","label":"loadExternal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L208-L236","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L208"}],"snippet":"export async function loadExternal<R = Loaded>(input: Input<R>): Promise<R[]> {\n    const candidates = input.items.map((origin) => ({ origin, plan: plan(origin.spec) }))\n    const list: Array<Promise<AttemptResult<R>>> = []\n    for (const candidate of candidates) {\n      list.push(attempt(candidate, input.kind, false, input.finish, input.missing, input.report))\n    }\n    const out = await Promise.all(list)\n    if (input.wait) {\n      let deps: Promise<void> | undefined\n      for (let i = 0; i < candidates.length; i++) {\n        const previous = out[i]\n        if (previous?.value !== undefined) continue\n        if (previous?.retry !== true) continue\n\n        // Only pre-import file plugin setup failures are retried. Bun caches failed dynamic imports,\n        // so dependency waiting cannot fix load/build/runtime/shape failures in this process.\n        const candidate = candidates[i]\n        if (!candidate || pluginSource(candidate.plan.spec) !== \"file\") continue\n        deps ??= input.wait()\n        await deps\n        out[i] = await attempt(candidate, input.kind, true, input.finish, input.missing, input.report)\n      }\n    }\n\n    // Drop skipped/failed entries while preserving the successful result order."}],"edges":[{"source":"packages_opencode_src_plugin_loader","target":"shared","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_plugin_loader","target":"plugin","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L11","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L11"}],"weight":1},{"source":"packages_opencode_src_plugin_loader","target":"version","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L13","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L13"}],"weight":1},{"source":"packages_opencode_src_plugin_loader","target":"packages_opencode_src_plugin_loader_errormessage","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/loader.ts","source_location":"L65"}