{"__madarTsExtractorVersion":67,"__madarFileStem":"webview-zoom","nodes":[{"id":"webview_zoom","label":"webview-zoom.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L1"}]},{"id":"webview_zoom_clamp","label":"clamp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L32"}],"snippet":"clamp = (value: number) => Math.min(Math.max(value, MIN_ZOOM_LEVEL), MAX_ZOOM_LEVEL)"},{"id":"webview_zoom_applyzoom","label":"applyZoom()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L34-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L34"}],"snippet":"applyZoom = (next: number) => {\n  requestedZoom = next\n  void window.api\n    .setZoomFactor(next)\n    .then(() => {\n      if (requestedZoom !== next) return\n      setWebviewZoom(next)\n    })\n    .catch(() => {\n      if (requestedZoom !== next) return\n      requestedZoom = webviewZoom()\n    })\n}"},{"id":"webview_zoom_setpinchzoomenabled","label":"setPinchZoomEnabled()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L62-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L62"}],"snippet":"setPinchZoomEnabled = (enabled: boolean) => {\n  pinchZoomEnabled = enabled\n  resetWheelPinch()\n  return window.api.setPinchZoomEnabled(enabled)\n}"},{"id":"webview_zoom_resetzoom","label":"resetZoom()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L68"}],"snippet":"resetZoom = () => applyZoom(1)"},{"id":"webview_zoom_zoomin","label":"zoomIn()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L69"}],"snippet":"zoomIn = () => applyZoom(clamp(requestedZoom + 0.2))"},{"id":"webview_zoom_zoomout","label":"zoomOut()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L70","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L70"}],"snippet":"zoomOut = () => applyZoom(clamp(requestedZoom - 0.2))"},{"id":"webview_zoom_resetwheelpinch","label":"resetWheelPinch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L72-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L72"}],"snippet":"resetWheelPinch = () => {\n  clearTimeout(wheelPinch?.timeout)\n  wheelPinch = undefined\n}"},{"id":"webview_zoom_normalizewheeldelta","label":"normalizeWheelDelta()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L77-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L77"}],"snippet":"normalizeWheelDelta = (event: WheelEvent) => {\n  if (event.deltaMode === WheelEvent.DOM_DELTA_LINE) return event.deltaY * 16\n  if (event.deltaMode === WheelEvent.DOM_DELTA_PAGE) return event.deltaY * window.innerHeight\n  return event.deltaY\n}"},{"id":"webview_zoom_updatewheelpinch","label":"updateWheelPinch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L83-L105","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L83"}],"snippet":"updateWheelPinch = (event: WheelEvent) => {\n  wheelPinch ??= {\n    active: false,\n    startZoom: requestedZoom,\n    totalDelta: 0,\n    timeout: undefined,\n  }\n\n  clearTimeout(wheelPinch.timeout)\n  wheelPinch.timeout = setTimeout(resetWheelPinch, WHEEL_PINCH_END_DELAY)\n  wheelPinch.totalDelta += normalizeWheelDelta(event)\n\n  if (!wheelPinch.active && Math.abs(wheelPinch.totalDelta) < WHEEL_PINCH_THRESHOLD) return\n  if (!wheelPinch.active) {\n    wheelPinch.active = true\n    wheelPinch.startZoom = requestedZoom\n    wheelPinch.totalDelta = 0\n    return\n  }\n\n  wheelPinch.active = true\n  applyZoom(clamp(wheelPinch.startZoom - (wheelPinch.totalDelta / WHEEL_PINCH_THRESHOLD) * WHEEL_PINCH_STEP))\n}"}],"edges":[{"source":"webview_zoom","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L5","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L5"}],"weight":1},{"source":"webview_zoom","target":"webview_zoom_clamp","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L32"}],"weight":1},{"source":"webview_zoom","target":"webview_zoom_applyzoom","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L34"}],"weight":1},{"source":"webview_zoom","target":"webview_zoom_setpinchzoomenabled","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/renderer/webview-zoom.ts","source_location":"L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_fil