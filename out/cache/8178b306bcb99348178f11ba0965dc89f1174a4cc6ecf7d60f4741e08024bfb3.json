  const tw = textWidth()\n    return tw > 0 ? progress() * tw : 0\n  }"},{"id":"text_strikethrough_textstrikethrough_overlayclip","label":"overlayClip()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/text-strikethrough.tsx","source_location":"L46-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/text-strikethrough.tsx","source_location":"L46"}],"snippet":"overlayClip = () => {\n    const cw = containerWidth()\n    const tw = textWidth()\n    if (cw <= 0 || tw <= 0) return `inset(0 ${(1 - progress()) * 100}% 0 0)`\n    const remaining = Math.max(0, cw - revealedPx())\n    return `inset(0 ${remaining}px 0 0)`\n  }"},{"id":"text_strikethrough_textstrikethrough_baseclip","label":"baseClip()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/text-strikethrough.tsx","source_location":"L55-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/text-strikethrough.tsx","source_location":"L55"}],"snippet":"baseClip = () => {\n    const px = revealedPx()\n    if (px <= 0.5) return \"none\"\n    return `inset(0 0 0 ${px}px)`\n  }"}],"edges":[{"source":"text_strikethrough","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/text-strikethrough.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/text-strikethrough.tsx","source_location":"L1"}],"weight":1},{"source":"text_strikethrough","target":"resize_observer","relation":"imports_from","confidence":"EXTRACTED"