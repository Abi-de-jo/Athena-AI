{"__madarTsExtractorVersion":67,"__madarFileStem":"dialog-stash","nodes":[{"id":"dialog_stash","label":"dialog-stash.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-stash.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-stash.tsx","source_location":"L1"}]},{"id":"dialog_stash_getrelativetime","label":"getRelativeTime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-stash.tsx","source_location":"L9-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-stash.tsx","source_location":"L9"}],"snippet":"function getRelativeTime(timestamp: number): string {\n  const now = Date.now()\n  const diff = now - timestamp\n  const seconds = Math.floor(diff / 1000)\n  const minutes = Math.floor(seconds / 60)\n  const hours = Math.floor(minutes / 60)\n  const days = Math.floor(hours / 24)\n\n  if (seconds < 60) return \"just now\"\n  if (minutes < 60) return `${minutes}m ago`\n  if (hours < 24) return `${hours}h ago`\n  if (days < 7) return `${days}d ago`\n  return Locale.datetime(timestamp)\n}"},{"id":"dialog_stash_getstashpreview","label":"getStashPreview()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-stash.tsx","source_location":"L24-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-stash.tsx","source_location":"L24"}],"snippet":"function getStashPreview(input: string, maxLength: number = 50): string {\n  const firstLine = input.split(\"\\n\")[0].trim()\n  return Locale.truncate(firstLine, maxLength)\n}"},{"id":"dialog_stash_dialogstash","label":"DialogStash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-stash.tsx","source_location":"L29-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-stash.tsx","source_location":"L29"}],"snippet":"export function DialogStash(props: { onSelect: (entry: StashEntry) => void }) {\n  const dialog = useDialog()\n  const stash = usePromptStash()\n  const { theme } = useTheme()\n\n  const [toDelete, setToDelete] = createSignal<number>()\n  const deleteHint = useCommandShortcut(\"stash.delete\")\n\n  const options = createMemo(() => {\n    const entries = stash.list()\n    // Show most recent first\n    return entries\n      .map((entry, index) => {\n        const isDeleting = toDelete() === index\n        const lineCount = (entry.input.match(/\\n/g)?.length ?? 0) + 1\n        return {\n          title: isDeleting ? `Press ${deleteHint()} again to confirm` : getStashPreview(entry.input),\n          bg: isDeleting ? theme.error : undefined,\n          value: index,\n          description: getRelativeTime(entry.timestamp),\n          footer: lineCount > 1 ? `~${lineCount} lines` : undefined,\n        }\n      })\n      .toReversed()\n  })","node_kind":"component"}],"edges":[{"source":"dialog_stash","target":"dialog","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-stash.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-stash.tsx","source_location":"L1"}],"weight":1},{"source":"dialog_stash","target":"dialog_select","relation":"import