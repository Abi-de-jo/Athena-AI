{"__madarTsExtractorVersion":67,"__madarFileStem":"fake-lsp-server","nodes":[{"id":"fake_lsp_server","label":"fake-lsp-server.js","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L1"}]},{"id":"fake_lsp_server_encode","label":"encode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L22-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L22"}],"snippet":"function encode(message) {\n  const json = JSON.stringify(message)\n  const header = `Content-Length: ${Buffer.byteLength(json, \"utf8\")}\\r\\n\\r\\n`\n  return Buffer.concat([Buffer.from(header, \"utf8\"), Buffer.from(json, \"utf8\")])\n}"},{"id":"fake_lsp_server_decodeframes","label":"decodeFrames()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L28-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L28"}],"snippet":"function decodeFrames(buffer) {\n  const results = []\n  let idx\n  while ((idx = buffer.indexOf(\"\\r\\n\\r\\n\")) !== -1) {\n    const header = buffer.slice(0, idx).toString(\"utf8\")\n    const match = /Content-Length:\\s*(\\d+)/i.exec(header)\n    const length = match ? parseInt(match[1], 10) : 0\n    const bodyStart = idx + 4\n    const bodyEnd = bodyStart + length\n    if (buffer.length < bodyEnd) break\n    results.push(buffer.slice(bodyStart, bodyEnd).toString(\"utf8\"))\n    buffer = buffer.slice(bodyEnd)\n  }\n  return { messages: results, rest: buffer }\n}"},{"id":"fake_lsp_server_send","label":"send()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L44-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L44"}],"snippet":"function send(message) {\n  process.stdout.write(encode(message))\n}"},{"id":"fake_lsp_server_sendrequest","label":"sendRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L48-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L48"}],"snippet":"function sendRequest(method, params) {\n  const id = nextId++\n  send({ jsonrpc: \"2.0\", id, method, params })\n  return id\n}"},{"id":"fake_lsp_server_sendresponse","label":"sendResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L54-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L54"}],"snippet":"function sendResponse(id, result) {\n  send({ jsonrpc: \"2.0\", id, result })\n}"},{"id":"fake_lsp_server_sendnotification","label":"sendNotification()","file_type":"code","source_file":"/home