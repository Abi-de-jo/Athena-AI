esult), delayMs)\n}"},{"id":"fake_lsp_server_diagnosticsforidentifier","label":"diagnosticsForIdentifier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L82-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L82"}],"snippet":"function diagnosticsForIdentifier(identifier) {\n  return pullConfig.documentDiagnosticsByIdentifier[identifier] ?? pullConfig.documentDiagnostics\n}"},{"id":"fake_lsp_server_workspacediagnosticsforidentifier","label":"workspaceDiagnosticsForIdentifier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L86-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L86"}],"snippet":"function workspaceDiagnosticsForIdentifier(identifier) {\n  return pullConfig.workspaceDiagnosticsByIdentifier[identifier] ?? pullConfig.workspaceDiagnostics\n}"},{"id":"fake_lsp_server_documentdelayforidentifier","label":"documentDelayForIdentifier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L90-L92","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L90"}],"snippet":"function documentDelayForIdentifier(identifier) {\n  return pullConfig.documentDelayMsByIdentifier[identifier] ?? pullConfig.delayMs\n}"},{"id":"fake_lsp_server_workspacedelayforidentifier","label":"workspaceDelayForIdentifier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L94-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L94"}],"snippet":"function workspaceDelayForIdentifier(identifier) {\n  return pullConfig.workspaceDelayMsByIdentifier[identifier] ?? pullConfig.delayMs\n}"},{"id":"fake_lsp_server_handle","label":"handle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L98-L242","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L98"}],"snippet":"function handle(raw) {\n  let data\n  try {\n    data = JSON.parse(raw)\n  } catch {\n    return\n  }\n\n  if (typeof data.method === \"undefined\" && typeof data.id !== \"undefined\") {\n    const pending = pendingClientRequests.get(data.id)\n    if (!pending) return\n    pendingClientRequests.delete(data.id)\n    sendResponse(pending, data.result ?? null)\n    return\n  }\n\n  if (data.method === \"initialize\") {\n    initializeParams = data.params\n    sendResponse(data.id, {\n      capabilities: {\n        textDocumentSync: {\n          change: 2,\n        },\n      },\n    })"}],"edges":[{"source":"fake_lsp_server","target":"fake_lsp_server_encode","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/lsp/fake-lsp-server.js","source_location":"L22","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/home/gowdaman