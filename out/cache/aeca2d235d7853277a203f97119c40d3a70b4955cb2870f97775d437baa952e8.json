jects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L29-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L29"}],"snippet":"export function jitCompatCheck(isEnabled: boolean | undefined) {\n  if (!isEnabled) return false\n  try {\n    return new Function(\"input\", '\"use strict\"; return input;')(true) === true\n  } catch {\n    return false\n  }\n}"},{"id":"drizzle_utils_orderselectedfields","label":"orderSelectedFields()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L38-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L38"}],"snippet":"export function orderSelectedFields<TColumn extends Column>(\n  fields: Record<string, unknown>,\n  pathPrefix?: string[],\n): SelectedFieldsOrdered {\n  return Object.entries(fields).flatMap(([name, field]) => {\n    const path = pathPrefix ? [...pathPrefix, name] : [name]\n    if (is(field, Column) || is(field, SQL) || is(field, SQL.Aliased) || is(field, Subquery)) {\n      return [{ path, field }] as SelectedFieldsOrdered\n    }\n    if (is(field, Table)) return orderSelectedFields(getTableColumnsRuntime(field as SQLiteTable), path)\n    return orderSelectedFields(field as Record<string, unknown>, path)\n  }) as SelectedFieldsOrdered\n}"},{"id":"drizzle_utils_mapupdateset","label":"mapUpdateSet()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L52-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L52"}],"snippet":"export function mapUpdateSet<TTable extends SQLiteTable>(table: TTable, values: SQLiteUpdateSetSource<TTable>) {\n  const entries = Object.entries(values).filter(([, value]) => value !== undefined)\n  if (entries.length === 0) throw new Error(\"No values to set\")\n\n  return Object.fromEntries(\n    entries.map(([key, value]) => [\n      key,\n      is(value, SQL) || is(value, Column) ? value : new Param(value, getTableColumnsRuntime(table)[key]),\n    ]),\n  ) as UpdateSet\n}"},{"id":"drizzle_utils_mapresultrow","label":"mapResultRow()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L64-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L64"}],"snippet":"export function mapResultRow(\n  columns: SelectedFieldsOrdered,\n  row: unknown[],\n  joinsNotNullableMap: Record<string, boolean> | undefined,\n) {\n  const nullifyMap: Record<string, string | false> = {}\n  const result: Record<string, unknown> = {}\n\n  columns.forEach((column, columnIndex) => {\n    const decoder = (\n      is(column.field, Column)\n        ? column.field\n        : is(column.field, SQL)\n          ? (column.field as unknown as { decoder: { mapFromDriverValue(value: unknown): unknown } }).decoder\n          : is(column.field, Subquery)\n            ? (column.field._.sql as unknown as { decoder: { mapFromDriverValue(value: unknown): unknown } }).decoder\n            : (column.field.sql as unknown as { decoder: { mapFromDriverValue(value: unknown): unknown } }).decoder\n    ) as {\n      mapFromDriverValue(value: unknown): unknown\n    }\n    const rawValue = row[columnIndex]\n    const value = rawValue === null ? null : decoder.mapFromDriverValue(rawValue)\n    const objectName = column.path[0]\n    let node = result"},{"id":"drizzle_utils_gettablelikename","label":"getTableLikeName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L116-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L116"}],"snippet":"export function getTableLikeName(table: SQLiteTable | Subquery | SQLiteViewBase | SQL) {\n  if (is(table, Subquery)) return table._.alias\n  if (is(table, SQLiteViewBase)) return getViewSelectedFieldsRuntime(table).name\n  if (is(table, SQL)) return undefined\n  return (table as unknown as Record<symbol, string | boolean>)[\n    (table as unknown as Record<symbol, string | boolean>)[TableSymbol.IsAlias]\n      ? TableSymbol.Name\n      : TableSymbol.BaseName\n  ] as string\n}"}],"edges":[{"source":"drizzle_utils","target":"column","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L2"}],"weight":1},{"source":"drizzle_utils","target":"entity","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/internal/drizzle-utils.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extra