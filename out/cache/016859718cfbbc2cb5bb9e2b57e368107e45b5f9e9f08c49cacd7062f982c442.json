{"__madarTsExtractorVersion":67,"__madarFileStem":"proxy-env","nodes":[{"id":"proxy_env","label":"proxy-env.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L1"}]},{"id":"proxy_env_getproxyforurl","label":"getProxyForUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L36-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L36"}],"snippet":"export function getProxyForUrl(input: string | URL) {\n  const url = typeof input === \"string\" ? (URL.canParse(input) ? new URL(input) : undefined) : input\n  if (!url) return\n\n  const protocol = url.protocol.split(\":\", 1)[0]\n  const hostname = url.host.replace(/:\\d*$/, \"\")\n  const port = Number.parseInt(url.port) || DEFAULT_PORTS[protocol] || 0\n  if (!shouldProxy(hostname, port)) return\n\n  const proxy = env(`${protocol}_proxy`) || env(\"all_proxy\")\n  if (!proxy) return\n  return proxy.includes(\"://\") ? proxy : `${protocol}://${proxy}`\n}"},{"id":"proxy_env_shouldproxy","label":"shouldProxy()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L50-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L50"}],"snippet":"function shouldProxy(hostname: string, port: number) {\n  const noProxy = env(\"no_proxy\").toLowerCase()\n  if (!noProxy) return true\n  if (noProxy === \"*\") return false\n\n  return noProxy.split(/[,\\s]/).every((proxy) => {\n    if (!proxy) return true\n\n    const parsed = proxy.match(/^(.+):(\\d+)$/)\n    const proxyHostname = parsed ? parsed[1] : proxy\n    const proxyPort = parsed ? Number.parseInt(parsed[2]) : 0\n    if (proxyPort && proxyPort !== port) return true\n\n    if (!/^[.*]/.test(proxyHostname)) return hostname !== proxyHostname\n    return !hostname.endsWith(proxyHostname.startsWith(\"*\") ? proxyHostname.slice(1) : proxyHostname)\n  })\n}"},{"id":"proxy_env_env","label":"env()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L68-L70","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L68"}],"snippet":"function env(key: string) {\n  return process.env[key.toLowerCase()] || process.env[key.toUpperCase()] || \"\"\n}"}],"edges":[{"source":"proxy_env","target":"proxy_env_getproxyforurl","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L36"}],"weight":1},{"source":"proxy_env","target":"proxy_env_shouldproxy","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/proxy-env.ts","source_location":"L50"}],"weight":1},{