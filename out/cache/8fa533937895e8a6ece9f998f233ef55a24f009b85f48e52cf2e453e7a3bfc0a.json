oup(comments: LineComment[]) {\n  return comments.reduce<Record<string, LineComment[]>>((acc, comment) => {\n    const list = acc[comment.file]\n    const next = cloneComment(comment)\n    if (list) {\n      list.push(next)\n      return acc\n    }\n    acc[comment.file] = [next]\n    return acc\n  }, {})\n}"},{"id":"comments_createcommentsessionstate","label":"createCommentSessionState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/comments.tsx","source_location":"L80-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/comments.tsx","source_location":"L80"}],"snippet":"function createCommentSessionState(store: Store<CommentStore>, setStore: SetStoreFunction<CommentStore>) {\n  const [state, setState] = createStore({\n    focus: null as CommentFocus | null,\n    active: null as CommentFocus | null,\n  })\n\n  const all = () => aggregate(store.comments)\n\n  const setRef = (\n    key: \"focus\" | \"active\",\n    value: CommentFocus | null | ((value: CommentFocus | null) => CommentFocus | null),\n  ) => setState(key, value)\n\n  const setFocus = (value: CommentFocus | null | ((value: CommentFocus | null) => CommentFocus | null)) =>\n    setRef(\"focus\", value)\n\n  const setActive = (value: CommentFocus | null | ((value: CommentFocus | null) => CommentFocus | null)) =>\n    setRef(\"active\", value)\n\n  const list = (file: string) => store.comments[file] ?? []\n\n  const add = (input: Omit<LineComment, \"id\" | \"time\">) => {\n    const next: LineComment = {\n      id: uuid(),\n      time: Date.now(),"},{"id":"comments_createcommentsessionstate_all","label":"all()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/comments.tsx","source_location":"L86","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","st