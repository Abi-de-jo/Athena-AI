of Process.RunFailedError) {\n        const lines = hit.stderr\n          .toString()\n          .split(/\\r?\\n/)\n          .map((line) => line.trim())\n          .filter(Boolean)\n        const errs = lines.filter((line) => line.startsWith(\"error:\")).map((line) => line.replace(/^error:\\s*/, \"\"))\n        const detail = errs[0] ?? lines.at(-1)\n        if (detail) dep.log.error(detail)\n        if (lines.some((line) => line.includes(\"No version matching\"))) {\n          dep.log.info(\"This package depends on a version that is not available in your npm registry.\")\n          dep.log.info(\"Check npm registry/auth settings and try again.\")"}],"edges":[{"source":"plug","target":"prompts","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/plug.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/plug.ts","source_location":"L1"}],"weight":1},{"source":"plug","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/plug.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/plug.ts","source_location":"L2"}],"weight":1},{"source":"plug","target":"paths","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/plug.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/plug.ts","source_location":"L4"}],"weight":1},{"source":"plug","target":"global","relation