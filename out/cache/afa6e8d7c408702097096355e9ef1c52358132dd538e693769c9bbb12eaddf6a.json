{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_test_config_config.test","nodes":[{"id":"packages_rimuru_test_config_config_test","label":"config.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L1"}]},{"id":"packages_rimuru_test_config_config_test_json","label":"json()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L55-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L55"}],"snippet":"json = (request: Parameters<typeof HttpClientResponse.fromWeb>[0], body: unknown, status = 200) =>\n  HttpClientResponse.fromWeb(\n    request,\n    new Response(JSON.stringify(body), {\n      status,\n      headers: { \"content-type\": \"application/json\" },\n    }),\n  )"},{"id":"packages_rimuru_test_config_config_test_wellknownauth","label":"wellKnownAuth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L64-L70","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L64"}],"snippet":"wellKnownAuth = (url: string) =>\n  Layer.mock(Auth.Service)({\n    all: () =>\n      Effect.succeed({\n        [url]: new Auth.WellKnown({ type: \"wellknown\", key: \"TEST_TOKEN\", token: \"test-token\" }),\n      }),\n  })"},{"id":"packages_rimuru_test_config_config_test_remoteconfigclient","label":"remoteConfigClient()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L72-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L72"}],"snippet":"function remoteConfigClient(input: {\n  wellKnown: unknown\n  remote?: unknown\n  remoteHtml?: string\n  seen: { wellKnown?: string; remote?: string; authorization?: string }\n}) {\n  return HttpClient.make((request) => {\n    if (request.url.includes(\".well-known/opencode\")) {\n      input.seen.wellKnown = request.url\n      return Effect.succeed(json(request, input.wellKnown))\n    }\n    if (request.url.includes(\"config.example.com\") && (input.remote !== undefined || input.remoteHtml !== undefined)) {\n      input.seen.remote = request.url\n      input.seen.authorization = request.headers.authorization\n      if (input.remoteHtml !== undefined) {\n        return Effect.succeed(\n          HttpClientResponse.fromWeb(\n            request,\n            new Response(input.remoteHtml, { status: 200, headers: { \"content-type\": \"text/html; charset=utf-8\" } }),\n          ),\n        )\n      }\n      return Effect.succeed(json(request, input.remote))\n    }\n    return Effect.succeed(json(request, {}, 404))"},{"id":"packages_rimuru_test_config_config_test_configlayer","label":"configLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L100-L116","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L100"}],"snippet":"configLayer = (\n  options: {\n    auth?: Layer.Layer<Auth.Service>\n    account?: Layer.Layer<Account.Service>\n    client?: HttpClient.HttpClient\n  } = {},\n) =>\n  Config.layer.pipe(\n    Layer.provide(testFlock),\n    Layer.provide(Env.defaultLayer),\n    Layer.provide(options.auth ?? AuthTest.empty),\n    Layer.provide(options.account ?? AccountTest.empty),\n    Layer.provideMerge(infra),\n    Layer.provide(NpmTest.noop),\n    Layer.provide(Layer.succeed(HttpClient.HttpClient, options.client ?? unexpectedHttp)),\n    Layer.provideMerge(FSUtil.defaultLayer),\n  )"},{"id":"packages_rimuru_test_config_config_test_configit","label":"configIt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L121","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L121"}],"snippet":"configIt = (options?: Parameters<typeof configLayer>[0]) => testEffect(configLayer(options))"},{"id":"packages_rimuru_test_config_config_test_schemaconfig","label":"schemaConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L123","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L123"}],"snippet":"schemaConfig = (config: object) => ({ $schema: \"https://github.com/gowdaman-dev/rimuru-ai/config.json\", ...config })"},{"id":"packages_rimuru_test_config_config_test_providecurrentinstance","label":"provideCurrentInstance()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L125-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L125"}],"snippet":"provideCurrentInstance = <A, E, R>(effect: Effect.Effect<A, E, R>, ctx: InstanceContext) =>\n  effect.pipe(Effect.provideService(InstanceRef, ctx))"},{"id":"packages_rimuru_test_config_config_test_load","label":"load()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L128-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L128"}],"snippet":"load = (ctx: InstanceContext) =>\n  Effect.runPromise(\n    Config.Service.use((svc) => provideCurrentInstance(svc.get(), ctx)).pipe(Effect.scoped, Effect.provide(layer)),\n  )"},{"id":"packages_rimuru_test_config_config_test_cleareffect","label":"clearEffect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L132-L139","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L132"}],"snippet":"clearEffect = (wait = false) =>\n  Config.use\n    .invalidate()\n    .pipe(\n      Effect.scoped,\n      Effect.provide(layer),\n      Effect.andThen(wait ? Effect.promise(() => InstanceRuntime.disposeAllInstances()) : Effect.void),\n    )"},{"id":"packages_rimuru_test_config_config_test_clear","label":"clear()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L140","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L140"}],"snippet":"clear = (wait = false) => Effect.runPromise(clearEffect(wait))"},{"id":"packages_rimuru_test_config_config_test_writemanagedsettingseffect","label":"writeManagedSettingsEffect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L159-L160","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L159"}],"snippet":"writeManagedSettingsEffect = (settings: object, filename?: string) =>\n  FSUtil.use.writeWithDirs(path.join(managedConfigDir, filename ?? \"rimuru.json\"), JSON.stringify(settings))"},{"id":"packages_rimuru_test_config_config_test_writeconfig","label":"writeConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L162-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L162"}],"snippet":"async function writeConfig(dir: string, config: object, name = \"rimuru.json\") {\n  await Filesystem.write(path.join(dir, name), JSON.stringify(config))\n}"},{"id":"packages_rimuru_test_config_config_test_writeconfigeffect","label":"writeConfigEffect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L166-L167","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L166"}],"snippet":"writeConfigEffect = (dir: string, config: object, name = \"rimuru.json\") =>\n  FSUtil.use.writeWithDirs(path.join(dir, name), JSON.stringify(config))"},{"id":"packages_rimuru_test_config_config_test_withinstancedir","label":"withInstanceDir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L169-L175","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L169"}],"snippet":"withInstanceDir = <A, E, R>(dir: string, effect: Effect.Effect<A, E, R>) =>\n  effect.pipe(\n    Effect.provideService(TestInstance, { directory: dir }),\n    provideInstanceEffect(dir),\n    Effect.provide(testInstanceStoreLayer),\n    Effect.provide(CrossSpawnSpawner.defaultLayer),\n  )"},{"id":"packages_rimuru_test_config_config_test_withglobalconfigdir","label":"withGlobalConfigDir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L177-L191","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L177"}],"snippet":"withGlobalConfigDir = <A, E, R>(dir: string, effect: Effect.Effect<A, E, R>) =>\n  Effect.acquireUseRelease(\n    Effect.gen(function* () {\n      const previous = Global.Path.config\n      ;(Global.Path as { config: string }).config = dir\n      yield* clearEffect(true)\n      return previous\n    }),\n    () => effect,\n    (previous) =>\n      Effect.gen(function* () {\n        ;(Global.Path as { config: string }).config = previous\n        yield* clearEffect(true)\n      }),\n  )"},{"id":"packages_rimuru_test_config_config_test_withglobalconfig","label":"withGlobalConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L193-L201","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L193"}],"snippet":"withGlobalConfig = <A, E, R>(\n  input: { config?: object; name?: string },\n  fn: (input: { dir: string }) => Effect.Effect<A, E, R>,\n) =>\n  Effect.gen(function* () {\n    const dir = yield* tmpdirScoped()\n    if (input.config) yield* writeConfigEffect(dir, schemaConfig(input.config), input.name)\n    return yield* withGlobalConfigDir(dir, fn({ dir }))\n  })"},{"id":"packages_rimuru_test_config_config_test_withconfigtree","label":"withConfigTree()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L203-L220","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L203"}],"snippet":"withConfigTree = <A, E, R>(\n  input: { global?: object; project?: object; local?: object },\n  effect: Effect.Effect<A, E, R>,\n) =>\n  Effect.gen(function* () {\n    const root = yield* tmpdirScoped()\n    const global = yield* tmpdirScoped()\n    const directory = path.join(root, \"project\")\n    yield* Effect.all(\n      [\n        input.global ? writeConfigEffect(global, schemaConfig(input.global)) : undefined,\n        input.project ? writeConfigEffect(directory, schemaConfig(input.project)) : undefined,\n        input.local ? writeConfigEffect(path.join(directory, \".rimuru\"), schemaConfig(input.local)) : undefined,\n      ].filter((effect): effect is Effect.Effect<void, FSUtil.Error, FSUtil.Service> => effect !== undefined),\n      { concurrency: \"unbounded\" },\n    )\n    return yield* withGlobalConfigDir(global, withInstanceDir(directory, effect))\n  })"},{"id":"packages_rimuru_test_config_config_test_wellknown","label":"wellKnown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L222-L244","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L222"}],"snippet":"wellKnown = (input: {\n  authUrl?: string\n  config?: unknown\n  remoteConfig?: { url: string; headers?: Record<string, string> }\n  remote?: unknown\n  remoteHtml?: string\n  wellKnown?: unknown\n}) => {\n  const seen: { wellKnown?: string; remote?: string; authorization?: string } = {}\n  const client = remoteConfigClient({\n    seen,\n    wellKnown: input.wellKnown ?? {\n      ...(input.config !== undefined ? { config: input.config } : {}),\n      ...(input.remoteConfig !== undefined ? { remote_config: input.remoteConfig } : {}),\n    },\n    remote: input.remote,\n    remoteHtml: input.remoteHtml,\n  })\n  return {\n    seen,\n    it: configIt({ auth: wellKnownAuth(input.authUrl ?? \"https://example.com\"), client }),\n  }\n}"},{"id":"packages_rimuru_test_config_config_test_withprocessenv","label":"withProcessEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L246-L248","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L246"}],"snippet":"function withProcessEnv<A, E, R>(key: string, value: string | undefined, effect: Effect.Effect<A, E, R>) {\n  return withProcessEnvs({ [key]: value }, effect)\n}"},{"id":"packages_rimuru_test_config_config_test_withprocessenvs","label":"withProcessEnvs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L250-L270","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L250"}],"snippet":"function withProcessEnvs<A, E, R>(entries: Record<string, string | undefined>, effect: Effect.Effect<A, E, R>) {\n  return Effect.acquireUseRelease(\n    Effect.sync(() => {\n      const originals: Record<string, string | undefined> = {}\n      for (const [key, value] of Object.entries(entries)) {\n        originals[key] = process.env[key]\n        if (value === undefined) delete process.env[key]\n        else process.env[key] = value\n      }\n      return originals\n    }),\n    () => effect,\n    (originals) =>\n      Effect.sync(() => {\n        for (const [key, original] of Object.entries(originals)) {\n          if (original !== undefined) process.env[key] = original\n          else delete process.env[key]\n        }\n      }),\n  )\n}"},{"id":"packages_rimuru_test_config_config_test_check","label":"check()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L272-L298","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L272"}],"snippet":"async function check(map: (dir: string) => string) {\n  if (process.platform !== \"win32\") return\n  await using globalTmp = await tmpdir()\n  await using tmp = await tmpdir({ git: true, config: { snapshot: true } })\n  const prev = Global.Path.config\n  ;(Global.Path as { config: string }).config = globalTmp.path\n  await clear()\n  try {\n    await writeConfig(globalTmp.path, {\n      $schema: \"https://github.com/gowdaman-dev/rimuru-ai/config.json\",\n      snapshot: false,\n    })\n    await withTestInstance({\n      directory: map(tmp.path),\n      fn: async (ctx) => {\n        const cfg = await load(ctx)\n        expect(cfg.snapshot).toBe(true)\n        expect(ctx.directory).toBe(Filesystem.resolve(tmp.path))\n        expect(ctx.project.id).not.toBe(ProjectV2.ID.global)\n      },\n    })\n  } finally {\n    await InstanceRuntime.disposeAllInstances()\n    ;(Global.Path as { config: string }).config = prev\n    await clear()"}],"edges":[{"source":"packages_rimuru_test_config_config_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_test_config_config_test","target":"config","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L2"}],"weight":1},{"source":"packages_rimuru_test_config_config_test","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/config/config.test.ts","source_location":"L3"}],"weight":1},{"source":"packages_rimuru_test_conf