c/acp/usage.ts","source_location":"L64"}],"snippet":"export class ContextLimitLoader extends Context.Service<ContextLimitLoader, ContextLimitLoaderInterface>()(\n  \"@opencode/ACPUsageContextLimitLoader\",\n) {}"},{"id":"usage_messageloaderfromsdk","label":"messageLoaderFromSDK()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L70-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L70"}],"snippet":"export function messageLoaderFromSDK(sdk: SDK): MessageLoaderInterface {\n  return MessageLoader.of({\n    messages: (input) =>\n      Effect.promise(() =>\n        sdk.session\n          .messages({ sessionID: input.sessionID, directory: input.directory }, { throwOnError: true })\n          .then((response) => response.data ?? []),\n      ),\n  })\n}"},{"id":"usage_messageloaderlayer","label":"messageLoaderLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L81"}],"snippet":"messageLoaderLayer = (sdk: SDK) => Layer.succeed(MessageLoader, messageLoaderFromSDK(sdk))"},{"id":"usage_buildusage","label":"buildUsage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L83-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L83"}],"snippet":"export function buildUsage(message: AssistantTokenCost): Usage {\n  const cachedReadTokens = message.tokens.cache.read\n  const cachedWriteTokens = message.tokens.cache.write\n  const thoughtTokens = message.tokens.reasoning\n\n  return {\n    inputTokens: message.tokens.input,\n    outputTokens: message.tokens.output,\n    totalTokens: message.tokens.input + message.tokens.output + thoughtTokens + cachedReadTokens + cachedWriteTokens,\n    ...(thoughtTokens > 0 ? { thoughtTokens } : {}),\n    ...(cachedReadTokens > 0 ? { cachedReadTokens } : {}),\n    ...(cachedWriteTokens > 0 ? { cachedWriteTokens } : {}),\n  }\n}"},{"id":"usage_latestassistantmessage","label":"latestAssistantMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L98-L102","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L98"}],"snippet":"export function latestAssistantMessage(messages: readonly SessionMessage[]): AssistantMessage | undefined {\n  return messages\n    .filter((message): message is { readonly info: AssistantMessage } => message.info.role === \"assistant\")\n    .at(-1)?.info\n}"},{"id":"usage_totalsessioncost","label":"totalSessionCost()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L104-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L104"}],"snippet":"export function totalSessionCost(messages: readonly SessionMessage[]): number {\n  return messages\n    .filter((message): message is { readonly info: AssistantMessage } => message.info.role === \"assistant\")\n    .reduce((sum, message) => sum + message.info.cost, 0)\n}"},{"id":"usage_findcontextlimit","label":"findContextLimit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L110-L116","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L110"}],"snippet":"export function findContextLimit(\n  providers: Record<ProviderV2.ID, Provider.Info>,\n  providerID: ProviderV2.ID,\n  modelID: ModelV2.ID,\n): number | undefined {\n  return providers[providerID]?.models[modelID]?.limit.context\n}"}],"edges":[{"source":"usage","target":"sdk","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L1"}],"weight":1},{"source":"usage","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L2"}],"weight":1},{"source":"usage","target":"instance_ref","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/usage.ts","source_location":"L3"}],"weight":1},{"source":"usage","target":"instance_store","relation":"imports_from","confidence":