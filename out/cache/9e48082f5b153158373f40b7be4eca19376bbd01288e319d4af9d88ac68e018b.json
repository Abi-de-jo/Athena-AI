{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_plugin_shared","nodes":[{"id":"packages_opencode_src_plugin_shared","label":"shared.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L1"}]},{"id":"packages_opencode_src_plugin_shared_isdeprecatedplugin","label":"isDeprecatedPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L12-L14","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L12"}],"snippet":"export function isDeprecatedPlugin(spec: string) {\n  return DEPRECATED_PLUGIN_PACKAGES.some((pkg) => spec.includes(pkg))\n}"},{"id":"packages_opencode_src_plugin_shared_parse","label":"parse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L16-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L16"}],"snippet":"function parse(spec: string) {\n  try {\n    return npa(spec)\n  } catch {}\n}"},{"id":"packages_opencode_src_plugin_shared_parsepluginspecifier","label":"parsePluginSpecifier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L22-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L22"}],"snippet":"export function parsePluginSpecifier(spec: string) {\n  const hit = parse(spec)\n  if (hit?.type === \"alias\" && !hit.name) {\n    const sub = (hit as npa.AliasResult).subSpec\n    if (sub?.name) {\n      const version = !sub.rawSpec || sub.rawSpec === \"*\" ? \"latest\" : sub.rawSpec\n      return { pkg: sub.name, version }\n    }\n  }\n  if (!hit?.name) return { pkg: spec, version: \"\" }\n  if (hit.raw === hit.name) return { pkg: hit.name, version: \"latest\" }\n  return { pkg: hit.name, version: hit.rawSpec }\n}"},{"id":"packages_opencode_src_plugin_shared_pluginsource","label":"pluginSource()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L56-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L56"}],"snippet":"export function pluginSource(spec: string): PluginSource {\n  if (isPathPluginSpec(spec)) return \"file\"\n  return \"npm\"\n}"},{"id":"packages_opencode_src_plugin_shared_resolveexportpath","label":"resolveExportPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L61-L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L61"}],"snippet":"function resolveExportPath(raw: string, dir: string) {\n  if (raw.startsWith(\"file://\")) return fileURLToPath(raw)\n  if (path.isAbsolute(raw)) return raw\n  return path.resolve(dir, raw)\n}"},{"id":"packages_opencode_src_plugin_shared_isabsolutepath","label":"isAbsolutePath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L67-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L67"}],"snippet":"function isAbsolutePath(raw: string) {\n  return path.isAbsolute(raw) || /^[A-Za-z]:[\\\\/]/.test(raw)\n}"},{"id":"packages_opencode_src_plugin_shared_extractexportvalue","label":"extractExportValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L71-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L71"}],"snippet":"function extractExportValue(value: unknown): string | undefined {\n  if (typeof value === \"string\") return value\n  if (!isRecord(value)) return undefined\n  for (const key of [\"import\", \"default\"]) {\n    const nested = value[key]\n    if (typeof nested === \"string\") return nested\n  }\n  return undefined\n}"},{"id":"packages_opencode_src_plugin_shared_packagemain","label":"packageMain()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L81-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L81"}],"snippet":"function packageMain(pkg: PluginPackage) {\n  const value = pkg.json.main\n  if (typeof value !== \"string\") return\n  const next = value.trim()\n  if (!next) return\n  return next\n}"},{"id":"packages_opencode_src_plugin_shared_resolvepackagefile","label":"resolvePackageFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L89-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L89"}],"snippet":"function resolvePackageFile(spec: string, raw: string, kind: string, pkg: PluginPackage) {\n  const resolved = resolveExportPath(raw, pkg.dir)\n  const root = Filesystem.resolve(pkg.dir)\n  const next = Filesystem.resolve(resolved)\n  if (!Filesystem.contains(root, next)) {\n    throw new Error(`Plugin ${spec} resolved ${kind} entry outside plugin directory`)\n  }\n  return next\n}"},{"id":"packages_opencode_src_plugin_shared_resolvepackagepath","label":"resolvePackagePath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L99-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L99"}],"snippet":"function resolvePackagePath(spec: string, raw: string, kind: PluginKind, pkg: PluginPackage) {\n  return pathToFileURL(resolvePackageFile(spec, raw, kind, pkg)).href\n}"},{"id":"packages_opencode_src_plugin_shared_resolvepackageentrypoint","label":"resolvePackageEntrypoint()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L103-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L103"}],"snippet":"function resolvePackageEntrypoint(spec: string, kind: PluginKind, pkg: PluginPackage) {\n  const exports = pkg.json.exports\n  if (isRecord(exports)) {\n    const raw = extractExportValue(exports[`./${kind}`])\n    if (raw) return resolvePackagePath(spec, raw, kind, pkg)\n  }\n\n  if (kind !== \"server\") return\n  const main = packageMain(pkg)\n  if (!main) return\n  return resolvePackagePath(spec, main, kind, pkg)\n}"},{"id":"packages_opencode_src_plugin_shared_targetpath","label":"targetPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L116-L119","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L116"}],"snippet":"function targetPath(target: string) {\n  if (target.startsWith(\"file://\")) return fileURLToPath(target)\n  if (path.isAbsolute(target)) return target\n}"},{"id":"packages_opencode_src_plugin_shared_resolvedirectoryindex","label":"resolveDirectoryIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L121-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L121"}],"snippet":"async function resolveDirectoryIndex(dir: string) {\n  for (const name of INDEX_FILES) {\n    const file = path.join(dir, name)\n    if (await Filesystem.exists(file)) return file\n  }\n}"},{"id":"packages_opencode_src_plugin_shared_resolvetargetdirectory","label":"resolveTargetDirectory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L128-L134","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L128"}],"snippet":"async function resolveTargetDirectory(target: string) {\n  const file = targetPath(target)\n  if (!file) return\n  const stat = await Filesystem.statAsync(file)\n  if (!stat?.isDirectory()) return\n  return file\n}"},{"id":"packages_opencode_src_plugin_shared_resolvepluginentrypoint","label":"resolvePluginEntrypoint()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L136-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L136"}],"snippet":"async function resolvePluginEntrypoint(spec: string, target: string, kind: PluginKind, pkg?: PluginPackage) {\n  const source = pluginSource(spec)\n  const hit =\n    pkg ?? (source === \"npm\" ? await readPluginPackage(target) : await readPluginPackage(target).catch(() => undefined))\n  if (!hit) return target\n\n  const entry = resolvePackageEntrypoint(spec, kind, hit)\n  if (entry) return entry\n\n  const dir = await resolveTargetDirectory(target)\n\n  if (kind === \"tui\") {\n    if (source === \"file\" && dir) {\n      const index = await resolveDirectoryIndex(dir)\n      if (index) return pathToFileURL(index).href\n    }\n\n    if (source === \"npm\") return\n    if (dir) return\n\n    return target\n  }\n\n  if (dir && isRecord(hit.json.exports)) {\n    if (source === \"file\") {"},{"id":"packages_opencode_src_plugin_shared_ispathpluginspec","label":"isPathPluginSpec()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L171-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L171"}],"snippet":"export function isPathPluginSpec(spec: string) {\n  return spec.startsWith(\"file://\") || spec.startsWith(\".\") || isAbsolutePath(spec)\n}"},{"id":"packages_opencode_src_plugin_shared_resolvepathplugintarget","label":"resolvePathPluginTarget()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L175-L192","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L175"}],"snippet":"export async function resolvePathPluginTarget(spec: string) {\n  const raw = spec.startsWith(\"file://\") ? fileURLToPath(spec) : spec\n  const file = path.isAbsolute(raw) || /^[A-Za-z]:[\\\\/]/.test(raw) ? raw : path.resolve(raw)\n  const stat = await Filesystem.statAsync(file)\n  if (!stat?.isDirectory()) {\n    if (spec.startsWith(\"file://\")) return spec\n    return pathToFileURL(file).href\n  }\n\n  if (await Filesystem.exists(path.join(file, \"package.json\"))) {\n    return pathToFileURL(file).href\n  }\n\n  const index = await resolveDirectoryIndex(file)\n  if (index) return pathToFileURL(index).href\n\n  throw new Error(`Plugin directory ${file} is missing package.json or index file`)\n}"},{"id":"packages_opencode_src_plugin_shared_checkplugincompatibility","label":"checkPluginCompatibility()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L194-L205","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L194"}],"snippet":"export async function checkPluginCompatibility(target: string, opencodeVersion: string, pkg?: PluginPackage) {\n  if (!semver.valid(opencodeVersion) || semver.major(opencodeVersion) === 0) return\n  const hit = pkg ?? (await readPluginPackage(target).catch(() => undefined))\n  if (!hit) return\n  const engines = hit.json.engines\n  if (!isRecord(engines)) return\n  const range = engines.opencode\n  if (typeof range !== \"string\") return\n  if (!semver.satisfies(opencodeVersion, range)) {\n    throw new Error(`Plugin requires opencode ${range} but running ${opencodeVersion}`)\n  }\n}"},{"id":"packages_opencode_src_plugin_shared_resolveplugintarget","label":"resolvePluginTarget()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L207-L213","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L207"}],"snippet":"export async function resolvePluginTarget(spec: string) {\n  if (isPathPluginSpec(spec)) return resolvePathPluginTarget(spec)\n  const hit = parse(spec)\n  const pkg = hit?.name && hit.raw === hit.name ? `${hit.name}@latest` : spec\n  const result = await Npm.add(pkg)\n  return result.directory\n}"},{"id":"packages_opencode_src_plugin_shared_readpluginpackage","label":"readPluginPackage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L215-L222","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L215"}],"snippet":"export async function readPluginPackage(target: string): Promise<PluginPackage> {\n  const file = target.startsWith(\"file://\") ? fileURLToPath(target) : target\n  const stat = await Filesystem.statAsync(file)\n  const dir = stat?.isDirectory() ? file : path.dirname(file)\n  const pkg = path.join(dir, \"package.json\")\n  const json = await Filesystem.readJson<Record<string, unknown>>(pkg)\n  return { dir, pkg, json }\n}"},{"id":"packages_opencode_src_plugin_shared_createpluginentry","label":"createPluginEntry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L224-L236","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L224"}],"snippet":"export async function createPluginEntry(spec: string, target: string, kind: PluginKind): Promise<PluginEntry> {\n  const source = pluginSource(spec)\n  const pkg =\n    source === \"npm\" ? await readPluginPackage(target) : await readPluginPackage(target).catch(() => undefined)\n  const entry = await resolvePluginEntrypoint(spec, target, kind, pkg)\n  return {\n    spec,\n    source,\n    target,\n    pkg,\n    entry,\n  }\n}"},{"id":"packages_opencode_src_plugin_shared_readpackagethemes","label":"readPackageThemes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L238-L262","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L238"}],"snippet":"export function readPackageThemes(spec: string, pkg: PluginPackage) {\n  const field = pkg.json[\"oc-themes\"]\n  if (field === undefined) return []\n  if (!Array.isArray(field)) {\n    throw new TypeError(`Plugin ${spec} has invalid oc-themes field`)\n  }\n\n  const list = field.map((item) => {\n    if (typeof item !== \"string\") {\n      throw new TypeError(`Plugin ${spec} has invalid oc-themes entry`)\n    }\n\n    const raw = item.trim()\n    if (!raw) {\n      throw new TypeError(`Plugin ${spec} has empty oc-themes entry`)\n    }\n    if (raw.startsWith(\"file://\") || isAbsolutePath(raw)) {\n      throw new TypeError(`Plugin ${spec} oc-themes entry must be relative: ${item}`)\n    }\n\n    return resolvePackageFile(spec, raw, \"oc-themes\", pkg)\n  })\n\n  return Array.from(new Set(list))\n}"},{"id":"packages_opencode_src_plugin_shared_readpluginid","label":"readPluginId()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L264-L270","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L264"}],"snippet":"export function readPluginId(id: unknown, spec: string) {\n  if (id === undefined) return\n  if (typeof id !== \"string\") throw new TypeError(`Plugin ${spec} has invalid id type ${typeof id}`)\n  const value = id.trim()\n  if (!value) throw new TypeError(`Plugin ${spec} has an empty id`)\n  return value\n}"},{"id":"packages_opencode_src_plugin_shared_readv1plugin","label":"readV1Plugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L272-L304","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L272"}],"snippet":"export function readV1Plugin(\n  mod: Record<string, unknown>,\n  spec: string,\n  kind: PluginKind,\n  mode: PluginMode = \"strict\",\n) {\n  const value = mod.default\n  if (!isRecord(value)) {\n    if (mode === \"detect\") return\n    throw new TypeError(`Plugin ${spec} must default export an object with ${kind}()`)\n  }\n  if (mode === \"detect\" && !(\"id\" in value) && !(\"server\" in value) && !(\"tui\" in value)) return\n\n  const server = \"server\" in value ? value.server : undefined\n  const tui = \"tui\" in value ? value.tui : undefined\n  if (server !== undefined && typeof server !== \"function\") {\n    throw new TypeError(`Plugin ${spec} has invalid server export`)\n  }\n  if (tui !== undefined && typeof tui !== \"function\") {\n    throw new TypeError(`Plugin ${spec} has invalid tui export`)\n  }\n  if (server !== undefined && tui !== undefined) {\n    throw new TypeError(`Plugin ${spec} must default export either server() or tui(), not both`)\n  }\n  if (kind === \"server\" && server === undefined) {"},{"id":"packages_opencode_src_plugin_shared_resolvepluginid","label":"resolvePluginId()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L306-L323","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L306"}],"snippet":"export async function resolvePluginId(\n  source: PluginSource,\n  spec: string,\n  target: string,\n  id: string | undefined,\n  pkg?: PluginPackage,\n) {\n  if (source === \"file\") {\n    if (id) return id\n    throw new TypeError(`Path plugin ${spec} must export id`)\n  }\n  if (id) return id\n  const hit = pkg ?? (await readPluginPackage(target))\n  if (typeof hit.json.name !== \"string\" || !hit.json.name.trim()) {\n    throw new TypeError(`Plugin package ${hit.pkg} is missing name`)\n  }\n  return hit.json.name.trim()\n}"}],"edges":[{"source":"packages_opencode_src_plugin_shared","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/shared.ts","source_location":"L1"}],"weight":1},{"source":"packages_o