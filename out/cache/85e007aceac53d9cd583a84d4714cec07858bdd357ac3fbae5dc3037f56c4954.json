function parse(input: string): Reference | undefined {\n  const cleaned = normalizeInput(input)\n  if (!cleaned) return\n\n  const githubPrefixed = cleaned.match(/^github:([^/\\s]+)\\/([^/\\s]+)$/)\n  if (githubPrefixed) return buildRemote({ host: \"github.com\", segments: [githubPrefixed[1], githubPrefixed[2]] })\n\n  if (!cleaned.includes(\"://\")) {\n    const scp = cleaned.match(/^(?:[^@/\\s]+@)?([^:/\\s]+):(.+)$/)\n    if (scp) return buildRemote({ host: scp[1], segments: parts(scp[2]), remote: cleaned })\n\n    const direct = parts(cleaned)\n    if (direct.length >= 2 && hostLike(direct[0])) return buildRemote({ host: direct[0], segments: direct.slice(1) })\n    if (direct.length === 2) return buildRemote({ host: \"github.com\", segments: direct })\n  }\n\n  try {\n    const url = new URL(cleaned)\n    if (url.protocol === \"file:\") return buildFile({ url, remote: cleaned })\n    const segments = parts(url.pathname)\n    return buildRemote({\n      host: url.host,\n      segments,\n      remote: url.host === \"github.com\" ? githubRemote(segments.join(\"/\")) : cleaned,\n      protocol: url.protocol,"},{"id":"packages_core_src_repository_parseremote","label":"parseRemote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L88-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L88"}],"snippet":"export function parseRemote(input: string): RemoteReference {\n  const reference = parse(input)\n  if (!reference) {\n    throw new InvalidReferenceError({\n      repository: input,\n      message: \"Repository must be a git URL, host/path reference, or GitHub owner/repo shorthand\",\n    })\n  }\n  if (!isRemote(reference)) {\n    throw new UnsupportedLocalRepositoryError({\n      repository: input,\n      message: \"Local file repositories are not supported\",\n    })\n  }\n  return reference\n}"},{"id":"packages_core_src_repository_validatebranch","label":"validateBranch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L105-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L105"}],"snippet":"export function validateBranch(branch: string): void {\n  if (/^[A-Za-z0-9/_.-]+$/.test(branch) && !branch.startsWith(\"-\") && !branch.includes(\"..\")) return\n  throw new InvalidBranchError({\n    branch,\n    message: \"Branch must contain only alphanumeric characters, /, _, ., and -, and cannot start with - or contain ..\",\n  })\n}"},{"id":"packages_core_src_repository_isfile","label":"isFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L113-L115","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L113"}],"snippet":"export function isFile(reference: Reference): reference is FileReference {\n  return reference.protocol === \"file:\"\n}"},{"id":"packages_core_src_repository_isremote","label":"isRemote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L117-L119","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L117"}],"snippet":"export function isRemote(reference: Reference): reference is RemoteReference {\n  return !isFile(reference)\n}"},{"id":"packages_core_src_repository_cachepath","label":"cachePath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L121-L123","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L121"}],"snippet":"export function cachePath(root: string, reference: Reference): string {\n  return path.join(root, ...reference.host.split(\":\"), ...reference.segments)\n}"},{"id":"packages_core_src_repository_cacheidentity","label":"cacheIdentity()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L125-L127","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L125"}],"snippet":"export function cacheIdentity(reference: Reference): string {\n  return `${reference.host}/${reference.path}`\n}"},{"id":"packages_core_src_repository_same","label":"same()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L129-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L129"}],"snippet":"export function same(left: Reference, right: Reference): boolean {\n  return cacheIdentity(left) === cacheIdentity(right)\n}"},{"id":"packages_core_src_repository_normalizeinput","label":"normalizeInput()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L133-L139","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L133"}],"snippet":"function normalizeInput(input: string) {\n  return input\n    .trim()\n    .replace(/^git\\+/, \"\")\n    .replace(/#.*$/, \"\")\n    .replace(/\\/+$/, \"\")\n}"},{"id":"packages_core_src_repository_trimgitsuffix","label":"trimGitSuffix()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L141-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L141"}],"snippet":"function trimGitSuffix(input: string) {\n  return input.replace(/\\.git$/, \"\")\n}"},{"id":"packages_core_src_repository_parts","label":"parts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L145-L150","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L145"}],"snippet":"function parts(input: string) {\n  return input\n    .split(\"/\")\n    .map((item) => trimGitSuffix(item.trim()))\n    .filter(Boolean)\n}"},{"id":"packages_core_src_repository_safehost","label":"safeHost()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L152-L154","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L152"}],"snippet":"function safeHost(input: string) {\n  return Boolean(input) && !input.startsWith(\"-\") && !/[\\s/\\\\]/.test(input)\n}"},{"id":"packages_core_src_repository_safesegment","label":"safeSegment()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L156-L158","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L156"}],"snippet":"function safeSegment(input: string) {\n  return input !== \".\" && input !== \"..\" && !input.includes(\":\") && !/[\\s/\\\\]/.test(input)\n}"},{"id":"packages_core_src_repository_hostlike","label":"hostLike()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L160-L162","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L160"}],"snippet":"function hostLike(input: string) {\n  return input.includes(\".\") || input.includes(\":\") || input === \"localhost\"\n}"},{"id":"packages_core_src_repository_withslash","label":"withSlash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L164-L166","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L164"}],"snippet":"function withSlash(input: string) {\n  return input.endsWith(\"/\") ? input : `${input}/`\n}"},{"id":"packages_core_src_repository_githubremote","label":"githubRemote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L168-L172","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L168"}],"snippet":"function githubRemote(pathname: string) {\n  const base = process.env.OPENCODE_REPO_CLONE_GITHUB_BASE_URL\n  if (!base) return `https://github.com/${pathname}.git`\n  return new URL(`${pathname}.git`, withSlash(base)).href\n}"},{"id":"packages_core_src_repository_buildremote","label":"buildRemote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L174-L190","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L174"}],"snippet":"function buildRemote(input: { host: string; segments: string[]; remote?: string; protocol?: string }) {\n  const segments = input.segments.map(trimGitSuffix).filter(Boolean)\n  if (!safeHost(input.host) || !segments.length || segments.some((segment) => !safeSegment(segment))) return\n  const repositoryPath = segments.join(\"/\")\n  const host = input.host.toLowerCase()\n  return {\n    host,\n    path: repositoryPath,\n    segments,\n    owner: segments.length === 2 ? segments[0] : undefined,\n    repo: segments[segments.length - 1],\n    remote:\n      input.remote ?? (host === \"github.com\" ? githubRemote(repositoryPath) : `https://${host}/${repositoryPath}.git`),\n    label: host === \"github.com\" && segments.length === 2 ? repositoryPath : `${host}/${repositoryPath}`,\n    protocol: input.protocol,\n  } satisfies RemoteReference\n}"},{"id":"packages_core_src_repository_buildfile","label":"buildFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L192-L206","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L192"}],"snippet":"function buildFile(input: { url: URL; remote: string }) {\n  const filePath = path.normalize(fileURLToPath(input.url))\n  const segments = filePath.split(/[\\\\/]+/).filter(Boolean)\n  if (!segments.length) return\n  return {\n    host: \"file\",\n    path: filePath,\n    segments: segments.map((segment) => segment.replace(/:$/, \"\")),\n    owner: undefined,\n    repo: trimGitSuffix(segments[segments.length - 1]),\n    remote: input.remote,\n    label: filePath,\n    protocol: \"file:\",\n  } satisfies FileReference\n}"}],"edges":[{"source":"packages_core_src_repository","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_src_repository","target":"url","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L2"}],"weight":1},{"source":"packages_core_src_repository","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/repository.ts","source_location":"L3"}],"weight":1},{"source":"packages_core_src_repository","target":"packages_core_src_repository_invalidreferenceerror","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/