}]},{"id":"packages_rimuru_src_server_routes_instance_httpapi_middleware_authorization_ptyconnectauthorization","label":"PtyConnectAuthorization","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L26-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L26"}],"snippet":"export class PtyConnectAuthorization extends HttpApiMiddleware.Service<PtyConnectAuthorization>()(\n  \"@rimuru/ExperimentalHttpApiPtyConnectAuthorization\",\n  {\n    error: HttpApiError.UnauthorizedNoContent,\n  },\n) {}"},{"id":"packages_rimuru_src_server_routes_instance_httpapi_middleware_authorization_emptycredential","label":"emptyCredential()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L33-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L33"}],"snippet":"function emptyCredential() {\n  return {\n    username: \"\",\n    password: Redacted.make(\"\"),\n  }\n}"},{"id":"packages_rimuru_src_server_routes_instance_httpapi_middleware_authorization_validatecredential","label":"validateCredential()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L40-L55","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L40"}],"snippet":"function validateCredential<A, E, R>(\n  effect: Effect.Effect<A, E, R>,\n  credential: ServerAuth.DecodedCredentials,\n  config: ServerAuth.Info,\n) {\n  return Effect.gen(function* () {\n    if (!ServerAuth.required(config)) return yield* effect\n    if (!ServerAuth.authorized(credential, config)) {\n      yield* HttpEffect.appendPreResponseHandler((_request, response) =>\n        Effect.succeed(HttpServerResponse.setHeader(response, \"www-authenticate\", WWW_AUTHENTICATE)),\n      )\n      return yield* new HttpApiError.Unauthorized({})\n    }\n    return yield* effect\n  })\n}"},{"id":"packages_rimuru_src_server_routes_instance_httpapi_middleware_authorization_decodecredential","label":"decodeCredential()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L57-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L57"}],"snippet":"function decodeCredential(input: string) {\n  return Effect.fromResult(Encoding.decodeBase64String(input)).pipe(\n    Effect.match({\n      onFailure: emptyCredential,\n      onSuccess: (header) => {\n        const separator = header.indexOf(\":\")\n        if (separator === -1) return emptyCredential()\n        return {\n          username: header.slice(0, separator),\n          password: Redacted.make(header.slice(separator + 1)),\n        }\n      },\n    }),\n  )\n}"},{"id":"packages_rimuru_src_server_routes_instance_httpapi_middleware_authorization_credentialfromrequest","label":"credentialFromRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L73-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L73"}],"snippet":"function credentialFromRequest(request: HttpServerRequest.HttpServerRequest) {\n  return credentialFromURL(new URL(request.url, \"http://localhost\"), request)\n}"},{"id":"packages_rimuru_src_server_routes_instance_httpapi_middleware_authorization_credentialfromurl","label":"credentialFromURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L77-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L77"}],"snippet":"function credentialFromURL(url: URL, request: HttpServerRequest.HttpServerRequest) {\n  const token = url.searchParams.get(AUTH_TOKEN_QUERY)\n  if (token) return decodeCredential(token)\n  const match = /^Basic\\s+(.+)$/i.exec(request.headers.authorization ?? \"\")\n  if (match) return decodeCredential(match[1])\n  return Effect.succeed(emptyCredential())\n}"},{"id":"packages_rimuru_src_server_routes_instance_httpapi_middleware_authorization_validaterawcredential","label":"validateRawCredential()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L85-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L85"}],"snippet":"function validateRawCredential<A, E, R>(\n  effect: Effect.Effect<A, E, R>,\n  credential: ServerAuth.DecodedCredentials,\n  config: ServerAuth.Info,\n) {\n  if (!ServerAuth.required(config)) return effect\n  if (!ServerAuth.authorized(credential, config))\n    return Effect.succeed(\n      HttpServerResponse.empty({\n        status: UNAUTHORIZED,\n        headers: { \"www-authenticate\": WWW_AUTHENTICATE },\n      }),\n    )\n  return effect\n}"}],"edges":[{"source":"packages_rimuru_src_server_routes_instance_httpapi_middleware_authorization","target":"auth","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_server_routes_instance_httpapi_middleware_authorization","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L2"}],"weight":1},{"source":"packages_rimuru_src_server_routes_instance_httpapi_middleware_authorization","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/server/routes/instance/httpapi/middleware/authorization.ts","source_location":"L3","la