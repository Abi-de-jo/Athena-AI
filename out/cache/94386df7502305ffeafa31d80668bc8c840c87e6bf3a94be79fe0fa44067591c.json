ovenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L101"}],"snippet":"function skin(api: TuiPluginApi): Skin {\n  return {\n    panel: ink(api, \"backgroundMenu\", \"#1c1c1c\"),\n    text: ink(api, \"text\", \"#f0f0f0\"),\n    muted: ink(api, \"textMuted\", \"#a5a5a5\"),\n    subtle: ink(api, \"borderSubtle\", \"#6f6f6f\"),\n    key: ink(api, \"warning\", \"#ffd75f\"),\n    accent: ink(api, \"primary\", \"#5f87ff\"),\n    tab: ink(api, \"primary\", \"#5f87ff\"),\n    tabText: ink(api, \"selectedListItemText\", \"#ffffff\"),\n  }\n}"},{"id":"which_key_activekeylabel","label":"activeKeyLabel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L114-L119","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L114"}],"snippet":"function activeKeyLabel(active: ActiveKey<Renderable, KeyEvent>) {\n  if (active.continues) return text(active.tokenName) ?? text(active.display) ?? UNKNOWN\n  return (\n    text(active.commandAttrs?.title) ?? text(active.bindingAttrs?.desc) ?? text(active.commandAttrs?.desc) ?? UNKNOWN\n  )\n}"},{"id":"which_key_activekeygroup","label":"activeKeyGroup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L121-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L121"}],"snippet":"function activeKeyGroup(active: ActiveKey<Renderable, KeyEvent>) {\n  if (active.continues) return \"System\"\n  return text(active.commandAttrs?.category) ?? text(active.bindingAttrs?.group) ?? UNKNOWN\n}"},{"id":"which_key_activekeyentry","label":"activeKeyEntry()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L126-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L126"}],"snippet":"function activeKeyEntry(api: TuiPluginApi, active: ActiveKey<Renderable, KeyEvent>): Entry {\n  const key = api.keys.formatSequence([\n    {\n      stroke: active.stroke,\n      display: active.display,\n      tokenName: active.tokenName,\n    },\n  ])\n  const label = activeKeyLabel(active)\n  return {\n    type: \"entry\",\n    key,\n    label: active.continues ? `+${label}` : label,\n    group: activeKeyGroup(active),\n    continues: active.continues,\n  }\n}"},{"id":"which_key_grouped","label":"grouped()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L144-L156","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L144"}],"snippet":"function grouped(entries: Entry[]): Group[] {\n  const map = new Map<string, Entry[]>()\n  for (const entry of entries) map.set(entry.group, [...(map.get(entry.group) ?? []), entry])\n  return [...map]\n    .map(([label, entries]) => ({\n      label,\n      entries: entries.toSorted(\n        (a, b) =>\n          Number(b.continues) - Number(a.continues) || a.label.localeCompare(b.label) || a.key.localeCompare(b.key),\n      ),\n    }))\n    .toSorted((a, b) => a.label.localeCompare(b.label))\n}"},{"id":"which_key_commandshortcut","label":"commandShortcut()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L158-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L158"}],"snippet":"function commandShortcut(api: TuiPluginApi, name: string) {\n  return useKeymapSelector((keymap) =>\n    api.keys.formatSequence(\n      keymap.getCommandBindings({ visibility: \"registered\", commands: [name] }).get(name)?.[0]?.sequence,\n    ),\n  )\n}"},{"id":"which_key_layout","label":"layout()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L166-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L166"}],"snippet":"function layout(value: unknown): Layout {\n  if (value === \"overlay\") return \"overlay\"\n  return \"dock\"\n}"},{"id":"which_key_homehint","label":"HomeHint()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L171-L182","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L171"}],"snippet":"function HomeHint(props: { api: TuiPluginApi }) {\n  const trigger = commandShortcut(props.api, command.toggle)\n  const look = createMemo(() => skin(props.api))\n\n  return (\n    <box width=\"100%\" maxWidth={75} alignItems=\"center\" paddingTop={1} flexShrink={0}>\n      <text fg={look().muted} wrapMode=\"none\">\n        Show keyboard shortcuts with <span style={{ fg: look().subtle }}>{trigger() || command.toggle}</span>\n      </text>\n    </box>\n  )\n}","node_kind":"component"},{"id":"which_key_whichkeypanel","label":"WhichKeyPanel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L184-L530","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L184"}],"snippet":"function WhichKeyPanel(props: {\n  api: TuiPluginApi\n  layout: Layout\n  mode: () => Layout\n  pendingPreview: () => boolean\n  pinned: () => boolean\n}) {\n  const dimensions = useTerminalDimensions()\n  const [offset, setOffset] = createSignal(0)\n  const [activeGroup, setActiveGroup] = createSignal<string | undefined>()\n  const pending = useKeymapSelector((keymap) => keymap.getPendingSequence())\n  const active = useKeymapSelector((keymap) => keymap.getActiveKeys({ includeMetadata: true }))\n  const pendingActive = createMemo(() => pending().length > 0 && active().length > 0)\n  const pendingAutoVisible = createMemo(() => props.mode() === \"overlay\" && props.pendingPreview() && pendingActive())\n  const visible = createMemo(() => props.pinned() || pendingAutoVisible())\n  const pendingMode = createMemo(() => visible() && pendingActive())\n  const left = 0\n  const width = createMemo(() => Math.max(1, dimensions().width))\n  const panelHeight = createMemo(() =>\n    Math.max(MIN_PANEL_HEIGHT, Math.min(MAX_PANEL_HEIGHT, Math.floor(dimensions().height * PANEL_HEIGHT_RATIO))),\n  )\n  const contentWidth = createMemo(() => Math.max(1, width() - 2))\n  const columns = createMemo(() =>\n    Math.max(1, Math.min(3, Math.floor((contentWidth() + COLUMN_GAP) / (MAX_COLUMN_WIDTH + COLUMN_GAP)) || 1)),\n  )","node_kind":"component"},{"id":"which_key_whichkeypanel_clamp","label":"clamp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L272","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L272"}],"snippet":"clamp = (value: number) => Math.max(0, Math.min(maxOffset(), value))"},{"id":"which_key_whichkeypanel_scroll","label":"scroll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L273","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L273"}],"snippet":"scroll = (delta: number) => setOffset((value) => clamp(value + delta))"},{"id":"which_key_whichkeypanel_movegroup","label":"moveGroup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L274-L284","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L274"}],"snippet":"moveGroup = (delta: number) => {\n    if (pendingMode()) return\n    const list = groups()\n    if (!list.length) return\n    const index = Math.max(\n      0,\n      list.findIndex((item) => item.label === currentGroup()?.label),\n    )\n    setActiveGroup(list[(index + delta + list.length) % list.length]!.label)\n    setOffset(0)\n  }"},{"id":"which_key_tui","label":"tui()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L532-L600","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L532"}],"snippet":"tui: TuiPlugin = async (api) => {\n  const [pinned, setPinned] = createSignal(false)\n  const [mode, setMode] = createSignal(layout(api.kv.get(KV_LAYOUT, \"dock\")))\n  const [pendingPreview, setPendingPreview] = createSignal(api.kv.get(KV_PENDING_PREVIEW, false))\n\n  api.keymap.registerLayer({\n    priority: LAYER_PRIORITY,\n    commands: [\n      {\n        name: command.toggle,\n        title: \"Show key bindings\",\n        desc: \"Toggle which-key overlay\",\n        category: \"System\",\n        run() {\n          setPinned((value) => !value)\n        },\n      },\n      {\n        name: command.toggleLayout,\n        title: \"Toggle key bindings layout\",\n        desc: \"Switch which-key between dock and overlay mode\",\n        category: \"System\",\n        run() {\n          setMode((value) => {\n            const next = value === \"dock\" ? \"overlay\" : \"dock\""}],"edges":[{"source":"which_key","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L2"}],"weight":1},{"source":"which_key","target":"solid","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/which-key.tsx","source_location":"L3","layer":"base","pro