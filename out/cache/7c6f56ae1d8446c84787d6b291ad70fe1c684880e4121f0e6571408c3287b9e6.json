{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_llm_src_providers_openai-options","nodes":[{"id":"packages_llm_src_providers_openai_options","label":"openai-options.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L1"}]},{"id":"packages_llm_src_providers_openai_options_openaioptionsinput","label":"OpenAIOptionsInput","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L7-L19","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L7"}],"snippet":"export interface OpenAIOptionsInput {\n  readonly [key: string]: unknown\n  readonly store?: boolean\n  readonly promptCacheKey?: string\n  readonly reasoningEffort?: ReasoningEffort\n  readonly reasoningSummary?: \"auto\"\n  // OpenAI Responses `include` wire field. Mirrors the official SDK's\n  // `ResponseIncludable[]` union exactly so AI SDK callers and direct\n  // native-SDK callers share one shape and no translation is required.\n  readonly include?: ReadonlyArray<OpenAIResponseIncludable>\n  readonly textVerbosity?: TextVerbosity\n  readonly serviceTier?: OpenAIServiceTier\n}"},{"id":"packages_llm_src_providers_openai_options_definedentries","label":"definedEntries()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L25-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L25"}],"snippet":"definedEntries = (input: Record<string, unknown>) =>\n  Object.entries(input).filter((entry) => entry[1] !== undefined)"},{"id":"packages_llm_src_providers_openai_options_openaiprovideroptions","label":"openAIProviderOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L28-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L28"}],"snippet":"openAIProviderOptions = (options: OpenAIOptionsInput | undefined): ProviderOptions | undefined => {\n  const openai = Object.fromEntries(\n    definedEntries({\n      store: options?.store,\n      promptCacheKey: options?.promptCacheKey,\n      reasoningEffort: options?.reasoningEffort,\n      reasoningSummary: options?.reasoningSummary,\n      include: options?.include,\n      textVerbosity: options?.textVerbosity,\n      serviceTier: options?.serviceTier,\n    }),\n  )\n  if (Object.keys(openai).length === 0) return undefined\n  return { openai }\n}"},{"id":"packages_llm_src_providers_openai_options_gpt5defaultoptions","label":"gpt5DefaultOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L44-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L44"}],"snippet":"gpt5DefaultOptions = (\n  modelID: string,\n  options: { readonly textVerbosity?: boolean } = {},\n): ProviderOptions | undefined => {\n  const id = modelID.toLowerCase()\n  if (!id.includes(\"gpt-5\") || id.includes(\"gpt-5-chat\") || id.includes(\"gpt-5-pro\")) return undefined\n  return openAIProviderOptions({\n    reasoningEffort: \"medium\",\n    reasoningSummary: \"auto\",\n    // GPT-5 reasoning models are configured stateless (`store: false`) by\n    // `openAIDefaultOptions` below, so the only way a follow-up turn can\n    // carry reasoning state is via the encrypted reasoning include. Without\n    // this, callers using the default model facade get reasoning summaries\n    // they cannot replay statelessly.\n    include: [\"reasoning.encrypted_content\"],\n    textVerbosity:\n      options.textVerbosity === true && id.includes(\"gpt-5.\") && !id.includes(\"codex\") && !id.includes(\"-chat\")\n        ? \"low\"\n        : undefined,\n  })\n}"},{"id":"packages_llm_src_providers_openai_options_openaidefaultoptions","label":"openAIDefaultOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L66-L70","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L66"}],"snippet":"openAIDefaultOptions = (\n  modelID: string,\n  options: { readonly textVerbosity?: boolean } = {},\n): ProviderOptions | undefined =>\n  mergeProviderOptions(openAIProviderOptions({ store: false }), gpt5DefaultOptions(modelID, options))"},{"id":"packages_llm_src_providers_openai_options_withopenaioptions","label":"withOpenAIOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L72-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L72"}],"snippet":"withOpenAIOptions = <Options extends { readonly providerOptions?: OpenAIProviderOptionsInput }>(\n  modelID: string,\n  options: Options,\n  defaults: { readonly textVerbosity?: boolean } = {},\n): Omit<Options, \"providerOptions\"> & { readonly providerOptions?: ProviderOptions } => {\n  return {\n    ...options,\n    providerOptions: mergeProviderOptions(openAIDefaultOptions(modelID, defaults), options.providerOptions),\n  }\n}"}],"edges":[{"source":"packages_llm_src_providers_openai_options","target":"schema","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L1"}],"weight":1},{"source":"packages_llm_src_providers_openai_options","target":"openai_options","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L3"}],"weight":1},{"source":"packages_llm_src_providers_openai_options","target":"packages_llm_src_providers_openai_options_openaioptionsinput","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L7","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/providers/openai-options.ts","source_location":"L7"}],"weight":1},{"source":"packages_llm_src_providers_openai_options","target":"packages_llm_src_providers_openai_options