{"__madarTsExtractorVersion":67,"__madarFileStem":"directory-picker","nodes":[{"id":"directory_picker","label":"directory-picker.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L1"}]},{"id":"directory_picker_usedirectorypicker","label":"useDirectoryPicker()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L20-L45","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L20"}],"snippet":"export function useDirectoryPicker() {\n  const platform = usePlatform()\n  const settings = useSettings()\n  const dialog = useDialog()\n\n  return (input: DirectoryPickerInput) => {\n    if (directoryPickerKind(platform.platform, input.server) === \"native\" && platform.platform === \"desktop\") {\n      void platform.openDirectoryPickerDialog({ title: input.title, multiple: input.multiple }).then(input.onSelect)\n      return\n    }\n\n    let selected = false\n    const onSelect = (result: string | string[] | null) => {\n      selected = result !== null\n      input.onSelect(result)\n    }\n    const cancel = () => {\n      if (!selected) input.onSelect(null)\n    }\n    if (platform.platform === \"desktop\" && settings.general.newLayoutDesigns()) {\n      dialog.show(() => <DialogSelectDirectoryV2 {...input} onSelect={onSelect} />, cancel)\n      return\n    }\n    dialog.show(() => <DialogSelectDirectory {...input} onSelect={onSelect} />, cancel)\n  }"},{"id":"directory_picker_usedirectorypicker_onselect","label":"onSelect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L32-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L32"}],"snippet":"onSelect = (result: string | string[] | null) => {\n      selected = result !== null\n      input.onSelect(result)\n    }"},{"id":"directory_picker_usedirectorypicker_cancel","label":"cancel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L36-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L36"}],"snippet":"cancel = () => {\n      if (!selected) input.onSelect(null)\n    }"}],"edges":[{"source":"directory_picker","target":"dialog","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L1"}],"weight":1},{"source":"directory_picker","target":"server","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/directory-picker.tsx","source_location"