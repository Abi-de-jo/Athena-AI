{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_ui_src_theme_resolve","nodes":[{"id":"packages_ui_src_theme_resolve","label":"resolve.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L1"}]},{"id":"packages_ui_src_theme_resolve_resolvethemevariant","label":"resolveThemeVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L4-L456","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L4"}],"snippet":"export function resolveThemeVariant(variant: ThemeVariant, isDark: boolean): ResolvedTheme {\n  const colors = getColors(variant)\n  const { overrides = {} } = variant\n\n  const neutral = generateNeutralScale(colors.neutral, isDark, colors.ink)\n  const primary = generateScale(colors.primary, isDark)\n  const accent = generateScale(colors.accent, isDark)\n  const success = generateScale(colors.success, isDark)\n  const warning = generateScale(colors.warning, isDark)\n  const error = generateScale(colors.error, isDark)\n  const info = generateScale(colors.info, isDark)\n  const interactive = generateScale(colors.interactive, isDark)\n  const amber = generateScale(\n    shift(colors.warning, isDark ? { h: -16, l: -0.058, c: 1.14 } : { h: -22, l: -0.082, c: 0.94 }),\n    isDark,\n  )\n  const blue = generateScale(shift(colors.interactive, { h: -12, l: 0.128, c: 1.12 }), isDark)\n  const diffAdd = generateScale(\n    colors.diffAdd ?? shift(colors.success, { c: isDark ? 0.7 : 0.55, l: isDark ? -0.18 : 0.14 }),\n    isDark,\n  )\n  const diffDelete = generateScale(\n    colors.diffDelete ?? shift(colors.error, { c: isDark ? 0.82 : 0.7, l: isDark ? -0.08 : 0.08 }),\n    isDark,\n  )"},{"id":"packages_ui_src_theme_resolve_resolvethemevariant_content","label":"content()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L40-L44","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L40"}],"snippet":"content = (seed: HexColor, scale: HexColor[]) => {\n    const base = hexToOklch(seed)\n    const value = isDark ? (base.l > 0.84 ? shift(seed, { c: 1.18 }) : scale[10]) : scale[10]\n    return shift(value, { l: isDark ? 0.034 : -0.024, c: isDark ? 1.3 : 1.18 })\n  }"},{"id":"packages_ui_src_theme_resolve_resolvethemevariant_modified","label":"modified()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L45-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L45"}],"snippet":"modified = () => {\n    if (!colors.compact) return isDark ? \"#ffba92\" : \"#FF8C00\"\n    const warningHue = hexToOklch(colors.warning).h\n    const deleteHue = hexToOklch(colors.diffDelete ?? colors.error).h\n    const delta = Math.abs(((((deleteHue - warningHue) % 360) + 540) % 360) - 180)\n    if (delta < 48) return isDark ? \"#ffba92\" : \"#FF8C00\"\n    return content(colors.warning, warning)\n  }"},{"id":"packages_ui_src_theme_resolve_resolvethemevariant_surface","label":"surface()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L53-L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L53"}],"snippet":"surface = (\n    seed: HexColor,\n    alpha: { base: number; weak: number; weaker: number; strong: number; stronger: number },\n  ) => {\n    const base = alphaTone(seed, alpha.base)\n    return {\n      base,\n      weak: alphaTone(seed, alpha.weak),\n      weaker: alphaTone(seed, alpha.weaker),\n      strong: alphaTone(seed, alpha.strong),\n      stronger: alphaTone(seed, alpha.stronger),\n    }\n  }"},{"id":"packages_ui_src_theme_resolve_resolvethemevariant_alphatone","label":"alphaTone()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L67-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L67"}],"snippet":"alphaTone = (color: HexColor, alpha: number) =>\n    overlay ? (withAlpha(color, alpha) as ColorValue) : blend(color, background, alpha)"},{"id":"packages_ui_src_theme_resolve_resolvethemevariant_bordertone","label":"borderTone()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L69-L70","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L69"}],"snippet":"borderTone = (light: number, dark: number) =>\n    alphaTone(ink, isDark ? Math.min(1, dark + 0.024 + (colors.compact ? 0.08 : 0)) : Math.min(1, light + 0.024))"},{"id":"packages_ui_src_theme_resolve_resolvethemevariant_lum","label":"lum()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L96-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L96"}],"snippet":"lum = (hex: HexColor) => {\n    const rgb = hexToRgb(hex)\n    const lift = (v: number) => (v <= 0.04045 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4))\n    return 0.2126 * lift(rgb.r) + 0.7152 * lift(rgb.g) + 0.0722 * lift(rgb.b)\n  }"},{"id":"packages_ui_src_theme_resolve_resolvethemevariant_lum_lift","label":"lift()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L98"}],"snippet":"lift = (v: number) => (v <= 0.04045 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4))"},{"id":"packages_ui_src_theme_resolve_resolvethemevariant_hit","label":"hit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L101-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L101"}],"snippet":"hit = (a: HexColor, b: HexColor) => {\n    const x = lum(a)\n    const y = lum(b)\n    const light = Math.max(x, y)\n    const dark = Math.min(x, y)\n    return (light + 0.05) / (dark + 0.05)\n  }"},{"id":"packages_ui_src_theme_resolve_resolvethemevariant_on","label":"on()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L108-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L108"}],"snippet":"on = (fill: HexColor) => {\n    const light = \"#ffffff\" as HexColor\n    const dark = \"#000000\" as HexColor\n    return hit(light, fill) > hit(dark, fill) ? light : dark\n  }"},{"id":"packages_ui_src_theme_resolve_themecolors","label":"ThemeColors","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L458-L471","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L458"}],"snippet":"interface ThemeColors {\n  compact: boolean\n  neutral: HexColor\n  ink?: HexColor\n  primary: HexColor\n  accent: HexColor\n  success: HexColor\n  warning: HexColor\n  error: HexColor\n  info: HexColor\n  interactive: HexColor\n  diffAdd?: HexColor\n  diffDelete?: HexColor\n}"},{"id":"packages_ui_src_theme_resolve_getcolors","label":"getColors()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L473-L514","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L473"}],"snippet":"function getColors(variant: ThemeVariant): ThemeColors {\n  const input = variant as { palette?: unknown; seeds?: unknown }\n  if (input.palette && input.seeds) {\n    throw new Error(\"Theme variant cannot define both `palette` and `seeds`\")\n  }\n\n  if (variant.palette) {\n    return {\n      compact: true,\n      neutral: variant.palette.neutral,\n      ink: variant.palette.ink,\n      primary: variant.palette.primary,\n      accent: variant.palette.accent ?? variant.palette.info,\n      success: variant.palette.success,\n      warning: variant.palette.warning,\n      error: variant.palette.error,\n      info: variant.palette.info,\n      interactive: variant.palette.interactive ?? variant.palette.primary,\n      diffAdd: variant.palette.diffAdd,\n      diffDelete: variant.palette.diffDelete,\n    }\n  }\n\n  if (variant.seeds) {\n    return {"},{"id":"packages_ui_src_theme_resolve_generateneutralalphascale","label":"generateNeutralAlphaScale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L516-L522","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L516"}],"snippet":"function generateNeutralAlphaScale(neutralScale: HexColor[], isDark: boolean): HexColor[] {\n  const alphas = isDark\n    ? [0.038, 0.066, 0.1, 0.142, 0.19, 0.252, 0.334, 0.446, 0.58, 0.718, 0.854, 0.985]\n    : [0.03, 0.06, 0.1, 0.145, 0.2, 0.265, 0.35, 0.47, 0.61, 0.74, 0.86, 0.97]\n\n  return alphas.map((alpha) => blend(neutralScale[11], neutralScale[0], alpha))\n}"},{"id":"packages_ui_src_theme_resolve_gethex","label":"getHex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L524-L527","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L524"}],"snippet":"function getHex(value: ColorValue | undefined): HexColor | undefined {\n  if (!value?.startsWith(\"#\")) return\n  return value as HexColor\n}"},{"id":"packages_ui_src_theme_resolve_resolvetheme","label":"resolveTheme()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L529-L534","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L529"}],"snippet":"export function resolveTheme(theme: DesktopTheme): { light: ResolvedTheme; dark: ResolvedTheme } {\n  return {\n    light: resolveThemeVariant(theme.light, false),\n    dark: resolveThemeVariant(theme.dark, true),\n  }\n}"},{"id":"packages_ui_src_theme_resolve_themetocss","label":"themeToCss()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L536-L540","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L536"}],"snippet":"export function themeToCss(tokens: ResolvedTheme): string {\n  return Object.entries(tokens)\n    .map(([key, value]) => `--${key}: ${value};`)\n    .join(\"\\n  \")\n}"}],"edges":[{"source":"packages_ui_src_theme_resolve","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L1"}],"weight":1},{"source":"packages_ui_src_theme_resolve","target":"color","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/resolve.ts","source_location":"L2"}],"weight":1},{"source":"packages_ui_src_theme_resolve","target":"packages_ui_src_theme_resolve_resolvethemevariant","relation":"contains","confidence":"EXTRACTED