{"__madarTsExtractorVersion":67,"__madarFileStem":"thinking","nodes":[{"id":"thinking","label":"thinking.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L1"}]},{"id":"thinking_reasoningsummary","label":"reasoningSummary()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L12-L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L12"}],"snippet":"export function reasoningSummary(text: string) {\n  const content = text.trim()\n  const match = content.match(/^\\*\\*([^*\\n]+)\\*\\*(?:\\r?\\n\\r?\\n|$)/)\n  if (!match) return { title: null, body: content }\n  return { title: match[1].trim(), body: content.slice(match[0].length).trimEnd() }\n}"},{"id":"thinking_isthinkingmode","label":"isThinkingMode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L19-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L19"}],"snippet":"export function isThinkingMode(value: unknown): value is ThinkingMode {\n  return typeof value === \"string\" && (MODES as readonly string[]).includes(value)\n}"},{"id":"thinking_nextthinkingmode","label":"nextThinkingMode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L24-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L24"}],"snippet":"export function nextThinkingMode(current: ThinkingMode): ThinkingMode {\n  const idx = MODES.indexOf(current)\n  return MODES[(idx + 1) % MODES.length] ?? \"show\"\n}"},{"id":"thinking_usethinkingmode","label":"useThinkingMode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L29-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L29"}],"snippet":"export function useThinkingMode() {\n  const kv = useKV()\n  // Capture pre-state before `kv.signal` seeds a default, so we can detect\n  // first-time users with a legacy `thinking_visibility` boolean and migrate.\n  // The KVProvider only renders children once kv.ready, so reads here are safe.\n  const hadStored = kv.get(\"thinking_mode\") !== undefined\n  const legacy = kv.get(\"thinking_visibility\")\n  const [stored, setStored] = kv.signal<ThinkingMode>(\"thinking_mode\", \"hide\")\n\n  // The kv signal exposes its setter typed as `Setter<T>` which carries Solid's\n  // overload set; passing an updater fn through a property access loses the\n  // bivariance trick the existing `setX((prev) => ...)` callsites rely on.\n  // Wrap it in a sane shape so consumers can just call `set(next)` or pass\n  // an updater.\n  const set = (next: ThinkingMode | ((prev: ThinkingMode) => ThinkingMode)) => {\n    if (typeof next === \"function\") setStored(next as Setter<ThinkingMode>)\n    else setStored(() => next)\n  }\n\n  // Preserve previous experience for users who had explicitly toggled the\n  // legacy `thinking_visibility` boolean. First-time users (no legacy key)\n  // get the new \"hide\" default (collapsed thinking).\n  if (!hadStored) {\n    if (legacy === true) set(\"show\")\n    else if (legacy === false) set(\"hide\")"},{"id":"thinking_usethinkingmode_set","label":"set()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L43-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L43"}],"snippet":"set = (next: ThinkingMode | ((prev: ThinkingMode) => ThinkingMode)) => {\n    if (typeof next === \"function\") setStored(next as Setter<ThinkingMode>)\n    else setStored(() => next)\n  }"}],"edges":[{"source":"thinking","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L1"}],"weight":1},{"source":"thinking","target":"kv","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L2"}],"weight":1},{"source":"thinking","target":"thinking_reasoningsummary","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/context/thinking.ts","source_location":"L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman