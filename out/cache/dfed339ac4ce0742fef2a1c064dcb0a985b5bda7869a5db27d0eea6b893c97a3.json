nance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L31"}],"snippet":"export function createWebSocketFetch(options?: CreateWebSocketFetchOptions) {\n  const httpFetch = options?.httpFetch ?? globalThis.fetch\n  const pool = new Map<string, PoolEntry>()\n  const connectTimeout = options?.connectTimeout ?? DEFAULT_CONNECT_TIMEOUT\n  const idleTimeout = options?.idleTimeout ?? DEFAULT_IDLE_TIMEOUT\n  const maxConnectionAge = options?.maxConnectionAge ?? DEFAULT_MAX_CONNECTION_AGE\n  const streamRetries = options?.streamRetries ?? 5\n  const pruneTimer = setInterval(() => prune(), Math.min(idleTimeout, 60_000))\n  if (typeof pruneTimer === \"object\" && \"unref\" in pruneTimer && typeof pruneTimer.unref === \"function\") {\n    pruneTimer.unref()\n  }\n\n  async function websocketFetch(input: RequestInfo | URL, init?: RequestInit): Promise<Response> {\n    const url = input instanceof URL ? input.toString() : typeof input === \"string\" ? input : input.url\n    const internalHeaders = OpenAIWebSocket.normalizeHeaders(init?.headers)\n    const httpInit = withoutInternalHeaders(init)\n\n    if (init?.method !== \"POST\" || !new URL(url).pathname.endsWith(\"/responses\")) {\n      return httpFetch(input, httpInit)\n    }\n\n    const body = (() => {\n      try {\n        if (typeof init?.body !== \"string\") return undefined\n        const parsed = JSON.parse(init.body)"},{"id":"ws_pool_createwebsocketfetch_websocketfetch","label":"websocketFetch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L43-L161","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L43"}],"snippet":"async function websocketFetch(input: RequestInfo | URL, init?: RequestInit): Promise<Response> {\n    const url = input instanceof URL ? input.toString() : typeof input === \"string\" ? input : input.url\n    const internalHeaders = OpenAIWebSocket.normalizeHeaders(init?.headers)\n    const httpInit = withoutInternalHeaders(init)\n\n    if (init?.method !== \"POST\" || !new URL(url).pathname.endsWith(\"/responses\")) {\n      return httpFetch(input, httpInit)\n    }\n\n    const body = (() => {\n      try {\n        if (typeof init?.body !== \"string\") return undefined\n        const parsed = JSON.parse(init.body)\n        return typeof parsed === \"object\" && parsed !== null ? parsed : undefined\n      } catch {\n        return undefined\n      }\n    })()\n    if (!body?.stream) return httpFetch(input, httpInit)\n    if (internalHeaders[TITLE_HEADER] === \"true\") {\n      return httpFetch(input, httpInit)\n    }\n\n    const sessionID = internalHeaders[\"x-session-affinity\"] ?? internalHeaders[\"session-id\"]\n    if (!sessionID) {"},{"id":"ws_pool_createwebsocketfetch_websocketfetch_resolvefirstevent","label":"resolveFirstEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L93"}],"snippet":"resolveFirstEvent: (event: boolean | OpenAIWebSocket.WrappedError) => void = () => {}"},{"id":"ws_pool_createwebsocketfetch_websocketfetch_rejectfirstevent","label":"rejectFirstEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L94"}],"snippet":"rejectFirstEvent: (error: Error) => void = () => {}"},{"id":"ws_pool_createwebsocketfetch_recordstreamfailure","label":"recordStreamFailure()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L163-L167","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L163"}],"snippet":"function recordStreamFailure(entry: PoolEntry) {\n    entry.streamFailures++\n    // Codex counts retries after the initial failed WebSocket attempt.\n    if (entry.streamFailures > streamRetries) entry.fallback = true\n  }"},{"id":"ws_pool_createwebsocketfetch_prune","label":"prune()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L169-L178","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L169"}],"snippet":"function prune() {\n    const now = Date.now()\n    for (const [key, entry] of pool) {\n      if (entry.busy) continue\n      if (entry.fallback) continue\n      if (now - entry.lastUsedAt < idleTimeout) continue\n      invalidate(entry)\n      pool.delete(key)\n    }\n  }"},{"id":"ws_pool_createwebsocketfetch_close","label":"close()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L180-L184","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L180"}],"snippet":"function close() {\n    clearInterval(pruneTimer)\n    for (const entry of pool.values()) invalidate(entry)\n    pool.clear()\n  }"},{"id":"ws_pool_createwebsocketfetch_remove","label":"remove()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L186-L192","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L186"}],"snippet":"function remove(sessionID: string) {\n    const key = `${sessionID}:conversation`\n    const entry = pool.get(key)\n    if (!entry) return\n    invalidate(entry)\n    pool.delete(key)\n  }"},{"id":"ws_pool_connectionlimiterror","label":"connectionLimitError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L197-L200","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L197"}],"snippet":"function connectionLimitError(event: Record<string, unknown>) {\n  if (event.type !== \"error\" || !isRecord(event.error) || event.error.code !== CONNECTION_LIMIT_REACHED_CODE) return\n  return new Error(typeof event.error.message === \"string\" ? event.error.message : CONNECTION_LIMIT_REACHED_CODE)\n}"},{"id":"ws_pool_failedresponse","label":"failedResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L202-L214","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L202"}],"snippet":"function failedResponse(error: ProviderError.ResponseStreamError) {\n  return new Response(\n    new ReadableStream({\n      start(controller) {\n        controller.error(error)\n      },\n    }),\n    {\n      status: 200,\n      headers: { \"content-type\": \"text/event-stream\" },\n    },\n  )\n}"},{"id":"ws_pool_socket","label":"socket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L216-L241","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L216"}],"snippet":"async function socket(\n  entry: PoolEntry,\n  url: string,\n  headers: Record<string, string>,\n  connectTimeout: number,\n  maxConnectionAge: number,\n  signal?: AbortSignal | null,\n) {\n  if (\n    entry.socket?.readyState === WebSocket.OPEN &&\n    entry.connectedAt &&\n    Date.now() - entry.connectedAt < maxConnectionAge\n  ) {\n    return entry.socket\n  }\n\n  invalidate(entry)\n  const next = await OpenAIWebSocket.connectResponsesWebSocket({\n    url: OpenAIWebSocket.toWebSocketUrl(url),\n    headers,\n    timeout: connectTimeout,\n    signal: signal ?? undefined,\n  })\n  entry.connectedAt = Date.now()\n  return next"},{"id":"ws_pool_invalidate","label":"invalidate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L243-L250","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L243"}],"snippet":"function invalidate(entry: PoolEntry) {\n  if (entry.socket) {\n    entry.socket.on(\"error\", () => {})\n    entry.socket.terminate()\n    entry.socket = undefined\n  }\n  entry.connectedAt = undefined\n}"},{"id":"ws_pool_withoutinternalheaders","label":"withoutInternalHeaders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L252-L268","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L252"}],"snippet":"export function withoutInternalHeaders<T extends { headers?: HeadersInit }>(init: T | undefined): T | undefined {\n  if (!init?.headers) return init\n  if (init.headers instanceof Headers) {\n    const headers = new Headers(init.headers)\n    headers.delete(TITLE_HEADER)\n    return { ...init, headers }\n  }\n\n  if (Array.isArray(init.headers)) {\n    return { ...init, headers: init.headers.filter((item) => item[0].toLowerCase() !== TITLE_HEADER) }\n  }\n\n  return {\n    ...init,\n    headers: Object.fromEntries(Object.entries(init.headers).filter(([key]) => key.toLowerCase() !== TITLE_HEADER)),\n  }\n}"}],"edges":[{"source":"ws_pool","target":"ws","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L1"}],"weight":1},{"source":"ws_pool","target":"error","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/ws-pool.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ope