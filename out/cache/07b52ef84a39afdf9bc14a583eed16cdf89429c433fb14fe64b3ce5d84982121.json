{"__madarTsExtractorVersion":67,"__madarFileStem":"session-trim","nodes":[{"id":"session_trim","label":"session-trim.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L1"}]},{"id":"session_trim_sessionupdatedat","label":"sessionUpdatedAt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L5-L7","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L5"}],"snippet":"export function sessionUpdatedAt(session: Session) {\n  return session.time.updated ?? session.time.created\n}"},{"id":"session_trim_comparesessionrecent","label":"compareSessionRecent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L9-L14","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L9"}],"snippet":"export function compareSessionRecent(a: Session, b: Session) {\n  const aUpdated = sessionUpdatedAt(a)\n  const bUpdated = sessionUpdatedAt(b)\n  if (aUpdated !== bUpdated) return bUpdated - aUpdated\n  return cmp(a.id, b.id)\n}"},{"id":"session_trim_takerecentsessions","label":"takeRecentSessions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L16-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L16"}],"snippet":"export function takeRecentSessions(sessions: Session[], limit: number, cutoff: number) {\n  if (limit <= 0) return [] as Session[]\n  const selected: Session[] = []\n  const seen = new Set<string>()\n  for (const session of sessions) {\n    if (!session?.id) continue\n    if (seen.has(session.id)) continue\n    seen.add(session.id)\n    if (sessionUpdatedAt(session) <= cutoff) continue\n    const index = selected.findIndex((x) => compareSessionRecent(session, x) < 0)\n    if (index === -1) selected.push(session)\n    if (index !== -1) selected.splice(index, 0, session)\n    if (selected.length > limit) selected.pop()\n  }\n  return selected\n}"},{"id":"session_trim_trimsessions","label":"trimSessions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L33-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L33"}],"snippet":"export function trimSessions(\n  input: Session[],\n  options: { limit: number; permission: Record<string, PermissionRequest[]>; now?: number },\n) {\n  const limit = Math.max(0, options.limit)\n  const cutoff = (options.now ?? Date.now()) - SESSION_RECENT_WINDOW\n  const all = input\n    .filter((s) => !!s?.id)\n    .filter((s) => !s.time?.archived)\n    .sort((a, b) => cmp(a.id, b.id))\n  const roots = all.filter((s) => !s.parentID)\n  roots.sort(compareSessionRecent)\n  const children = all.filter((s) => !!s.parentID)\n  const base = roots.slice(0, limit)\n  const recent = takeRecentSessions(roots.slice(limit), SESSION_RECENT_LIMIT, cutoff)\n  const keepRoots = [...base, ...recent]\n  const keepRootIds = new Set(keepRoots.map((s) => s.id))\n  const keepChildren = children.filter((s) => {\n    if (s.parentID && keepRootIds.has(s.parentID)) return true\n    const perms = options.permission[s.id] ?? []\n    if (perms.length > 0) return true\n    return sessionUpdatedAt(s) > cutoff\n  })\n  return [...keepRoots, ...keepChildren].sort((a, b) => cmp(a.id, b.id))\n}"}],"edges":[{"source":"session_trim","target":"client","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L1"}],"weight":1},{"source":"session_trim","target":"utils","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L2"}],"weight":1},{"source":"session_trim","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-trim.ts","source_location":"L3"}],"weight":1},{"source":"session_trim","target":"session_trim_sessionupdatedat","relation":"contains","confidence":"EXTRACTED","source_fi