roviderId }, \"provider authentication required\")\n    case \"ACPUnknownAuthMethodError\":\n      return RequestError.invalidParams({ methodId: error.methodId }, `unknown auth method: ${error.methodId}`)\n    case \"ACPUnsupportedOperationError\":\n      return RequestError.methodNotFound(error.method)\n    case \"ACPServiceFailureError\":\n      return RequestError.internalError({ service: error.service }, error.safeMessage)\n  }\n}"},{"id":"packages_opencode_src_acp_error_fromunknowndefect","label":"fromUnknownDefect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/error.ts","source_location":"L88-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/error.ts","source_location":"L88"}],"snippet":"export function fromUnknownDefect(_defect: unknown, safeMessage = \"Internal service failure\") {\n  return new ServiceFailureError({ safeMessage })\n}"}],"edges":[{"source":"packages_opencode_src_acp_error","target":"sdk","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/error.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/error.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_acp_error","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/error.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/acp/error.ts","source_location":"L2"}],"weight":1},{"source":"packages_opencode_src_acp_