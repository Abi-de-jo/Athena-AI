{"__madarTsExtractorVersion":67,"__madarFileStem":"use-filtered-list","nodes":[{"id":"use_filtered_list","label":"use-filtered-list.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L1"}]},{"id":"use_filtered_list_filteredlistprops","label":"FilteredListProps","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L7-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L7"}],"snippet":"export interface FilteredListProps<T> {\n  items: T[] | ((filter: string) => T[] | Promise<T[]>)\n  key: (item: T) => string\n  filterKeys?: string[]\n  current?: T\n  groupBy?: (x: T) => string\n  sortBy?: (a: T, b: T) => number\n  sortGroupsBy?: (a: { category: string; items: T[] }, b: { category: string; items: T[] }) => number\n  skipFilter?: (item: T) => boolean\n  onSelect?: (value: T | undefined, index: number) => void\n  noInitialSelection?: boolean\n}"},{"id":"use_filtered_list_usefilteredlist","label":"useFilteredList()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L20-L134","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L20"}],"snippet":"export function useFilteredList<T>(props: FilteredListProps<T>) {\n  const [store, setStore] = createStore<{ filter: string }>({ filter: \"\" })\n\n  type Group = { category: string; items: [T, ...T[]] }\n  const empty: Group[] = []\n\n  const [grouped, { refetch }] = createResource(\n    () => ({\n      filter: store.filter,\n      items: typeof props.items === \"function\" ? props.items(store.filter) : props.items,\n    }),\n    async ({ filter, items }) => {\n      const query = filter ?? \"\"\n      const needle = query.toLowerCase()\n      const all = (await Promise.resolve(items)) || []\n      const result = pipe(\n        all,\n        (x) => {\n          if (!needle) return x\n          const skipFilter = props.skipFilter\n          const filterable = skipFilter ? x.filter((item) => !skipFilter(item)) : x\n          const skipped = skipFilter ? x.filter(skipFilter) : []\n          const filtered =\n            !props.filterKeys && Array.isArray(filterable) && filterable.every((e) => typeof e === \"string\")\n              ? (fuzzysort.go(needle, filterable).map((x) => x.target) as T[])"},{"id":"use_filtered_list_usefilteredlist_initialactive","label":"initialActive()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L65-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L65"}],"snippet":"function initialActive() {\n    if (props.noInitialSelection) return \"\"\n    if (props.current) return props.key(props.current)\n\n    const items = flat()\n    if (items.length === 0) return \"\"\n    return props.key(items[0])\n  }"},{"id":"use_filtered_list_usefilteredlist_reset","label":"reset()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L80-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L80"}],"snippet":"reset = () => {\n    if (props.noInitialSelection) {\n      list.setActive(\"\")\n      return\n    }\n    const all = flat()\n    if (all.length === 0) return\n    list.setActive(props.key(all[0]))\n  }"},{"id":"use_filtered_list_usefilteredlist_onkeydown","label":"onKeyDown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L90-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L90"}],"snippet":"onKeyDown = (event: KeyboardEvent) => {\n    if (event.key === \"Enter\" && !event.isComposing) {\n      event.preventDefault()\n      const selectedIndex = flat().findIndex((x) => props.key(x) === list.active())\n      const selected = flat()[selectedIndex]\n      if (selected) props.onSelect?.(selected, selectedIndex)\n    } else if (event.ctrlKey && !event.metaKey && !event.altKey && !event.shiftKey) {\n      if (event.key === \"n\" || event.key === \"p\") {\n        event.preventDefault()\n        const navEvent = new KeyboardEvent(\"keydown\", {\n          key: event.key === \"n\" ? \"ArrowDown\" : \"ArrowUp\",\n          bubbles: true,\n        })\n        list.onKeyDown(navEvent)\n      }\n    } else {\n      // Skip list navigation for text editing shortcuts (e.g., Option+Arrow, Option+Backspace on macOS)\n      if (event.altKey || event.metaKey) return\n      list.onKeyDown(event)\n    }\n  }"},{"id":"use_filtered_list_usefilteredlist_oninput","label":"onInput()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L118-L120","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L118"}],"snippet":"onInput = (value: string) => {\n    setStore(\"filter\", value)\n  }"}],"edges":[{"source":"use_filtered_list","target":"fuzzysort","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L1"}],"weight":1},{"source":"use_filtered_list","target":"remeda","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L2"}],"weight":1},{"source":"use_filtered_list","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L3"}],"weight":1},{"source":"use_filtered_list","target":"store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/hooks/use-filtered-list.tsx","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/pers