{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_sdk_js_src_gen_core_queryKeySerializer.gen","nodes":[{"id":"packages_sdk_js_src_gen_core_querykeyserializer_gen","label":"queryKeySerializer.gen.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L1"}]},{"id":"packages_sdk_js_src_gen_core_querykeyserializer_gen_querykeyjsonreplacer","label":"queryKeyJsonReplacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L11-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L11"}],"snippet":"queryKeyJsonReplacer = (_key: string, value: unknown) => {\n  if (value === undefined || typeof value === \"function\" || typeof value === \"symbol\") {\n    return undefined\n  }\n  if (typeof value === \"bigint\") {\n    return value.toString()\n  }\n  if (value instanceof Date) {\n    return value.toISOString()\n  }\n  return value\n}"},{"id":"packages_sdk_js_src_gen_core_querykeyserializer_gen_stringifytojsonvalue","label":"stringifyToJsonValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L27-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L27"}],"snippet":"stringifyToJsonValue = (input: unknown): JsonValue | undefined => {\n  try {\n    const json = JSON.stringify(input, queryKeyJsonReplacer)\n    if (json === undefined) {\n      return undefined\n    }\n    return JSON.parse(json) as JsonValue\n  } catch {\n    return undefined\n  }\n}"},{"id":"packages_sdk_js_src_gen_core_querykeyserializer_gen_isplainobject","label":"isPlainObject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L42-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L42"}],"snippet":"isPlainObject = (value: unknown): value is Record<string, unknown> => {\n  if (value === null || typeof value !== \"object\") {\n    return false\n  }\n  const prototype = Object.getPrototypeOf(value as object)\n  return prototype === Object.prototype || prototype === null\n}"},{"id":"packages_sdk_js_src_gen_core_querykeyserializer_gen_serializesearchparams","label":"serializeSearchParams()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L53-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L53"}],"snippet":"serializeSearchParams = (params: URLSearchParams): JsonValue => {\n  const entries = Array.from(params.entries()).sort(([a], [b]) => a.localeCompare(b))\n  const result: Record<string, JsonValue> = {}\n\n  for (const [key, value] of entries) {\n    const existing = result[key]\n    if (existing === undefined) {\n      result[key] = value\n      continue\n    }\n\n    if (Array.isArray(existing)) {\n      ;(existing as string[]).push(value)\n    } else {\n      result[key] = [existing, value]\n    }\n  }\n\n  return result\n}"},{"id":"packages_sdk_js_src_gen_core_querykeyserializer_gen_serializequerykeyvalue","label":"serializeQueryKeyValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L77-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L77"}],"snippet":"serializeQueryKeyValue = (value: unknown): JsonValue | undefined => {\n  if (value === null) {\n    return null\n  }\n\n  if (typeof value === \"string\" || typeof value === \"number\" || typeof value === \"boolean\") {\n    return value\n  }\n\n  if (value === undefined || typeof value === \"function\" || typeof value === \"symbol\") {\n    return undefined\n  }\n\n  if (typeof value === \"bigint\") {\n    return value.toString()\n  }\n\n  if (value instanceof Date) {\n    return value.toISOString()\n  }\n\n  if (Array.isArray(value)) {\n    return stringifyToJsonValue(value)\n  }"}],"edges":[{"source":"packages_sdk_js_src_gen_core_querykeyserializer_gen","target":"packages_sdk_js_src_gen_core_querykeyserializer_gen_querykeyjsonreplacer","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L11","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/core/queryKeySerializer.gen.ts","source_location":"L11"}],"weight":1},{"source":"packages_sdk_js_src_gen_core_querykeyserializer_gen","target":"packages_sdk_js_src_gen_core_querykeyserializer_gen_stringifytojsonvalue","relation":"contains","confidence":"EXTRACTED