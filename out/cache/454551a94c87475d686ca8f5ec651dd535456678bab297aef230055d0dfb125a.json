{"__madarTsExtractorVersion":67,"__madarFileStem":"file-tabs","nodes":[{"id":"file_tabs","label":"file-tabs.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L1"}]},{"id":"file_tabs_filecommentmenu","label":"FileCommentMenu()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L23-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L23"}],"snippet":"function FileCommentMenu(props: {\n  moreLabel: string\n  editLabel: string\n  deleteLabel: string\n  onEdit: VoidFunction\n  onDelete: VoidFunction\n}) {\n  return (\n    <div onMouseDown={(event) => event.stopPropagation()} onClick={(event) => event.stopPropagation()}>\n      <DropdownMenu gutter={4} placement=\"bottom-end\">\n        <DropdownMenu.Trigger\n          as={IconButton}\n          icon=\"dot-grid\"\n          variant=\"ghost\"\n          size=\"small\"\n          class=\"size-6 rounded-md\"\n          aria-label={props.moreLabel}\n        />\n        <DropdownMenu.Portal>\n          <DropdownMenu.Content>\n            <DropdownMenu.Item onSelect={props.onEdit}>\n              <DropdownMenu.ItemLabel>{props.editLabel}</DropdownMenu.ItemLabel>\n            </DropdownMenu.Item>\n            <DropdownMenu.Item onSelect={props.onDelete}>\n              <DropdownMenu.ItemLabel>{props.deleteLabel}</DropdownMenu.ItemLabel>","node_kind":"component"},{"id":"file_tabs_createscrollsync","label":"createScrollSync()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L58-L172","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L58"}],"snippet":"function createScrollSync(input: { tab: () => string; view: ReturnType<typeof useSessionLayout>[\"view\"] }) {\n  let scroll: HTMLDivElement | undefined\n  let scrollFrame: number | undefined\n  let restoreFrame: number | undefined\n  let pending: ScrollPos | undefined\n  const [code, setCode] = createSignal<HTMLElement[]>([])\n\n  const getCode = () => {\n    const el = scroll\n    if (!el) return []\n\n    const host = el.querySelector(\"diffs-container\")\n    if (!(host instanceof HTMLElement)) return []\n\n    const root = host.shadowRoot\n    if (!root) return []\n\n    return Array.from(root.querySelectorAll(\"[data-code]\")).filter(\n      (node): node is HTMLElement => node instanceof HTMLElement && node.clientWidth > 0,\n    )\n  }\n\n  const save = (next: ScrollPos) => {\n    pending = next\n    if (scrollFrame !== undefined) return"},{"id":"file_tabs_createscrollsync_getcode","label":"getCode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L65-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L65"}],"snippet":"getCode = () => {\n    const el = scroll\n    if (!el) return []\n\n    const host = el.querySelector(\"diffs-container\")\n    if (!(host instanceof HTMLElement)) return []\n\n    const root = host.shadowRoot\n    if (!root) return []\n\n    return Array.from(root.querySelectorAll(\"[data-code]\")).filter(\n      (node): node is HTMLElement => node instanceof HTMLElement && node.clientWidth > 0,\n    )\n  }"},{"id":"file_tabs_createscrollsync_save","label":"save()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L80-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L80"}],"snippet":"save = (next: ScrollPos) => {\n    pending = next\n    if (scrollFrame !== undefined) return\n\n    scrollFrame = requestAnimationFrame(() => {\n      scrollFrame = undefined\n\n      const out = pending\n      pending = undefined\n      if (!out) return\n\n      input.view().setScroll(input.tab(), out)\n    })\n  }"},{"id":"file_tabs_createscrollsync_oncodescroll","label":"onCodeScroll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L95-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L95"}],"snippet":"onCodeScroll = (event: Event) => {\n    const el = scroll\n    if (!el) return\n\n    const target = event.currentTarget\n    if (!(target instanceof HTMLElement)) return\n\n    save({\n      x: target.scrollLeft,\n      y: el.scrollTop,\n    })\n  }"},{"id":"file_tabs_createscrollsync_sync","label":"sync()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L108-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L108"}],"snippet":"sync = () => {\n    const next = getCode()\n    const current = code()\n    if (next.length === current.length && next.every((el, i) => el === current[i])) return\n    setCode(next)\n  }"},{"id":"file_tabs_createscrollsync_restore","label":"restore()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L115-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L115"}],"snippet":"restore = () => {\n    const el = scroll\n    if (!el) return\n\n    const pos = input.view().scroll(input.tab())\n    if (!pos) return\n\n    sync()\n\n    if (code().length > 0) {\n      for (const item of code()) {\n        if (item.scrollLeft !== pos.x) item.scrollLeft = pos.x\n      }\n    }\n\n    if (el.scrollTop !== pos.y) el.scrollTop = pos.y\n    if (code().length > 0) return\n    if (el.scrollLeft !== pos.x) el.scrollLeft = pos.x\n  }"},{"id":"file_tabs_createscrollsync_queuerestore","label":"queueRestore()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L135-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L135"}],"snippet":"queueRestore = () => {\n    if (restoreFrame !== undefined) return\n\n    restoreFrame = requestAnimationFrame(() => {\n      restoreFrame = undefined\n      restore()\n    })\n  }"},{"id":"file_tabs_createscrollsync_handlescroll","label":"handleScroll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L144-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L144"}],"snippet":"handleScroll = (event: Event & { currentTarget: HTMLDivElement }) => {\n    if (code().length === 0) sync()\n\n    save({\n      x: code()[0]?.scrollLeft ?? event.currentTarget.scrollLeft,\n      y: event.currentTarget.scrollTop,\n    })\n  }"},{"id":"file_tabs_createscrollsync_setviewport","label":"setViewport()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L157-L160","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L157"}],"snippet":"setViewport = (el: HTMLDivElement) => {\n    scroll = el\n    restore()\n  }"},{"id":"file_tabs_filetabcontent","label":"FileTabContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L174-L456","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L174"}],"snippet":"export function FileTabContent(props: { tab: string }) {\n  const file = useFile()\n  const comments = useComments()\n  const language = useLanguage()\n  const prompt = usePrompt()\n  const fileComponent = useFileComponent()\n  const { sessionKey, tabs, view } = useSessionLayout()\n  const activeFileTab = createSessionTabs({\n    tabs,\n    pathFromTab: file.pathFromTab,\n    normalizeTab: (tab) => (tab.startsWith(\"file://\") ? file.tab(tab) : tab),\n  }).activeFileTab\n\n  let find: FileSearchHandle | null = null\n\n  const search = {\n    register: (handle: FileSearchHandle | null) => {\n      find = handle\n    },\n  }\n\n  const path = createMemo(() => file.pathFromTab(props.tab))\n  const state = createMemo(() => {\n    const p = path()\n    if (!p) return","node_kind":"component"},{"id":"file_tabs_filetabcontent_selectionpreview","label":"selectionPreview()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L214-L219","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L214"}],"snippet":"selectionPreview = (source: string, selection: FileSelection) => {\n    return previewSelectedLines(source, {\n      start: selection.startLine,\n      end: selection.endLine,\n    })\n  }"},{"id":"file_tabs_filetabcontent_buildpreview","label":"buildPreview()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L221-L225","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L221"}],"snippet":"buildPreview = (filePath: string, selection: FileSelection) => {\n    const source = filePath === path() ? contents() : file.get(filePath)?.content?.content\n    if (!source) return undefined\n    return selectionPreview(source, selection)\n  }"},{"id":"file_tabs_filetabcontent_addcommenttocontext","label":"addCommentToContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L227-L251","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L227"}],"snippet":"addCommentToContext = (input: {\n    file: string\n    selection: SelectedLineRange\n    comment: string\n    preview?: string\n    origin?: \"review\" | \"file\"\n  }) => {\n    const selection = selectionFromLines(input.selection)\n    const preview = input.preview ?? buildPreview(input.file, selection)\n\n    const saved = comments.add({\n      file: input.file,\n      selection: input.selection,\n      comment: input.comment,\n    })\n    prompt.context.add({\n      type: \"file\",\n      path: input.file,\n      selection,\n      comment: input.comment,\n      commentID: saved.id,\n      commentOrigin: input.origin,\n      preview,\n    })\n  }"},{"id":"file_tabs_filetabcontent_updatecommentincontext","label":"updateCommentInContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L253-L265","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L253"}],"snippet":"updateCommentInContext = (input: {\n    id: string\n    file: string\n    selection: SelectedLineRange\n    comment: string\n  }) => {\n    comments.update(input.file, input.id, input.comment)\n    const preview = input.file === path() ? buildPreview(input.file, selectionFromLines(input.selection)) : undefined\n    prompt.context.updateComment(input.file, input.id, {\n      comment: input.comment,\n      ...(preview ? { preview } : {}),\n    })\n  }"},{"id":"file_tabs_filetabcontent_removecommentfromcontext","label":"removeCommentFromContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L267-L270","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L267"}],"snippet":"removeCommentFromContext = (input: { id: string; file: string }) => {\n    comments.remove(input.file, input.id)\n    prompt.context.removeComment(input.file, input.id)\n  }"},{"id":"file_tabs_filetabcontent_syncselected","label":"syncSelected()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L286-L290","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L286"}],"snippet":"syncSelected = (range: SelectedLineRange | null) => {\n    const p = path()\n    if (!p) return\n    file.setSelectedLines(p, range ? cloneSelectedLineRange(range) : null)\n  }"},{"id":"file_tabs_filetabcontent_activeselection","label":"activeSelection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L292","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L292"}],"snippet":"activeSelection = () => note.selected ?? selectedLines()"},{"id":"file_tabs_filetabcontent_onkeydown","label":"onKeyDown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L344-L352","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L344"}],"snippet":"onKeyDown = (event: KeyboardEvent) => {\n      if (activeFileTab() !== props.tab) return\n      if (!(event.metaKey || event.ctrlKey) || event.altKey || event.shiftKey) return\n      if (event.key.toLowerCase() !== \"f\") return\n\n      event.preventDefault()\n      event.stopPropagation()\n      find?.focus()\n    }"},{"id":"file_tabs_filetabcontent_renderfile","label":"renderFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L397-L441","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L397"}],"snippet":"renderFile = (source: string) => (\n    <div class=\"relative overflow-hidden pb-40\">\n      <Dynamic\n        component={fileComponent}\n        mode=\"text\"\n        file={{\n          name: path() ?? \"\",\n          contents: source,\n          cacheKey: cacheKey(),\n        }}\n        enableLineSelection\n        enableHoverUtility\n        selectedLines={activeSelection()}\n        commentedLines={commentedLines()}\n        onRendered={() => {\n          scrollSync.queueRestore()\n        }}\n        annotations={commentsUi.annotations()}\n        renderAnnotation={commentsUi.renderAnnotation}\n        renderHoverUtility={commentsUi.renderHoverUtility}\n        onLineSelected={(range: SelectedLineRange | null) => {\n          commentsUi.onLineSelected(range)\n        }}\n        onLineNumberSelectionEnd={commentsUi.onLineNumberSelectionEnd}\n        onLineSelectionEnd={(range: SelectedLineRange | null) => {"}],"edges":[{"source":"file_tabs","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/file-tabs.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimu