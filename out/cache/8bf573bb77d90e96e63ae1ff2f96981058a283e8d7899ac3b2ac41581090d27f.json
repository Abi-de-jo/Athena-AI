{"__madarTsExtractorVersion":67,"__madarFileStem":"acp-test-client","nodes":[{"id":"acp_test_client","label":"acp-test-client.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L1"}]},{"id":"acp_test_client_createacpclient","label":"createAcpClient()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L36-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L36"}],"snippet":"export function createAcpClient(acp: AcpHandle): AcpClient {\n  const state = { nextId: 1 }\n\n  const request = <T>(method: string, params?: unknown) =>\n    Effect.gen(function* () {\n      const id = state.nextId++\n      const message: JsonRpcRequest =\n        params === undefined ? { jsonrpc: \"2.0\", id, method } : { jsonrpc: \"2.0\", id, method, params }\n      yield* acp.send(message)\n\n      while (true) {\n        const received = yield* acp.receive.pipe(Effect.timeout(Duration.seconds(15)))\n        if (isJsonRpcResponse<T>(received) && received.id === id) return received\n      }\n    })\n\n  const waitForNotification = <T>(method: string, predicate: (params: T) => boolean, timeoutMs = 15_000) =>\n    Effect.gen(function* () {\n      while (true) {\n        const received = yield* acp.receive.pipe(Effect.timeout(Duration.millis(timeoutMs)))\n        if (!isJsonRpcNotification<T>(received)) continue\n        if (received.method === method && predicate(received.params as T)) return received\n      }\n    })"},{"id":"acp_test_client_createacpclient_request","label":"request()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L39-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L39"}],"snippet":"request = <T>(method: string, params?: unknown) =>\n    Effect.gen(function* () {\n      const id = state.nextId++\n      const message: JsonRpcRequest =\n        params === undefined ? { jsonrpc: \"2.0\", id, method } : { jsonrpc: \"2.0\", id, method, params }\n      yield* acp.send(message)\n\n      while (true) {\n        const received = yield* acp.receive.pipe(Effect.timeout(Duration.seconds(15)))\n        if (isJsonRpcResponse<T>(received) && received.id === id) return received\n      }\n    })"},{"id":"acp_test_client_createacpclient_waitfornotification","label":"waitForNotification()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L52-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L52"}],"snippet":"waitForNotification = <T>(method: string, predicate: (params: T) => boolean, timeoutMs = 15_000) =>\n    Effect.gen(function* () {\n      while (true) {\n        const received = yield* acp.receive.pipe(Effect.timeout(Duration.millis(timeoutMs)))\n        if (!isJsonRpcNotification<T>(received)) continue\n        if (received.method === method && predicate(received.params as T)) return received\n      }\n    })"},{"id":"acp_test_client_expectok","label":"expectOk()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L68-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L68"}],"snippet":"export function expectOk<T>(response: JsonRpcResponse<T>) {\n  expect(response.error).toBeUndefined()\n  expect(response.result).toBeDefined()\n  return response.result as T\n}"},{"id":"acp_test_client_selectconfigoption","label":"selectConfigOption()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L74-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L74"}],"snippet":"export function selectConfigOption(options: SessionConfigOption[] | null | undefined, id: string) {\n  return options?.find(\n    (option): option is Extract<SessionConfigOption, { type: \"select\" }> =>\n      option.id === id && option.type === \"select\",\n  )\n}"},{"id":"acp_test_client_firstalternatevalue","label":"firstAlternateValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L81-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L81"}],"snippet":"export function firstAlternateValue(option: Extract<SessionConfigOption, { type: \"select\" }>) {\n  return flattenSelectOptions(option).find((item) => item.value !== option.currentValue)?.value\n}"},{"id":"acp_test_client_flattenselectoptions","label":"flattenSelectOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L85-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L85"}],"snippet":"export function flattenSelectOptions(option: Extract<SessionConfigOption, { type: \"select\" }>) {\n  return option.options.flatMap((item): SessionConfigSelectOption[] => (\"value\" in item ? [item] : item.options))\n}"},{"id":"acp_test_client_isjsonrpcresponse","label":"isJsonRpcResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L89-L92","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L89"}],"snippet":"function isJsonRpcResponse<T>(input: unknown): input is JsonRpcResponse<T> {\n  if (!input || typeof input !== \"object\") return false\n  return \"id\" in input && \"jsonrpc\" in input\n}"},{"id":"acp_test_client_isjsonrpcnotification","label":"isJsonRpcNotification()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L94-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/acp/acp-test-client.ts","source_location":"L94"}],"snippet":"function isJsonRpcNotification<T>(input: unknown): input is JsonRpcNotification<T> {\n  if (!input || typeof input !== \"object\") return false\n  return \"method\" in input && !(\"id\" in input) && \"jsonrpc\" in input\n}"}],"edges":[{"source":"acp_test_client","target":"bun_test","relation