kages/opencode/src/plugin/index.ts","source_location":"L84"}],"snippet":"function isServerPlugin(value: unknown): value is PluginInstance {\n  return typeof value === \"function\"\n}"},{"id":"packages_opencode_src_plugin_index_getserverplugin","label":"getServerPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/index.ts","source_location":"L88-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/index.ts","source_location":"L88"}],"snippet":"function getServerPlugin(value: unknown) {\n  if (isServerPlugin(value)) return value\n  if (!value || typeof value !== \"object\" || !(\"server\" in value)) return\n  if (!isServerPlugin(value.server)) return\n  return value.server\n}"},{"id":"packages_opencode_src_plugin_index_getlegacyplugins","label":"getLegacyPlugins()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/index.ts","source_location":"L95-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/index.ts","source_location":"L95"}],"snippet":"function getLegacyPlugins(mod: Record<string, unknown>) {\n  const seen = new Set<unknown>()\n  const result: PluginInstance[] = []\n\n  for (const entry of Object.values(mod)) {\n    if (seen.has(entry)) continue\n    seen.add(entry)\n    const plugin = getServerPlugin(entry)\n    if (!plugin) throw new TypeError(\"Plugin export is not a function\")\n    result.push(plugin)\n  }\n\n  return result\n}"},{"id":"packages_opencode_src_plugin_index_applyplugin","label":"applyPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/index.ts","source_location":"L110-L121","layer":"base","provenance