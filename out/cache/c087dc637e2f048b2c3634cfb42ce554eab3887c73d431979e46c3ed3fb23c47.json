Part[]) => {\n  if (!parts) return want.length === 0\n  return want.every((part) => Binary.search(parts, part.id, (item) => item.id).found)\n}"},{"id":"packages_app_src_context_sync_mergeparts","label":"mergeParts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/sync.tsx","source_location":"L48-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/sync.tsx","source_location":"L48"}],"snippet":"mergeParts = (parts: Part[] | undefined, want: Part[]) => {\n  if (!parts) return sortParts(want)\n  const next = [...parts]\n  let changed = false\n  for (const part of want) {\n    const result = Binary.search(next, part.id, (item) => item.id)\n    if (result.found) continue\n    next.splice(result.index, 0, part)\n    changed = true\n  }\n  if (!changed) return parts\n  return next\n}"},{"id":"packages_app_src_context_sync_mergeoptimisticpage","label":"mergeOptimisticPage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/sync.tsx","source_location":"L62-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/sync.tsx","source_location":"L62"}],"snippet":"export function mergeOptimisticPage(page: MessagePage, items: OptimisticItem[]) {\n  if (items.length === 0) return { ...page, confirmed: [] as string[] }\n\n  const session = [...page.session]\n  const part = new Map(page.part.map((item) => [item.id, sortParts(item.part)]))\n  const confirmed: string[] = []\n\n  for (const item of items) {\n    const result = Binary.search(session, item.message.id, (message) => message.id)\n    const found = result.found\n    if (!found) session.splice(result.index, 0, item.message)\n\n    const current = part.get(item.message.id)\n    if (found && hasParts(current, item.parts)) {\n      confirmed.push(item.message.id)\n      continue\n    }\n\n    part.set(item.message.id, mergeParts(current, item.parts))\n  }\n\n  return {\n    cursor: page.cursor,\n    complete: page.complete,\n    session,"},{"id":"packages_app_src_context_sync_applyoptimisticadd","label":"applyOptimisticAdd()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/sync.tsx","source_location":"L92-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/sync.tsx","source_location":"L92"}],"snippet":"export function applyOptimisticAdd(draft: OptimisticStore, input: OptimisticAddInput) {\n  const messages = draft.message[input.sessionID]\n  if (messages) {\n    const result = Binary.search(messages, input.message.id, (m) => m.id)\n    messages.splice(result.index, 0, input.message)\n  } else {\n    draft.message[input.sessionID] = [input.message]\n  }\n  draft.part[input.message.id] = sortParts(input.parts)\n}"},{"id":"packages_app_src_context_sync_applyoptimisticremove","label":"applyOptimisticRemove()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/sync.tsx","source_location":"L103-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/sync.tsx","source_location":"L103"}],"snippet":"export function applyOptimisticRemove(draft: OptimisticStore, input: OptimisticRemoveInput) {\n  const messages = draft.message[input.sessionID]\n  if (messages) {\n    const result = Binary.search(messages, input.messageID, (m) => m.id)\n    if (result.found) messages.splice(result.index, 1)\n  }\n  delete draft.part[input.messageID]\n}"},{"id":"packages_app_src_context_sync_usesync","label":"useS