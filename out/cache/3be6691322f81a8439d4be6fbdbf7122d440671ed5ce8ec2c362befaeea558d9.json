{"__madarTsExtractorVersion":67,"__madarFileStem":"selection","nodes":[{"id":"selection","label":"selection.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L1"}]},{"id":"selection_copy","label":"copy()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L26-L44","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L26"}],"snippet":"export function copy(renderer: Renderer, toast: Toast, clipboard: ClipboardService): boolean {\n  const selection = renderer.getSelection()\n  if (!selection) return false\n\n  const text = selection.getSelectedText()\n  if (!text) return false\n\n  const focus = renderer.currentFocusedRenderable\n  const clipboardText =\n    focus?.getClipboardText && selection.selectedRenderables.includes(focus) ? focus.getClipboardText(text) : text\n\n  clipboard\n    ?.write?.(clipboardText)\n    .then(() => toast.show({ message: \"Copied to clipboard\", variant: \"info\" }))\n    .catch(toast.error)\n\n  renderer.clearSelection()\n  return true\n}"},{"id":"selection_handleselectionkey","label":"handleSelectionKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L46-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L46"}],"snippet":"export function handleSelectionKey(\n  renderer: Renderer,\n  toast: Toast,\n  event: SelectionKeyEvent,\n  clipboard: ClipboardService,\n) {\n  const selection = renderer.getSelection()\n  if (!selection) return\n\n  if (event.ctrl && event.name === \"c\") {\n    if (!copy(renderer, toast, clipboard)) {\n      renderer.clearSelection()\n      return\n    }\n\n    event.preventDefault()\n    event.stopPropagation()\n    return\n  }\n\n  if (event.name === \"escape\") {\n    renderer.clearSelection()\n    event.preventDefault()\n    event.stopPropagation()\n    return"}],"edges":[{"source":"selection","target":"clipboard","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L1"}],"weight":1},{"source":"selection","target":"selection_copy","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L26"}],"weight":1},{"source":"selection","target":"selection_handleselectionkey","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/selection.ts","source_location":"L46"}],"weight":1},{"source":"selection","target":"selection","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/ri