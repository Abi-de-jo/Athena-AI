"L90-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L90"}],"snippet":"ok(status = 200, compare: Comparison = \"status\") {\n    return this.done(compare, (_ctx, result) =>\n      Effect.sync(() => {\n        if (result.status !== status) throw new Error(`expected ${status}, got ${result.status}: ${result.text}`)\n      }),\n    )\n  }"},{"id":"dsl_scenariobuilder_status","label":".status()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L98-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L98"}],"snippet":"status(\n    status = 200,\n    inspect?: (ctx: SeededContext<S>, result: CallResult) => Effect.Effect<void>,\n    compare: Comparison = \"status\",\n  ) {\n    return this.done(compare, (ctx, result) =>\n      Effect.gen(function* () {\n        if (result.status !== status) throw new Error(`expected ${status}, got ${result.status}: ${result.text}`)\n        if (inspect) yield* inspect(ctx, result)\n      }),\n    )\n  }"},{"id":"dsl_scenariobuilder_json","label":".json()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L112-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L112"}],"snippet":"json(status = 200, inspect?: (body: unknown, ctx: SeededContext<S>) => void, compare: Comparison = \"json\") {\n    return this.jsonEffect(status, inspect ? (body, ctx) => Effect.sync(() => inspect(body, ctx)) : undefined, compare)\n  }"},{"id":"dsl_scenariobuilder_jsoneffect","label":".jsonEffect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L117-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L117"}],"snippet":"jsonEffect(\n    status = 200,\n    inspect?: (body: unknown, ctx: SeededContext<S>) => Effect.Effect<void>,\n    compare: Comparison = \"json\",\n  ) {\n    return this.done(compare, (ctx, result) =>\n      Effect.gen(function* () {\n        if (result.status !== status) throw new Error(`expected ${status}, got ${result.status}: ${result.text}`)\n        if (!looksJson(result))\n          throw new Error(`expected JSON response, got ${result.contentType || \"no content-type\"}`)\n        if (inspect) yield* inspect(result.body, ctx)\n      }),\n    )\n  }"},{"id":"dsl_scenariobuilder_clone","label":".clone()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L132-L136","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L132"}],"snippet":"private clone(next: Partial<BuilderState<S>>) {\n    const builder = new ScenarioBuilder<S>(this.state.method, this.state.path, this.state.name, this.state.auth)\n    Object.assign(builder.state, this.state, next)\n    return builder\n  }"},{"id":"dsl_scenariobuilder_seeded","label":".seeded()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L142-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L142"}],"snippet":"seeded<Next>(seed: (ctx: ScenarioContext) => Effect.Effect<Next>) {\n    const builder = new ScenarioBuilder<Next>(this.state.method, this.state.path, this.state.name, this.state.auth)\n    Object.assign(builder.state, this.state, { seed })\n    return builder\n  }"},{"id":"dsl_scenariobuilder_done","label":".done()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L148-L171","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L148"}],"snippet":"private done(\n    compare: Comparison,\n    expect: (ctx: SeededContext<S>, result: CallResult) => Effect.Effect<void>,\n  ): ActiveScenario {\n    const state = this.state\n    return {\n      kind: \"active\",\n      method: state.method,\n      path: state.path,\n      name: state.name,\n      project: state.project,\n      seed: state.seed,\n      authProbe: state.authProbe,\n      // oxlint-disable-next-line typescript-eslint/no-unsafe-type-assertion -- `.seeded(...)` preserves the paired request/state type inside the builder.\n      request: (ctx, seeded) => state.request({ ...ctx, state: seeded as S }),\n      // oxlint-disable-next-line typescript-eslint/no-unsafe-type-assertion -- `.seeded(...)` preserves the paired assertion/state type inside the builder.\n      expect: (ctx, seeded, result) => expect({ ...ctx, state: seeded as S }, result),\n      compare,\n      capture: state.capture,\n      mutates: state.mutates,\n      reset: state.reset,\n      auth: state.auth,\n    }\n  }"},{"id":"dsl_routes","label":"routes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L174-L180","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L174"}],"snippet":"routes = (auth: AuthPolicy) => ({\n  get: (path: string, name: string) => new ScenarioBuilder(\"GET\", path, name, auth),\n  post: (path: string, name: string) => new ScenarioBuilder(\"POST\", path, name, auth),\n  put: (path: string, name: string) => new ScenarioBuilder(\"PUT\", path, name, auth),\n  patch: (path: string, name: string) => new ScenarioBuilder(\"PATCH\", path, name, auth),\n  delete: (path: string, name: string) => new ScenarioBuilder(\"DELETE\", path, name, auth),\n})"},{"id":"dsl_pending","label":"pending()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L189-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L189"}],"snippet":"pending = (method: Method, path: string, name: string, reason: string): TodoScenario => ({\n  kind: \"todo\",\n  method,\n  path,\n  name,\n  reason,\n})"},{"id":"dsl_route","label":"route()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L197-L202","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L197"}],"snippet":"export function route(template: string, params: Record<string, string>) {\n  return Object.entries(params).reduce(\n    (next, [key, value]) => next.replaceAll(`{${key}}`, value).replaceAll(`:${key}`, value),\n    template,\n  )\n}"},{"id":"dsl_controlledptyinput","label":"controlledPtyInput()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L204-L210","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L204"}],"snippet":"export function controlledPtyInput(title: string | undefined) {\n  return {\n    command: \"/bin/sh\",\n    args: [\"-c\", \"sleep 30\"],\n    ...(title ? { title } : {}),\n  }\n}"}],"edges":[{"source":"dsl","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L1"}],"weight":1},{"source":"dsl","target":"assertions","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-exercise/dsl.ts","source_location":"L2"}],"weight":1},{"source":"dsl","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/t