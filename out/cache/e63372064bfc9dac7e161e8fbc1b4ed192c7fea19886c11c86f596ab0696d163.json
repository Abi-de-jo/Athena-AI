ource_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L27"}],"snippet":"export class UnsupportedApiError extends Schema.TaggedErrorClass<UnsupportedApiError>()(\n  \"SessionRunnerModel.UnsupportedApiError\",\n  {\n    providerID: ProviderV2.ID,\n    modelID: ModelV2.ID,\n    api: Schema.String,\n  },\n) {}"},{"id":"packages_core_src_session_runner_model_interface","label":"Interface","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L42-L44","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L42"}],"snippet":"export interface Interface {\n  readonly resolve: (session: SessionSchema.Info) => Effect.Effect<Model, Error>\n}"},{"id":"packages_core_src_session_runner_model_service","label":"Service","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L46"}],"snippet":"export class Service extends Context.Service<Service, Interface>()(\"@opencode/v2/SessionRunnerModel\") {}"},{"id":"packages_core_src_session_runner_model_layerwith","label":"layerWith()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L49"}],"snippet":"layerWith = (resolve: Interface[\"resolve\"]) => Layer.succeed(Service, Service.of({ resolve }))"},{"id":"packages_core_src_session_runner_model_apikey","label":"apiKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L51-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L51"}],"snippet":"apiKey = (model: ModelV2.Info, connection?: IntegrationConnection.Info, credential?: Credential.Stored) => {\n  if (credential?.value.type === \"key\") return Auth.value(credential.value.key)\n  if (credential?.value.type === \"oauth\") return Auth.value(credential.value.access)\n  const value = model.request.body.apiKey ?? model.api.settings?.apiKey\n  if (typeof value === \"string\") return Auth.value(value)\n  return connection?.type === \"env\" ? Auth.config(connection.name) : undefined\n}"},{"id":"packages_core_src_session_runner_model_withdefaults","label":"withDefaults()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L59-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L59"}],"snippet":"withDefaults = (model: ModelV2.Info, route: AnyRoute) => {\n  const options = model.request.options ?? {}\n  const namespace = model.api.type === \"aisdk\" ? ModelRequest.namespace(model.api.package) : undefined\n  const body = model.request.body\n  const httpBody = Object.hasOwn(body, \"apiKey\")\n    ? Object.fromEntries(Object.entries(body).filter(([key]) => key !== \"apiKey\"))\n    : body\n  return route.with({\n    provider: model.providerID,\n    endpoint: model.api.url === undefined ? undefined : { baseURL: model.api.url },\n    headers: model.request.headers,\n    generation: model.request.generation,\n    providerOptions: namespace && Object.keys(options).length > 0 ? { [namespace]: options } : undefined,\n    http: { body: httpBody },\n    limits: { context: model.limit.context, output: model.limit.output },\n  })\n}"},{"id":"packages_core_src_session_runner_model_withvariant","label":"withVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L77-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L77"}],"snippet":"withVariant = (model: ModelV2.Info, variantID: ModelV2.VariantID | undefined) => {\n  const id = variantID === \"default\" || variantID === undefined ? model.request.variant : variantID\n  const variant = model.variants.find((item) => item.id === id)\n  if (!variant) return model\n  return produce(model, (draft) => {\n    ModelRequest.assign(draft.request, variant)\n  })\n}"},{"id":"packages_core_src_session_runner_model_apiname","label":"apiName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L86-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L86"}],"snippet":"apiName = (model: ModelV2.Info) =>\n  model.api.type === \"aisdk\" ? `${model.api.type}:${model.api.package}` : model.api.type"},{"id":"packages_core_src_session_runner_model_fromcatalogmodel","label":"fromCatalogModel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L89-L129","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L89"}],"snippet":"fromCatalogModel = (\n  model: ModelV2.Info,\n  connection?: IntegrationConnection.Info,\n  credential?: Credential.Stored,\n): Effect.Effect<Model, UnsupportedApiError> => {\n  const resolved =\n    credential?.value.metadata === undefined\n      ? model\n      : produce(model, (draft) => {\n          Object.assign(draft.request.body, credential.value.metadata)\n        })\n  const key = apiKey(resolved, connection, credential)\n  if (resolved.api.type === \"aisdk\" && resolved.api.package === \"@ai-sdk/openai\") {\n    return Effect.succeed(\n      withDefaults(resolved, OpenAIResponses.route)\n        .with({ auth: key === undefined ? Auth.none : Auth.bearer(key) })\n        .model({ id: resolved.api.id }),\n    )\n  }\n  if (resolved.api.type === \"aisdk\" && resolved.api.package === \"@ai-sdk/anthropic\") {\n    return Effect.succeed(\n      withDefaults(resolved, AnthropicMessages.route)\n        .with({ auth: key === undefined ? Auth.none : Auth.header(\"x-api-key\", key) })\n        .model({ id: resolved.api.id }),\n    )"},{"id":"packages_core_src_session_runner_model_resolve","label":"resolve()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L131-L132","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L131"}],"snippet":"resolve = (session: SessionSchema.Info, model: ModelV2.Info) =>\n  fromCatalogModel(withVariant(model, session.model?.variant))"},{"id":"packages_core_src_session_runner_model_supported","label":"supported()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L134-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L134"}],"snippet":"supported = (model: ModelV2.Info) =>\n  model.api.type === \"aisdk\" &&\n  (model.api.package === \"@ai-sdk/openai\" ||\n    model.api.package === \"@ai-sdk/anthropic\" ||\n    (model.api.package === \"@ai-sdk/openai-compatible\" && model.api.url !== undefined))"}],"edges":[{"source":"packages_core_src_session_runner_model","target":"model","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_src_session_runner_model","target":"llm","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L3"}],"weight":1},{"source":"packages_core_src_session_runner_model","target":"anthropic_messages","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/runner/model.ts","source_location":"L4