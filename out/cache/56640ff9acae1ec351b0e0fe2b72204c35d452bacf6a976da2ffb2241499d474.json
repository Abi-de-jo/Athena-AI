{"__madarTsExtractorVersion":67,"__madarFileStem":"display","nodes":[{"id":"display","label":"display.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L1"}]},{"id":"display_promptoffsetwidth","label":"promptOffsetWidth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L3-L10","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L3"}],"snippet":"export function promptOffsetWidth(value: string) {\n  let width = 0\n  for (const part of graphemes.segment(value)) {\n    // Textarea offsets count newlines as one position; Bun.stringWidth counts them as zero.\n    width += part.segment === \"\\n\" ? 1 : Bun.stringWidth(part.segment)\n  }\n  return width\n}"},{"id":"display_displayoffsetindex","label":"displayOffsetIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L12-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L12"}],"snippet":"function displayOffsetIndex(value: string, offset: number) {\n  if (offset <= 0) return 0\n\n  let width = 0\n  for (const part of graphemes.segment(value)) {\n    const next = width + promptOffsetWidth(part.segment)\n    if (next > offset) return part.index\n    width = next\n  }\n\n  return value.length\n}"},{"id":"display_displayslice","label":"displaySlice()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L25-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L25"}],"snippet":"export function displaySlice(value: string, start = 0, end = promptOffsetWidth(value)) {\n  return value.slice(displayOffsetIndex(value, start), displayOffsetIndex(value, end))\n}"},{"id":"display_displaycharat","label":"displayCharAt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L29-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L29"}],"snippet":"export function displayCharAt(value: string, offset: number) {\n  let width = 0\n  for (const part of graphemes.segment(value)) {\n    const next = width + promptOffsetWidth(part.segment)\n    if (offset === width || offset < next) return part.segment\n    width = next\n  }\n}"},{"id":"display_mentiontriggerindex","label":"mentionTriggerIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L38-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L38"}],"snippet":"export function mentionTriggerIndex(value: string, offset = promptOffsetWidth(value)) {\n  const text = displaySlice(value, 0, offset)\n  const index = text.lastIndexOf(\"@\")\n  if (index === -1) return\n\n  const before = index === 0 ? undefined : text[index - 1]\n  const query = text.slice(index)\n  if ((before === undefined || /\\s/.test(before)) && !/\\s/.test(query)) {\n    return promptOffsetWidth(text.slice(0, index))\n  }\n}"}],"edges":[{"source":"display","target":"display_promptoffsetwidth","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L3"}],"weight":1},{"source":"display","target":"display_displayoffsetindex","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L12"}],"weight":1},{"source":"display","target":"display_displayslice","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L25","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L25"}],"weight":1},{"source":"display","target":"display_displaycharat","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L29","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/prompt/display.ts","source_location":"L29"}],"weight":1},{"source":"display","target":"display_mentiontriggerindex","relation":"contains","confidence":"EXTR