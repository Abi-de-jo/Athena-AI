{"__madarTsExtractorVersion":67,"__madarFileStem":"server-errors","nodes":[{"id":"server_errors","label":"server-errors.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L1"}]},{"id":"server_errors_tr","label":"tr()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L21-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L21"}],"snippet":"function tr(translator: Translator | undefined, key: string, text: string, vars?: Record<string, string | number>) {\n  if (!translator) return text\n  const out = translator(key, vars)\n  if (!out || out === key) return text\n  return out\n}"},{"id":"server_errors_formatservererror","label":"formatServerError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L28-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L28"}],"snippet":"export function formatServerError(error: unknown, translate?: Translator, fallback?: string) {\n  const unwrapped = unwrapNamedError(error)\n  if (isConfigInvalidErrorLike(unwrapped)) return parseReadableConfigInvalidError(unwrapped, translate)\n  if (isProviderModelNotFoundErrorLike(unwrapped)) return parseReadableProviderModelNotFoundError(unwrapped, translate)\n  if (error instanceof Error && error.message) return error.message\n  if (typeof error === \"string\" && error) return error\n  if (fallback) return fallback\n  return tr(translate, \"error.chain.unknown\", \"Unknown error\")\n}"},{"id":"server_errors_unwrapnamederror","label":"unwrapNamedError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L38-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L38"}],"snippet":"function unwrapNamedError(error: unknown): unknown {\n  if (error instanceof Error && error.cause && typeof error.cause === \"object\" && \"body\" in error.cause) {\n    return (error.cause as Record<string, unknown>).body\n  }\n  return error\n}"},{"id":"server_errors_isconfiginvaliderrorlike","label":"isConfigInvalidErrorLike()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L45-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L45"}],"snippet":"function isConfigInvalidErrorLike(error: unknown): error is ConfigInvalidError {\n  if (typeof error !== \"object\" || error === null) return false\n  const o = error as Record<string, unknown>\n  return o.name === \"ConfigInvalidError\" && typeof o.data === \"object\" && o.data !== null\n}"},{"id":"server_errors_isprovidermodelnotfounderrorlike","label":"isProviderModelNotFoundErrorLike()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L51-L55","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L51"}],"snippet":"function isProviderModelNotFoundErrorLike(error: unknown): error is ProviderModelNotFoundError {\n  if (typeof error !== \"object\" || error === null) return false\n  const o = error as Record<string, unknown>\n  return o.name === \"ProviderModelNotFoundError\" && typeof o.data === \"object\" && o.data !== null\n}"},{"id":"server_errors_parsereadableconfiginvaliderror","label":"parseReadableConfigInvalidError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L57-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L57"}],"snippet":"export function parseReadableConfigInvalidError(errorInput: ConfigInvalidError, translator?: Translator) {\n  const file = errorInput.data.path && errorInput.data.path !== \"config\" ? errorInput.data.path : \"config\"\n  const detail = errorInput.data.message?.trim() ?? \"\"\n  const issues = (errorInput.data.issues ?? [])\n    .map((issue) => {\n      const msg = issue.message.trim()\n      if (!issue.path.length) return msg\n      return `${issue.path.join(\".\")}: ${msg}`\n    })\n    .filter(Boolean)\n  const msg = issues.length ? issues.join(\"\\n\") : detail\n  if (!msg) return tr(translator, \"error.chain.configInvalid\", `Config file at ${file} is invalid`, { path: file })\n  return tr(translator, \"error.chain.configInvalidWithMessage\", `Config file at ${file} is invalid: ${msg}`, {\n    path: file,\n    message: msg,\n  })\n}"},{"id":"server_errors_parsereadableprovidermodelnotfounderror","label":"parseReadableProviderModelNotFoundError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L75-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L75"}],"snippet":"function parseReadableProviderModelNotFoundError(errorInput: ProviderModelNotFoundError, translator?: Translator) {\n  const p = errorInput.data.providerID.trim()\n  const m = errorInput.data.modelID.trim()\n  const list = (errorInput.data.suggestions ?? []).map((v) => v.trim()).filter(Boolean)\n  const body = tr(translator, \"error.chain.modelNotFound\", `Model not found: ${p}/${m}`, { provider: p, model: m })\n  const tail = tr(translator, \"error.chain.checkConfig\", \"Check your config (rimuru.json) provider/model names\")\n  if (list.length) {\n    const suggestions = list.slice(0, 5).join(\", \")\n    return [body, tr(translator, \"error.chain.didYouMean\", `Did you mean: ${suggestions}`, { suggestions }), tail].join(\n      \"\\n\",\n    )\n  }\n  return [body, tail].join(\"\\n\")\n}"}],"edges":[{"source":"server_errors","target":"server_errors_tr","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L21"}],"weight":1},{"source":"server_errors","target":"server_errors_formatservererror","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-errors.ts","source_location":"L28"}],"weight":1},{"source":"server_errors