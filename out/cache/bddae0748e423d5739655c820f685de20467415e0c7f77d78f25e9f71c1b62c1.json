80-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L80"}],"snippet":"export function normalizeCustomProviderID(value: string) {\n  const providerID = value.trim().replace(/^@ai-sdk\\//, \"\")\n  if (!CUSTOM_PROVIDER_ID.test(providerID)) return\n  return providerID\n}"},{"id":"dialog_provider_createdialogprovideroptions","label":"createDialogProviderOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L86-L226","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L86"}],"snippet":"export function createDialogProviderOptions() {\n  const sync = useSync()\n  const dialog = useDialog()\n  const sdk = useSDK()\n  const toast = useToast()\n  const { theme } = useTheme()\n  const onboarded = useConnected()\n\n  async function promptCustomProviderID(): Promise<string | undefined> {\n    const value = await DialogPrompt.show(dialog, \"Other\", {\n      placeholder: \"Provider id\",\n      description: () => (\n        <text fg={theme.textMuted}>\n          This only stores a credential. Configure the provider in rimuru.json to use it.\n        </text>\n      ),\n    })\n    if (value === null) return\n\n    const providerID = normalizeCustomProviderID(value)\n    if (providerID) return providerID\n\n    toast.show({\n      variant: \"error\",\n      message:"},{"id":"dialog_provider_createdialogprovideroptions_promptcustomproviderid","label":"promptCustomProviderID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L94-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L94"}],"snippet":"async function promptCustomProviderID(): Promise<string | undefined> {\n    const value = await DialogPrompt.show(dialog, \"Other\", {\n      placeholder: \"Provider id\",\n      description: () => (\n        <text fg={theme.textMuted}>\n          This only stores a credential. Configure the provider in rimuru.json to use it.\n        </text>\n      ),\n    })\n    if (value === null) return\n\n    const providerID = normalizeCustomProviderID(value)\n    if (providerID) return providerID\n\n    toast.show({\n      variant: \"error\",\n      message:\n        \"Provider ids must start with a lowercase letter or number and only use lowercase letters, numbers, hyphens, and underscores\",\n    })\n    return promptCustomProviderID()\n  }"},{"id":"dialog_provider_dialogprovider","label":"DialogProvider()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L228-L231","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L228"}],"snippet":"export function DialogProvider() {\n  const options = createDialogProviderOptions()\n  return <DialogSelect title=\"Connect a provider\" options={options()} />\n}","node_kind":"component"},{"id":"dialog_provider_automethodprops","label":"AutoMethodProps","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L233-L238","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L233"}],"snippet":"interface AutoMethodProps {\n  index: number\n  providerID: string\n  title: string\n  authorization: ProviderAuthAuthorization\n}"},{"id":"dialog_provider_automethod","label":"AutoMethod()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L239-L306","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L239"}],"snippet":"function AutoMethod(props: AutoMethodProps) {\n  const { theme } = useTheme()\n  const sdk = useSDK()\n  const dialog = useDialog()\n  const sync = useSync()\n  const toast = useToast()\n  const clipboard = useClipboard()\n\n  useBindings(() => ({\n    bindings: [\n      {\n        key: \"c\",\n        desc: \"Copy provider code\",\n        group: \"Dialog\",\n        cmd: () => {\n          const code =\n            props.authorization.instructions.match(/[A-Z0-9]{4}-[A-Z0-9]{4,5}/)?.[0] ?? props.authorization.url\n          clipboard\n            .write?.(code)\n            .then(() => toast.show({ message: \"Copied to clipboard\", variant: \"info\" }))\n            .catch(toast.error)\n        },\n      },\n    ],\n  }))","node_kind":"component"},{"id":"dialog_provider_codemethodprops","label":"CodeMethodProps","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L308-L313","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L308"}],"snippet":"interface CodeMethodProps {\n  index: number\n  title: string\n  providerID: string\n  authorization: ProviderAuthAuthorization\n}"},{"id":"dialog_provider_codemethod","label":"CodeMethod()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L314-L350","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L314"}],"snippet":"function CodeMethod(props: CodeMethodProps) {\n  const { theme } = useTheme()\n  const sdk = useSDK()\n  const sync = useSync()\n  const dialog = useDialog()\n  const [error, setError] = createSignal(false)\n\n  return (\n    <DialogPrompt\n      title={props.title}\n      placeholder=\"Authorization code\"\n      onConfirm={async (value) => {\n        const { error } = await sdk.client.provider.oauth.callback({\n          providerID: props.providerID,\n          method: props.index,\n          code: value,\n        })\n        if (!error) {\n          await sdk.client.instance.dispose()\n          await sync.bootstrap()\n          dialog.replace(() => <DialogModel providerID={props.providerID} />)\n          return\n        }\n        setError(true)\n      }}","node_kind":"component"},{"id":"dialog_provider_apimethodprops","label":"ApiMethodProps","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L352-L357","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L352"}],"snippet":"interface ApiMethodProps {\n  providerID: string\n  title: string\n  metadata?: Record<string, string>\n  custom?: boolean\n}"},{"id":"dialog_provider_apimethod","label":"ApiMethod()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L358-L419","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L358"}],"snippet":"function ApiMethod(props: ApiMethodProps) {\n  const dialog = useDialog()\n  const sdk = useSDK()\n  const sync = useSync()\n  const toast = useToast()\n  const { theme } = useTheme()\n\n  return (\n    <DialogPrompt\n      title={props.title}\n      placeholder=\"API key\"\n      description={\n        {\n          opencode: (\n            <box gap={1}>\n              <text fg={theme.textMuted}>\n                OpenCode Zen gives you access to all the best coding models at the cheapest prices with a single API\n                key.\n              </text>\n              <text fg={theme.text}>\n                Go to <span style={{ fg: theme.primary }}>https://github.com/gowdaman-dev/rimuru-ai/zen</span> to get a key\n              </text>\n            </box>\n          ),\n          \"opencode-go\": (","node_kind":"component"},{"id":"dialog_provider_promptsmethodprops","label":"PromptsMethodProps","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L421-L424","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L421"}],"snippet":"interface PromptsMethodProps {\n  dialog: ReturnType<typeof useDialog>\n  prompts: NonNullable<ProviderAuthMethod[\"prompts\"]>[number][]\n}"},{"id":"dialog_provider_promptsmethod","label":"PromptsMethod()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L425-L469","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L425"}],"snippet":"async function PromptsMethod(props: PromptsMethodProps) {\n  const inputs: Record<string, string> = {}\n  for (const prompt of props.prompts) {\n    if (prompt.when) {\n      const value = inputs[prompt.when.key]\n      if (value === undefined) continue\n      const matches = prompt.when.op === \"eq\" ? value === prompt.when.value : value !== prompt.when.value\n      if (!matches) continue\n    }\n\n    if (prompt.type === \"select\") {\n      const value = await new Promise<string | null>((resolve) => {\n        props.dialog.replace(\n          () => (\n            <DialogSelect\n              title={prompt.message}\n              options={prompt.options.map((x) => ({\n                title: x.label,\n                value: x.value,\n                description: x.hint,\n              }))}\n              onSelect={(option) => resolve(option.value)}\n            />\n          ),\n          () => resolve(null),","node_kind":"component"}],"edges":[{"source":"dialog_provider","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L1"}],"weight":1},{"source":"dialog_provider","target":"sync","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-provider.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/comp