{"__madarTsExtractorVersion":67,"__madarFileStem":"session-header","nodes":[{"id":"session_header","label":"session-header.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L1"}]},{"id":"session_header_detectos","label":"detectOS()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L116-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L116"}],"snippet":"detectOS = (platform: ReturnType<typeof usePlatform>): OS => {\n  if (platform.platform === \"desktop\" && platform.os) return platform.os\n  if (typeof navigator !== \"object\") return \"unknown\"\n  const value = navigator.platform || navigator.userAgent\n  if (/Mac/i.test(value)) return \"macos\"\n  if (/Win/i.test(value)) return \"windows\"\n  if (/Linux/i.test(value)) return \"linux\"\n  return \"unknown\"\n}"},{"id":"session_header_showrequesterror","label":"showRequestError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L126-L132","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L126"}],"snippet":"showRequestError = (language: ReturnType<typeof useLanguage>, err: unknown) => {\n  showToast({\n    variant: \"error\",\n    title: language.t(\"common.requestFailed\"),\n    description: err instanceof Error ? err.message : String(err),\n  })\n}"},{"id":"session_header_sessionheader","label":"SessionHeader()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L134-L514","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L134"}],"snippet":"export function SessionHeader() {\n  const layout = useLayout()\n  const command = useCommand()\n  const server = useServer()\n  const platform = usePlatform()\n  const language = useLanguage()\n  const settings = useSettings()\n  const sync = useSync()\n  const terminal = useTerminal()\n  const { params, view } = useSessionLayout()\n\n  const projectDirectory = createMemo(() => decode64(params.dir) ?? \"\")\n  const project = createMemo(() => {\n    const directory = projectDirectory()\n    if (!directory) return\n    return layout.projects.list().find((p) => p.worktree === directory || p.sandboxes?.includes(directory))\n  })\n  const name = createMemo(() => {\n    const current = project()\n    if (current) return current.name || getFilename(current.worktree)\n    return getFilename(projectDirectory())\n  })\n  const hotkey = createMemo(() => command.keybind(\"file.open\"))\n  const os = createMemo(() => detectOS(platform))\n  const isV2 = settings.general.newLayoutDesigns","node_kind":"component"},{"id":"session_header_sessionheader_toggleterminal","label":"toggleTerminal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L207-L215","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L207"}],"snippet":"toggleTerminal = () => {\n    const next = !view().terminal.opened()\n    view().terminal.toggle()\n    if (!next) return\n\n    const id = terminal.active()\n    if (!id) return\n    focusTerminalById(id)\n  }"},{"id":"session_header_sessionheader_selectapp","label":"selectApp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L243-L246","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L243"}],"snippet":"selectApp = (app: OpenApp) => {\n    if (!options().some((item) => item.id === app)) return\n    setPrefs(\"app\", app)\n  }"},{"id":"session_header_sessionheader_opendir","label":"openDir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L248-L262","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L248"}],"snippet":"openDir = (app: OpenApp) => {\n    if (opening() || !canOpen() || !platform.openPath) return\n    const directory = projectDirectory()\n    if (!directory) return\n\n    const item = options().find((o) => o.id === app)\n    const openWith = item && \"openWith\" in item ? item.openWith : undefined\n    setOpenRequest(\"app\", app)\n    platform\n      .openPath(directory, openWith)\n      .catch((err: unknown) => showRequestError(language, err))\n      .finally(() => {\n        setOpenRequest(\"app\", undefined)\n      })\n  }"},{"id":"session_header_sessionheader_copypath","label":"copyPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L264-L278","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L264"}],"snippet":"copyPath = () => {\n    const directory = projectDirectory()\n    if (!directory) return\n    navigator.clipboard\n      .writeText(directory)\n      .then(() => {\n        showToast({\n          variant: \"success\",\n          icon: \"circle-check\",\n          title: language.t(\"session.share.copy.copied\"),\n          description: directory,\n        })\n      })\n      .catch((err: unknown) => showRequestError(language, err))\n  }"},{"id":"session_header_sessionheaderv2actions","label":"SessionHeaderV2Actions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L525-L549","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L525"}],"snippet":"function SessionHeaderV2Actions(props: { state: SessionHeaderV2ActionsState }) {\n  return (\n    <div class=\"flex items-center gap-2\">\n      <Show when={props.state.statusVisible}>\n        <Tooltip placement=\"bottom\" value={props.state.statusLabel}>\n          <StatusPopoverV2 />\n        </Tooltip>\n      </Show>\n      <TooltipKeybind title={props.state.reviewLabel} keybind={props.state.reviewKeybind}>\n        <IconButtonV2\n          type=\"button\"\n          variant=\"ghost-muted\"\n          size=\"large\"\n          class=\"!w-9 shrink-0\"\n          state={props.state.reviewOpened ? \"pressed\" : undefined}\n          onClick={props.state.onReviewToggle}\n          aria-label={props.state.reviewLabel}\n          aria-expanded={props.state.reviewOpened}\n          aria-controls=\"review-panel\"\n          icon={<IconV2 name=\"sidebar-right\" />}\n        />\n      </TooltipKeybind>\n    </div>\n  )\n}","node_kind":"component"}],"edges":[{"source":"session_header","target":"app_icon","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L1"}],"weight":1},{"source":"session_header","target":"button","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L2"}],"weight":1},{"source":"session_header","target":"dropdown_menu","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L3"}],"weight":1},{"source":"session_header","target":"icon","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session/session-header.tsx","source_location":"L4","layer":"base","provenance":[{"ca