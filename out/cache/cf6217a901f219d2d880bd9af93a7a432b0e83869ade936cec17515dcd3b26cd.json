split(\",\")\n    .map((raw) => raw.trim())\n    .filter(Boolean)\n    .map((raw) => {\n      const parts = raw.split(\";\").map((x) => x.trim())\n      const lang = parts[0] ?? \"\"\n      const q = parts\n        .slice(1)\n        .find((x) => x.startsWith(\"q=\"))\n        ?.slice(2)\n      return {\n        lang,\n        q: q ? Number.parseFloat(q) : 1,\n      }\n    })\n    .sort((a, b) => b.q - a.q)\n\n  const locale = items\n    .map((item) => item.lang)\n    .filter((lang) => lang && lang !== \"*\")\n    .map((lang) => matchLocale(lang))"},{"id":"home_gowdaman_projects_personal_rimuru_ai_packages_web_src_nextjs_special_middleware","label":"middleware","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/web/src/middleware.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/web/src/middleware.ts","source_location":"L1"}],"node_kind":"function","framework":"nextjs","framework_role":"next_middleware","runtime_boundary":"server"}],"edges":[{"source":"packages_web_src_middleware","target":"astro_middleware","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/web/src/middleware.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/web/src/middleware.ts","source_location":"L1"}],"weight":1},{"source":"packages_web_src_middleware","target":"locales","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/web/src/middleware.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/web/src/middleware.ts","source_locati