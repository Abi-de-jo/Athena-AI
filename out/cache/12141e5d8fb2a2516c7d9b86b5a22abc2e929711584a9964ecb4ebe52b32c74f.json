_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L46-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L46"}],"snippet":"function setup() {\n  return Effect.gen(function* () {\n    const root = yield* Effect.acquireRelease(\n      Effect.promise(() => tmpdir()),\n      (dir) => Effect.promise(() => dir[Symbol.asyncDispose]()),\n    )\n    yield* Effect.promise(() => initRepo(root.path))\n    const sourceDirectory = abs(yield* Effect.promise(() => fs.realpath(root.path)))\n    const projectID = Project.ID.make(\"copy-project\")\n    const { db } = yield* Database.Service\n    yield* db\n      .insert(ProjectTable)\n      .values({ id: projectID, worktree: sourceDirectory, sandboxes: [], time_created: 1, time_updated: 1 })\n      .run()\n      .pipe(Effect.orDie)\n    yield* db\n      .insert(ProjectDirectoryTable)\n      .values({ project_id: projectID, directory: sourceDirectory })\n      .run()\n      .pipe(Effect.orDie)\n    return { root, sourceDirectory, projectID, db }\n  })\n}"},{"id":"packages_core_test_project_copy_test_stored","label":"stored()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L70-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L70"}],"snippet":"function stored(projectID: Project.ID) {\n  return Database.Service.use(({ db }) =>\n    db\n      .select({ directory: ProjectDirectoryTable.directory, strategy: ProjectDirectoryTable.strategy })\n      .from(ProjectDirectoryTable)\n      .where(eq(ProjectDirectoryTable.project_id, projectID))\n      .all()\n      .pipe(\n        Effect.orDie,\n        Effect.map((rows) => rows.toSorted((a, b) => a.directory.localeCompare(b.directory))),\n      ),\n  )\n}"}],"edges":[{"source":"packages_core_test_project_copy_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_test_project_copy_test","target":"bun","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L2"}],"weight":1},{"source":"packages_core_test_project_copy_test","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L3"}],"weight":1},{"source":"packages_core_test_project_copy_test","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.test.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/test/project-copy.tes