\n  }\n\n  const cleanContent = contentType.split(\";\")[0]?.trim()\n\n  if (!cleanContent) {\n    return\n  }\n\n  if (cleanContent.startsWith(\"application/json\") || cleanContent.endsWith(\"+json\")) {\n    return \"json\"\n  }\n\n  if (cleanContent === \"multipart/form-data\") {\n    return \"formData\"\n  }\n\n  if ([\"application/\", \"audio/\", \"image/\", \"video/\"].some((type) => cleanContent.startsWith(type))) {\n    return \"blob\"\n  }"},{"id":"packages_sdk_js_src_gen_client_utils_gen_checkforexistence","label":"checkForExistence()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/client/utils.gen.ts","source_location":"L91-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/client/utils.gen.ts","source_location":"L91"}],"snippet":"checkForExistence = (\n  options: Pick<RequestOptions, \"auth\" | \"query\"> & {\n    headers: Headers\n  },\n  name?: string,\n): boolean => {\n  if (!name) {\n    return false\n  }\n  if (options.headers.has(name) || options.query?.[name] || options.headers.get(\"Cookie\")?.includes(`${name}=`)) {\n    return true\n  }\n  return false\n}"},{"id":"packages_sdk_js_src_gen_client_utils_gen_setauthparams","label":"setAuthParams()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/client/utils.gen.ts","source_location":"L106-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/client/utils.gen.ts","source_location":"L106"}],"snippet":"setAuthParams = async ({\n  security,\n  ...options\n}: Pick<Required<RequestOptions>, \"security\"> &\n  Pick<RequestOptions, \"auth\" | \"query\"> & {\n    headers: Headers\n  }) => {\n  for (const auth of security) {\n    if (checkForExistence(options, auth.name)) {\n      continue\n    }\n\n    const token = await getAuthToken(auth, options.auth)\n\n    if (!token) {\n      continue\n    }\n\n    const name = auth.name ?? \"Authorization\"\n\n    switch (auth.in) {\n      case \"query\":\n        if (!options.query) {\n          options.query = {}\n        }"},{"id":"packages_sdk_js_src_gen_client_utils_gen_buildurl","label":"buildUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/client/utils.gen.ts","source_location":"L144-L154","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/client/utils.gen.ts","source_location":"L144"}],"snippet":"buildUrl: Client[\"buildUrl\"] = (options) =>\n  getUrl({\n    baseUrl: options.baseUrl as string,\n    path: options.path,\n    query: options.query,\n    querySerializer:\n      typeof options.querySerializer === \"function\"\n        ? options.querySerializer\n        : createQuerySerializer(options.querySerializer),\n    url: options.url,\n  })"},{"id":"packages_sdk_js_src_gen_client_utils_gen_mergeconfigs","label":"mergeConfigs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/client/utils.gen.ts","source_location":"L156-L163","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/gen/client/utils.gen.ts","source_location":"L156"}],"snippet":"mergeConfigs = (a: Config, b: Config): Config => {\n  const config = { ...a, ...b }\n  if (config.baseUrl?.endsWith(\"/\")) {\n    config.baseUrl = config.baseUrl.substring(0, config.baseUrl.length - 1)\n  }\n  config.headers = mergeHeaders(a.headers, b.headers)\n  return config\n}"},{"id":"packages_sdk_js_src_gen_client_utils_gen_mergeheaders","label":"mergeHeaders()","file_type"