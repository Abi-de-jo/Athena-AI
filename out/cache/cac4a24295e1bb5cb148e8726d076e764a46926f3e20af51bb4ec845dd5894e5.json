{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_util_wildcard","nodes":[{"id":"packages_rimuru_src_util_wildcard","label":"wildcard.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_util_wildcard_match","label":"match()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L3-L19","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L3"}],"snippet":"export function match(str: string, pattern: string) {\n  if (str) str = str.replaceAll(\"\\\\\", \"/\")\n  if (pattern) pattern = pattern.replaceAll(\"\\\\\", \"/\")\n  let escaped = pattern\n    .replace(/[.+^${}()|[\\]\\\\]/g, \"\\\\$&\") // escape special regex chars\n    .replace(/\\*/g, \".*\") // * becomes .*\n    .replace(/\\?/g, \".\") // ? becomes .\n\n  // If pattern ends with \" *\" (space + wildcard), make the trailing part optional\n  // This allows \"ls *\" to match both \"ls\" and \"ls -la\"\n  if (escaped.endsWith(\" .*\")) {\n    escaped = escaped.slice(0, -3) + \"( .*)?\"\n  }\n\n  const flags = process.platform === \"win32\" ? \"si\" : \"s\"\n  return new RegExp(\"^\" + escaped + \"$\", flags).test(str)\n}"},{"id":"packages_rimuru_src_util_wildcard_all","label":"all()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L21-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L21"}],"snippet":"export function all(input: string, patterns: Record<string, any>) {\n  const sorted = pipe(patterns, Object.entries, sortBy([([key]) => key.length, \"asc\"], [([key]) => key, \"asc\"]))\n  let result = undefined\n  for (const [pattern, value] of sorted) {\n    if (match(input, pattern)) {\n      result = value\n      continue\n    }\n  }\n  return result\n}"},{"id":"packages_rimuru_src_util_wildcard_allstructured","label":"allStructured()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L33-L45","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L33"}],"snippet":"export function allStructured(input: { head: string; tail: string[] }, patterns: Record<string, any>) {\n  const sorted = pipe(patterns, Object.entries, sortBy([([key]) => key.length, \"asc\"], [([key]) => key, \"asc\"]))\n  let result = undefined\n  for (const [pattern, value] of sorted) {\n    const parts = pattern.split(/\\s+/)\n    if (!match(input.head, parts[0])) continue\n    if (parts.length === 1 || matchSequence(input.tail, parts.slice(1))) {\n      result = value\n      continue\n    }\n  }\n  return result\n}"},{"id":"packages_rimuru_src_util_wildcard_matchsequence","label":"matchSequence()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L47-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L47"}],"snippet":"function matchSequence(items: string[], patterns: string[]): boolean {\n  if (patterns.length === 0) return true\n  const [pattern, ...rest] = patterns\n  if (pattern === \"*\") return matchSequence(items, rest)\n  for (let i = 0; i < items.length; i++) {\n    if (match(items[i], pattern) && matchSequence(items.slice(i + 1), rest)) {\n      return true\n    }\n  }\n  return false\n}"}],"edges":[{"source":"packages_rimuru_src_util_wildcard","target":"remeda","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_src_util_wildcard","target":"packages_rimuru_src_util_wildcard_match","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L3"}],"weight":1},{"source":"packages_rimuru_src_util_wildcard","target":"packages_rimuru_src_util_wildcard_all","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_location":"L21"}],"weight":1},{"source":"packages_rimuru_src_util_wildcard","target":"packages_rimuru_src_util_wildcard_allstructured","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/wildcard.ts","source_lo