id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/permission-auto-respond.ts","source_location":"L12"}],"snippet":"function accepted(autoAccept: Record<string, boolean>, sessionID: string, directory?: string) {\n  const key = acceptKey(sessionID, directory)\n  const directoryKey = directory ? directoryAcceptKey(directory) : undefined\n  return autoAccept[key] ?? autoAccept[sessionID] ?? (directoryKey ? autoAccept[directoryKey] : undefined)\n}"},{"id":"permission_auto_respond_isdirectoryautoaccepting","label":"isDirectoryAutoAccepting()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/permission-auto-respond.ts","source_location":"L18-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/permission-auto-respond.ts","source_location":"L18"}],"snippet":"export function isDirectoryAutoAccepting(autoAccept: Record<string, boolean>, directory: string) {\n  const key = directoryAcceptKey(directory)\n  return autoAccept[key] ?? false\n}"},{"id":"permission_auto_respond_sessionlineage","label":"sessionLineage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/permission-auto-respond.ts","source_location":"L23-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/permission-auto-respond.ts","source_location":"L23"}],"snippet":"function sessionLineage(session: { id: string; parentID?: string }[], sessionID: string) {\n  const parent = session.reduce((acc, item) => {\n    if (item.parentID) acc.set(item.id, item.parentID)\n    return acc\n  }, new Map<string, string>())\n  const seen = new Set([sessionID])\n  const ids = [sessionID]\n\n  for (const id of ids) {\n    const parentID = parent.get(id)\n    if (!parentID || seen.has(parentID)) continue\n    seen.add(parentID)\n    ids.push(parentID)\n  }\n\n  return ids\n}"},{"id":"permission_auto_respond_autorespondspermission","label":"autoRespondsPermission()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/permission-auto-respond.ts","source_location":"L41-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/permission-auto-respond.ts","source_location":"L41"}],"snippet":"export function autoRespondsPermission(\n  autoAccept: Record<string, boolean>,\n  session: { id: string; parentID?: string }[],\n  permission: { sessionID: string },\n  directory?: string,\n) {\n  const value = sessionLineage(session, permission.sessionID)\n    .map((id) => accepted(autoAccept, id, directory))\n    .find((item): item is boolean => item !== undefined)\n  return value ?? false\n}"}],"edges":[{"source":"permission_auto_respond","target":"encode","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/permission-auto-respond.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/permission-auto-respond.ts","source_location":"L1"}],"weight":1},{"source":"permission_auto_respond","target":"permission_auto_respond_acceptkey","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/permission-auto-respond.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/contex