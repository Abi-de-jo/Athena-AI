{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_test_acp_event.test","nodes":[{"id":"packages_opencode_test_acp_event_test","label":"event.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L1"}]},{"id":"packages_opencode_test_acp_event_test_polluntil","label":"pollUntil()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L19-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L19"}],"snippet":"pollUntil = async (\n  check: () => boolean | Promise<boolean>,\n  message: string,\n  opts?: { timeoutMs?: number; intervalMs?: number },\n) => {\n  const started = Date.now()\n  while (true) {\n    if (await check()) return\n    if (Date.now() - started > (opts?.timeoutMs ?? 2000)) throw new Error(message)\n    await new Promise((resolve) => setTimeout(resolve, opts?.intervalMs ?? 5))\n  }\n}"},{"id":"packages_opencode_test_acp_event_test_makesessionservice","label":"makeSessionService()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L32-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L32"}],"snippet":"function makeSessionService() {\n  return ManagedRuntime.make(ACPSession.defaultLayer).runSync(\n    ACPSession.Service.use((service) => Effect.succeed(service)),\n  )\n}"},{"id":"packages_opencode_test_acp_event_test_createeventstream","label":"createEventStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L38-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L38"}],"snippet":"function createEventStream() {\n  const queue: GlobalEventEnvelope[] = []\n  const waiters: Array<(value: GlobalEventEnvelope | undefined) => void> = []\n  const state = { closed: false }\n\n  const push = (event: GlobalEventEnvelope) => {\n    const waiter = waiters.shift()\n    if (waiter) {\n      waiter(event)\n      return\n    }\n    queue.push(event)\n  }\n\n  const close = () => {\n    state.closed = true\n    for (const waiter of waiters.splice(0)) {\n      waiter(undefined)\n    }\n  }\n\n  const stream = async function* (signal?: AbortSignal) {\n    while (true) {\n      if (signal?.aborted) return\n      const next = queue.shift()"},{"id":"packages_opencode_test_acp_event_test_createeventstream_push","label":"push()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L43-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L43"}],"snippet":"push = (event: GlobalEventEnvelope) => {\n    const waiter = waiters.shift()\n    if (waiter) {\n      waiter(event)\n      return\n    }\n    queue.push(event)\n  }"},{"id":"packages_opencode_test_acp_event_test_createeventstream_close","label":"close()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L52-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L52"}],"snippet":"close = () => {\n    state.closed = true\n    for (const waiter of waiters.splice(0)) {\n      waiter(undefined)\n    }\n  }"},{"id":"packages_opencode_test_acp_event_test_createeventstream_stream","label":"stream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L59-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L59"}],"snippet":"stream = async function* (signal?: AbortSignal) {\n    while (true) {\n      if (signal?.aborted) return\n      const next = queue.shift()\n      if (next) {\n        yield next\n        continue\n      }\n      if (state.closed) return\n      const value = await new Promise<GlobalEventEnvelope | undefined>((resolve) => {\n        waiters.push(resolve)\n        signal?.addEventListener(\"abort\", () => resolve(undefined), { once: true })\n      })\n      if (!value) return\n      yield value\n    }\n  }"},{"id":"packages_opencode_test_acp_event_test_createharness","label":"createHarness()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L80-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L80"}],"snippet":"function createHarness(messages: Record<string, SessionMessageResponse> = {}) {\n  const updates: SessionUpdateParams[] = []\n  const calls = {\n    eventSubscribe: 0,\n    message: 0,\n  }\n  const events = createEventStream()\n  const sdk = {\n    global: {\n      event: (options?: { signal?: AbortSignal }) => {\n        calls.eventSubscribe++\n        return Promise.resolve({ stream: events.stream(options?.signal) })\n      },\n    },\n    session: {\n      message: (input: { messageID: string }) => {\n        calls.message++\n        return Promise.resolve({ data: messages[input.messageID] })\n      },\n      get: () => Promise.resolve({ data: { id: \"ses_loaded\" } }),\n      messages: () => Promise.resolve({ data: [] }),\n    },\n  } as unknown as OpencodeClient\n  const connection = {\n    sessionUpdate: (params: SessionUpdateParams) => {"},{"id":"packages_opencode_test_acp_event_test_textdelta","label":"textDelta()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L115-L127","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L115"}],"snippet":"function textDelta(sessionID: string, messageID: string, partID: string, delta: string): Event {\n  return {\n    id: `evt_${sessionID}_${messageID}_${partID}_${delta}`,\n    type: \"message.part.delta\",\n    properties: {\n      sessionID,\n      messageID,\n      partID,\n      field: \"text\",\n      delta,\n    },\n  }\n}"},{"id":"packages_opencode_test_acp_event_test_partupdated","label":"partUpdated()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L129-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L129"}],"snippet":"function partUpdated(sessionID: string, messageID: string, partID: string, type: DeltaPartType): Event {\n  return {\n    id: `evt_${sessionID}_${messageID}_${partID}`,\n    type: \"message.part.updated\",\n    properties: {\n      sessionID,\n      time: Date.now(),\n      part:\n        type === \"text\"\n          ? {\n              id: partID,\n              sessionID,\n              messageID,\n              type: \"text\",\n              text: \"\",\n            }\n          : {\n              id: partID,\n              sessionID,\n              messageID,\n              type: \"reasoning\",\n              text: \"\",\n              time: { start: Date.now() },\n            },\n    },"},{"id":"packages_opencode_test_acp_event_test_toolupdated","label":"toolUpdated()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L157-L167","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L157"}],"snippet":"function toolUpdated(part: ToolPart): Event {\n  return {\n    id: `evt_${part.sessionID}_${part.messageID}_${part.id}_${part.state.status}`,\n    type: \"message.part.updated\",\n    properties: {\n      sessionID: part.sessionID,\n      time: Date.now(),\n      part,\n    },\n  }\n}"},{"id":"packages_opencode_test_acp_event_test_assistantmessage","label":"assistantMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L169-L204","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L169"}],"snippet":"function assistantMessage(sessionID: string, messageID: string, partID: string, type: DeltaPartType) {\n  return {\n    info: {\n      id: messageID,\n      sessionID,\n      role: \"assistant\",\n      time: { created: Date.now() },\n      parentID: \"msg_parent\",\n      modelID: \"model\",\n      providerID: \"provider\",\n      mode: \"build\",\n      agent: \"build\",\n      path: { cwd: \"/workspace\", root: \"/workspace\" },\n      cost: 0,\n      tokens: { input: 0, output: 0, reasoning: 0, cache: { read: 0, write: 0 } },\n    },\n    parts: [\n      type === \"text\"\n        ? {\n            id: partID,\n            sessionID,\n            messageID,\n            type: \"text\",\n            text: \"\",\n          }"},{"id":"packages_opencode_test_acp_event_test_assistanttoolmessage","label":"assistantToolMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L206-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L206"}],"snippet":"function assistantToolMessage(part: ToolPart) {\n  return {\n    info: {\n      id: part.messageID,\n      sessionID: part.sessionID,\n      role: \"assistant\",\n      time: { created: Date.now() },\n      parentID: \"msg_parent\",\n      modelID: \"model\",\n      providerID: \"provider\",\n      mode: \"build\",\n      agent: \"build\",\n      path: { cwd: \"/workspace\", root: \"/workspace\" },\n      cost: 0,\n      tokens: { input: 0, output: 0, reasoning: 0, cache: { read: 0, write: 0 } },\n    },\n    parts: [part],\n  } satisfies SessionMessageResponse\n}"},{"id":"packages_opencode_test_acp_event_test_runningtool","label":"runningTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L226-L247","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L226"}],"snippet":"function runningTool(\n  sessionID: string,\n  callID: string,\n  output?: string,\n  input: Record<string, unknown> = { cmd: \"printf hello\" },\n) {\n  return {\n    id: `part_${callID}`,\n    sessionID,\n    messageID: `msg_${callID}`,\n    type: \"tool\",\n    callID,\n    tool: \"bash\",\n    state: {\n      status: \"running\",\n      input,\n      title: \"bash\",\n      ...(output !== undefined ? { metadata: { output } } : {}),\n      time: { start: Date.now() },\n    },\n  } satisfies ToolPart\n}"},{"id":"packages_opencode_test_acp_event_test_completedtool","label":"completedTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L249-L277","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/acp/event.test.ts","source_location":"L249"}],"snippet":"function completedTool(\n  sessionID: string,\n  callID: string,\n  output = \"done\",\n  attachments: Extract<ToolPart[\"state\"], { status: \"completed\" }>[\"attachments\"] = [],\n  options: {\n    readonly tool?: string\n    readonly input?: Record<string, unknown>\n    readonly metadata?: Record<string, unknown>\n  } = {},\n) {\n  return {\n    id: `part_${callID}`,\n    sessionID,\n    messageID: `msg_${callID}`,\n    type: \"tool\",\n    callID,\n    tool: options.tool ?? \"bash\",\n    state: {\n      status: \"completed\",\n      input: options.input ?? { cmd: \"printf done\" },\n      output,\n      title: \"bash\",\n      metadata: options.metadata ?? { exit: 0 },\n      time: { start: Date.now() - 1, end: Date.now() },"},{"id":"packages_opencode_test_acp_event_test_errortool","label":"errorTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/openco