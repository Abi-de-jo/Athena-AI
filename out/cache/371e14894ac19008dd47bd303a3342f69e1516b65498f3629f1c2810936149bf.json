itting = false\n  return async function submit(h: Harness) {\n    if (submitting) return false\n    submitting = true\n    try {\n      if (!h.store.input) return false\n      const sessionID = await h.createSession()\n      const inputText = h.store.input\n      await h.sendPrompt(sessionID, inputText)\n      h.store.input = \"\"\n      return true\n    } finally {\n      submitting = false\n    }\n  }\n}"}],"edges":[{"source":"prompt_submit_race_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/prompt-submit-race.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/prompt-submit-race.test.ts","source_location":"L1"}],"weight":1},{"source":"prompt_submit_race_test","target":"prompt_submit_race_test_createharness","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/prompt-submit-race.test.ts","source_location":"L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/prompt-submit-race.test.ts","source_location":"L33"}],"weight":1},{"source":"prompt_submit_race_test","target":"prompt_submit_race_test_createsubmit","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/prompt-submit-race.test.ts","source_location":"L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/prompt-submit-race.test.ts","source_location":"L52"}],"weight":1}]}