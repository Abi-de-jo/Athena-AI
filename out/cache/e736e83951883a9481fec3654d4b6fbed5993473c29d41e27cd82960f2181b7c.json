{"__madarTsExtractorVersion":67,"__madarFileStem":"commented-lines","nodes":[{"id":"commented_lines","label":"commented-lines.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L1"}]},{"id":"commented_lines_annotationindex","label":"annotationIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L6-L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L6"}],"snippet":"function annotationIndex(node: HTMLElement) {\n  const value = node.dataset.lineAnnotation?.split(\",\")[1]\n  if (!value) return\n  const line = parseInt(value, 10)\n  if (Number.isNaN(line)) return\n  return line\n}"},{"id":"commented_lines_clear","label":"clear()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L14-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L14"}],"snippet":"function clear(root: ShadowRoot) {\n  const marked = Array.from(root.querySelectorAll(\"[data-comment-selected]\"))\n  for (const node of marked) {\n    if (!(node instanceof HTMLElement)) continue\n    node.removeAttribute(\"data-comment-selected\")\n  }\n}"},{"id":"commented_lines_markcommenteddifflines","label":"markCommentedDiffLines()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L22-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L22"}],"snippet":"export function markCommentedDiffLines(root: ShadowRoot, ranges: SelectedLineRange[]) {\n  clear(root)\n\n  const diffs = root.querySelector(\"[data-diff]\")\n  if (!(diffs instanceof HTMLElement)) return\n\n  const split = diffs.dataset.diffType === \"split\"\n  const rows = Array.from(diffs.querySelectorAll(\"[data-line-index]\")).filter(\n    (node): node is HTMLElement => node instanceof HTMLElement,\n  )\n  if (rows.length === 0) return\n\n  const annotations = Array.from(diffs.querySelectorAll(\"[data-line-annotation]\")).filter(\n    (node): node is HTMLElement => node instanceof HTMLElement,\n  )\n\n  for (const range of ranges) {\n    const start = diffRowIndex(root, split, range.start, range.side as CommentSide | undefined)\n    if (start === undefined) continue\n\n    const end = (() => {\n      const same = range.end === range.start && (range.endSide == null || range.endSide === range.side)\n      if (same) return start\n      return diffRowIndex(root, split, range.end, (range.endSide ?? range.side) as CommentSide | undefined)\n    })()"},{"id":"commented_lines_markcommentedfilelines","label":"markCommentedFileLines()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L66-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L66"}],"snippet":"export function markCommentedFileLines(root: ShadowRoot, ranges: SelectedLineRange[]) {\n  clear(root)\n\n  const annotations = Array.from(root.querySelectorAll(\"[data-line-annotation]\")).filter(\n    (node): node is HTMLElement => node instanceof HTMLElement,\n  )\n\n  for (const range of ranges) {\n    const start = Math.max(1, Math.min(range.start, range.end))\n    const end = Math.max(range.start, range.end)\n\n    for (let line = start; line <= end; line++) {\n      const nodes = Array.from(root.querySelectorAll(`[data-line=\"${line}\"], [data-column-number=\"${line}\"]`))\n      for (const node of nodes) {\n        if (!(node instanceof HTMLElement)) continue\n        node.setAttribute(\"data-comment-selected\", \"\")\n      }\n    }\n\n    for (const annotation of annotations) {\n      const line = annotationIndex(annotation)\n      if (line === undefined || line < start || line > end) continue\n      annotation.setAttribute(\"data-comment-selected\", \"\")\n    }\n  }"}],"edges":[{"source":"commented_lines","target":"diffs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L1"}],"weight":1},{"source":"commented_lines","target":"diff_selection","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L2"}],"weight":1},{"source":"commented_lines","target":"commented_lines_annotationindex","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/pierre/commented-lines.ts","source_location":"L6","layer"