{"__madarTsExtractorVersion":67,"__madarFileStem":"shell-env","nodes":[{"id":"shell_env","label":"shell-env.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L1"}]},{"id":"shell_env_resolveusershell","label":"resolveUserShell()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L12-L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L12"}],"snippet":"export function resolveUserShell(envShell: string | undefined, loginShell: string | null | undefined) {\n  const resolvedLoginShell = loginShell && loginShell !== \"unknown\" ? loginShell : undefined\n  return envShell || resolvedLoginShell || \"/bin/sh\"\n}"},{"id":"shell_env_getusershell","label":"getUserShell()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L17-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L17"}],"snippet":"export function getUserShell() {\n  try {\n    return resolveUserShell(process.env.SHELL, userInfo().shell)\n  } catch {\n    return resolveUserShell(process.env.SHELL, undefined)\n  }\n}"},{"id":"shell_env_parseshellenv","label":"parseShellEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L25-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L25"}],"snippet":"export function parseShellEnv(out: Buffer) {\n  const env: Record<string, string> = {}\n  for (const line of out.toString(\"utf8\").split(\"\\0\")) {\n    if (!line) continue\n    const ix = line.indexOf(\"=\")\n    if (ix <= 0) continue\n    env[line.slice(0, ix)] = line.slice(ix + 1)\n  }\n  return env\n}"},{"id":"shell_env_probe","label":"probe()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L36-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L36"}],"snippet":"function probe(shell: string, mode: \"-il\" | \"-l\"): Probe {\n  const out = spawnSync(shell, [mode, \"-c\", \"env -0\"], {\n    stdio: [\"ignore\", \"pipe\", \"ignore\"],\n    timeout: TIMEOUT,\n    windowsHide: true,\n  })\n\n  const err = out.error as NodeJS.ErrnoException | undefined\n  if (err) {\n    if (err.code === \"ETIMEDOUT\") return { type: \"Timeout\" }\n    console.log(`[server] Shell env probe failed for ${shell} ${mode}: ${err.message}`)\n    return { type: \"Unavailable\" }\n  }\n\n  if (out.status !== 0) {\n    console.log(`[server] Shell env probe exited with non-zero status for ${shell} ${mode}`)\n    return { type: \"Unavailable\" }\n  }\n\n  const env = parseShellEnv(out.stdout)\n  if (Object.keys(env).length === 0) {\n    console.log(`[server] Shell env probe returned empty env for ${shell} ${mode}`)\n    return { type: \"Unavailable\" }\n  }"},{"id":"shell_env_isnushell","label":"isNushell()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L64-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L64"}],"snippet":"export function isNushell(shell: string) {\n  const name = basename(shell).toLowerCase()\n  const raw = shell.toLowerCase()\n  return name === \"nu\" || name === \"nu.exe\" || raw.endsWith(\"\\\\nu.exe\")\n}"},{"id":"shell_env_loadshellenv","label":"loadShellEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L70-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L70"}],"snippet":"export function loadShellEnv(shell: string, logger: ShellEnvLogger) {\n  if (isNushell(shell)) {\n    logger.log(`[server] Skipping shell env probe for nushell: ${shell}`)\n    return null\n  }\n\n  const interactive = probe(shell, \"-il\")\n  if (interactive.type === \"Loaded\") {\n    logger.log(`[server] Loaded shell environment with -il (${Object.keys(interactive.value).length} vars)`)\n    return interactive.value\n  }\n  if (interactive.type === \"Timeout\") {\n    logger.log(`[server] Interactive shell env probe timed out: ${shell}`)\n    return null\n  }\n\n  const login = probe(shell, \"-l\")\n  if (login.type === \"Loaded\") {\n    logger.log(`[server] Loaded shell environment with -l (${Object.keys(login.value).length} vars)`)\n    return login.value\n  }\n\n  logger.log(`[server] Falling back to app environment: ${shell}`)\n  return null\n}"},{"id":"shell_env_mergeshellenv","label":"mergeShellEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L96-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L96"}],"snippet":"export function mergeShellEnv(shell: Record<string, string> | null, env: Record<string, string>) {\n  return {\n    ...shell,\n    ...env,\n  }\n}"}],"edges":[{"source":"shell_env","target":"child_process","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L1"}],"weight":1},{"source":"shell_env","target":"os","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L2"}],"weight":1},{"source":"shell_env","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L3"}],"weight":1},{"source":"shell_env","target":"shell_env_resolveusershell","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/shell-env.ts","source_location":"L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file"