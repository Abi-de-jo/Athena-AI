{"__madarTsExtractorVersion":67,"__madarFileStem":"debug-workspace-plugin","nodes":[{"id":"debug_workspace_plugin","label":"debug-workspace-plugin.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/dev/debug-workspace-plugin.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/dev/debug-workspace-plugin.ts","source_location":"L1"}]},{"id":"debug_workspace_plugin_waitforhealth","label":"waitForHealth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/dev/debug-workspace-plugin.ts","source_location":"L9-L25","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/dev/debug-workspace-plugin.ts","source_location":"L9"}],"snippet":"async function waitForHealth(port: number) {\n  const url = `http://127.0.0.1:${port}/global/health`\n  const started = Date.now()\n\n  while (Date.now() - started < 30_000) {\n    try {\n      const response = await fetch(url)\n      if (response.ok) {\n        return\n      }\n    } catch {}\n\n    await sleep(250)\n  }\n\n  throw new Error(`Timed out waiting for debug server health check at ${url}`)\n}"},{"id":"debug_workspace_plugin_writedebugdata","label":"writeDebugData()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/dev/debug-workspace-plugin.ts","source_location":"L29-L44","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/dev/debug-workspace-plugin.ts","source_location":"L29"}],"snippet":"async function writeDebugData(port: number, id: string, env: Record<string, string | undefined>) {\n  await writeFile(\n    DEV_DATA_TEMP_FILE,\n    JSON.stringify(\n      {\n        port,\n        id,\n        env,\n      },\n      null,\n      2,\n    ),\n  )\n\n  await rename(DEV_DATA_TEMP_FILE, DEV_DATA_FILE)\n}"},{"id":"debug_workspace_plugin_debugworkspaceplugin","label":"DebugWorkspacePlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/dev/debug-workspace-plugin.ts","source_location":"L46-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/dev/debug-workspace-plugin.ts","source_location":"L46"}],"snippet":"DebugWorkspacePlugin: Plugin = async ({ experimental_workspace }) => {\n  experimental_workspace.register(\"debug\", {\n    name: \"Debug\",\n    description: \"Create a debugging server\",\n    configure(config) {\n      return config\n    },\n    async create(config, env) {\n      const port = randomInt(5000, 9001)\n      PORT = port\n\n      await writeDebugData(port, config.id, env)\n\n      await waitForHealth(port)\n    },\n    async remove(_config) {},\n    target(_config) {\n      return {\n        type: \"remote\",\n        url: `http://localhost:${PORT!}/`,\n      }\n    },\n  })\n\n  return {}"}],"edges":[{"source":"debug_workspace_plugin","target":"plugin","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/dev/debug-workspace-plugin.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/control-plane/dev/debug-workspace-plugin.ts","source_location":"L1"}],"weight":1},{"source":"debug_workspace_plugin","target":"promises","relation":"i