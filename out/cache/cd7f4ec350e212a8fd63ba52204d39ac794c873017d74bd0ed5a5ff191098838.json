kspace-routing.ts","source_location":"L65-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L65"}],"snippet":"function configuredWorkspaceID(): WorkspaceV2.ID | undefined {\n  return Flag.OPENCODE_WORKSPACE_ID ? WorkspaceV2.ID.make(Flag.OPENCODE_WORKSPACE_ID) : undefined\n}"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_selectedworkspaceid","label":"selectedWorkspaceID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L69-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L69"}],"snippet":"function selectedWorkspaceID(url: URL, sessionWorkspaceID?: WorkspaceV2.ID): WorkspaceV2.ID | undefined {\n  const workspaceParam = url.searchParams.get(\"workspace\")\n  return sessionWorkspaceID ?? (workspaceParam ? WorkspaceV2.ID.make(workspaceParam) : undefined)\n}"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_selectedv2workspaceid","label":"selectedV2WorkspaceID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L74-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L74"}],"snippet":"function selectedV2WorkspaceID(\n  url: URL,\n  sessionWorkspaceID?: WorkspaceV2.ID,\n): WorkspaceV2.ID | typeof InvalidWorkspaceID | undefined {\n  if (sessionWorkspaceID) return sessionWorkspaceID\n  const workspaceParam = url.searchParams.get(\"workspace\")\n  if (!workspaceParam) return undefined\n  const workspaceID = Schema.decodeUnknownOption(WorkspaceV2.ID)(workspaceParam)\n  if (Option.isNone(workspaceID)) return InvalidWorkspaceID\n  return workspaceID.value\n}"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_defaultdirectory","label":"defaultDirectory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L86-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L86"}],"snippet":"function defaultDirectory(request: HttpServerRequest.HttpServerRequest, url: URL): string {\n  return url.searchParams.get(\"directory\") || request.headers[\"x-opencode-directory\"] || process.cwd()\n}"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_shouldstayoncontrolplane","label":"shouldStayOnControlPlane()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L90-L92","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L90"}],"snippet":"function shouldStayOnControlPlane(request: HttpServerRequest.HttpServerRequest, url: URL): boolean {\n  return isLocalWorkspaceRoute(request.method, url.pathname) || url.pathname.startsWith(\"/console\")\n}"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_resolveworkspace","label":"resolveWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L94-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L94"}],"snippet":"function resolveWorkspace(\n  id: WorkspaceV2.ID | undefined,\n  envWorkspaceID: WorkspaceV2.ID | undefined,\n): Effect.Effect<Workspace.Info | void, never, Workspace.Service> {\n  if (!id || envWorkspaceID) return Effect.void\n  return Workspace.Service.use((workspace) => workspace.get(id))\n}"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_missingworkspaceresponse","label":"missingWorkspaceResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L102-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L102"}],"snippet":"function missingWorkspaceResponse(id: WorkspaceV2.ID): HttpServerResponse.HttpServerResponse {\n  return HttpServerResponse.text(`Workspace not found: ${id}`, {\n    status: 500,\n    contentType: \"text/plain; charset=utf-8\",\n  })\n}"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_resolvetarget","label":"resolveTarget()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L109-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L109"}],"snippet":"function resolveTarget(workspace: Workspace.Info): Effect.Effect<Target> {\n  return WorkspaceAdapterRuntime.target(workspace)\n}"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_proxyremote","label":"proxyRemote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L113-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L113"}],"snippet":"function proxyRemote(\n  client: HttpClient.HttpClient,\n  request: HttpServerRequest.HttpServerRequest,\n  workspace: Workspace.Info,\n  target: RemoteTarget,\n  url: URL,\n): Effect.Effect<HttpServerResponse.HttpServerResponse, never, Socket.WebSocketConstructor | Workspace.Service> {\n  return Effect.gen(function* () {\n    const syncing = yield* Workspace.Service.use((svc) => svc.isSyncing(workspace.id))\n    if (!syncing) {\n      return HttpServerResponse.text(`broken sync connection for workspace: ${workspace.id}`, {\n        status: 503,\n        contentType: \"text/plain; charset=utf-8\",\n      })\n    }\n    const proxyURL = workspaceProxyURL(target.url, url)\n    const headers = request.headers as Record<string, string>\n    if (headers[\"upgrade\"]?.toLowerCase() === \"websocket\") return yield* HttpApiProxy.websocket(request, proxyURL)\n    const response = yield* HttpApiProxy.http(client, proxyURL, target.headers, request)\n    const sync = Fence.parse(new Headers(response.headers))\n    if (sync) {\n      const syncFailure = yield* Fence.wait(\n        workspace.id,\n        sync,\n        request.source instanceof Request ? request.source.signal : undefined,"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_planworkspacerequest","label":"planWorkspaceRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L148-L158","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L148"}],"snippet":"function planWorkspaceRequest(\n  request: HttpServerRequest.HttpServerRequest,\n  url: URL,\n  workspace: Workspace.Info,\n): Effect.Effect<RequestPlan, never, Workspace.Service> {\n  return Effect.gen(function* () {\n    const target = yield* resolveTarget(workspace)\n    if (target.type === \"remote\") return RequestPlan.Remote({ request, workspace, target, url })\n    return RequestPlan.Local({ directory: target.directory, workspaceID: workspace.id })\n  })\n}"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_planrequest","label":"planRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L160-L186","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L160"}],"snippet":"function planRequest(\n  request: HttpServerRequest.HttpServerRequest,\n  session?: Session.Info,\n): Effect.Effect<RequestPlan, never, Workspace.Service> {\n  return Effect.gen(function* () {\n    const url = requestURL(request)\n    const envWorkspaceID = configuredWorkspaceID()\n    const workspaceID = url.pathname.startsWith(\"/api/\")\n      ? selectedV2WorkspaceID(url, session?.workspaceID)\n      : selectedWorkspaceID(url, session?.workspaceID)\n    if (workspaceID === InvalidWorkspaceID) return RequestPlan.InvalidWorkspace()\n    const workspace = yield* resolveWorkspace(workspaceID, envWorkspaceID)\n\n    if (workspaceID && workspace === undefined && !envWorkspaceID) {\n      return RequestPlan.MissingWorkspace({ workspaceID })\n    }\n\n    if (workspace !== undefined && !envWorkspaceID && !shouldStayOnControlPlane(request, url)) {\n      return yield* planWorkspaceRequest(request, url, workspace)\n    }\n\n    return RequestPlan.Local({\n      directory: session?.directory || defaultDirectory(request, url),\n      workspaceID: envWorkspaceID ?? workspaceID,\n    })"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_routeworkspace","label":"routeWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L188-L210","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L188"}],"snippet":"function routeWorkspace<E>(\n  client: HttpClient.HttpClient,\n  effect: Effect.Effect<HttpServerResponse.HttpServerResponse, E, WorkspaceRouteContext>,\n  plan: RequestPlan,\n): Effect.Effect<HttpServerResponse.HttpServerResponse, E, Socket.WebSocketConstructor | Workspace.Service> {\n  return RequestPlan.$match(plan, {\n    InvalidWorkspace: () =>\n      Effect.succeed(\n        HttpServerResponse.jsonUnsafe(\n          new InvalidRequestError({\n            message: \"Invalid workspace query parameter\",\n            kind: \"Query\",\n            field: \"workspace\",\n          }),\n          { status: 400 },\n        ),\n      ),\n    MissingWorkspace: ({ workspaceID }) => Effect.succeed(missingWorkspaceResponse(workspaceID)),\n    Remote: ({ request, workspace, target, url }) => proxyRemote(client, request, workspace, target, url),\n    Local: ({ directory, workspaceID }) =>\n      effect.pipe(Effect.provideService(WorkspaceRouteContext, WorkspaceRouteContext.of({ directory, workspaceID }))),\n  })\n}"},{"id":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing_routehttpapiworkspace","label":"routeHttpApiWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L212-L235","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L212"}],"snippet":"function routeHttpApiWorkspace<E>(\n  client: HttpClient.HttpClient,\n  effect: Effect.Effect<HttpServerResponse.HttpServerResponse, E, WorkspaceRouteContext>,\n): Effect.Effect<\n  HttpServerResponse.HttpServerResponse,\n  E,\n  Session.Service | Workspace.Service | HttpServerRequest.HttpServerRequest | Socket.WebSocketConstructor\n> {\n  return Effect.gen(function* () {\n    const request = yield* HttpServerRequest.HttpServerRequest\n    const sessionID = getWorkspaceRouteSessionID(requestURL(request))\n    const session = sessionID\n      ? yield* Session.Service.use((svc) => svc.get(sessionID)).pipe(\n          Effect.catchIf(\n            (error): error is NotFoundError => NotFoundError.isInstance(error),\n            () => Effect.succeed(undefined),\n          ),\n          Effect.catchDefect(() => Effect.succeed(undefined)),\n        )\n      : undefined\n    const plan = yield* planRequest(request, session)\n    return yield* routeWorkspace(client, effect, plan)\n  })\n}"}],"edges":[{"source":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing","target":"workspace","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L2"}],"weight":1},{"source":"packages_opencode_src_server_routes_instance_httpapi_middleware_workspace_routing","target":"workspace_adapter_runtime","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/routes/instance/httpapi/middleware/workspace-routing.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:ex