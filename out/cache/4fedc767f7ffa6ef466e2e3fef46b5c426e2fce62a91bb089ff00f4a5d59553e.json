ider-options.ts","source_location":"L192-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/provider-options.ts","source_location":"L192"}],"snippet":"function compact(input: Record<string, string | undefined>) {\n  const entries = Object.entries(input).filter((entry): entry is [string, string] => entry[1] !== undefined)\n  return entries.length ? Object.fromEntries(entries) : undefined\n}"},{"id":"provider_options_compactunknown","label":"compactUnknown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/provider-options.ts","source_location":"L197-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/provider-options.ts","source_location":"L197"}],"snippet":"function compactUnknown(input: Record<string, unknown>) {\n  return Object.fromEntries(Object.entries(input).filter((entry) => entry[1] !== undefined))\n}"},{"id":"provider_options_string","label":"string()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/provider-options.ts","source_location":"L201-L203","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/provider-options.ts","source_location":"L201"}],"snippet":"function string(input: unknown) {\n  return typeof input === \"string\" && input ? input : undefined\n}"},{"id":"provider_options_bearer","label":"bearer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/v1/config/provider-options.ts","source_location":"L205-L207","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","s