{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_context_server","nodes":[{"id":"packages_app_src_context_server","label":"server.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L1"}]},{"id":"packages_app_src_context_server_normalizeserverurl","label":"normalizeServerUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L12-L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L12"}],"snippet":"export function normalizeServerUrl(input: string) {\n  const trimmed = input.trim()\n  if (!trimmed) return\n  const withProtocol = /^https?:\\/\\//.test(trimmed) ? trimmed : `http://${trimmed}`\n  return withProtocol.replace(/\\/+$/, \"\")\n}"},{"id":"packages_app_src_context_server_servername","label":"serverName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L19-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L19"}],"snippet":"export function serverName(conn?: ServerConnection.Any, ignoreDisplayName = false) {\n  if (!conn) return \"\"\n  if (conn.displayName && !ignoreDisplayName) return conn.displayName\n  return conn.http.url.replace(/^https?:\\/\\//, \"\").replace(/\\/+$/, \"\")\n}"},{"id":"packages_app_src_context_server_islocalhost","label":"isLocalHost()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L25-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L25"}],"snippet":"function isLocalHost(url: string) {\n  const host = url.replace(/^https?:\\/\\//, \"\").split(\":\")[0]\n  if (host === \"localhost\" || host === \"127.0.0.1\") return \"local\"\n}"},{"id":"packages_app_src_context_server_isrecord","label":"isRecord()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L30-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L30"}],"snippet":"function isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value)\n}"},{"id":"packages_app_src_context_server_migratecanonicallocalserverstate","label":"migrateCanonicalLocalServerState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L34-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L34"}],"snippet":"export function migrateCanonicalLocalServerState(value: unknown, canonicalLocalServer?: ServerConnection.Key) {\n  if (!canonicalLocalServer || canonicalLocalServer === \"local\") return value\n  if (!isRecord(value)) return value\n  const projects = isRecord(value.projects) ? value.projects : undefined\n  const lastProject = isRecord(value.lastProject) ? value.lastProject : undefined\n  const previousProjects = projects?.[canonicalLocalServer]\n  const previousLastProject = lastProject?.[canonicalLocalServer]\n  if (!Array.isArray(previousProjects) && typeof previousLastProject !== \"string\") return value\n\n  const next = { ...value }\n  if (projects && Array.isArray(previousProjects)) {\n    const local = Array.isArray(projects.local) ? projects.local : []\n    const worktrees = new Set(\n      local.flatMap((project) => (isRecord(project) && typeof project.worktree === \"string\" ? [project.worktree] : [])),\n    )\n    const migrated = previousProjects.filter((project) => {\n      if (!isRecord(project) || typeof project.worktree !== \"string\") return true\n      if (worktrees.has(project.worktree)) return false\n      worktrees.add(project.worktree)\n      return true\n    })\n    const nextProjects: Record<string, unknown> = { ...projects, local: [...local, ...migrated] }\n    delete nextProjects[canonicalLocalServer]\n    next.projects = nextProjects\n  }"},{"id":"packages_app_src_context_server_createserverprojects","label":"createServerProjects()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L68-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L68"}],"snippet":"export function createServerProjects<T extends ServerProjectState>(input: {\n  scope: Accessor<ServerScope>\n  store: Store<T>\n  setStore: SetStoreFunction<T>\n}) {\n  const setStore = input.setStore as unknown as SetStoreFunction<ServerProjectState>\n  const current = () => input.store.projects[input.scope()] ?? []\n  return {\n    list: current,\n    open(directory: string) {\n      const scope = input.scope()\n      if (current().some((project) => project.worktree === directory)) return\n      setStore(\"projects\", scope, [{ worktree: directory, expanded: true }, ...current()])\n    },\n    close(directory: string) {\n      setStore(\n        \"projects\",\n        input.scope(),\n        current().filter((project) => project.worktree !== directory),\n      )\n    },\n    expand(directory: string) {\n      const index = current().findIndex((project) => project.worktree === directory)\n      if (index !== -1) setStore(\"projects\", input.scope(), index, \"expanded\", true)\n    },"},{"id":"packages_app_src_context_server_createserverprojects_current","label":"current()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L74"}],"snippet":"current = () => input.store.projects[input.scope()] ?? []"},{"id":"packages_app_src_context_server_resolveserverlist","label":"resolveServerList()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L114-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L114"}],"snippet":"export function resolveServerList(input: {\n  props?: Array<ServerConnection.Any>\n  stored: StoredServer[]\n}): Array<ServerConnection.Any> {\n  const deduped = new Map<ServerConnection.Key, ServerConnection.Any>(\n    input.props?.map((v) => [ServerConnection.key(v), v]) ?? [],\n  )\n\n  for (const value of input.stored) {\n    const conn: ServerConnection.Http =\n      typeof value === \"string\"\n        ? {\n            type: \"http\" as const,\n            http: { url: value },\n          }\n        : \"http\" in value\n          ? value\n          : { type: \"http\", http: value }\n    const key = ServerConnection.key(conn)\n\n    const existing = deduped.get(key)\n    if (existing)\n      deduped.set(key, {\n        ...existing,\n        ...conn,"},{"id":"packages_app_src_context_server_key","label":"key()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L190-L201","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L190"}],"snippet":"key = (conn: Any): Key => {\n    switch (conn.type) {\n      case \"http\":\n        return Key.make(conn.http.url)\n      case \"sidecar\": {\n        if (conn.variant === \"wsl\") return Key.make(`wsl:${conn.distro}`)\n        return Key.make(\"sidecar\")\n      }\n      case \"ssh\":\n        return Key.make(`ssh:${conn.host}`)\n    }\n  }"},{"id":"packages_app_src_context_server_builtin","label":"builtin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L206","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L206"}],"snippet":"builtin = (conn: Any) => conn.type === \"sidecar\" && conn.variant === \"base\""},{"id":"packages_app_src_context_server_local","label":"local()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L207-L208","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L207"}],"snippet":"local = (conn?: Any) =>\n    !!conn && (builtin(conn) || (conn.type === \"http\" && isLocalHost(conn.http.url) === \"local\"))"},{"id":"packages_app_src_context_server_nextserverafterremoval","label":"nextServerAfterRemoval()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L211-L219","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L211"}],"snippet":"export function nextServerAfterRemoval(\n  servers: ServerConnection.Any[],\n  removed: ServerConnection.Key,\n  fallback: ServerConnection.Key,\n) {\n  const remaining = servers.filter((server) => ServerConnection.key(server) !== removed)\n  const next = remaining.find((server) => ServerConnection.key(server) === fallback) ?? remaining[0]\n  return next ? ServerConnection.key(next) : fallback\n}"}],"edges":[{"source":"packages_app_src_context_server","target":"context","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L1"}],"weight":1},{"source":"packages_app_src_context_server","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server.tsx","source_location":"L2"}],"weight":1},{"source":"packages_app_src_context_server","target":"store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdama