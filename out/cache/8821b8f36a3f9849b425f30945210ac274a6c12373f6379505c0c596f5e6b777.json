{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_plugin_snowflake-cortex","nodes":[{"id":"packages_opencode_src_plugin_snowflake_cortex","label":"snowflake-cortex.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L1"}]},{"id":"packages_opencode_src_plugin_snowflake_cortex_pkcecodes","label":"PkceCodes","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L13-L16","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L13"}],"snippet":"interface PkceCodes {\n  verifier: string\n  challenge: string\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_tokenresponse","label":"TokenResponse","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L18-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L18"}],"snippet":"interface TokenResponse {\n  access_token: string\n  refresh_token?: string\n  expires_in?: number\n  token_type?: string\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_pendingoauth","label":"PendingOAuth","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L25-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L25"}],"snippet":"interface PendingOAuth {\n  account: string\n  state: string\n  pkce: PkceCodes\n  resolve: (tokens: TokenResponse) => void\n  reject: (error: Error) => void\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_normalizeaccount","label":"normalizeAccount()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L37-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L37"}],"snippet":"function normalizeAccount(input: string) {\n  return input\n    .trim()\n    .replace(/^https?:\\/\\//, \"\")\n    .replace(/\\.snowflakecomputing\\.com\\/?$/, \"\")\n    .replace(/\\/+$/, \"\")\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_generaterandomstring","label":"generateRandomString()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L45-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L45"}],"snippet":"function generateRandomString(length: number) {\n  const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~\"\n  return Array.from(crypto.getRandomValues(new Uint8Array(length)))\n    .map((b) => chars[b % chars.length])\n    .join(\"\")\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_base64urlencode","label":"base64UrlEncode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L52-L55","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L52"}],"snippet":"function base64UrlEncode(buffer: ArrayBuffer) {\n  const binary = String.fromCharCode(...new Uint8Array(buffer))\n  return btoa(binary).replace(/\\+/g, \"-\").replace(/\\//g, \"_\").replace(/=+$/, \"\")\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_generatepkce","label":"generatePKCE()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L57-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L57"}],"snippet":"async function generatePKCE(): Promise<PkceCodes> {\n  const verifier = generateRandomString(64)\n  const hash = await crypto.subtle.digest(\"SHA-256\", new TextEncoder().encode(verifier))\n  return {\n    verifier,\n    challenge: base64UrlEncode(hash),\n  }\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_callbackurl","label":"callbackUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L66-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L66"}],"snippet":"function callbackUrl() {\n  if (!oauthServerPort) throw new Error(\"Snowflake OAuth callback server is not running\")\n  return `http://${OAUTH_CALLBACK_HOST}:${oauthServerPort}${OAUTH_CALLBACK_PATH}`\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_oauthscope","label":"oauthScope()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L71-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L71"}],"snippet":"export function oauthScope(role: string | undefined) {\n  if (!role) return \"refresh_token\"\n  return /^[-_A-Za-z0-9]+$/.test(role)\n    ? `refresh_token session:role:${role}`\n    : `refresh_token session:role-encoded:${encodeURIComponent(role)}`\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_authheaders","label":"authHeaders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L78-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L78"}],"snippet":"function authHeaders() {\n  return {\n    \"Content-Type\": \"application/x-www-form-urlencoded\",\n    Accept: \"application/json\",\n    \"User-Agent\": `opencode/${InstallationVersion}`,\n  }\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_authbasicheader","label":"authBasicHeader()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L86-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L86"}],"snippet":"function authBasicHeader() {\n  return `Basic ${Buffer.from(`${OAUTH_CLIENT_ID}:${OAUTH_CLIENT_ID}`).toString(\"base64\")}`\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_buildauthorizeurl","label":"buildAuthorizeUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L90-L102","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L90"}],"snippet":"function buildAuthorizeUrl(account: string, role: string | undefined, state: string, pkce: PkceCodes) {\n  const scope = oauthScope(role)\n  const params = new URLSearchParams({\n    client_id: OAUTH_CLIENT_ID,\n    response_type: \"code\",\n    redirect_uri: callbackUrl(),\n    scope,\n    state,\n    code_challenge: pkce.challenge,\n    code_challenge_method: \"S256\",\n  })\n  return `https://${account}.snowflakecomputing.com/oauth/authorize?${params.toString()}`\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_exchangecodefortoken","label":"exchangeCodeForToken()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L104-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L104"}],"snippet":"async function exchangeCodeForToken(account: string, code: string, pkce: PkceCodes) {\n  const response = await fetch(`https://${account}.snowflakecomputing.com/oauth/token-request`, {\n    method: \"POST\",\n    headers: {\n      ...authHeaders(),\n      Authorization: authBasicHeader(),\n    },\n    body: new URLSearchParams({\n      grant_type: \"authorization_code\",\n      code,\n      redirect_uri: callbackUrl(),\n      client_id: OAUTH_CLIENT_ID,\n      code_verifier: pkce.verifier,\n    }).toString(),\n  })\n\n  if (!response.ok) {\n    const detail = await response.text().catch(() => \"\")\n    throw new Error(`Snowflake token exchange failed (${response.status})${detail ? `: ${detail}` : \"\"}`)\n  }\n\n  const token = (await response.json()) as TokenResponse\n  if (!token.access_token) throw new Error(\"Snowflake token response did not include access_token\")\n  if (!token.refresh_token) {\n    throw new Error("},{"id":"packages_opencode_src_plugin_snowflake_cortex_refreshaccesstoken","label":"refreshAccessToken()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L135-L157","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L135"}],"snippet":"async function refreshAccessToken(account: string, refreshToken: string) {\n  const response = await fetch(`https://${account}.snowflakecomputing.com/oauth/token-request`, {\n    method: \"POST\",\n    headers: {\n      ...authHeaders(),\n      Authorization: authBasicHeader(),\n    },\n    body: new URLSearchParams({\n      grant_type: \"refresh_token\",\n      refresh_token: refreshToken,\n      client_id: OAUTH_CLIENT_ID,\n    }).toString(),\n  })\n\n  if (!response.ok) {\n    const detail = await response.text().catch(() => \"\")\n    throw new Error(`Snowflake token refresh failed (${response.status})${detail ? `: ${detail}` : \"\"}`)\n  }\n\n  const token = (await response.json()) as TokenResponse\n  if (!token.access_token) throw new Error(\"Snowflake refresh response did not include access_token\")\n  return token\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_htmlerror","label":"htmlError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L171-L180","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L171"}],"snippet":"htmlError = (message: string) => `<!doctype html>\n<html>\n  <head><title>OpenCode - Snowflake Authorization Failed</title></head>\n  <body style=\"font-family: system-ui; display:flex; align-items:center; justify-content:center; height:100vh; margin:0; background:#111; color:#eee;\">\n    <div style=\"text-align:center; max-width:48rem; padding:2rem;\">\n      <h1 style=\"color:#ff7b72;\">Authorization Failed</h1>\n      <pre style=\"white-space:pre-wrap; color:#ffb3ad; background:#2a1210; padding:1rem; border-radius:.5rem;\">${message}</pre>\n    </div>\n  </body>\n</html>`"},{"id":"packages_opencode_src_plugin_snowflake_cortex_startoauthserver","label":"startOAuthServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L182-L249","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L182"}],"snippet":"async function startOAuthServer() {\n  if (oauthServer) return\n\n  oauthServer = createServer((req, res) => {\n    const host = req.headers.host || `${OAUTH_CALLBACK_HOST}:${oauthServerPort ?? 0}`\n    const url = new URL(req.url || \"/\", `http://${host}`)\n\n    if (url.pathname !== OAUTH_CALLBACK_PATH) {\n      res.writeHead(404)\n      res.end(\"Not found\")\n      return\n    }\n\n    const state = url.searchParams.get(\"state\")\n    const code = url.searchParams.get(\"code\")\n    const error = url.searchParams.get(\"error\")\n    const errorDescription = url.searchParams.get(\"error_description\")\n\n    // CSRF guard: validate state before processing any callback\n    if (!pendingOAuth || state !== pendingOAuth.state) {\n      const message = \"Invalid state - potential CSRF attack\"\n      pendingOAuth?.reject(new Error(message))\n      pendingOAuth = undefined\n      res.writeHead(400, { \"Content-Type\": \"text/html\" })\n      res.end(htmlError(message))"},{"id":"packages_opencode_src_plugin_snowflake_cortex_stopoauthserver","label":"stopOAuthServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L251-L256","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L251"}],"snippet":"function stopOAuthServer() {\n  if (!oauthServer) return\n  oauthServer.close()\n  oauthServer = undefined\n  oauthServerPort = undefined\n}"},{"id":"packages_opencode_src_plugin_snowflake_cortex_waitforoauthcallback","label":"waitForOAuthCallback()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L258-L286","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L258"}],"snippet":"function waitForOAuthCallback(account: string, pkce: PkceCodes, state: string): Promise<TokenResponse> {\n  if (pendingOAuth) {\n    pendingOAuth.reject(new Error(\"Superseded by a newer Snowflake authorize request\"))\n    pendingOAuth = undefined\n  }\n\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => {\n      if (!pendingOAuth) return\n      pendingOAuth = undefined\n      stopOAuthServer()\n      reject(new Error(\"Snowflake OAuth callback timeout - authorization took too long\"))\n    }, OAUTH_TIMEOUT_MS)\n\n    pendingOAuth = {\n      account,\n      state,\n      pkce,\n      resolve: (tokens) => {\n        clearTimeout(timeout)\n        resolve(tokens)\n      },\n      reject: (error) => {\n        clearTimeout(timeout)\n        reject(error)"},{"id":"packages_opencode_src_plugin_snowflake_cortex_snowflakecortexauthplugin","label":"SnowflakeCortexAuthPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L288-L529","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L288"}],"snippet":"export async function SnowflakeCortexAuthPlugin(_input: PluginInput): Promise<Hooks> {\n  const prompts = [\n    {\n      type: \"text\" as const,\n      key: \"account\",\n      message: \"Snowflake Account Identifier\",\n      placeholder: \"myorg-myaccount\",\n      validate: (value: string) => (value && value.trim().length > 0 ? undefined : \"Required\"),\n    },\n    {\n      type: \"text\" as const,\n      key: \"role\",\n      message: \"Snowflake Role (optional)\",\n      placeholder: \"PUBLIC\",\n    },\n  ]\n\n  return {\n    auth: {\n      provider: \"snowflake-cortex\",\n      async loader(getAuth, _provider) {\n        let auth = await getAuth()\n        if (auth.type !== \"oauth\") return {}\n\n        let refreshPromise:"},{"id":"packages_opencode_src_plugin_snowflake_cortex_snowflakecortexauthplugin_refresh","label":"refresh()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L357-L389","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L357"}],"snippet":"refresh = async () => {\n              if (!refreshPromise) {\n                const refreshToken = currentOauth.refresh\n                refreshPromise = refreshAccessToken(accountId, refreshToken)\n                  .then(async (tokens) => {\n                    const refreshedRefresh = tokens.refresh_token || refreshToken\n                    const refreshedExpires = Date.now() + (tokens.expires_in ?? 600) * 1000\n                    await _input.client.auth\n                      .set({\n                        path: { id: \"snowflake-cortex\" },\n                        body: {\n                          type: \"oauth\",\n                          access: tokens.access_token,\n                          refresh: refreshedRefresh,\n                          expires: refreshedExpires,\n                          ...(accountId && { accountId }),\n                        },\n                      })\n                      .catch(() => {})\n                    return {\n                      access: tokens.access_token,\n                      refresh: refreshedRefresh,\n                      expires: refreshedExpires,\n                    }\n                  })"},{"id":"packages_opencode_src_plugin_snowflake_cortex_snowflakecortexauthplugin_preparerequest","label":"prepareRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L391-L420","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L391"}],"snippet":"prepareRequest = () => {\n              const headers = new Headers(requestInput instanceof Request ? requestInput.headers : undefined)\n              if (init?.headers) {\n                const entries =\n                  init.headers instanceof Headers\n                    ? init.headers.entries()\n                    : Array.isArray(init.headers)\n                      ? init.headers\n                      : Object.entries(init.headers as Record<string, string | undefined>)\n                for (const [key, value] of entries) {\n                  if (value !== undefined) headers.set(key, String(value))\n                }\n              }\n              headers.set(\"authorization\", `Bearer ${currentOauth.access}`)\n              headers.set(\"User-Agent\", `opencode/${InstallationVersion}`)\n\n              let body = init?.body\n              if (body && typeof body === \"string\") {\n                try {\n                  const parsed = JSON.parse(body)\n                  if (\"max_tokens\" in parsed) {\n                    parsed.max_completion_tokens = parsed.max_tokens\n                    delete parsed.max_tokens\n                    body = JSON.stringify(parsed)\n                  }"},{"id":"packages_opencode_src_plugin_snowflake_cortex_snowflakecortexauthplugin_transformresponse","label":"transformResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L422-L460","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/snowflake-cortex.ts","source_location":"L422"}],"snippet":"transformResponse = async (response: Response) => {\n              if (!response.ok && response.status === 400) {\n                try {\n                  const errorData = await response.clone().json()\n                  const errorMessage = String(errorData.message || errorData.error || \"\")\n                  if (errorMessage.toLowerCase().includes(\"conversation complete\")) {\n                    return new Response(\n                      JSON.stringify({\n                        choices: [{ finish_reason: \"stop\", message: { co