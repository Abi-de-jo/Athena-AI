omain\"])\n  const port = portExplicitlySet ? args.port : (config?.server?.port ?? args.port)\n  const hostname = hostnameExplicitlySet\n    ? args.hostname\n    : mdns && !config?.server?.hostname\n      ? \"0.0.0.0\"\n      : (config?.server?.hostname ?? args.hostname)\n  const configCors = config?.server?.cors ?? []\n  const argsCors = Array.isArray(args.cors) ? args.cors : args.cors ? [args.cors] : []\n  const cors = [...configCors, ...argsCors]\n\n  return { hostname, port, mdns, mdnsDomain, cors }\n}"}],"edges":[{"source":"network","target":"yargs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/network.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/network.ts","source_location":"L1"}],"weight":1},{"source":"network","target":"config","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/network.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/network.ts","source_location":"L2"}],"weight":1},{"source":"network","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/network.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/network.ts","source_location":"L4"}],"weight":1},{"source":"network","target":"network_withnetworkoptions","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/