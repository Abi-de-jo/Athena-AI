ages_desktop_src_main_server_spawnlocalserver_onprocessgone","label":"onProcessGone()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L71-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L71"}],"snippet":"onProcessGone = (_event: unknown, details: Details) => {\n    if (details.type !== \"Utility\" || details.name !== SIDECAR_SERVICE_NAME) return\n    options.onStderr?.(`utility process gone reason=${details.reason} exitCode=${details.exitCode}`)\n  }"},{"id":"packages_desktop_src_main_server_spawnlocalserver_fail","label":"fail()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L92-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L92"}],"snippet":"fail = (error: Error) => {\n      if (done) return\n      done = true\n      cleanup()\n      reject(error)\n    }"},{"id":"packages_desktop_src_main_server_spawnlocalserver_refreshtimeout","label":"refreshTimeout()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L99-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L99"}],"snippet":"refreshTimeout = () => {\n      clearTimeout(timeout)\n      timeout = setTimeout(() => {\n        fail(new Error(`Sidecar did not become ready within ${SIDECAR_START_STALL_TIMEOUT}ms: ${sidecar}`))\n      }, SIDECAR_START_STALL_TIMEOUT)\n    }"},{"id":"packages_desktop_src_main_server_spawnlocalserver_onmessage","label":"onMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L106-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L106"}],"snippet":"onMessage = (message: SidecarMessage) => {\n      if (message.type === \"ready\") {\n        if (done) return\n        done = true\n        cleanup()\n        resolve()\n        return\n      }\n      if (message.type === \"error\") {\n        fail(Object.assign(new Error(message.error.message), { stack: message.error.stack }))\n      }\n    }"},{"id":"packages_desktop_src_main_server_spawnlocalserver_onexit","label":"onExit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L118-L120","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L118"}],"snippet":"onExit = (code: number) => {\n      fail(new Error(`Sidecar exited before ready with code ${code}`))\n    }"},{"id":"packages_desktop_src_main_server_spawnlocalserver_cleanup","label":"cleanup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L121-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L121"}],"snippet":"cleanup = () => {\n      clearTimeout(timeout)\n      child.off(\"message\", onMessage)\n      child.off(\"exit\", onExit)\n    }"},{"id":"packages_desktop_src_main_server_checkhealth","label":"checkHealth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L184-L208","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L184"}],"snippet":"export async function checkHealth(url: string, password?: string | null): Promise<boolean> {\n  let healthUrl: URL\n  try {\n    healthUrl = new URL(\"/global/health\", url)\n  } catch {\n    return false\n  }\n\n  const headers = new Headers()\n  if (password) {\n    const auth = Buffer.from(`opencode:${password}`).toString(\"base64\")\n    headers.set(\"authorization\", `Basic ${auth}`)\n  }\n\n  try {\n    const res = await fetch(healthUrl, {\n      method: \"GET\",\n      headers,\n      signal: AbortSignal.timeout(3000),\n    })\n    return res.ok\n  } catch {\n    return false\n  }\n}"},{"id":"packages_desktop_src_main_server_createsidecarenv","label":"createSidecarEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L210-L218","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts","source_location":"L210"}],"snippet":"function createSidecarEnv(): Record<string, string> {\n  const env = Object.fromEntries(\n    Object.entries(process.env).flatMap(([key, value]) => (value === undefined ? [] : [[key, String(value)]])),\n  )\n  delete env.DEBUG\n  if (process.platform === \"linux\") delete env.LD_PRELOAD\n  if (!app.isPackaged) env.OPENCODE_DISABLE_CHANNEL_DB = \"1\"\n  return env\n}"},{"id":"packages_desktop_src_main_server_delay","label":"delay()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/server.ts",