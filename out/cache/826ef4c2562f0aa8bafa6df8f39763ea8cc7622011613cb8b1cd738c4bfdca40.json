{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_plugin_github-copilot_copilot","nodes":[{"id":"packages_rimuru_src_plugin_github_copilot_copilot","label":"copilot.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_plugin_github_copilot_copilot_normalizedomain","label":"normalizeDomain()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L15-L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L15"}],"snippet":"function normalizeDomain(url: string) {\n  return url.replace(/^https?:\\/\\//, \"\").replace(/\\/$/, \"\")\n}"},{"id":"packages_rimuru_src_plugin_github_copilot_copilot_geturls","label":"getUrls()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L19-L24","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L19"}],"snippet":"function getUrls(domain: string) {\n  return {\n    DEVICE_CODE_URL: `https://${domain}/login/device/code`,\n    ACCESS_TOKEN_URL: `https://${domain}/login/oauth/access_token`,\n  }\n}"},{"id":"packages_rimuru_src_plugin_github_copilot_copilot_base","label":"base()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L26-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L26"}],"snippet":"function base(enterpriseUrl?: string) {\n  return enterpriseUrl ? `https://copilot-api.${normalizeDomain(enterpriseUrl)}` : \"https://api.githubcopilot.com\"\n}"},{"id":"packages_rimuru_src_plugin_github_copilot_copilot_imgmsg","label":"imgMsg()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L31-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L31"}],"snippet":"function imgMsg(msg: any): boolean {\n  if (msg?.role !== \"user\") return false\n\n  // Handle the 3 api formats\n\n  const content = msg.content\n  if (typeof content === \"string\") return content === MessageV2.SYNTHETIC_ATTACHMENT_PROMPT\n  if (!Array.isArray(content)) return false\n  return content.some(\n    (part: any) =>\n      (part?.type === \"text\" || part?.type === \"input_text\") && part.text === MessageV2.SYNTHETIC_ATTACHMENT_PROMPT,\n  )\n}"},{"id":"packages_rimuru_src_plugin_github_copilot_copilot_fix","label":"fix()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L45-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L45"}],"snippet":"function fix(model: Model, url: string): Model {\n  return {\n    ...model,\n    api: {\n      ...model.api,\n      url,\n      npm: \"@ai-sdk/github-copilot\",\n    },\n  }\n}"},{"id":"packages_rimuru_src_plugin_github_copilot_copilot_copilotauthplugin","label":"CopilotAuthPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L56-L413","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L56"}],"snippet":"export async function CopilotAuthPlugin(input: PluginInput): Promise<Hooks> {\n  const sdk = input.client\n  let models: Record<string, Model> = {}\n  return {\n    provider: {\n      id: \"github-copilot\",\n      async models(provider, ctx) {\n        if (ctx.auth?.type !== \"oauth\") {\n          models = {}\n          return Object.fromEntries(Object.entries(provider.models).map(([id, model]) => [id, fix(model, base())]))\n        }\n\n        const auth = ctx.auth\n\n        return CopilotModels.get(\n          base(auth.enterpriseUrl),\n          {\n            Authorization: `Bearer ${auth.refresh}`,\n            \"User-Agent\": `rimuru-ai/${InstallationVersion}`,\n            \"X-GitHub-Api-Version\": API_VERSION,\n          },\n          provider.models,\n        )\n          .then((result) => {\n            models = result.models"}],"edges":[{"source":"packages_rimuru_src_plugin_github_copilot_copilot","target":"plugin","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/plugin/github-copilot/copilot.ts","source_location":"L1"}],"weight":1},{"sou