{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_ui_src_theme_v2_resolve","nodes":[{"id":"packages_ui_src_theme_v2_resolve","label":"resolve.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L1"}]},{"id":"packages_ui_src_theme_v2_resolve_paletteinput","label":"PaletteInput","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L11-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L11"}],"snippet":"interface PaletteInput {\n  neutral: HexColor\n  ink: HexColor\n  primary: HexColor\n  accent: HexColor\n  success: HexColor\n  warning: HexColor\n  error: HexColor\n  info: HexColor\n  interactive: HexColor\n  diffAdd: HexColor\n  diffDelete: HexColor\n}"},{"id":"packages_ui_src_theme_v2_resolve_clamp","label":"clamp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L25-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L25"}],"snippet":"function clamp(v: number, min: number, max: number) {\n  return Math.max(min, Math.min(max, v))\n}"},{"id":"packages_ui_src_theme_v2_resolve_generatev2huescale","label":"generateV2HueScale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L30-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L30"}],"snippet":"function generateV2HueScale(seed: HexColor, isDark: boolean): HexColor[] {\n  const base = hexToOklch(seed)\n  const chromaBoost = isDark ? 1 : 1.05\n  const lightSteps = [\n    0.99,\n    0.965,\n    0.93,\n    0.885,\n    0.835,\n    clamp(base.l, 0.48, 0.72),\n    clamp(base.l - 0.07, 0.4, 0.64),\n    clamp(base.l - 0.14, 0.32, 0.55),\n    clamp(base.l - 0.21, 0.24, 0.46),\n    clamp(base.l - 0.28, 0.17, 0.38),\n    clamp(base.l - 0.34, 0.12, 0.3),\n    clamp(base.l - 0.4, 0.08, 0.22),\n  ]\n  const chromaMultipliers = [0.28, 0.48, 0.68, 0.86, 1.02, 1.28, 1.34, 1.28, 1.18, 1.08, 0.98, 0.88]\n\n  return lightSteps.map((l, i) =>\n    oklchToHex({\n      l,\n      c: base.c * chromaMultipliers[i]! * chromaBoost,\n      h: base.h,\n    }),"},{"id":"packages_ui_src_theme_v2_resolve_generatev2neutralscale","label":"generateV2NeutralScale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L59-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L59"}],"snippet":"function generateV2NeutralScale(neutral: HexColor, ink: HexColor, isDark: boolean): HexColor[] {\n  const scale = generateNeutralScale(neutral, isDark, ink)\n  return isDark ? scale.toReversed() : scale\n}"},{"id":"packages_ui_src_theme_v2_resolve_assignhueramp","label":"assignHueRamp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L64-L70","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L64"}],"snippet":"function assignHueRamp(prefix: string, scale: HexColor[]): Record<string, V2ColorValue> {\n  const tokens: Record<string, V2ColorValue> = {}\n  for (let i = 0; i < V2_STEPS.length; i++) {\n    tokens[`v2-${prefix}-${V2_STEPS[i]}`] = scale[i]!\n  }\n  return tokens\n}"},{"id":"packages_ui_src_theme_v2_resolve_readpalette","label":"readPalette()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L72-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L72"}],"snippet":"function readPalette(variant: ThemeVariant): PaletteInput {\n  if (\"palette\" in variant && variant.palette) {\n    const palette = variant.palette\n    return {\n      neutral: palette.neutral,\n      ink: palette.ink,\n      primary: palette.primary,\n      accent: palette.accent ?? palette.info,\n      success: palette.success,\n      warning: palette.warning,\n      error: palette.error,\n      info: palette.info,\n      interactive: palette.interactive ?? palette.primary,\n      diffAdd: palette.diffAdd ?? shift(palette.success, { c: 0.55, l: 0.14 }),\n      diffDelete: palette.diffDelete ?? palette.error,\n    }\n  }\n  if (\"seeds\" in variant && variant.seeds) {\n    const seeds = variant.seeds\n    return {\n      neutral: seeds.neutral,\n      ink: seeds.neutral,\n      primary: seeds.primary,\n      accent: seeds.info,\n      success: seeds.success,"},{"id":"packages_ui_src_theme_v2_resolve_generatev2primitives","label":"generateV2Primitives()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L109-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L109"}],"snippet":"export function generateV2Primitives(variant: ThemeVariant, isDark: boolean): Record<string, V2ColorValue> {\n  const colors = readPalette(variant)\n  const grey = generateV2NeutralScale(colors.neutral, colors.ink, isDark)\n  const blue = generateV2HueScale(colors.interactive, isDark)\n  const green = generateV2HueScale(colors.success, isDark)\n  const yellow = generateV2HueScale(colors.warning, isDark)\n  const red = generateV2HueScale(colors.error, isDark)\n  const purple = generateV2HueScale(colors.accent, isDark)\n  const pink = generateV2HueScale(colors.info, isDark)\n  const orange = generateV2HueScale(shift(colors.warning, { h: -22, l: -0.082, c: 0.94 }), isDark)\n  const cyan = generateV2HueScale(shift(colors.info, { h: -12, l: 0.128, c: 1.12 }), isDark)\n\n  return {\n    ...V2_PRIMITIVES_DEFAULT,\n    ...assignHueRamp(\"grey\", grey),\n    ...assignHueRamp(\"blue\", blue),\n    ...assignHueRamp(\"green\", green),\n    ...assignHueRamp(\"yellow\", yellow),\n    ...assignHueRamp(\"red\", red),\n    ...assignHueRamp(\"purple\", purple),\n    ...assignHueRamp(\"pink\", pink),\n    ...assignHueRamp(\"orange\", orange),\n    ...assignHueRamp(\"cyan\", cyan),\n  }\n}"},{"id":"packages_ui_src_theme_v2_resolve_resolvethemevariantv2","label":"resolveThemeVariantV2()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L135-L140","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L135"}],"snippet":"export function resolveThemeVariantV2(variant: ThemeVariant, isDark: boolean): ResolvedV2Theme {\n  const primitives = generateV2Primitives(variant, isDark)\n  const semantics = mapV2Semantics(isDark)\n  const foreground = mapV2Foreground(readPalette(variant).ink, isDark, primitives, variant.overrides)\n  return mergeV2Tokens(primitives, semantics, foreground, variant.v2Overrides ?? {})\n}"},{"id":"packages_ui_src_theme_v2_resolve_resolvethemev2","label":"resolveThemeV2()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L142-L147","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L142"}],"snippet":"export function resolveThemeV2(theme: DesktopTheme): { light: ResolvedV2Theme; dark: ResolvedV2Theme } {\n  return {\n    light: resolveThemeVariantV2(theme.light, false),\n    dark: resolveThemeVariantV2(theme.dark, true),\n  }\n}"},{"id":"packages_ui_src_theme_v2_resolve_themev2tocss","label":"themeV2ToCss()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L149-L153","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L149"}],"snippet":"export function themeV2ToCss(tokens: ResolvedV2Theme): string {\n  return Object.entries(tokens)\n    .map(([key, value]) => `--${key}: ${value};`)\n    .join(\"\\n  \")\n}"}],"edges":[{"source":"packages_ui_src_theme_v2_resolve","target":"color","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/v2/resolve.ts","source_location":"L3"}],"weight":1},{"source":"packages_ui_src_theme_v2_resol