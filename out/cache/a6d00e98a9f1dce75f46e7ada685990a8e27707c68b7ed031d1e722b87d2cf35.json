{"__madarTsExtractorVersion":67,"__madarFileStem":"agent.handler","nodes":[{"id":"agent_handler","label":"agent.handler.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L1"}]},{"id":"agent_handler_resolvetools","label":"resolveTools()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L88-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L88"}],"snippet":"function resolveTools(agent: Agent.Info, availableTools: { id: string }[]) {\n  const disabled = Permission.disabled(\n    availableTools.map((tool) => tool.id),\n    agent.permission,\n  )\n  const resolved: Record<string, boolean> = {}\n  for (const tool of availableTools) {\n    resolved[tool.id] = !disabled.has(tool.id)\n  }\n  return resolved\n}"},{"id":"agent_handler_parsetoolparams","label":"parseToolParams()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L100-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L100"}],"snippet":"function parseToolParams(input?: string) {\n  if (!input) return {}\n  const trimmed = input.trim()\n  if (trimmed.length === 0) return {}\n\n  const parsed = iife(() => {\n    try {\n      return JSON.parse(trimmed)\n    } catch (jsonError) {\n      try {\n        return new Function(`return (${trimmed})`)()\n      } catch (evalError) {\n        throw new Error(\n          `Failed to parse --params. Use JSON or a JS object literal. JSON error: ${jsonError}. Eval error: ${evalError}.`,\n          { cause: evalError },\n        )\n      }\n    }\n  })\n\n  if (!parsed || typeof parsed !== \"object\" || Array.isArray(parsed)) {\n    throw new Error(\"Tool params must be an object.\")\n  }\n  return parsed as Record<string, unknown>\n}"}],"edges":[{"source":"agent_handler","target":"permission","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L1"}],"weight":1},{"source":"agent_handler","target":"os","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L2"}],"weight":1},{"source":"agent_handler","target":"session","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/debug/agent.handler.ts","source_location":"L3"}],"weight":1},{"source":"agent_handler","target":"path","relation":"imp