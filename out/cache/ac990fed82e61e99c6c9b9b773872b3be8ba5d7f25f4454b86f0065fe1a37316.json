{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_test_server_httpapi-exercise_runner","nodes":[{"id":"packages_rimuru_test_server_httpapi_exercise_runner","label":"runner.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L1"}]},{"id":"packages_rimuru_test_server_httpapi_exercise_runner_runscenario","label":"runScenario()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L17-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L17"}],"snippet":"export function runScenario(options: Options) {\n  return (scenario: Scenario) => {\n    if (scenario.kind === \"todo\") return Effect.succeed({ status: \"skip\", scenario } as Result)\n    return runActive(options, scenario).pipe(\n      Effect.timeoutOrElse({\n        duration: options.scenarioTimeout,\n        orElse: () => Effect.die(new Error(`scenario timed out after ${Duration.format(options.scenarioTimeout)}`)),\n      }),\n      Effect.as({ status: \"pass\", scenario } as Result),\n      Effect.catchCause((cause) => Effect.succeed({ status: \"fail\" as const, scenario, message: Cause.pretty(cause) })),\n      Effect.scoped,\n    )\n  }\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_runner_runactive","label":"runActive()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L32-L45","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L32"}],"snippet":"function runActive(options: Options, scenario: ActiveScenario) {\n  if (options.mode === \"auth\") return runAuth(scenario)\n\n  return withContext(options, scenario, \"shared\", (ctx) =>\n    Effect.gen(function* () {\n      yield* trace(options, scenario, \"request start\")\n      const result = yield* call(scenario, ctx)\n      yield* trace(options, scenario, `response ${result.status}`)\n      yield* trace(options, scenario, \"expect start\")\n      yield* scenario.expect(ctx, ctx.state, result)\n      yield* trace(options, scenario, \"expect done\")\n    }),\n  )\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_runner_runauth","label":"runAuth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L47-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L47"}],"snippet":"function runAuth(scenario: ActiveScenario) {\n  return Effect.gen(function* () {\n    const result = yield* callAuthProbe(scenario, \"missing\")\n    if (scenario.auth === \"protected\") {\n      if (result.status !== 401) throw new Error(`auth expected 401, got ${result.status}`)\n      const authed = yield* callAuthProbe(scenario, \"valid\")\n      if (authed.status === 401) throw new Error(\"auth rejected valid credentials\")\n      return\n    }\n\n    if (result.status === 401) throw new Error(\"auth expected public access, got 401\")\n    if (result.timedOut) throw new Error(\"auth expected public access, probe timed out\")\n  })\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_runner_withcontext","label":"withContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L62-L198","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L62"}],"snippet":"function withContext<A, E>(\n  options: Options,\n  scenario: ActiveScenario,\n  label: string,\n  use: (ctx: SeededContext<unknown>) => Effect.Effect<A, E>,\n) {\n  return Effect.acquireRelease(\n    Effect.gen(function* () {\n      yield* trace(options, scenario, `${label} context acquire start`)\n      const llm = scenario.project?.llm ? yield* TestLLMServer : undefined\n      const project = scenario.project\n      const dir = project\n        ? yield* Effect.promise(async () => (await runtime()).tmpdir(projectOptions(project, llm?.url)))\n        : undefined\n      yield* trace(options, scenario, `${label} context acquire done`)\n      return { dir, llm }\n    }),\n    (ctx) =>\n      Effect.gen(function* () {\n        yield* trace(options, scenario, `${label} tmpdir cleanup start`)\n        yield* Effect.promise(async () => {\n          await ctx.dir?.[Symbol.asyncDispose]()\n        }).pipe(Effect.ignore)\n        yield* trace(options, scenario, `${label} tmpdir cleanup done`)\n      }),"},{"id":"packages_rimuru_test_server_httpapi_exercise_runner_withcontext_run","label":"run()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L116-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L116"}],"snippet":"run = <A, E, R>(effect: Effect.Effect<A, E, R>) =>\n          effect.pipe(Effect.provideService(modules.InstanceRef, instance), Effect.provide(app))"},{"id":"packages_rimuru_test_server_httpapi_exercise_runner_withcontext_directory","label":"directory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L118-L121","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L118"}],"snippet":"directory = () => {\n          if (!context.dir?.path) throw new Error(\"scenario needs a project directory\")\n          return context.dir.path\n        }"},{"id":"packages_rimuru_test_server_httpapi_exercise_runner_withcontext_llm","label":"llm()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L122-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L122"}],"snippet":"llm = () => {\n          if (!context.llm) throw new Error(\"scenario needs fake LLM\")\n          return context.llm\n        }"},{"id":"packages_rimuru_test_server_httpapi_exercise_runner_trace","label":"trace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L200-L205","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L200"}],"snippet":"function trace(options: Options, scenario: ActiveScenario, phase: string) {\n  return Effect.sync(() => {\n    if (!options.trace) return\n    console.log(`[trace] ${scenario.name}: ${phase}`)\n  })\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_runner_projectoptions","label":"projectOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L207-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L207"}],"snippet":"function projectOptions(\n  project: ProjectOptions,\n  llmUrl: string | undefined,\n): { git?: boolean; config?: Partial<ConfigV1.Info> } {\n  if (!project.llm || !llmUrl) return { git: project.git, config: project.config }\n  const fake = fakeLlmConfig(llmUrl)\n  return {\n    git: project.git,\n    config: {\n      ...fake,\n      ...project.config,\n      provider: {\n        ...fake.provider,\n        ...project.config?.provider,\n      },\n    },\n  }\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_runner_fakellmconfig","label":"fakeLlmConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L226-L257","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L226"}],"snippet":"function fakeLlmConfig(url: string): Partial<ConfigV1.Info> {\n  return {\n    model: \"test/test-model\",\n    small_model: \"test/test-model\",\n    provider: {\n      test: {\n        name: \"Test\",\n        id: \"test\",\n        env: [],\n        npm: \"@ai-sdk/openai-compatible\",\n        models: {\n          \"test-model\": {\n            id: \"test-model\",\n            name: \"Test Model\",\n            attachment: false,\n            reasoning: false,\n            temperature: false,\n            tool_call: true,\n            release_date: \"2025-01-01\",\n            limit: { context: 100000, output: 10000 },\n            cost: { input: 0, output: 0 },\n            options: {},\n          },\n        },\n        options: {"}],"edges":[{"source":"packages_rimuru_test_server_httpapi_exercise_runner","target":"flag","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_test_server_httpapi_exercise_runner","target":"config","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L2"}],"weight":1},{"source":"packages_rimuru_test_server_httpapi_exercise_runner","target":"session","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/runner.ts","source_location":"L3"}],"weight":1},{"source":"packages_rimuru_test_server_httpapi_exercise_runner","target":"effect","relation":