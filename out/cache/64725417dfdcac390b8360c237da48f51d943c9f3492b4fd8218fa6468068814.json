{"__madarTsExtractorVersion":67,"__madarFileStem":"native-request","nodes":[{"id":"native_request","label":"native-request.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L1"}]},{"id":"native_request_providermetadata","label":"providerMetadata()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L37-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L37"}],"snippet":"providerMetadata = (value: unknown): ProviderMetadata | undefined => {\n  if (!isRecord(value)) return undefined\n  const result = Object.fromEntries(\n    Object.entries(value).filter((entry): entry is [string, Record<string, unknown>] => isRecord(entry[1])),\n  )\n  return Object.keys(result).length === 0 ? undefined : result\n}"},{"id":"native_request_partprovidermetadata","label":"partProviderMetadata()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L47-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L47"}],"snippet":"partProviderMetadata = (part: Record<string, unknown>) =>\n  providerMetadata(part.providerMetadata) ?? providerMetadata(part.providerOptions)"},{"id":"native_request_textpart","label":"textPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L50-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L50"}],"snippet":"textPart = (part: Record<string, unknown>) => ({\n  type: \"text\" as const,\n  text: typeof part.text === \"string\" ? part.text : \"\",\n  providerMetadata: partProviderMetadata(part),\n})"},{"id":"native_request_mediapart","label":"mediaPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L56-L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L56"}],"snippet":"mediaPart = (part: Record<string, unknown>) => {\n  if (typeof part.data !== \"string\" && !(part.data instanceof Uint8Array))\n    throw new Error(\"Native LLM request adapter only supports file parts with string or Uint8Array data\")\n  return {\n    type: \"media\" as const,\n    mediaType: typeof part.mediaType === \"string\" ? part.mediaType : \"application/octet-stream\",\n    data: part.data,\n    filename: typeof part.filename === \"string\" ? part.filename : undefined,\n  }\n}"},{"id":"native_request_toolresult","label":"toolResult()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L67-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L67"}],"snippet":"toolResult = (part: Record<string, unknown>) => {\n  const output = isRecord(part.output) ? part.output : { type: \"json\", value: part.output }\n  const type = output.type === \"text\" ? \"text\" : output.type === \"error-text\" ? \"error\" : \"json\"\n  return ToolResultPart.make({\n    id: typeof part.toolCallId === \"string\" ? part.toolCallId : \"\",\n    name: typeof part.toolName === \"string\" ? part.toolName : \"\",\n    result: \"value\" in output ? output.value : output,\n    resultType: type,\n    providerExecuted: typeof part.providerExecuted === \"boolean\" ? part.providerExecuted : undefined,\n    providerMetadata: partProviderMetadata(part),\n  })\n}"},{"id":"native_request_contentpart","label":"contentPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L80-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L80"}],"snippet":"contentPart = (part: unknown) => {\n  if (!isRecord(part)) throw new Error(\"Native LLM request adapter only supports object content parts\")\n  if (part.type === \"text\") return textPart(part)\n  if (part.type === \"file\") return mediaPart(part)\n  if (part.type === \"reasoning\")\n    return {\n      type: \"reasoning\" as const,\n      text: typeof part.text === \"string\" ? part.text : \"\",\n      providerMetadata: partProviderMetadata(part),\n    }\n  if (part.type === \"tool-call\")\n    return ToolCallPart.make({\n      id: typeof part.toolCallId === \"string\" ? part.toolCallId : \"\",\n      name: typeof part.toolName === \"string\" ? part.toolName : \"\",\n      input: part.input,\n      providerExecuted: typeof part.providerExecuted === \"boolean\" ? part.providerExecuted : undefined,\n      providerMetadata: partProviderMetadata(part),\n    })\n  if (part.type === \"tool-result\") return toolResult(part)\n  throw new Error(`Native LLM request adapter does not support ${String(part.type)} content parts`)\n}"},{"id":"native_request_content","label":"content()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L102-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L102"}],"snippet":"content = (value: ModelMessage[\"content\"]) =>\n  typeof value === \"string\" ? [{ type: \"text\" as const, text: value }] : value.map(contentPart)"},{"id":"native_request_messages","label":"messages()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L105-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L105"}],"snippet":"messages = (input: readonly ModelMessage[]) => {\n  const system = input.flatMap((message) => (message.role === \"system\" ? [SystemPart.make(message.content)] : []))\n  const messages = input.flatMap((message) => {\n    if (message.role === \"system\") return []\n    return [\n      Message.make({\n        role: message.role,\n        content: content(message.content),\n        native: isRecord(message.providerOptions) ? { providerOptions: message.providerOptions } : undefined,\n      }),\n    ]\n  })\n  return { system, messages }\n}"},{"id":"native_request_schema","label":"schema()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L120-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L120"}],"snippet":"schema = (value: unknown): JsonSchema => {\n  if (!isRecord(value)) return { type: \"object\", properties: {} }\n  if (isRecord(value.jsonSchema)) return value.jsonSchema\n  return value\n}"},{"id":"native_request_tools","label":"tools()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L126-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L126"}],"snippet":"tools = (input: Record<string, ToolInput> | undefined): ToolDefinition[] =>\n  Object.entries(input ?? {}).map(([name, item]) =>\n    ToolDefinition.make({\n      name,\n      description: item.description ?? \"\",\n      inputSchema: schema(item.inputSchema),\n    }),\n  )"},{"id":"native_request_generation","label":"generation()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L135-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L135"}],"snippet":"generation = (input: RequestInput) => {\n  const result = {\n    temperature: input.temperature,\n    topP: input.topP,\n    topK: input.topK,\n    maxTokens: input.maxOutputTokens,\n  }\n  return Object.values(result).some((value) => value !== undefined) ? result : undefined\n}"},{"id":"native_request_baseurl","label":"baseURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L145-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L145"}],"snippet":"baseURL = (input: Provider.Model | RequestInput) =>\n  \"model\" in input ? (input.baseURL ?? (input.model.api.url || undefined)) : input.api.url || undefined"},{"id":"native_request_requirebaseurl","label":"requireBaseURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L148-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L148"}],"snippet":"requireBaseURL = (model: Provider.Model, url: string | undefined) => {\n  if (url) return url\n  throw new Error(`Native LLM request adapter requires a base URL for ${model.providerID}/${model.id}`)\n}"},{"id":"native_request_model","label":"model()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L153-L179","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L153"}],"snippet":"model = (input: Provider.Model | RequestInput, headers?: Record<string, string>) => {\n  const model = \"model\" in input ? input.model : input\n  const url = baseURL(input)\n  const options = {\n    ...(\"model\" in input && input.apiKey ? { apiKey: input.apiKey } : {}),\n    ...(url ? { baseURL: url } : {}),\n    headers: Object.keys({ ...model.headers, ...headers }).length === 0 ? undefined : { ...model.headers, ...headers },\n    limits: {\n      context: model.limit.context,\n      output: model.limit.output,\n    },\n  }\n  if (model.api.npm === \"@ai-sdk/openai\") return OpenAI.configure(options).responses(model.api.id)\n  if (model.api.npm === \"@ai-sdk/azure\")\n    return Azure.configure({ ...options, baseURL: requireBaseURL(model, url) }).responses(model.api.id)\n  if (model.api.npm === \"@ai-sdk/anthropic\") return Anthropic.configure(options).model(model.api.id)\n  if (model.api.npm === \"@ai-sdk/google\") return Google.configure(options).model(model.api.id)\n  if (model.api.npm === \"@ai-sdk/amazon-bedrock\") return AmazonBedrock.configure(options).model(model.api.id)\n  if (model.api.npm === \"@ai-sdk/openai-compatible\")\n    return OpenAICompatible.configure({\n      ...options,\n      provider: String(model.providerID),\n      baseURL: requireBaseURL(model, url),\n    }).model(model.api.id)\n  if (model.api.npm === \"@openrouter/ai-sdk-provider\") return OpenRouter.configure(options).model(model.api.id)"},{"id":"native_request_request","label":"request()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L181-L194","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L181"}],"snippet":"request = (input: RequestInput) => {\n  const converted = messages(input.messages)\n  // This is the only native adapter boundary that should construct canonical\n  // @rimuru-ai/llm request objects from opencode's session/AI SDK-shaped data.\n  return LLM.request({\n    model: model(input, input.headers),\n    system: [...(input.system ?? []).map(SystemPart.make), ...converted.system],\n    messages: converted.messages,\n    tools: tools(input.tools),\n    toolChoice: input.toolChoice,\n    generation: generation(input),\n    providerOptions: input.providerOptions,\n  })\n}"}],"edges":[{"source":"native_request","target":"llm","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L1"}],"weight":1},{"source":"native_request","target":"providers","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L3"}],"weight":1},{"source":"native_request","target":"ai","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L12"}],"weight":1},{"source":"native_request","target":"provider","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L13","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/session/llm/native-request.ts","source_location":"L13"}],"weight":1},{"source":"nativ