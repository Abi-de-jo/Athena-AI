{"__madarTsExtractorVersion":67,"__madarFileStem":"sidebar-items","nodes":[{"id":"sidebar_items","label":"sidebar-items.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L1"}]},{"id":"sidebar_items_projecticon","label":"ProjectIcon()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L20-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L20"}],"snippet":"ProjectIcon = (props: {\n  project: LocalProject\n  class?: string\n  notify?: boolean\n  working?: boolean\n}): JSX.Element => {\n  const serverSync = useServerSync()\n  const notification = useNotification()\n  const permission = usePermission()\n  const dirs = createMemo(() => [props.project.worktree, ...(props.project.sandboxes ?? [])])\n  const unseenCount = createMemo(() =>\n    dirs().reduce((total, directory) => total + notification.project.unseenCount(directory), 0),\n  )\n  const hasError = createMemo(() => dirs().some((directory) => notification.project.unseenHasError(directory)))\n  const hasPermissions = createMemo(() =>\n    dirs().some((directory) => {\n      const [store] = serverSync().child(directory, { bootstrap: false })\n      return hasProjectPermissions(store.permission, (item) => !permission.autoResponds(item, directory))\n    }),\n  )\n  const notify = createMemo(() => props.notify && (hasPermissions() || unseenCount() > 0))\n  const name = createMemo(() => props.project.name || getFilename(props.project.worktree))\n\n  return (\n    <div class={`relative size-8 shrink-0 rounded ${props.class ?? \"\"}`}>","node_kind":"component"},{"id":"sidebar_items_sessionrow","label":"SessionRow()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L89-L141","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L89"}],"snippet":"SessionRow = (props: {\n  session: Session\n  slug: string\n  mobile?: boolean\n  dense?: boolean\n  tint: Accessor<string | undefined>\n  isWorking: Accessor<boolean>\n  hasPermissions: Accessor<boolean>\n  hasError: Accessor<boolean>\n  unseenCount: Accessor<number>\n  clearHoverProjectSoon: () => void\n  sidebarOpened: Accessor<boolean>\n  warmPress: () => void\n  warmFocus: () => void\n}): JSX.Element => {\n  const title = () => sessionTitle(props.session.title)\n\n  return (\n    <A\n      href={`/${props.slug}/session/${props.session.id}`}\n      class={`flex items-center gap-2 min-w-0 w-full text-left focus:outline-none ${props.dense ? \"py-0.5\" : \"py-1\"}`}\n      onPointerDown={props.warmPress}\n      onFocus={props.warmFocus}\n      onClick={() => {\n        if (props.sidebarOpened()) return","node_kind":"component"},{"id":"sidebar_items_sessionrow_title","label":"title()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L104"}],"snippet":"title = () => sessionTitle(props.session.title)"},{"id":"sidebar_items_sessionitem","label":"SessionItem()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L143-L270","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L143"}],"snippet":"SessionItem = (props: SessionItemProps): JSX.Element => {\n  const params = useParams()\n  const layout = useLayout()\n  const language = useLanguage()\n  const notification = useNotification()\n  const permission = usePermission()\n  const serverSync = useServerSync()\n  const unseenCount = createMemo(() => notification.session.unseenCount(props.session.id))\n  const hasError = createMemo(() => notification.session.unseenHasError(props.session.id))\n  const [sessionStore] = serverSync().child(props.session.directory)\n  const hasPermissions = createMemo(() => {\n    return !!sessionPermissionRequest(sessionStore.session, sessionStore.permission, props.session.id, (item) => {\n      return !permission.autoResponds(item, props.session.directory)\n    })\n  })\n  const isWorking = createMemo(() => {\n    if (hasPermissions()) return false\n    return sessionStore.session_working(props.session.id)\n  })\n\n  const tint = createMemo(() => messageAgentColor(sessionStore.message[props.session.id], sessionStore.agent))\n  const tooltip = createMemo(() => props.showTooltip ?? (props.mobile || !props.sidebarExpanded()))\n  const currentChild = createMemo(() => {\n    if (!props.showChild) return\n    return childSessionOnPath(sessionStore.session, props.session.id, params.id)","node_kind":"component"},{"id":"sidebar_items_sessionitem_warm","label":"warm()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L170-L188","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L170"}],"snippet":"warm = (span: number, priority: \"high\" | \"low\") => {\n    const nav = props.navList?.()\n    const list = nav?.some((item) => item.id === props.session.id && item.directory === props.session.directory)\n      ? nav\n      : props.list\n\n    props.prefetchSession(props.session, priority)\n\n    const idx = list.findIndex((item) => item.id === props.session.id && item.directory === props.session.directory)\n    if (idx === -1) return\n\n    for (let step = 1; step <= span; step++) {\n      const next = list[idx + step]\n      if (next) props.prefetchSession(next, step === 1 ? \"high\" : priority)\n\n      const prev = list[idx - step]\n      if (prev) props.prefetchSession(prev, step === 1 ? \"high\" : priority)\n    }\n  }"},{"id":"sidebar_items_newsessionitem","label":"NewSessionItem()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L272-L314","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/sidebar-items.tsx","source_location":"L272"}],"snippet":"NewSessionItem = (props: {\n  slug: string\n  mobile?: boolean\n  dense?: boolean\n  sidebarExpanded: Accessor<boolean>\n  clearHoverProjectSoon: () => void\n}): JSX.Element => {\n  const layout = useLayout()\n  const language = useLanguage()\n  const label = language.t(\"command.session.new\")\n  const tooltip = () => props.mobile || !props.sidebarExpanded()\n  const item = (\n    <A\n      href={`/${props.slug}/session`}\n      end\n      class={`flex items-center gap-2 min-w-0 w-full text-left focus:outline-none ${props.dense ? \"py-0.5\" : \"py-1\"}`}\n      onClick={() => {\n        if (layout.sidebar.opened()) return\n        props.clearHoverProjectSoon()\n      }}\