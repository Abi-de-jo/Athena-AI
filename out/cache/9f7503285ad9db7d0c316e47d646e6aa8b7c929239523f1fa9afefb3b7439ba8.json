{"__madarTsExtractorVersion":67,"__madarFileStem":"httpapi-sdk.test","nodes":[{"id":"httpapi_sdk_test","label":"httpapi-sdk.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L1"}]},{"id":"httpapi_sdk_test_client","label":"client()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L61-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L61"}],"snippet":"function client(\n  serverPath: ServerPath,\n  directory?: string,\n  input?: {\n    password?: string\n    username?: string\n    headers?: Record<string, string>\n    workspaceID?: string\n    onRequest?: (request: Request) => void\n  },\n) {\n  return serverFetch(serverPath, input).pipe(\n    Effect.map((fetch) =>\n      createOpencodeClient({\n        baseUrl: \"http://localhost\",\n        directory,\n        experimental_workspaceID: input?.workspaceID,\n        headers: input?.headers,\n        fetch,\n      }),\n    ),\n  )\n}"},{"id":"httpapi_sdk_test_serverfetch","label":"serverFetch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L85-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L85"}],"snippet":"function serverFetch(\n  serverPath: ServerPath,\n  input?: { password?: string; username?: string; onRequest?: (request: Request) => void },\n) {\n  return HttpServer.HttpServer.use((server) =>\n    Effect.sync(() => {\n      void serverPath\n      Flag.OPENCODE_SERVER_PASSWORD = input?.password\n      Flag.OPENCODE_SERVER_USERNAME = input?.username\n      const baseUrl = HttpServer.formatAddress(server.address)\n      return Object.assign(\n        async (request: RequestInfo | URL, init?: RequestInit) => {\n          const source = request instanceof Request ? request : new Request(request, init)\n          input?.onRequest?.(source)\n          const url = new URL(source.url)\n          return globalThis.fetch(new Request(new URL(`${url.pathname}${url.search}`, baseUrl), source))\n        },\n        { preconnect: globalThis.fetch.preconnect },\n      ) satisfies typeof globalThis.fetch\n    }),\n  )\n}"},{"id":"httpapi_sdk_test_authorization","label":"authorization()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L108-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L108"}],"snippet":"function authorization(username: string, password: string) {\n  return `Basic ${Buffer.from(`${username}:${password}`).toString(\"base64\")}`\n}"},{"id":"httpapi_sdk_test_call","label":"call()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L112-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L112"}],"snippet":"function call<T>(request: () => Promise<T>) {\n  return Effect.promise(request)\n}"},{"id":"httpapi_sdk_test_capture","label":"capture()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L116-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L116"}],"snippet":"function capture(request: () => Promise<SdkResult>) {\n  return call(request).pipe(\n    Effect.map((result) => ({\n      status: result.response.status,\n      data: result.data,\n      error: result.error,\n    })),\n  )\n}"},{"id":"httpapi_sdk_test_capturethrown","label":"captureThrown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L126-L134","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L126"}],"snippet":"function captureThrown(request: () => Promise<unknown>) {\n  return call(async () => {\n    try {\n      await request()\n    } catch (error) {\n      return error\n    }\n  })\n}"},{"id":"httpapi_sdk_test_expectstatus","label":"expectStatus()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L136-L141","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L136"}],"snippet":"function expectStatus(request: () => Promise<{ response: Response }>, status: number) {\n  return call(request).pipe(\n    Effect.tap((result) => Effect.sync(() => expect(result.response.status).toBe(status))),\n    Effect.asVoid,\n  )\n}"},{"id":"httpapi_sdk_test_firstevent","label":"firstEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L143-L165","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L143"}],"snippet":"function firstEvent(open: (signal: AbortSignal) => Promise<{ stream: AsyncIterator<unknown> }>) {\n  return Effect.acquireRelease(\n    Effect.sync(() => new AbortController()),\n    (controller) => Effect.sync(() => controller.abort()),\n  ).pipe(\n    Effect.flatMap((controller) =>\n      Effect.acquireRelease(\n        call(() => open(controller.signal)),\n        (events) => call(async () => void (await events.stream.return?.(undefined))).pipe(Effect.ignore),\n      ).pipe(\n        Effect.flatMap((events) =>\n          call(() => events.stream.next()).pipe(\n            Effect.timeoutOrElse({\n              duration: \"1 second\",\n              orElse: () => Effect.fail(new Error(\"timed out waiting for SDK event\")),\n            }),\n          ),\n        ),\n        Effect.map((result) => result.value),\n      ),\n    ),\n  )\n}"},{"id":"httpapi_sdk_test_record","label":"record()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L167-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L167"}],"snippet":"function record(value: unknown) {\n  return value && typeof value === \"object\" && !Array.isArray(value) ? Object.fromEntries(Object.entries(value)) : {}\n}"},{"id":"httpapi_sdk_test_array","label":"array()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L171-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L171"}],"snippet":"function array(value: unknown) {\n  return Array.isArray(value) ? value : []\n}"},{"id":"httpapi_sdk_test_statuses","label":"statuses()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L175-L177","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L175"}],"snippet":"function statuses(input: Record<string, Captured>) {\n  return Object.fromEntries(Object.entries(input).map(([key, value]) => [key, value.status]))\n}"},{"id":"httpapi_sdk_test_firstparttext","label":"firstPartText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L179-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L179"}],"snippet":"function firstPartText(value: unknown) {\n  return record(array(record(value).parts)[0]).text\n}"},{"id":"httpapi_sdk_test_sessiontitles","label":"sessionTitles()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L183-L188","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L183"}],"snippet":"function sessionTitles(value: unknown) {\n  return array(value)\n    .map((item) => record(item).title)\n    .filter((title): title is string => typeof title === \"string\")\n    .sort()\n}"},{"id":"httpapi_sdk_test_resetstate","label":"resetState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L190-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L190"}],"snippet":"function resetState() {\n  return Effect.promise(async () => {\n    await disposeAllInstances()\n    await resetDatabase()\n  })\n}"},{"id":"httpapi_sdk_test_httpapi","label":"httpapi()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L197-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L197"}],"snippet":"function httpapi<A, E>(name: string, effect: Effect.Effect<A, E, TestScope>) {\n  it.live(name, effect)\n}"},{"id":"httpapi_sdk_test_httpapiinstance","label":"httpapiInstance()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L201-L220","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L201"}],"snippet":"function httpapiInstance<A, E>(\n  name: string,\n  options: {\n    serverPath: ServerPath\n    git?: boolean\n    config?: Partial<ConfigV1.Info>\n    setup?: (dir: string) => Effect.Effect<void, E, TestServices>\n  },\n  run: (input: ProjectFixture) => Effect.Effect<A, E, TestScope>,\n) {\n  it.instance(\n    name,\n    Effect.gen(function* () {\n      const instance = yield* TestInstance\n      yield* options.setup?.(instance.directory) ?? Effect.void\n      return yield* run({ sdk: yield* client(options.serverPath, instance.directory), directory: instance.directory })\n    }),\n    { git: options.git ?? true, config: { formatter: false, lsp: false, ...options.config } },\n  )\n}"},{"id":"httpapi_sdk_test_serverpathparity","label":"serverPathParity()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L222-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L222"}],"snippet":"function serverPathParity<A, E>(name: string, scenario: (serverPath: ServerPath) => Effect.Effect<A, E, TestScope>) {\n  it.live(name, scenario(\"raw\"))\n}"},{"id":"httpapi_sdk_test_withproject","label":"withProject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L226-L243","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L226"}],"snippet":"function withProject<A, E, E2 = never>(\n  serverPath: ServerPath,\n  options: {\n    git?: boolean\n    config?: Partial<ConfigV1.Info>\n    setup?: (dir: string) => Effect.Effect<void, E2, TestServices>\n  },\n  run: (input: ProjectFixture) => Effect.Effect<A, E, TestScope>,\n) {\n  return Effect.gen(function* () {\n    const directory = yield* tmpdirScoped({\n      git: options.git ?? false,\n      config: { formatter: false, lsp: false, ...options.config },\n    })\n    yield* options.setup?.(directory) ?? Effect.void\n    return yield* run({ sdk: yield* client(serverPath, directory), directory })\n  })\n}"},{"id":"httpapi_sdk_test_withstandardproject","label":"withStandardProject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L245-L250","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L245"}],"snippet":"function withStandardProject<A, E>(\n  serverPath: ServerPath,\n  run: (input: ProjectFixture) => Effect.Effect<A, E, TestScope>,\n) {\n  return withProject(serverPath, { setup: writeStandardFiles }, run)\n}"},{"id":"httpapi_sdk_test_withfakellm","label":"withFakeLlm()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L252-L257","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L252"}],"snippet":"function withFakeLlm<A, E>(serverPath: ServerPath, run: (input: LlmProjectFixture) => Effect.Effect<A, E, TestScope>) {\n  return Effect.gen(function* () {\n    const llm = yield* TestLLMServer\n    return yield* withProject(serverPath, { config: testProviderConfig(llm.url) }, (input) => run({ ...input, llm }))\n  }).pipe(Effect.provide(TestLLMServer.layer))\n}"},{"id":"httpapi_sdk_test_withfakellmproject","label":"withFakeLlmProject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L259-L275","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L259"}],"snippet":"function withFakeLlmProject<A, E>(\n  serverPath: ServerPath,\n  options: { setup?: (dir: string) => Effect.Effect<void, E, TestServices> },\n  run: (input: LlmProjectFixture) => Effect.Effect<A, E, TestScope>,\n) {\n  return Effect.gen(function* () {\n    const llm = yield* TestLLMServer\n    return yield* withProject(\n      serverPath,\n      {\n        config: testProviderConfig(llm.url),\n        setup: options.setup,\n      },\n      (input) => run({ ...input, llm }),\n    )\n  }).pipe(Effect.provide(TestLLMServer.layer))\n}"},{"id":"httpapi_sdk_test_writestandardfiles","label":"writeStandardFiles()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L277-L284","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L277"}],"snippet":"function writeStandardFiles(dir: string) {\n  return FSUtil.Service.use((fs) =>\n    Effect.all([\n      fs.writeWithDirs(path.join(dir, \"hello.txt\"), \"hello\"),\n      fs.writeWithDirs(path.join(dir, \"needle.ts\"), \"export const needle = 'sdk-parity'\\n\"),\n    ]).pipe(Effect.asVoid),\n  )\n}"},{"id":"httpapi_sdk_test_writeprojectskill","label":"writeProjectSkill()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L286-L299","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L286"}],"snippet":"function writeProjectSkill(dir: string) {\n  return FSUtil.Service.use((fs) =>\n    fs.writeWithDirs(\n      path.join(dir, \".opencode\", \"skills\", \"project-rest-skill\", \"SKILL.md\"),\n      `---\nname: project-rest-skill\ndescription: A project skill visible to REST API prompts.\n---\n\n# Project REST Skill\n`,\n    ),\n  )\n}"},{"id":"httpapi_sdk_test_seedmessage","label":"seedMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L301-L329","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-sdk.test.ts","source_location":"L301"}],"snippet":"function seedMessage(directory: string, sessionID: string) {\n  const id = SessionID.make(sessionID)\n  return InstanceStore.Service.use((store) =>\n    store.provide(\n      { directory },\n      SessionNs.Service.use((svc) =>\n        Effect.gen(function* () {\n          const message = yield* svc.updateMessage({\n            id: MessageID.ascending(),\n            sessionID: id,\n            role: \"user\",\n            time: { created: Date.now() },\n            agent: \"test\",\n            model: { providerID: ProviderV2.ID.make(\"test\"), modelID: ModelV2.ID.make(\"test\") },\n            tools: {},\n          } satisfies SessionV1.User)\n          const part = yield* svc.updatePart({\n            id: PartID.ascending(),\n            sessionID: id,\n            messageID: message.id,\n            type: \"text\",\n            text: \"seeded message\",\n          })\n          return { message, part }\n        }),"}],"edges":[{"source":"httpapi_sdk_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru