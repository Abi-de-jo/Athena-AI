{"__madarTsExtractorVersion":67,"__madarFileStem":"openai-ws.test","nodes":[{"id":"openai_ws_test","label":"openai-ws.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L1"}]},{"id":"openai_ws_test_streamrequest","label":"streamRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L769-L780","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L769"}],"snippet":"function streamRequest(headers?: Record<string, string>, signal?: AbortSignal): RequestInit {\n  return {\n    method: \"POST\",\n    headers: {\n      \"session-id\": \"session-1\",\n      authorization: \"Bearer test\",\n      ...headers,\n    },\n    body: JSON.stringify({ stream: true, input: \"hi\" }),\n    signal,\n  }\n}"},{"id":"openai_ws_test_readtexterror","label":"readTextError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L782-L793","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L782"}],"snippet":"async function readTextError(promise: Promise<string>) {\n  // Bun 1.3.14 hangs on expect(response.text()).rejects for streams errored from ws callbacks.\n  return promise.then(\n    () => {\n      throw new Error(\"Expected response text to reject\")\n    },\n    (error) => {\n      expect(error).toBeInstanceOf(Error)\n      return error as Error\n    },\n  )\n}"},{"id":"openai_ws_test_createwebsocketserver","label":"createWebSocketServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L795-L800","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L795"}],"snippet":"async function createWebSocketServer(onConnection: (socket: WebSocket, request: IncomingMessage) => void) {\n  const http = await createHttpServer()\n  const server = new WebSocketServer({ server: http.server })\n  server.on(\"connection\", onConnection)\n  return websocketServerHandle(server, http)\n}"},{"id":"openai_ws_test_createhangingtcpserver","label":"createHangingTcpServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L802-L821","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L802"}],"snippet":"async function createHangingTcpServer() {\n  const sockets = new Set<Socket>()\n  let connections = 0\n  const server = net.createServer((socket) => {\n    connections += 1\n    sockets.add(socket)\n    socket.on(\"close\", () => sockets.delete(socket))\n  })\n  await new Promise<void>((resolve) => server.listen(0, \"127.0.0.1\", resolve))\n  const address = server.address() as AddressInfo\n  return {\n    url: `http://127.0.0.1:${address.port}/v1/responses`,\n    wsUrl: `ws://127.0.0.1:${address.port}/v1/responses`,\n    connections: () => connections,\n    async [Symbol.asyncDispose]() {\n      for (const socket of sockets) socket.destroy()\n      server.close()\n    },\n  }\n}"},{"id":"openai_ws_test_createrejectingwebsocketserver","label":"createRejectingWebSocketServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L823-L833","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L823"}],"snippet":"async function createRejectingWebSocketServer(onAttempt: () => void) {\n  const http = await createHttpServer()\n  const server = new WebSocketServer({\n    server: http.server,\n    verifyClient(_info, callback) {\n      onAttempt()\n      callback(false, 401, \"denied\")\n    },\n  })\n  return websocketServerHandle(server, http)\n}"},{"id":"openai_ws_test_createhttpserver","label":"createHttpServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L835-L852","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L835"}],"snippet":"async function createHttpServer() {\n  const httpRequests: IncomingMessage[] = []\n  const server = createServer((request, response) => {\n    httpRequests.push(request)\n    response.writeHead(200, { \"content-type\": \"text/plain\" })\n    response.end(\"http\")\n  })\n  await new Promise<void>((resolve) => server.listen(0, \"127.0.0.1\", resolve))\n  const address = server.address() as AddressInfo\n  return {\n    server,\n    httpRequests,\n    url: `http://127.0.0.1:${address.port}/v1/responses`,\n    async [Symbol.asyncDispose]() {\n      await closeHttpServer(server)\n    },\n  }\n}"},{"id":"openai_ws_test_websocketserverhandle","label":"websocketServerHandle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L854-L865","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L854"}],"snippet":"function websocketServerHandle(server: WebSocketServer, http: Awaited<ReturnType<typeof createHttpServer>>) {\n  return {\n    url: http.url,\n    wsUrl: http.url.replace(/^http/, \"ws\"),\n    httpRequests: http.httpRequests,\n    async [Symbol.asyncDispose]() {\n      for (const socket of server.clients) socket.terminate()\n      server.close()\n      http.server.close()\n    },\n  }\n}"},{"id":"openai_ws_test_closehttpserver","label":"closeHttpServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L867-L869","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L867"}],"snippet":"function closeHttpServer(server: HttpServer) {\n  return new Promise<void>((resolve, reject) => server.close((error) => (error ? reject(error) : resolve())))\n}"},{"id":"openai_ws_test_waitfor","label":"waitFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L871-L877","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L871"}],"snippet":"async function waitFor(predicate: () => boolean, message: string) {\n  const started = Date.now()\n  while (!predicate()) {\n    if (Date.now() - started > 1_000) throw new Error(message)\n    await new Promise((resolve) => setTimeout(resolve, 1))\n  }\n}"}],"edges":[{"source":"openai_ws_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L1"}],"weight":1},{"source":"openai_ws_test","target":"events","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L2"}],"weight":1},{"source":"openai_ws_test","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L3"}],"weight":1},{"source":"openai_ws_test","target":"net","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/openai-ws.test.ts","source_location":"L4"}],"weigh