{"__madarTsExtractorVersion":67,"__madarFileStem":"mcp-websearch","nodes":[{"id":"mcp_websearch","label":"mcp-websearch.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L1"}]},{"id":"mcp_websearch_parsepayload","label":"parsePayload()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L22-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L22"}],"snippet":"parsePayload = (payload: string) =>\n  Effect.gen(function* () {\n    const trimmed = payload.trim()\n    if (!trimmed.startsWith(\"{\")) return undefined\n    const data = yield* decode(trimmed)\n    return data.result.content.find((item) => item.text)?.text\n  })"},{"id":"mcp_websearch_mcprequest","label":"McpRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L58-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L58"}],"snippet":"McpRequest = <F extends Schema.Struct.Fields>(args: Schema.Struct<F>) =>\n  Schema.Struct({\n    jsonrpc: Schema.Literal(\"2.0\"),\n    id: Schema.Literal(1),\n    method: Schema.Literal(\"tools/call\"),\n    params: Schema.Struct({\n      name: Schema.String,\n      arguments: args,\n    }),\n  })"},{"id":"mcp_websearch_call","label":"call()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L69-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L69"}],"snippet":"call = <F extends Schema.Struct.Fields>(\n  http: HttpClient.HttpClient,\n  url: string,\n  tool: string,\n  args: Schema.Struct<F>,\n  value: Schema.Struct.Type<F>,\n  timeout: Duration.Input,\n  headers?: Record<string, string>,\n) =>\n  Effect.gen(function* () {\n    const request = yield* HttpClientRequest.post(url).pipe(\n      HttpClientRequest.accept(\"application/json, text/event-stream\"),\n      HttpClientRequest.setHeaders(headers ?? {}),\n      HttpClientRequest.schemaBodyJson(McpRequest(args))({\n        jsonrpc: \"2.0\" as const,\n        id: 1 as const,\n        method: \"tools/call\" as const,\n        params: { name: tool, arguments: value },\n      }),\n    )\n    const response = yield* HttpClient.filterStatusOk(http)\n      .execute(request)\n      .pipe(\n        Effect.timeoutOrElse({ duration: timeout, orElse: () => Effect.die(new Error(`${tool} request timed out`)) }),\n      )"}],"edges":[{"source":"mcp_websearch","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L1"}],"weight":1},{"source":"mcp_websearch","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/mcp-websearch.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"built