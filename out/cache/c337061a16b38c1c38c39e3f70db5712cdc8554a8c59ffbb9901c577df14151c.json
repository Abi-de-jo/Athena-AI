{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_components_prompt-input_files","nodes":[{"id":"packages_app_src_components_prompt_input_files","label":"files.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L1"}]},{"id":"packages_app_src_components_prompt_input_files_pickattachmentfiles","label":"pickAttachmentFiles()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L14-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L14"}],"snippet":"export function pickAttachmentFiles(input: {\n  picker?: AttachmentPicker\n  directory: () => string\n  fallback: () => void\n  onFile: (file: File) => Promise<unknown>\n  onError: (error: unknown) => void\n}) {\n  if (!input.picker) {\n    input.fallback()\n    return\n  }\n  void input\n    .picker(\n      {\n        defaultPath: input.directory(),\n        multiple: true,\n        accept: ACCEPTED_FILE_TYPES,\n      },\n      input.onFile,\n    )\n    .catch(input.onError)\n}"},{"id":"packages_app_src_components_prompt_input_files_kind","label":"kind()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L57-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L57"}],"snippet":"function kind(type: string) {\n  return type.split(\";\", 1)[0]?.trim().toLowerCase() ?? \"\"\n}"},{"id":"packages_app_src_components_prompt_input_files_ext","label":"ext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L61-L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L61"}],"snippet":"function ext(name: string) {\n  const idx = name.lastIndexOf(\".\")\n  if (idx === -1) return \"\"\n  return name.slice(idx + 1).toLowerCase()\n}"},{"id":"packages_app_src_components_prompt_input_files_textmime","label":"textMime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L67-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L67"}],"snippet":"function textMime(type: string) {\n  if (!type) return false\n  if (type.startsWith(\"text/\")) return true\n  if (TEXT_MIMES.has(type)) return true\n  if (type.endsWith(\"+json\")) return true\n  return type.endsWith(\"+xml\")\n}"},{"id":"packages_app_src_components_prompt_input_files_textbytes","label":"textBytes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L75-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L75"}],"snippet":"function textBytes(bytes: Uint8Array) {\n  if (bytes.length === 0) return true\n  let count = 0\n  for (const byte of bytes) {\n    if (byte === 0) return false\n    if (byte < 9 || (byte > 13 && byte < 32)) count += 1\n  }\n  return count / bytes.length <= 0.3\n}"},{"id":"packages_app_src_components_prompt_input_files_attachmentmime","label":"attachmentMime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L85-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L85"}],"snippet":"export async function attachmentMime(file: File) {\n  const type = kind(file.type)\n  if (IMAGE_MIMES.has(type)) return type\n  if (type === \"application/pdf\") return type\n\n  const suffix = ext(file.name)\n  const fallback = IMAGE_EXTS.get(suffix) ?? (suffix === \"pdf\" ? \"application/pdf\" : undefined)\n  if ((!type || type === \"application/octet-stream\") && fallback) return fallback\n\n  if (textMime(type)) return \"text/plain\"\n  const bytes = new Uint8Array(await file.slice(0, SAMPLE).arrayBuffer())\n  if (!textBytes(bytes)) return\n  return \"text/plain\"\n}"}],"edges":[{"source":"packages_app_src_components_prompt_input_files","target":"file_picker","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/prompt-input/files.ts","source_location":"L1"}],"weight":1},{"source":"packages_app_src_components_prompt_input_files","target":"packages_app_src_components_prompt_input_files_pickattachmentfiles","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/