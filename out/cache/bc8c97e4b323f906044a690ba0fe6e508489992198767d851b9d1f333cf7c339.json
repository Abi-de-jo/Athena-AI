session-prefetch.ts","source_location":"L40-L45","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L40"}],"snippet":"export function clearSessionPrefetchInflight(scope: ServerScope) {\n  const prefix = ScopedKey.prefix(scope)\n  for (const id of inflight.keys()) {\n    if (id.startsWith(prefix)) inflight.delete(id)\n  }\n}"},{"id":"session_prefetch_issessionprefetchcurrent","label":"isSessionPrefetchCurrent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L47-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L47"}],"snippet":"export function isSessionPrefetchCurrent(scope: ServerScope, directory: string, sessionID: string, value: number) {\n  return version(key(scope, directory, sessionID)) === value\n}"},{"id":"session_prefetch_runsessionprefetch","label":"runSessionPrefetch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L51-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L51"}],"snippet":"export function runSessionPrefetch(input: {\n  directory: string\n  scope: ServerScope\n  sessionID: string\n  task: (value: number) => Promise<Meta | undefined>\n}) {\n  const id = key(input.scope, input.directory, input.sessionID)\n  const pending = inflight.get(id)\n  if (pending) return pending\n\n  const value = version(id)\n\n  const promise = input.task(value).finally(() => {\n    if (inflight.get(id) === promise) inflight.delete(id)\n  })\n\n  inflight.set(id, promise)\n  return promise\n}"},{"id":"session_prefetch_setsessionprefetch","label":"setSessionPrefetch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L71-L86","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L71"}],"snippet":"export function setSessionPrefetch(input: {\n  directory: string\n  scope: ServerScope\n  sessionID: string\n  limit: number\n  cursor?: string\n  complete: boolean\n  at?: number\n}) {\n  cache.set(key(input.scope, input.directory, input.sessionID), {\n    limit: input.limit,\n    cursor: input.cursor,\n    complete: input.complete,\n    at: input.at ?? Date.now(),\n  })\n}"},{"id":"session_prefetch_clearsessionprefetch","label":"clearSessionPrefetch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L88-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L88"}],"snippet":"export function clearSessionPrefetch(scope: ServerScope, directory: string, sessionIDs: Iterable<string>) {\n  for (const sessionID of sessionIDs) {\n    if (!sessionID) continue\n    const id = key(scope, directory, sessionID)\n    rev.set(id, version(id) + 1)\n    cache.delete(id)\n    inflight.delete(id)\n  }\n}"},{"id":"session_prefetch_clearsessionprefetchdirectory","label":"clearSessionPrefetchDirectory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L98-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L98"}],"snippet":"export function clearSessionPrefetchDirectory(scope: ServerScope, directory: string) {\n  const prefix = ScopedKey.prefix(scope, directory)\n  const keys = new Set([...cache.keys(), ...inflight.keys()])\n  for (const id of keys) {\n    if (!id.startsWith(prefix)) continue\n    rev.set(id, version(id) + 1)\n    cache.delete(id)\n    inflight.delete(id)\n  }\n}"}],"edges":[{"source":"session_prefetch","target":"server_scope","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L1"}],"weight":1},{"source":"session_prefetch","target":"session_prefetch_key","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L3"}],"weight":1},{"source":"session_prefetch","target":"session_prefetch_shouldskipsessionprefetch","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/session-prefetch.ts","source_location":"L14","layer":"base","provena