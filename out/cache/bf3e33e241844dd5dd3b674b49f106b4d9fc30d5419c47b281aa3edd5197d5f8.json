\", (next: number) => setValue(next))\n\n  createEffect(() => {\n    source.set(target())\n  })\n\n  createEffect(() => {\n    if (!options) return\n    const next = read()\n    if (eq(config, next)) return\n    config = next\n    stop()\n    stop = attachSpring(spring, source, next)\n    setValue(spring.get())\n  })\n\n  onCleanup(() => {\n    off()"},{"id":"motion_spring_usespring_read","label":"read()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/motion-spring.tsx","source_location":"L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/motion-spring.tsx","source_location":"L15"}],"snippet":"read = () => (typeof options === \"function\" ? options() : options)"}],"edges":[{"source":"motion_spring","target":"motion","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/motion-spring.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/motion-spring.tsx","source_location":"L1"}],"weight":1},{"source":"motion_spring","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/motion-spring.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/motion-spring.tsx","source_location":"L3"}],"weight":1},{"source":"motion_spring","target":"motion_spring_eq","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/motion-spring.tsx","source_lo