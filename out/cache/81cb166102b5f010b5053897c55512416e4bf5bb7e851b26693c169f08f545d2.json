{"__madarTsExtractorVersion":67,"__madarFileStem":"prompt.editor","nodes":[{"id":"prompt_editor","label":"prompt.editor.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L1"}]},{"id":"prompt_editor_resolveeditorslashvalue","label":"resolveEditorSlashValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L5-L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L5"}],"snippet":"export function resolveEditorSlashValue(text: string) {\n  const head = slashHead(text)\n  if (!head || head.name.toLowerCase() !== \"editor\") {\n    return text\n  }\n\n  return head.arguments\n}"},{"id":"prompt_editor_realigneditorpromptparts","label":"realignEditorPromptParts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L14-L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L14"}],"snippet":"export function realignEditorPromptParts(content: string, parts: RunPromptPart[]): RunPromptPart[] {\n  const matches = new Map<number, Mention | undefined>()\n  const used: Array<{ start: number; end: number }> = []\n\n  for (const [index, part] of parts.entries()) {\n    if (part.type !== \"file\" && part.type !== \"agent\") {\n      continue\n    }\n\n    const text = promptPartText(part)\n    if (!text) {\n      continue\n    }\n\n    const start = findPromptPartIndex(content, text, used, promptPartStart(part))\n    if (start === -1) {\n      matches.set(index, undefined)\n      continue\n    }\n\n    const end = start + text.length\n    used.push({ start, end })\n    matches.set(index, updatePromptPart(part, start, end, text))\n  }"},{"id":"prompt_editor_slashhead","label":"slashHead()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L60-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L60"}],"snippet":"function slashHead(text: string) {\n  if (!text.startsWith(\"/\")) {\n    return\n  }\n\n  for (let i = 1; i < text.length; i++) {\n    switch (text[i]) {\n      case \" \":\n      case \"\\t\":\n      case \"\\n\":\n        return {\n          name: text.slice(1, i),\n          arguments: text.slice(i + 1),\n        }\n    }\n  }\n\n  return {\n    name: text.slice(1),\n    arguments: \"\",\n  }\n}"},{"id":"prompt_editor_promptparttext","label":"promptPartText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L83-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L83"}],"snippet":"function promptPartText(part: Mention) {\n  if (part.type === \"agent\") {\n    return part.source?.value\n  }\n\n  return part.source?.text.value\n}"},{"id":"prompt_editor_promptpartstart","label":"promptPartStart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L91-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L91"}],"snippet":"function promptPartStart(part: Mention) {\n  if (part.type === \"agent\") {\n    return part.source?.start ?? Number.POSITIVE_INFINITY\n  }\n\n  return part.source?.text.start ?? Number.POSITIVE_INFINITY\n}"},{"id":"prompt_editor_findpromptpartindex","label":"findPromptPartIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L99-L127","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L99"}],"snippet":"function findPromptPartIndex(content: string, text: string, used: Array<{ start: number; end: number }>, hint: number) {\n  let searchFrom = 0\n  let best = -1\n  let distance = Number.POSITIVE_INFINITY\n  const hinted = Number.isFinite(hint)\n\n  while (true) {\n    const start = content.indexOf(text, searchFrom)\n    if (start === -1) {\n      return best\n    }\n\n    const end = start + text.length\n    searchFrom = start + 1\n    if (used.some((range) => start < range.end && end > range.start)) {\n      continue\n    }\n\n    if (!hinted) {\n      return start\n    }\n\n    const nextDistance = Math.abs(start - hint)\n    if (nextDistance < distance) {\n      best = start"},{"id":"prompt_editor_updatepromptpart","label":"updatePromptPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L129-L157","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L129"}],"snippet":"function updatePromptPart(part: Mention, start: number, end: number, text: string): Mention {\n  if (part.type === \"agent\") {\n    return {\n      ...part,\n      source: {\n        start,\n        end,\n        value: text,\n      },\n    }\n  }\n\n  if (!part.source?.text) {\n    return part\n  }\n\n  return {\n    ...part,\n    source: {\n      ...part.source,\n      text: {\n        ...part.source.text,\n        start,\n        end,\n        value: text,"}],"edges":[{"source":"prompt_editor","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L1"}],"weight":1},{"source":"prompt_editor","target":"prompt_editor_resolveeditorslashvalue","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L5","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L5"}],"weight":1},{"source":"prompt_editor","target":"prompt_editor_realigneditorpromptparts","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/prompt.editor.ts","source_location":"L14","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/