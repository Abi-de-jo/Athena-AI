e_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L35"}]},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_effectsqlitesession_constructor","label":".constructor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L42-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L42"}],"snippet":"constructor(\n    private client: SqlClient,\n    dialect: SQLiteAsyncDialect,\n    protected relations: TRelations,\n    private options: EffectSQLiteSessionOptions,\n  ) {\n    super(dialect)\n  }"},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_effectsqlitesession_preparequery","label":".prepareQuery()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L51-L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L51"}],"snippet":"override prepareQuery<T extends PreparedQueryConfig = PreparedQueryConfig>(\n    query: Query,\n    fields: SelectedFieldsOrdered | undefined,\n    executeMethod: SQLiteExecuteMethod,\n    customResultMapper?: (rows: unknown[][], mapColumnValue?: (value: unknown) => unknown) => unknown,\n    queryMetadata?: {\n      type: \"select\" | \"update\" | \"delete\" | \"insert\"\n      tables: string[]\n    },\n    cacheConfig?: WithCacheConfig,\n  ): SQLiteEffectPreparedQuery<T, EffectSQLiteQueryEffectHKT> {\n    return new SQLiteEffectPreparedQuery<T, EffectSQLiteQueryEffectHKT>(\n      (params, method) => this.execute(query, params, method),\n      query,\n      this.options.logger,\n      this.options.cache,\n      queryMetadata,\n      cacheConfig,\n      fields,\n      executeMethod,\n      this.options.useJitMappers,\n      customResultMapper,\n      undefined,\n      undefined,\n      this.isInTransaction(),"},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_effectsqlitesession_preparerelationalquery","label":".prepareRelationalQuery()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L79-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L79"}],"snippet":"override prepareRelationalQuery<T extends PreparedQueryConfig = PreparedQueryConfig>(\n    query: Query,\n    fields: SelectedFieldsOrdered | undefined,\n    executeMethod: SQLiteExecuteMethod,\n    customResultMapper: (rows: Record<string, unknown>[], mapColumnValue?: (value: unknown) => unknown) => unknown,\n    config: RelationalQueryMapperConfig,\n  ): SQLiteEffectPreparedQuery<T, EffectSQLiteQueryEffectHKT, true> {\n    return new SQLiteEffectPreparedQuery<T, EffectSQLiteQueryEffectHKT, true>(\n      (params, method) => this.execute(query, params, method),\n      query,\n      this.options.logger,\n      this.options.cache,\n      undefined,\n      undefined,\n      fields,\n      executeMethod,\n      this.options.useJitMappers,\n      customResultMapper,\n      true,\n      config,\n      this.isInTransaction(),\n    )\n  }"},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_effectsqlitesession_execute","label":".execute()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L103-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L103"}],"snippet":"private execute(query: Query, params: unknown[], method: SQLiteExecuteMethod | \"values\") {\n    const statement = this.client.unsafe(query.sql, params)\n    if (method === \"values\") return statement.values\n    if (method === \"get\") return statement.withoutTransform.pipe(Effect.map((rows) => rows[0]))\n    return statement.withoutTransform\n  }"},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_effectsqlitesession_isintransaction","label":".isInTransaction()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L110-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L110"}],"snippet":"private isInTransaction() {\n    return Effect.serviceOption(this.client.transactionService).pipe(Effect.map((option) => option._tag === \"Some\"))\n  }"},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_effectsqlitesession_executetransactionstatement","label":".executeTransactionStatement()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L114-L116","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L114"}],"snippet":"private executeTransactionStatement(connection: Effect.Success<SqlClient[\"reserve\"]>, query: string) {\n    return connection.executeUnprepared(query, [], undefined).pipe(Effect.asVoid)\n  }"},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_effectsqlitesession_withtransaction","label":".withTransaction()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L118-L187","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L118"}],"snippet":"private withTransaction<A, E, R>(effect: Effect.Effect<A, E, R>, config: SQLiteTransactionConfig | undefined) {\n    return Effect.uninterruptibleMask((restore) =>\n      Effect.withFiber<A, E | SqlError, R>((fiber) => {\n        const services = fiber.context\n        const connectionOption = Context.getOption(services, this.client.transactionService)\n        const connection: Effect.Effect<\n          readonly [Scope.Closeable | undefined, Effect.Success<SqlClient[\"reserve\"]>],\n          SqlError\n        > =\n          connectionOption._tag === \"Some\"\n            ? Effect.succeed([undefined, connectionOption.value[0]] as const)\n            : Scope.make().pipe(\n                Effect.flatMap((scope) =>\n                  Scope.provide(this.client.reserve, scope).pipe(\n                    Effect.map((connection) => [scope, connection] as const),\n                    Effect.catch((error) =>\n                      Scope.close(scope, Exit.fail(error)).pipe(Effect.andThen(Effect.fail(error))),\n                    ),\n                  ),\n                ),\n              )\n        const id = connectionOption._tag === \"Some\" ? connectionOption.value[1] + 1 : 0\n\n        return connection.pipe(\n          Effect.flatMap(([scope, connection]) => {"},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_effectsqlitesession_transaction","label":".transaction()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L189-L203","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L189"}],"snippet":"override transaction<A, E, R>(\n    transaction: (tx: EffectSQLiteTransaction<TRelations>) => Effect.Effect<A, E, R>,\n    config?: SQLiteTransactionConfig,\n  ): Effect.Effect<A, E | SqlError, R> {\n    const { dialect, relations } = this\n\n    return this.withTransaction(\n      Effect.gen({ self: this }, function* () {\n        const tx = new EffectSQLiteTransaction<TRelations>(dialect, this, relations)\n\n        return yield* transaction(tx)\n      }),\n      config,\n    )\n  }"},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_effectsqlitetransaction","label":"EffectSQLiteTransaction","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L206-L218","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L206"}],"snippet":"export class EffectSQLiteTransaction<TRelations extends AnyRelations> extends SQLiteEffectTransaction<\n  EffectSQLiteQueryEffectHKT,\n  EffectSQLiteRunResult,\n  TRelations\n> {\n  static override readonly [entityKind]: string = \"EffectSQLiteTransaction\"\n\n  override transaction: <A, E, R>(\n    transaction: (\n      tx: SQLiteEffectTransaction<EffectSQLiteQueryEffectHKT, EffectSQLiteRunResult, TRelations>,\n    ) => Effect.Effect<A, E, R>,\n  ) => Effect.Effect<A, SqlError | E, R> = (tx) => this.session.transaction(tx)\n}"},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_sqliteeffecttransaction","label":"SQLiteEffectTransaction","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L206","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L206"}]},{"id":"packages_effect_drizzle_sqlite_src_effect_sqlite_session_effectsqlitetransaction_transaction","label":".transaction()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L213-L217","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L213"}],"snippet":"override transaction: <A, E, R>(\n    transaction: (\n      tx: SQLiteEffectTransaction<EffectSQLiteQueryEffectHKT, EffectSQLiteRunResult, TRelations>,\n    ) => Effect.Effect<A, E, R>,\n  ) => Effect.Effect<A, SqlError | E, R> = (tx) => this.session.transaction(tx)"}],"edges":[{"source":"packages_effect_drizzle_sqlite_src_effect_sqlite_session","target":"context","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/effect-drizzle-sqlite/src/effect-sqlite/session.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript"