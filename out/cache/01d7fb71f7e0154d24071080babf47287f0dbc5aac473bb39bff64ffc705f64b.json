cursive: true })\n  await Bun.write(\n    path.join(p, \"package.json\"),\n    JSON.stringify(\n      {\n        name: \"acme\",\n        version: \"1.0.0\",\n        ...(server ? { main: \"./server.js\" } : {}),\n        ...(Object.keys(exports).length ? { exports } : {}),\n      },\n      null,\n      2,\n    ),\n  )\n  return p\n}"},{"id":"install_concurrency_test_read","label":"read()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/install-concurrency.test.ts","source_location":"L50-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/install-concurrency.test.ts","source_location":"L50"}],"snippet":"async function read(file: string) {\n  return Filesystem.readJson<{ plugin?: unknown[] }>(file)\n}"},{"id":"install_concurrency_test_mods","label":"mods()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/install-concurrency.test.ts","source_location":"L54-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/install-concurrency.test.ts","source_location":"L54"}],"snippet":"function mods(prefix: string, n: number) {\n  return Array.from({ length: n }, (_, i) => `${prefix}-${i}@1.0.0`)\n}"},{"id":"install_concurrency_test_expectplugins","label":"expectPlugins()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/install-concurrency.test.ts","source_location":"L58-L63","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/plugin/install-concurrency.test.ts","source_location":"L58"}],"snippet":"function expectPlugins(list