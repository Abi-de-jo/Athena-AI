{"__madarTsExtractorVersion":67,"__madarFileStem":"backend","nodes":[{"id":"backend","label":"backend.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L1"}]},{"id":"backend_call","label":"call()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L14-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L14"}],"snippet":"export function call(scenario: ActiveScenario, ctx: SeededContext<unknown>, options: CallOptions = {}) {\n  return Effect.promise(async () =>\n    capture(await app(await runtime(), options).request(toRequest(scenario, ctx)), scenario.capture),\n  )\n}"},{"id":"backend_callauthprobe","label":"callAuthProbe()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L20-L41","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L20"}],"snippet":"export function callAuthProbe(scenario: ActiveScenario, credentials: \"missing\" | \"valid\" = \"missing\") {\n  return Effect.promise(async () => {\n    const controller = new AbortController()\n    return Promise.race([\n      Promise.resolve(\n        app(await runtime(), { auth: { password: \"secret\" } }).request(\n          toAuthProbeRequest(scenario, credentials, controller.signal),\n        ),\n      ).then((response) => capture(response, scenario.capture)),\n      Bun.sleep(1_000).then(() => {\n        controller.abort(\"auth probe timed out\")\n        return {\n          status: 0,\n          contentType: \"\",\n          text: \"auth probe timed out\",\n          body: undefined,\n          timedOut: true,\n        }\n      }),\n    ])\n  })\n}"},{"id":"backend_disposeapps","label":"disposeApps()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L47-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L47"}],"snippet":"export async function disposeApps() {\n  const apps = Object.values(appCache)\n  for (const key of Object.keys(appCache)) delete appCache[key]\n  await Promise.all(apps.flatMap((app) => (app === undefined ? [] : [app.dispose()])))\n}"},{"id":"backend_app","label":"app()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L53-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L53"}],"snippet":"function app(modules: Runtime, options: CallOptions) {\n  const username = options.auth?.username\n  const password = options.auth?.password\n  const cacheKey = `${username ?? \"\"}:${password ?? \"\"}`\n  if (appCache[cacheKey]) return appCache[cacheKey]\n\n  const web = HttpRouter.toWebHandler(\n    modules.HttpApiApp.routes.pipe(\n      Layer.provide(\n        ConfigProvider.layer(\n          ConfigProvider.fromUnknown({ RIMURU_SERVER_PASSWORD: password, RIMURU_SERVER_USERNAME: username }),\n        ),\n      ),\n    ),\n    { disableLogger: true, memoMap: modules.memoMap },\n  )\n  return (appCache[cacheKey] = {\n    dispose: web.dispose,\n    request(input: string | URL | Request, init?: RequestInit) {\n      return web.handler(\n        input instanceof Request ? input : new Request(new URL(input, \"http://localhost\"), init),\n        modules.HttpApiApp.context,\n      )\n    },\n  })"},{"id":"backend_torequest","label":"toRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L80-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L80"}],"snippet":"function toRequest(scenario: ActiveScenario, ctx: SeededContext<unknown>) {\n  const spec = scenario.request(ctx, ctx.state)\n  return new Request(new URL(spec.path, \"http://localhost\"), {\n    method: scenario.method,\n    headers: spec.body === undefined ? spec.headers : { \"content-type\": \"application/json\", ...spec.headers },\n    body: spec.body === undefined ? undefined : JSON.stringify(spec.body),\n  })\n}"},{"id":"backend_toauthproberequest","label":"toAuthProbeRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L89-L105","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L89"}],"snippet":"function toAuthProbeRequest(scenario: ActiveScenario, credentials: \"missing\" | \"valid\", signal: AbortSignal) {\n  const spec = scenario.authProbe ?? {\n    path: authProbePath(scenario.path),\n    body: scenario.method === \"GET\" ? undefined : {},\n  }\n  const headers = {\n    ...(spec.body === undefined ? {} : { \"content-type\": \"application/json\" }),\n    ...spec.headers,\n    ...(credentials === \"valid\" ? { authorization: basic(\"rimuru-ai\", \"secret\") } : {}),\n  }\n  return new Request(new URL(spec.path, \"http://localhost\"), {\n    method: scenario.method,\n    headers,\n    body: spec.body === undefined ? undefined : JSON.stringify(spec.body),\n    signal,\n  })\n}"},{"id":"backend_basic","label":"basic()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L107-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L107"}],"snippet":"function basic(username: string, password: string) {\n  return `Basic ${Buffer.from(`${username}:${password}`).toString(\"base64\")}`\n}"},{"id":"backend_authprobepath","label":"authProbePath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L111-L115","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L111"}],"snippet":"function authProbePath(path: string) {\n  return path\n    .replace(/\\{([^}]+)\\}/g, (_match, key: string) => `auth_${key}`)\n    .replace(/:([^/]+)/g, (_match, key: string) => `auth_${key}`)\n}"},{"id":"backend_capture","label":"capture()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L117-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L117"}],"snippet":"async function capture(response: Response, mode: CaptureMode): Promise<CallResult> {\n  const text = mode === \"stream\" ? await captureStream(response) : await response.text()\n  return {\n    status: response.status,\n    contentType: response.headers.get(\"content-type\") ?? \"\",\n    text,\n    body: parse(text),\n    timedOut: false,\n  }\n}"},{"id":"backend_capturestream","label":"captureStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L128-L144","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L128"}],"snippet":"async function captureStream(response: Response) {\n  if (!response.body) return \"\"\n  const reader = response.body.getReader()\n  const read = reader.read().then(\n    (result) => ({ result }),\n    (error: unknown) => ({ error }),\n  )\n  const winner = await Promise.race([read, Bun.sleep(1_000).then(() => ({ timeout: true }))])\n  if (\"timeout\" in winner) {\n    await reader.cancel(\"timed out waiting for stream chunk\").catch(() => undefined)\n    throw new Error(\"timed out waiting for stream chunk\")\n  }\n  if (\"error\" in winner) throw winner.error\n  await reader.cancel().catch(() => undefined)\n  if (winner.result.done) return \"\"\n  return new TextDecoder().decode(winner.result.value)\n}"}],"edges":[{"source":"backend","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/backend.ts","source_location":"L