{"__madarTsExtractorVersion":67,"__madarFileStem":"settings-keybinds","nodes":[{"id":"settings_keybinds","label":"settings-keybinds.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L1"}]},{"id":"settings_keybinds_groupfor","label":"groupFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L60-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L60"}],"snippet":"function groupFor(id: string): KeybindGroup {\n  if (id === PALETTE_ID) return \"General\"\n  if (id.startsWith(\"terminal.\")) return \"Terminal\"\n  if (id.startsWith(\"model.\") || id.startsWith(\"agent.\") || id.startsWith(\"mcp.\")) return \"Model and agent\"\n  if (id.startsWith(\"file.\") || id.startsWith(\"fileTree.\")) return \"Navigation\"\n  if (id.startsWith(\"prompt.\")) return \"Prompt\"\n  if (\n    id.startsWith(\"session.\") ||\n    id.startsWith(\"message.\") ||\n    id.startsWith(\"permissions.\") ||\n    id.startsWith(\"steps.\") ||\n    id.startsWith(\"review.\")\n  )\n    return \"Session\"\n\n  return \"General\"\n}"},{"id":"settings_keybinds_ismodifier","label":"isModifier()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L78-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L78"}],"snippet":"function isModifier(key: string) {\n  return key === \"Shift\" || key === \"Control\" || key === \"Alt\" || key === \"Meta\"\n}"},{"id":"settings_keybinds_normalizekey","label":"normalizeKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L82-L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L82"}],"snippet":"function normalizeKey(key: string) {\n  if (key === \",\") return \"comma\"\n  if (key === \"+\") return \"plus\"\n  if (key === \" \") return \"space\"\n  return key.toLowerCase()\n}"},{"id":"settings_keybinds_recordkeybind","label":"recordKeybind()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L89-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L89"}],"snippet":"function recordKeybind(event: KeyboardEvent) {\n  if (isModifier(event.key)) return\n\n  const parts: string[] = []\n\n  const mod = IS_MAC ? event.metaKey : event.ctrlKey\n  if (mod) parts.push(\"mod\")\n\n  if (IS_MAC && event.ctrlKey) parts.push(\"ctrl\")\n  if (!IS_MAC && event.metaKey) parts.push(\"meta\")\n  if (event.altKey) parts.push(\"alt\")\n  if (event.shiftKey) parts.push(\"shift\")\n\n  const key = normalizeKey(event.key)\n  if (!key) return\n  parts.push(key)\n\n  return parts.join(\"+\")\n}"},{"id":"settings_keybinds_signatures","label":"signatures()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L109-L125","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L109"}],"snippet":"function signatures(config: string | undefined) {\n  if (!config) return []\n  const sigs: string[] = []\n\n  for (const kb of parseKeybind(config)) {\n    const parts: string[] = []\n    if (kb.ctrl) parts.push(\"ctrl\")\n    if (kb.alt) parts.push(\"alt\")\n    if (kb.shift) parts.push(\"shift\")\n    if (kb.meta) parts.push(\"meta\")\n    if (kb.key) parts.push(kb.key)\n    if (parts.length === 0) continue\n    sigs.push(parts.join(\"+\"))\n  }\n\n  return sigs\n}"},{"id":"settings_keybinds_keybinds","label":"keybinds()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L127-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L127"}],"snippet":"function keybinds(value: unknown): KeybindMap {\n  if (!value || typeof value !== \"object\" || Array.isArray(value)) return {}\n  return value as KeybindMap\n}"},{"id":"settings_keybinds_listfor","label":"listFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L132-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L132"}],"snippet":"function listFor(command: CommandContext, map: KeybindMap, palette: string) {\n  const out = new Map<string, KeybindMeta>()\n  out.set(PALETTE_ID, { title: palette, group: \"General\" })\n\n  for (const opt of command.catalog) {\n    if (opt.id.startsWith(\"suggested.\")) continue\n    if (opt.hidden) continue\n    out.set(opt.id, { title: opt.title, group: groupFor(opt.id) })\n  }\n\n  for (const opt of command.options) {\n    if (opt.id.startsWith(\"suggested.\")) continue\n    if (opt.hidden) continue\n    out.set(opt.id, { title: opt.title, group: groupFor(opt.id) })\n  }\n\n  for (const [id, value] of Object.entries(map)) {\n    if (typeof value !== \"string\") continue\n    if (out.has(id)) continue\n    out.set(id, { title: id, group: groupFor(id) })\n  }\n\n  return out\n}"},{"id":"settings_keybinds_groupedfor","label":"groupedFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L157-L174","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L157"}],"snippet":"function groupedFor(list: Map<string, KeybindMeta>) {\n  const out = new Map<KeybindGroup, string[]>()\n  for (const group of GROUPS) out.set(group, [])\n\n  for (const [id, item] of list) {\n    const ids = out.get(item.group)\n    if (!ids) continue\n    ids.push(id)\n  }\n\n  for (const group of GROUPS) {\n    const ids = out.get(group)\n    if (!ids) continue\n    ids.sort((a, b) => (list.get(a)?.title ?? \"\").localeCompare(list.get(b)?.title ?? \"\"))\n  }\n\n  return out\n}"},{"id":"settings_keybinds_filteredfor","label":"filteredFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L176-L207","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L176"}],"snippet":"function filteredFor(\n  query: string,\n  list: Map<string, KeybindMeta>,\n  grouped: Map<KeybindGroup, string[]>,\n  keybind: (id: string) => string,\n) {\n  const value = query.toLowerCase().trim()\n  if (!value) return grouped\n\n  const out = new Map<KeybindGroup, string[]>()\n  for (const group of GROUPS) out.set(group, [])\n\n  const items = Array.from(list.entries()).map(([id, meta]) => ({\n    id,\n    title: meta.title,\n    group: meta.group,\n    keybind: keybind(id),\n  }))\n\n  const results = fuzzysort.go(value, items, {\n    keys: [\"title\", \"keybind\"],\n    threshold: -10000,\n  })\n\n  for (const result of results) {"},{"id":"settings_keybinds_usekeycapture","label":"useKeyCapture()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L209-L270","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L209"}],"snippet":"function useKeyCapture(input: {\n  active: () => string | null\n  stop: () => void\n  set: (id: string, keybind: string) => void\n  used: () => Map<string, { id: string; title: string }[]>\n  language: ReturnType<typeof useLanguage>\n}) {\n  onMount(() => {\n    const handle = (event: KeyboardEvent) => {\n      const id = input.active()\n      if (!id) return\n\n      event.preventDefault()\n      event.stopPropagation()\n      event.stopImmediatePropagation()\n\n      if (event.key === \"Escape\") {\n        input.stop()\n        return\n      }\n\n      const clear =\n        (event.key === \"Backspace\" || event.key === \"Delete\") &&\n        !event.ctrlKey &&\n        !event.metaKey &&"},{"id":"settings_keybinds_usekeycapture_handle","label":"handle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L217-L266","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L217"}],"snippet":"handle = (event: KeyboardEvent) => {\n      const id = input.active()\n      if (!id) return\n\n      event.preventDefault()\n      event.stopPropagation()\n      event.stopImmediatePropagation()\n\n      if (event.key === \"Escape\") {\n        input.stop()\n        return\n      }\n\n      const clear =\n        (event.key === \"Backspace\" || event.key === \"Delete\") &&\n        !event.ctrlKey &&\n        !event.metaKey &&\n        !event.altKey &&\n        !event.shiftKey\n      if (clear) {\n        input.set(id, \"none\")\n        input.stop()\n        return\n      }"},{"id":"settings_keybinds_settingskeybinds","label":"SettingsKeybinds()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L272-L560","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L272"}],"snippet":"SettingsKeybinds: Component<{ v2?: boolean }> = (props) => {\n  const command = useCommand()\n  const language = useLanguage()\n  const settings = useSettings()\n\n  const [store, setStore] = createStore({\n    active: null as string | null,\n    filter: \"\",\n  })\n\n  const stop = () => {\n    if (!store.active) return\n    setStore(\"active\", null)\n    command.keybinds(true)\n  }\n\n  const start = (id: string) => {\n    if (store.active === id) {\n      stop()\n      return\n    }\n\n    if (store.active) stop()\n\n    setStore(\"active\", id)","node_kind":"component"},{"id":"settings_keybinds_settingskeybinds_stop","label":"stop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L282-L286","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L282"}],"snippet":"stop = () => {\n    if (!store.active) return\n    setStore(\"active\", null)\n    command.keybinds(true)\n  }"},{"id":"settings_keybinds_settingskeybinds_start","label":"start()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L288-L298","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L288"}],"snippet":"start = (id: string) => {\n    if (store.active === id) {\n      stop()\n      return\n    }\n\n    if (store.active) stop()\n\n    setStore(\"active\", id)\n    command.keybinds(false)\n  }"},{"id":"settings_keybinds_settingskeybinds_resetall","label":"resetAll()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L304-L311","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L304"}],"snippet":"resetAll = () => {\n    stop()\n    settings.keybinds.resetAll()\n    showToast({\n      title: language.t(\"settings.shortcuts.reset.toast.title\"),\n      description: language.t(\"settings.shortcuts.reset.toast.description\"),\n    })\n  }"},{"id":"settings_keybinds_settingskeybinds_title","label":"title()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L318","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L318"}],"snippet":"title = (id: string) => list().get(id)?.title ?? \"\""},{"id":"settings_keybinds_settingskeybinds_setkeybind","label":"setKeybind()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L372","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L372"}],"snippet":"setKeybind = (id: string, keybind: string) => settings.keybinds.set(id, keybind)"}],"edges":[{"source":"settings_keybinds","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L1"}],"weight":1},{"source":"settings_keybinds","target":"store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-keybinds.tsx","source_location":"L2"}],"weight":1},{"source":"settings_keybinds","target":"event_listener","relation":"imports_from","confidenc