{"__madarTsExtractorVersion":67,"__madarFileStem":"httpapi-session.test","nodes":[{"id":"httpapi_session_test","label":"httpapi-session.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L1"}]},{"id":"httpapi_session_test_pathfor","label":"pathFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L73-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L73"}],"snippet":"function pathFor(path: string, params: Record<string, string>) {\n  return Object.entries(params).reduce((result, [key, value]) => result.replace(`:${key}`, value), path)\n}"},{"id":"httpapi_session_test_createsession","label":"createSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L77-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L77"}],"snippet":"function createSession(input?: Session.CreateInput) {\n  return Session.use.create(input)\n}"},{"id":"httpapi_session_test_createtextmessage","label":"createTextMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L81-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L81"}],"snippet":"function createTextMessage(sessionID: SessionIDType, text: string) {\n  return Effect.gen(function* () {\n    const svc = yield* Session.Service\n    const info = yield* svc.updateMessage({\n      id: MessageID.ascending(),\n      role: \"user\",\n      sessionID,\n      agent: \"build\",\n      model: { providerID: ProviderV2.ID.make(\"test\"), modelID: ModelV2.ID.make(\"test\") },\n      time: { created: Date.now() },\n    })\n    const part = yield* svc.updatePart({\n      id: PartID.ascending(),\n      sessionID,\n      messageID: info.id,\n      type: \"text\",\n      text,\n    })\n    return { info, part }\n  })\n}"},{"id":"httpapi_session_test_localadapter","label":"localAdapter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L103-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L103"}],"snippet":"localAdapter = (directory: string): WorkspaceAdapter => ({\n  name: \"Local Test\",\n  description: \"Create a local test workspace\",\n  configure: (info) => ({ ...info, name: \"local-test\", directory }),\n  create: async () => {\n    await mkdir(directory, { recursive: true })\n  },\n  async remove() {},\n  target: () => ({ type: \"local\" as const, directory }),\n})"},{"id":"httpapi_session_test_createlocalworkspace","label":"createLocalWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L114-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L114"}],"snippet":"createLocalWorkspace = (input: { projectID: Project.Info[\"id\"]; type: string; directory: string }) =>\n  Effect.acquireRelease(\n    Effect.gen(function* () {\n      registerAdapter(input.projectID, input.type, localAdapter(input.directory))\n      return yield* Workspace.Service.use((svc) =>\n        svc.create({\n          type: input.type,\n          branch: null,\n          extra: null,\n          projectID: input.projectID,\n        }),\n      )\n    }),\n    (info) => Workspace.use.remove(info.id).pipe(Effect.ignore),\n  )"},{"id":"httpapi_session_test_insertlegacyassistantmessage","label":"insertLegacyAssistantMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L130-L165","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L130"}],"snippet":"insertLegacyAssistantMessage = (sessionID: SessionIDType, seq = 1, time = seq) =>\n  Effect.gen(function* () {\n    const message = new SessionMessage.Assistant({\n      id: SessionMessage.ID.create(),\n      type: \"assistant\",\n      agent: \"build\",\n      model: {\n        id: ModelV2.ID.make(\"model\"),\n        providerID: ProviderV2.ID.make(\"provider\"),\n        variant: ModelV2.VariantID.make(\"default\"),\n      },\n      time: { created: DateTime.makeUnsafe(time) },\n      content: [],\n    })\n    const { db } = yield* Database.Service\n    yield* db\n      .insert(SessionMessageTable)\n      .values([\n        {\n          id: message.id,\n          session_id: sessionID,\n          type: message.type,\n          seq,\n          time_created: time,\n          data: {"},{"id":"httpapi_session_test_insertcorruptv2message","label":"insertCorruptV2Message()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L167-L184","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L167"}],"snippet":"insertCorruptV2Message = (sessionID: SessionIDType, time = 1) =>\n  Effect.gen(function* () {\n    const { db } = yield* Database.Service\n    yield* db\n      .insert(SessionMessageTable)\n      .values([\n        {\n          id: SessionMessage.ID.create(),\n          session_id: sessionID,\n          type: \"assistant\",\n          seq: time,\n          time_created: time,\n          data: {} as NonNullable<(typeof SessionMessageTable.$inferInsert)[\"data\"]>,\n        },\n      ])\n      .run()\n      .pipe(Effect.orDie)\n  })"},{"id":"httpapi_session_test_setlegacysummarydiff","label":"setLegacySummaryDiff()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L186-L200","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L186"}],"snippet":"setLegacySummaryDiff = (sessionID: SessionIDType) =>\n  Effect.gen(function* () {\n    const { db } = yield* Database.Service\n    yield* db\n      .update(SessionTable)\n      .set({\n        summary_additions: 1,\n        summary_deletions: 0,\n        summary_files: 1,\n        summary_diffs: [{ additions: 1, deletions: 0 }],\n      })\n      .where(eq(SessionTable.id, sessionID))\n      .run()\n      .pipe(Effect.orDie)\n  })"},{"id":"httpapi_session_test_getworkspaceid","label":"getWorkspaceID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L202-L211","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L202"}],"snippet":"getWorkspaceID = (sessionID: SessionIDType) =>\n  Effect.gen(function* () {\n    const { db } = yield* Database.Service\n    return yield* db\n      .select({ workspaceID: SessionTable.workspace_id })\n      .from(SessionTable)\n      .where(eq(SessionTable.id, sessionID))\n      .get()\n      .pipe(Effect.orDie)\n  })"},{"id":"httpapi_session_test_clearsessionpath","label":"clearSessionPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L213-L217","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L213"}],"snippet":"clearSessionPath = (sessionID: SessionIDType) =>\n  Effect.gen(function* () {\n    const { db } = yield* Database.Service\n    yield* db.update(SessionTable).set({ path: null }).where(eq(SessionTable.id, sessionID)).run().pipe(Effect.orDie)\n  })"},{"id":"httpapi_session_test_request","label":"request()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L219-L225","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L219"}],"snippet":"function request(path: string, init?: RequestInit) {\n  const url = new URL(path, \"http://localhost\")\n  return HttpClientRequest.fromWeb(new Request(url, init)).pipe(\n    HttpClientRequest.setUrl(url.pathname),\n    HttpClient.execute,\n  )\n}"},{"id":"httpapi_session_test_json","label":"json()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L227-L230","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L227"}],"snippet":"function json<T>(response: HttpClientResponse.HttpClientResponse) {\n  if (response.status !== 200) return response.text.pipe(Effect.flatMap((text) => Effect.die(new Error(text))))\n  return response.json.pipe(Effect.map((value) => value as T))\n}"},{"id":"httpapi_session_test_responsejson","label":"responseJson()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L232-L234","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L232"}],"snippet":"function responseJson(response: HttpClientResponse.HttpClientResponse) {\n  return response.json\n}"},{"id":"httpapi_session_test_requestjson","label":"requestJson()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L236-L238","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/server/httpapi-session.test.ts","source_location":"L236"}],"snippet":"function requestJson<T