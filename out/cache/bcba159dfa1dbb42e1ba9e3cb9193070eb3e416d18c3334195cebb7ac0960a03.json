on/index.ts","source_location":"L189-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L189"}],"snippet":"function expand(pattern: string): string {\n  if (pattern.startsWith(\"~/\")) return os.homedir() + pattern.slice(1)\n  if (pattern === \"~\") return os.homedir()\n  if (pattern.startsWith(\"$HOME/\")) return os.homedir() + pattern.slice(5)\n  if (pattern.startsWith(\"$HOME\")) return os.homedir() + pattern.slice(5)\n  return pattern\n}"},{"id":"packages_opencode_src_permission_index_fromconfig","label":"fromConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L197-L209","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L197"}],"snippet":"export function fromConfig(permission: ConfigPermissionV1.Info) {\n  const ruleset: PermissionV1.Rule[] = []\n  for (const [key, value] of Object.entries(permission)) {\n    if (typeof value === \"string\") {\n      ruleset.push({ permission: key, action: value, pattern: \"*\" })\n      continue\n    }\n    ruleset.push(\n      ...Object.entries(value).map(([pattern, action]) => ({ permission: key, pattern: expand(pattern), action })),\n    )\n  }\n  return ruleset\n}"},{"id":"packages_opencode_src_permission_index_merge","label":"merge()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L211-L213","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L211"}],"sni