{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_permission_index","nodes":[{"id":"packages_opencode_src_permission_index","label":"index.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L1"}]},{"id":"packages_opencode_src_permission_index_interface","label":"Interface","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L23-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L23"}],"snippet":"export interface Interface {\n  readonly ask: (input: PermissionV1.AskInput) => Effect.Effect<void, PermissionV1.Error>\n  readonly reply: (input: PermissionV1.ReplyInput) => Effect.Effect<void, PermissionV1.NotFoundError>\n  readonly list: () => Effect.Effect<ReadonlyArray<PermissionV1.Request>>\n}"},{"id":"packages_opencode_src_permission_index_pendingentry","label":"PendingEntry","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L29-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/permission/index.ts","source_location":"L29"}],"snippet":"interface PendingEntry {\n  info: PermissionV1.Request\n  deferred: Deferred.Deferred<void, PermissionV1.RejectedError | PermissionV1.CorrectedError>\n}"},{"id":"packages_opencode_src_permission_index_state","label":"State","file_type":"code","source