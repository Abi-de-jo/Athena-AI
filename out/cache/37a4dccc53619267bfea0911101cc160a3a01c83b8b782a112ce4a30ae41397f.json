,"source_location":"L152-L176","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L152"}],"snippet":"export function docs(locale: Locale, pathname: string) {\n  const value = DOCS[locale]\n  const next = suffix(pathname)\n  if (next.path !== \"/docs\" && next.path !== \"/docs/\" && !next.path.startsWith(\"/docs/\")) {\n    return `${next.path}${next.suffix}`\n  }\n\n  if (value === \"root\") {\n    if (next.path === \"/docs/en\") return `/docs${next.suffix}`\n    if (next.path === \"/docs/en/\") return `/docs/${next.suffix}`\n    if (next.path.startsWith(\"/docs/en/\")) return `/docs/${next.path.slice(\"/docs/en/\".length)}${next.suffix}`\n    return `${next.path}${next.suffix}`\n  }\n\n  if (next.path === \"/docs\") return `/docs/${value}${next.suffix}`\n  if (next.path === \"/docs/\") return `/docs/${value}/${next.suffix}`\n\n  const head = next.path.slice(\"/docs/\".length).split(\"/\")[0] ?? \"\"\n  if (!head) return `/docs/${value}/${next.suffix}`\n  if (DOCS_SEGMENT.has(head)) return `${next.path}${next.suffix}`\n  if (head.startsWith(\"_\")) return `${next.path}${next.suffix}`\n  if (head.includes(\".\")) return `${next.path}${next.suffix}`\n\n  return `/docs/${value}${next.path.slice(\"/docs\".length)}${next.suffix}`\n}"},{"id":"packages_console_app_src_lib_language_parselocale","label":"parseLocale()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L178-L182","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L178"}],"snippet":"export function parseLocale(value: unknown): Locale | null {\n  if (typeof value !== \"string\") return null\n  if ((LOCALES as readonly string[]).includes(value)) return value as Locale\n  return null\n}"},{"id":"packages_console_app_src_lib_language_frompathname","label":"fromPathname()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L184-L186","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L184"}],"snippet":"export function fromPathname(pathname: string) {\n  return parseLocale(fix(pathname).split(\"/\")[1])\n}"},{"id":"packages_console_app_src_lib_language_fromdocspathname","label":"fromDocsPathname()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L188-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L188"}],"snippet":"export function fromDocsPathname(pathname: string) {\n  const next = fix(pathname)\n  const value = next.split(\"/\")[2]?.toLowerCase()\n  if (!value) return null\n  if (!next.startsWith(\"/docs/\")) return null\n  if (!(value in DOCS_LOCALE)) return null\n  return DOCS_LOCALE[value as keyof typeof DOCS_LOCALE]\n}"},{"id":"packages_console_app_src_lib_language_strip","label":"strip()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L197-L205","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L197"}],"snippet":"export function strip(pathname: string) {\n  const locale = fromPathname(pathname)\n  if (!locale) return fix(pathname)\n\n  const next = fix(pathname).slice(locale.length + 1)\n  if (!next) return \"/\"\n  if (next.startsWith(\"/\")) return next\n  return `/${next}`\n}"},{"id":"packages_console_app_src_lib_language_route","label":"route()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L207-L215","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L207"}],"snippet":"export function route(locale: Locale, pathname: string) {\n  const next = strip(pathname)\n  if (next.startsWith(\"/docs\")) return docs(locale, next)\n  if (next.startsWith(\"/auth\")) return next\n  if (next.startsWith(\"/workspace\")) return next\n  if (locale === \"en\") return next\n  if (next === \"/\") return `/${locale}`\n  return `/${locale}${next}`\n}"},{"id":"packages_console_app_src_lib_language_label","label":"label()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L217-L219","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L217"}],"snippet":"export function label(locale: Locale) {\n  return LABEL[locale]\n}"},{"id":"packages_console_app_src_lib_language_tag","label":"tag()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L221-L223","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L221"}],"snippet":"export function tag(locale: Locale) {\n  return TAG[locale]\n}"},{"id":"packages_console_app_src_lib_language_dir","label":"dir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L225-L228","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L225"}],"snippet":"export function dir(locale: Locale) {\n  if (locale === \"ar\") return \"rtl\"\n  return \"ltr\"\n}"},{"id":"packages_console_app_src_lib_language_match","label":"match()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L230-L256","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L230"}],"snippet":"function match(input: string): Locale | null {\n  const value = input.trim().toLowerCase()\n  if (!value) return null\n\n  if (value.startsWith(\"zh\")) {\n    if (value.includes(\"hant\") || value.includes(\"-tw\") || value.includes(\"-hk\") || value.includes(\"-mo\")) return \"zht\"\n    return \"zh\"\n  }\n\n  if (value.startsWith(\"ko\")) return \"ko\"\n  if (value.startsWith(\"de\")) return \"de\"\n  if (value.startsWith(\"es\")) return \"es\"\n  if (value.startsWith(\"fr\")) return \"fr\"\n  if (value.startsWith(\"it\")) return \"it\"\n  if (value.startsWith(\"da\")) return \"da\"\n  if (value.startsWith(\"ja\")) return \"ja\"\n  if (value.startsWith(\"pl\")) return \"pl\"\n  if (value.startsWith(\"ru\")) return \"ru\"\n  if (value.startsWith(\"uk\")) return \"uk\"\n  if (value.startsWith(\"ar\")) return \"ar\"\n  if (value.startsWith(\"tr\")) return \"tr\"\n  if (value.startsWith(\"th\")) return \"th\"\n  if (value.startsWith(\"pt\")) return \"br\"\n  if (value.startsWith(\"no\") || value.startsWith(\"nb\") || value.startsWith(\"nn\")) return \"no\"\n  if (value.startsWith(\"en\")) return \"en\""},{"id":"packages_console_app_src_lib_language_detectfromlanguages","label":"detectFromLanguages()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L258-L264","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L258"}],"snippet":"export function detectFromLanguages(languages: readonly string[]) {\n  for (const language of languages) {\n    const locale = match(language)\n    if (locale) return locale\n  }\n  return \"en\" satisfies Locale\n}"},{"id":"packages_console_app_src_lib_language_detectfromacceptlanguage","label":"detectFromAcceptLanguage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L266-L294","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L266"}],"snippet":"export function detectFromAcceptLanguage(header: string | null) {\n  if (!header) return \"en\" satisfies Locale\n\n  const items = header\n    .split(\",\")\n    .map((raw) => raw.trim())\n    .filter(Boolean)\n    .map((raw) => {\n      const parts = raw.split(\";\").map((x) => x.trim())\n      const lang = parts[0] ?? \"\"\n      const q = parts\n        .slice(1)\n        .find((x) => x.startsWith(\"q=\"))\n        ?.slice(2)\n      return {\n        lang,\n        q: q ? Number.parseFloat(q) : 1,\n      }\n    })\n    .sort((a, b) => b.q - a.q)\n\n  for (const item of items) {\n    if (!item.lang || item.lang === \"*\") continue\n    const locale = match(item.lang)\n    if (locale) return locale"},{"id":"packages_console_app_src_lib_language_localefromcookieheader","label":"localeFromCookieHeader()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L296-L307","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L296"}],"snippet":"export function localeFromCookieHeader(header: string | null) {\n  if (!header) return null\n\n  const raw = header\n    .split(\";\")\n    .map((x) => x.trim())\n    .find((x) => x.startsWith(`${LOCALE_COOKIE}=`))\n    ?.slice(`${LOCALE_COOKIE}=`.length)\n\n  if (!raw) return null\n  return parseLocale(decodeURIComponent(raw))\n}"},{"id":"packages_console_app_src_lib_language_localefromrequest","label":"localeFromRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L309-L323","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L309"}],"snippet":"export function localeFromRequest(request: Request) {\n  const fromHeader = parseLocale(request.headers.get(LOCALE_HEADER))\n  if (fromHeader) return fromHeader\n\n  const fromPath = fromPathname(new URL(request.url).pathname)\n  if (fromPath) return fromPath\n\n  const fromDocsPath = fromDocsPathname(new URL(request.url).pathname)\n  if (fromDocsPath) return fromDocsPath\n\n  return (\n    localeFromCookieHeader(request.headers.get(\"cookie\")) ??\n    detectFromAcceptLanguage(request.headers.get(\"accept-language\"))\n  )\n}"},{"id":"packages_console_app_src_lib_language_cookie","label":"cookie()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L325-L327","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L325"}],"snippet":"export function cookie(locale: Locale) {\n  return `${LOCALE_COOKIE}=${encodeURIComponent(locale)}; Path=/; Max-Age=31536000; SameSite=Lax`\n}"},{"id":"packages_console_app_src_lib_language_clearcookie","label":"clearCookie()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L329-L331","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L329"}],"snippet":"export function clearCookie() {\n  return `${LOCALE_COOKIE}=; Path=/; Max-Age=0; SameSite=Lax`\n}"}],"edges":[{"source":"packages_console_app_src_lib_language","target":"packages_console_app_src_lib_language_fix","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L27"}],"weight":1},{"source":"packages_console_app_src_lib_language","target":"packages_console_app_src_lib_language_suffix","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","source_location":"L137","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/lib/language.ts","