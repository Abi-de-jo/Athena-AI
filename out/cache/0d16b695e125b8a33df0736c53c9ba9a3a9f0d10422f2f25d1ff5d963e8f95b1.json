{"__madarTsExtractorVersion":67,"__madarFileStem":"entry.body","nodes":[{"id":"entry_body","label":"entry.body.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L1"}]},{"id":"entry_body_cleanruntext","label":"cleanRunText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L13-L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L13"}],"snippet":"export function cleanRunText(text: string): string {\n  return text.replace(/\\r\\n/g, \"\\n\").replace(/\\r/g, \"\\n\")\n}"},{"id":"entry_body_textbody","label":"textBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L17-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L17"}],"snippet":"function textBody(content: string): RunEntryBody {\n  if (!content) {\n    return RUN_ENTRY_NONE\n  }\n\n  return {\n    type: \"text\",\n    content,\n  }\n}"},{"id":"entry_body_codebody","label":"codeBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L28-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/