n/entry.body.ts","source_location":"L61"}],"snippet":"function reasoningBody(raw: string): RunEntryBody {\n  const clean = raw.replace(/\\[REDACTED\\]/g, \"\")\n  if (!clean) {\n    return RUN_ENTRY_NONE\n  }\n\n  const lead = clean.match(/^\\n+/)?.[0] ?? \"\"\n  const body = lead ? clean.slice(lead.length) : clean\n  const mark = \"Thinking:\"\n  if (body.startsWith(mark)) {\n    return codeBody(`${lead}_Thinking:_ ${body.slice(mark.length).trimStart()}`, \"markdown\")\n  }\n\n  return codeBody(clean, \"markdown\")\n}"},{"id":"entry_body_systembody","label":"systemBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L77-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L77"}],"snippet":"function systemBody(raw: string, phase: StreamCommit[\"phase\"]): RunEntryBody {\n  return textBody(phase === \"progress\" ? raw : raw.trim())\n}"},{"id":"entry_body_entryflags","label":"entryFlags()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L81-L135","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L81"}],"snippet":"export function entryFlags(commit: StreamCommit): EntryFlags {\n  if (commit.summary) {\n    return {\n      startOnNewLine: true,\n      trailingNewline: false,\n    }\n  }\n\n  if (commit.kind === \"user\") {\n    return {\n      startOnNewLine: true,\n      trailingNewline: false,\n    }\n  }\n\n  if (commit.kind === \"tool\") {\n    if (commit.phase === \"progress\") {\n      return {\n        startOnNewLine: false,\n        trailingNewline: false,\n      }\n    }\n\n    return {\n      startOnNewLine: true,"},{"id":"entry_body_entrydone","label":"entryDone()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L137-L147","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L137"}],"snippet":"export function entryDone(commit: StreamCommit): boolean {\n  if (commit.kind === \"assistant\" || commit.kind === \"reasoning\") {\n    return commit.phase === \"final\"\n  }\n\n  if (commit.kind === \"tool\") {\n    return commit.phase === \"final\" || (commit.phase === \"progress\" && commit.toolState === \"completed\")\n  }\n\n  return true\n}"},{"id":"entry_body_entrycanstream","label":"entryCanStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L149-L163","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L149"}],"snippet":"export function entryCanStream(commit: StreamCommit, body: RunEntryBody): boolean {\n  if (commit.phase !== \"progress\") {\n    return false\n  }\n\n  if (body.type === \"none\") {\n    return false\n  }\n\n  if (commit.kind === \"tool\") {\n    return commit.toolState !== \"completed\"\n  }\n\n  return commit.kind === \"assistant\" || commit.kind === \"reasoning\"\n}"},{"id":"entry_body_entrybody","label":"entryBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L165-L205","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L165"}],"snippet":"export function entryBody(commit: StreamCommit): RunEntryBody {\n  if (commit.summary) {\n    return RUN_ENTRY_NONE\n  }\n\n  const raw = cleanRunText(commit.text)\n\n  if (commit.kind === \"user\") {\n    return userBody(raw)\n  }\n\n  if (commit.kind === \"tool\") {\n    return toolEntryBody(commit, raw) ?? RUN_ENTRY_NONE\n  }\n\n  if (commit.kind === \"assistant\") {\n    if (commit.phase === \"start\") {\n      return RUN_ENTRY_NONE\n    }\n\n    if (commit.phase === \"final\") {\n      return commit.interrupted ? textBody(\"assistant interrupted\") : RUN_ENTRY_NONE\n    }\n\n    return markdownBody(raw)"}],"edges":[{"source":"entry_body","target":"tool","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L1"}],"weight":1},{"source":"entry_body","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L2"}],"weight":1},{"source":"entry_body","target":"entry_body_cleanruntext","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/entry.body.ts","source_location":"L13","layer":"base","provenance":[{"capability_id":"builtin:extract:typ