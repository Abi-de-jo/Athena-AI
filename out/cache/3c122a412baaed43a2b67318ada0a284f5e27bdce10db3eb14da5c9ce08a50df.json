\n  const visit = (input: AnyNode): RuntimeLayer => {\n    const node = replacements.get(input) ?? input\n    const cached = cache.get(node)\n    if (cached) return cached\n    if (visiting.has(node)) {\n      const start = stack.indexOf(node)\n      const cycle = [...stack.slice(start), node].map((item) => `${item.kind}#${ids.get(item)}`).join(\" -> \")\n      throw new Error(`Cycle detected in app graph: ${cycle}`)\n    }\n    if (!ids.has(node)) ids.set(node, ids.size + 1)\n    visiting.add(node)\n    stack.push(node)\n    try {\n      const dependencies = node.dependencies.map(visit)\n      const nonEmpty = dependencies as [RuntimeLayer, ...RuntimeLayer[]]\n      const result =\n        node.kind === \"group\"\n          ? dependencies.length === 0"},{"id":"layer_node_buildlayer_visit","label":"visit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/layer-node.ts","source_location":"L68-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/layer-node.ts","source_location":"L68"}],"snippet":"visit = (input: AnyNode): RuntimeLayer => {\n    const node = replacements.get(input) ?? input\n    const cached = cache.get(node)\n    if (cached) return cached\n    if (visiting.has(node)) {\n      const start = stack.indexOf(node)\n      const cycle = [...stack.slice(start), node].map((item) => `${item.kind}#${ids.get(item)}`).join(\" -> \")\n      throw new Error(`Cycle detected in app graph: ${cycle}`)\n    }\n    if (!ids.has(node)) ids.set(node, ids.size + 1)\n    visiting.add(node)\n    stack.push(node)\n    try {\n      const dependencies = node.dependencies.map(visit)\n      const nonEmpty = dependencies as [RuntimeLayer, ...RuntimeLayer[]]\n      const result =\n        node.kind === \"group\"\n          ? dependencies.length === 0\n            ? Layer.empty\n            : Layer.mergeAll(...nonEmpty)\n          : dependencies.length === 0\n            ? (node.implementation as RuntimeLayer)\n            : Layer.provide(node.implementation as RuntimeLayer, nonEmpty)\n      cache.set(node, result)\n      return result"}],"edges":[{"source":"layer_node","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/layer-node.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/layer-node.ts","source_location":"L1"}],"weight":1},{"source":"layer_node","target":"layer_node_make","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/layer-node.ts","source_location":"L25","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/layer-node.ts","source_location":"L25"}],"weight":1},{"source":"layer_node","target":"layer_node_group","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/layer-node.ts","source_location":"L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/layer-node.ts","source_location":"L32"}],"weight":1},{"source":"layer_node","target":"layer_node_replacewithnode","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/layer-node.ts","source_location":"L47","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/effect/layer-nod