{"__madarTsExtractorVersion":67,"__madarFileStem":"unresponsive","nodes":[{"id":"unresponsive","label":"unresponsive.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L1"}]},{"id":"unresponsive_createunresponsivesampler","label":"createUnresponsiveSampler()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L7-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L7"}],"snippet":"export function createUnresponsiveSampler(win: BrowserWindow, name: string) {\n  let sampleTimer: ReturnType<typeof setTimeout> | undefined\n  let stopTimer: ReturnType<typeof setTimeout> | undefined\n  let sampling = false\n  const samples = new Map<string, number>()\n\n  const active = () => sampling && !win.isDestroyed() && !win.webContents.isDestroyed()\n  const clearTimers = () => {\n    if (sampleTimer) clearTimeout(sampleTimer)\n    if (stopTimer) clearTimeout(stopTimer)\n    sampleTimer = undefined\n    stopTimer = undefined\n  }\n\n  const schedule = () => {\n    sampleTimer = setTimeout(() => {\n      void collect()\n    }, sampleInterval)\n  }\n\n  const collect = async () => {\n    if (!active()) return\n    const stack = await win.webContents.mainFrame.collectJavaScriptCallStack().catch((error) => {\n      writeLog(\"window\", \"failed to collect unresponsive sample\", { window: name, error }, \"error\")\n      return undefined"},{"id":"unresponsive_createunresponsivesampler_active","label":"active()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L13","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L13"}],"snippet":"active = () => sampling && !win.isDestroyed() && !win.webContents.isDestroyed()"},{"id":"unresponsive_createunresponsivesampler_cleartimers","label":"clearTimers()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L14-L19","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L14"}],"snippet":"clearTimers = () => {\n    if (sampleTimer) clearTimeout(sampleTimer)\n    if (stopTimer) clearTimeout(stopTimer)\n    sampleTimer = undefined\n    stopTimer = undefined\n  }"},{"id":"unresponsive_createunresponsivesampler_schedule","label":"schedule()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L21-L25","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L21"}],"snippet":"schedule = () => {\n    sampleTimer = setTimeout(() => {\n      void collect()\n    }, sampleInterval)\n  }"},{"id":"unresponsive_createunresponsivesampler_collect","label":"collect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L27-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L27"}],"snippet":"collect = async () => {\n    if (!active()) return\n    const stack = await win.webContents.mainFrame.collectJavaScriptCallStack().catch((error) => {\n      writeLog(\"window\", \"failed to collect unresponsive sample\", { window: name, error }, \"error\")\n      return undefined\n    })\n    if (!active()) return\n    if (stack) samples.set(stack, (samples.get(stack) ?? 0) + 1)\n    schedule()\n  }"},{"id":"unresponsive_createunresponsivesampler_stopandflush","label":"stopAndFlush()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L38-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L38"}],"snippet":"stopAndFlush = () => {\n    const wasSampling = sampling\n    sampling = false\n    clearTimers()\n    if (samples.size === 0) return wasSampling\n\n    const entries = [...samples.entries()].sort((a, b) => b[1] - a[1])\n    const total = entries.reduce((sum, entry) => sum + entry[1], 0)\n    const message = [\n      \"renderer unresponsive samples\",\n      `Window: ${name}`,\n      `URL: ${win.isDestroyed() ? \"<destroyed>\" : win.webContents.getURL()}`,\n      ...entries.map((entry) => `<${entry[1]}> ${entry[0]}`),\n      `Total Samples: ${total}`,\n    ].join(\"\\n\")\n    writeLog(\"window\", message, undefined, \"error\")\n    samples.clear()\n    return wasSampling\n  }"},{"id":"unresponsive_createunresponsivesampler_start","label":"start()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L58-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L58"}],"snippet":"start = () => {\n    if (sampling || win.isDestroyed() || win.webContents.isDestroyed() || win.webContents.isDevToolsOpened()) return\n    sampling = true\n    samples.clear()\n    schedule()\n    stopTimer = setTimeout(stopAndFlush, samplePeriod)\n  }"}],"edges":[{"source":"unresponsive","target":"electron","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L1"}],"weight":1},{"source":"unresponsive","target":"logging","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L2"}],"weight":1},{"source":"unresponsive","target":"unresponsive_createunresponsivesampler","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L7","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","source_location":"L7"}],"weight":1},{"source":"unresponsive_createunresponsivesampler","target":"unresponsive_createunresponsivesampler_active","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/unresponsive.ts","s