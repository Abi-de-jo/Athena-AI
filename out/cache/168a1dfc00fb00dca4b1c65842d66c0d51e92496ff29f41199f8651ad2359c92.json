:"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L54-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L54"}],"snippet":"export function questionSingle(request: QuestionRequest): boolean {\n  return request.questions.length === 1 && request.questions[0]?.multiple !== true\n}"},{"id":"question_shared_questiontabs","label":"questionTabs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L58-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L58"}],"snippet":"export function questionTabs(request: QuestionRequest): number {\n  return questionSingle(request) ? 1 : request.questions.length + 1\n}"},{"id":"question_shared_questionconfirm","label":"questionConfirm()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L62-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L62"}],"snippet":"export function questionConfirm(request: QuestionRequest, state: QuestionBodyState): boolean {\n  return !questionSingle(request) && state.tab === request.questions.length\n}"},{"id":"question_shared_questioninfo","label":"questionInfo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L66-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L66"}],"snippet":"export function questionInfo(request: QuestionRequest, state: QuestionBodyState): QuestionInfo | undefined {\n  return request.questions[state.tab]\n}"},{"id":"question_shared_questioncustom","label":"questionCustom()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L70-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L70"}],"snippet":"export function questionCustom(request: QuestionRequest, state: QuestionBodyState): boolean {\n  return questionInfo(request, state)?.custom !== false\n}"},{"id":"question_shared_questioninput","label":"questionInput()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L74-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L74"}],"snippet":"export function questionInput(state: QuestionBodyState): string {\n  return state.custom[state.tab] ?? \"\"\n}"},{"id":"question_shared_questionpicked","label":"questionPicked()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L78-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L78"}],"snippet":"export function questionPicked(state: QuestionBodyState): boolean {\n  const value = questionInput(state)\n  if (!value) {\n    return false\n  }\n\n  return state.answers[state.tab]?.includes(value) ?? false\n}"},{"id":"question_shared_questionother","label":"questionOther()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L87-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L87"}],"snippet":"export function questionOther(request: QuestionRequest, state: QuestionBodyState): boolean {\n  const info = questionInfo(request, state)\n  if (!info || info.custom === false) {\n    return false\n  }\n\n  return state.selected === info.options.length\n}"},{"id":"question_shared_questiontotal","label":"questionTotal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L96-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L96"}],"snippet":"export function questionTotal(request: QuestionRequest, state: QuestionBodyState): number {\n  const info = questionInfo(request, state)\n  if (!info) {\n    return 0\n  }\n\n  return info.options.length + (questionCustom(request, state) ? 1 : 0)\n}"},{"id":"question_shared_questionanswers","label":"questionAnswers()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L105-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L105"}],"snippet":"export function questionAnswers(state: QuestionBodyState, count: number): string[][] {\n  return Array.from({ length: count }, (_, idx) => state.answers[idx] ?? [])\n}"},{"id":"question_shared_questionsettab","label":"questionSetTab()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L109-L116","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L109"}],"snippet":"export function questionSetTab(state: QuestionBodyState, tab: number): QuestionBodyState {\n  return {\n    ...state,\n    tab,\n    selected: 0,\n    editing: false,\n  }\n}"},{"id":"question_shared_questionsetselected","label":"questionSetSelected()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L118-L123","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L118"}],"snippet":"export function questionSetSelected(state: QuestionBodyState, selected: number): QuestionBodyState {\n  return {\n    ...state,\n    selected,\n  }\n}"},{"id":"question_shared_questionsetediting","label":"questionSetEditing()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L125-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L125"}],"snippet":"export function questionSetEditing(state: QuestionBodyState, editing: boolean): QuestionBodyState {\n  return {\n    ...state,\n    editing,\n  }\n}"},{"id":"question_shared_questionsetsubmitting","label":"questionSetSubmitting()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L132-L137","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L132"}],"snippet":"export function questionSetSubmitting(state: QuestionBodyState, submitting: boolean): QuestionBodyState {\n  return {\n    ...state,\n    submitting,\n  }\n}"},{"id":"question_shared_storeanswers","label":"storeAnswers()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L139-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L139"}],"snippet":"function storeAnswers(state: QuestionBodyState, tab: number, list: string[]): QuestionBodyState {\n  const answers = [...state.answers]\n  answers[tab] = list\n  return {\n    ...state,\n    answers,\n  }\n}"},{"id":"question_shared_questionstorecustom","label":"questionStoreCustom()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L148-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L148"}],"snippet":"export function questionStoreCustom(state: QuestionBodyState, tab: number, text: string): QuestionBodyState {\n  const custom = [...state.custom]\n  custom[tab] = text\n  return {\n    ...state,\n    custom,\n  }\n}"},{"id":"question_shared_questionpick","label":"questionPick()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L157-L193","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L157"}],"snippet":"function questionPick(\n  state: QuestionBodyState,\n  request: QuestionRequest,\n  answer: string,\n  custom = false,\n): QuestionStep {\n  const answers = [...state.answers]\n  answers[state.tab] = [answer]\n  let next: QuestionBodyState = {\n    ...state,\n    answers,\n    editing: false,\n  }\n\n  if (custom) {\n    const list = [...state.custom]\n    list[state.tab] = answer\n    next = {\n      ...next,\n      custom: list,\n    }\n  }\n\n  if (questionSingle(request)) {\n    return {"},{"id":"question_shared_questiontoggle","label":"questionToggle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L195-L205","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L195"}],"snippet":"function questionToggle(state: QuestionBodyState, answer: string): QuestionBodyState {\n  const list = [...(state.answers[state.tab] ?? [])]\n  const idx = list.indexOf(answer)\n  if (idx === -1) {\n    list.push(answer)\n  } else {\n    list.splice(idx, 1)\n  }\n\n  return storeAnswers(state, state.tab, list)\n}"},{"id":"question_shared_questionmove","label":"questionMove()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L207-L217","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L207"}],"snippet":"export function questionMove(state: QuestionBodyState, request: QuestionRequest, dir: -1 | 1): QuestionBodyState {\n  const total = questionTotal(request, state)\n  if (total === 0) {\n    return state\n  }\n\n  return {\n    ...state,\n    selected: (state.selected + dir + total) % total,\n  }\n}"},{"id":"question_shared_questionselect","label":"questionSelect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L219-L256","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L219"}],"snippet":"export function questionSelect(state: QuestionBodyState, request: QuestionRequest): QuestionStep {\n  const info = questionInfo(request, state)\n  if (!info) {\n    return { state }\n  }\n\n  if (questionOther(request, state)) {\n    if (!info.multiple) {\n      return {\n        state: questionSetEditing(state, true),\n      }\n    }\n\n    const value = questionInput(state)\n    if (value && questionPicked(state)) {\n      return {\n        state: questionToggle(state, value),\n      }\n    }\n\n    return {\n      state: questionSetEditing(state, true),\n    }\n  }"},{"id":"question_shared_questionsave","label":"questionSave()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L258-L306","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L258"}],"snippet":"export function questionSave(state: QuestionBodyState, request: QuestionRequest): QuestionStep {\n  const info = questionInfo(request, state)\n  if (!info) {\n    return { state }\n  }\n\n  const value = questionInput(state).trim()\n  const prev = state.custom[state.tab]\n  if (!value) {\n    if (!prev) {\n      return {\n        state: questionSetEditing(state, false),\n      }\n    }\n\n    const next = questionStoreCustom(state, state.tab, \"\")\n    return {\n      state: questionSetEditing(\n        storeAnswers(\n          next,\n          state.tab,\n          (state.answers[state.tab] ?? []).filter((item) => item !== prev),\n        ),\n        false,\n      ),"},{"id":"question_shared_questionsubmit","label":"questionSubmit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L308-L313","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L308"}],"snippet":"export function questionSubmit(request: QuestionRequest, state: QuestionBodyState): QuestionReply {\n  return {\n    requestID: request.id,\n    answers: questionAnswers(state, request.questions.length),\n  }\n}"},{"id":"question_shared_questionreject","label":"questionReject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L315-L319","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L315"}],"snippet":"export function questionReject(request: QuestionRequest): QuestionReject {\n  return {\n    requestID: request.id,\n  }\n}"},{"id":"question_shared_questionhint","label":"questionHint()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L321-L340","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L321"}],"snippet":"export function questionHint(request: QuestionRequest, state: QuestionBodyState): string {\n  if (state.submitting) {\n    return \"Waiting for question event...\"\n  }\n\n  if (questionConfirm(request, state)) {\n    return \"enter submit   esc dismiss\"\n  }\n\n  if (state.editing) {\n    return \"enter save   esc cancel\"\n  }\n\n  const info = questionInfo(request, state)\n  if (questionSingle(request)) {\n    return `↑↓ select   enter ${info?.multiple ? \"toggle\" : \"submit\"}   esc dismiss`\n  }\n\n  return `⇆ tab   ↑↓ select   enter ${info?.multiple ? \"toggle\" : \"confirm\"}   esc dismiss`\n}"}],"edges":[{"source":"question_shared","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L16","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/question.shared.ts","source_location":"L16"}],"weight":1},{"source":"question_shared","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/open