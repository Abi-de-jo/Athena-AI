3.5 shrink-0 text-icon-strong-base\" />\n                                </Show>\n                                <div class=\"text-12-regular text-text-base\">{model()?.name ?? modelID()}</div>\n                              </div>\n                              <div class=\"text-12-regular text-text-weaker\">\n                                {DateTime.fromMillis(info().time.created).toFormat(\"dd MMM yyyy, HH:mm\")}\n                              </div>\n                            </div>\n                          </div>\n                          <div class=\"text-left text-16-medium text-text-strong\">{info().title}</div>\n                        </div>\n                      )"},{"id":"shareid_default_turns","label":"turns()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/routes/share/[shareID].tsx","source_location":"L247-L269","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/enterprise/src/routes/share/[shareID].tsx","source_location":"L247"}],"snippet":"turns = () => (\n                        <div class=\"relative mt-2 pb-8 min-w-0 w-full h-full overflow-y-auto no-scrollbar\">\n                          <div class=\"px-4 py-6\">{title()}</div>\n                          <div class=\"flex flex-col gap-15 items-start justify-start mt-4\">\n                            <For each={messages()}>\n                              {(message) => (\n                                <SessionTurn\n                                  sessionID={data().sessionID}\n                                  messageID={message.id}\n                                  classes={{\n                                    root: \"min-w-0 w-full relative\",\n                                    content: \"flex flex-col justify-between !overflow-visible\",\n                                    container: \"px-4\",\n                        