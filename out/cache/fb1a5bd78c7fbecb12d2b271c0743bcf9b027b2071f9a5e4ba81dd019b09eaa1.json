rkspaceID))\n        .innerJoin(ModelTable, and(eq(ModelTable.workspaceID, KeyTable.workspaceID), isNull(ModelTable.timeDeleted)))\n        .where(and(eq(KeyTable.key, apiKey), isNull(KeyTable.timeDeleted)))\n        .then((rows) => rows.map((row) => row.model)),\n    )\n  })()\n\n  const models = Object.keys(ZenData.list(\"full\").models)\n    .filter((id) => !id.endsWith(\":global\"))\n    .filter((id) => !disabledModels.includes(id))\n\n  return buildModelsResponse(models)\n}"}],"edges":[{"source":"packages_console_app_src_routes_zen_v1_models","target":"server","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/v1/models.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/v1/models.ts","source_location":"L1"}],"weight":1},{"source":"packages_console_app_src_routes_zen_v1_models","target":"model","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/v1/models.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/v1/models.ts","source_location":"L2"}],"weight":1},{"source":"packages_console_app_src_routes_zen_v1_models","target":"index","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/v1/models.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/zen/v1/models.ts","source_location":"L3"}],"weight":1},{"source":"package