ance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/llm-native.test.ts","source_location":"L90"}],"snippet":"sessionOpenAIReasoning = (\n  text: string,\n  options: {\n    readonly storedAs: \"providerMetadata\" | \"providerOptions\"\n    readonly itemId: string\n    readonly encryptedContent: string | null\n  },\n) => {\n  const metadata = {\n    openai: { itemId: options.itemId, reasoningEncryptedContent: options.encryptedContent },\n  }\n  if (options.storedAs === \"providerMetadata\")\n    return Object.assign({ type: \"reasoning\" as const, text }, { providerMetadata: metadata })\n  return Object.assign({ type: \"reasoning\" as const, text }, { providerOptions: metadata })\n}"},{"id":"llm_native_test_preparenativerequest","label":"prepareNativeRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/llm-native.test.ts","source_location":"L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/llm-native.test.ts","source_location":"L126"}],"snippet":"prepareNativeRequest = (input: NativeRequestInput) => LLMClient.prepare(LLMNative.request(input))"},{"id":"llm_native_test_expectopenairesponsesrequest","label":"expectOpenAIResponsesRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/llm-native.test.ts","source_location":"L128-L150","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/test/session/llm-native.test.ts","source_location":"L128"}],"snippet":"expectOpenAIResponsesRequest = (input: {\n  readonly history: NativeRequestInput[\"messages\"]\n  readonly providerOptions?: NativeReques