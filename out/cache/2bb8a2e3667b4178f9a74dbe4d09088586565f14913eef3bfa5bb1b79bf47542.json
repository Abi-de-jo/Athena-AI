iveHeaderName = (name: string) => SENSITIVE_NAME.test(name)"},{"id":"executor_issensitivequeryname","label":"isSensitiveQueryName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L58"}],"snippet":"isSensitiveQueryName = (name: string) => isSensitiveHeaderName(name) || SHORT_QUERY_NAME.test(name)"},{"id":"executor_redactheaders","label":"redactHeaders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L60-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L60"}],"snippet":"redactHeaders = (headers: Headers.Headers, redactedNames: ReadonlyArray<string | RegExp>) =>\n  Object.fromEntries(\n    Object.entries(Headers.redact(headers, [...redactedNames, SENSITIVE_NAME])).map(([name, value]) => [\n      name,\n      String(value),\n    ]),\n  )"},{"id":"executor_redacturl","label":"redactUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L68-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L68"}],"snippet":"redactUrl = (value: string) => {\n  if (!URL.canParse(value)) return REDACTED\n  const url = new URL(value)\n  url.searchParams.forEach((_, key) => {\n    if (isSensitiveQueryName(key)) url.searchParams.set(key, REDACTED)\n  })\n  return url.toString()\n}"},{"id":"executor_normalizedheaders","label":"normalizedHeaders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L77-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L77"}],"snippet":"normalizedHeaders = (headers: Headers.Headers) =>\n  Object.fromEntries(Object.entries(headers).map(([key, value]) => [key.toLowerCase(), value]))"},{"id":"executor_requestid","label":"requestId()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L80-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L80"}],"snippet":"requestId = (headers: Record<string, string>) => {\n  return (\n    headers[\"x-request-id\"] ??\n    headers[\"request-id\"] ??\n    headers[\"x-amzn-requestid\"] ??\n    headers[\"x-amz-request-id\"] ??\n    headers[\"x-goog-request-id\"] ??\n    headers[\"cf-ray\"]\n  )\n}"},{"id":"executor_retryablestatus","label":"retryableStatus()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L91"}],"snippet":"retryableStatus = (status: number) => status === 429 || status === 503 || status === 504 || status === 529"},{"id":"executor_retryafterms","label":"retryAfterMs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L93-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L93"}],"snippet":"retryAfterMs = (headers: Record<string, string>) => {\n  const millis = Number(headers[\"retry-after-ms\"])\n  if (Number.isFinite(millis)) return Math.max(0, millis)\n\n  const value = headers[\"retry-after\"]\n  if (!value) return undefined\n\n  const seconds = Number(value)\n  if (Number.isFinite(seconds)) return Math.max(0, seconds * 1000)\n\n  const date = Date.parse(value)\n  if (!Number.isNaN(date)) return Math.max(0, date - Date.now())\n  return undefined\n}"},{"id":"executor_addratelimitvalue","label":"addRateLimitValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L108-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L108"}],"snippet":"addRateLimitValue = (target: Record<string, string>, key: string, value: string) => {\n  if (key.length > 0) target[key] = value\n}"},{"id":"executor_ratelimitdetails","label":"rateLimitDetails()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L112-L148","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L112"}],"snippet":"rateLimitDetails = (headers: Record<string, string>, retryAfter: number | undefined) => {\n  const limit: Record<string, string> = {}\n  const remaining: Record<string, string> = {}\n  const reset: Record<string, string> = {}\n\n  Object.entries(headers).forEach(([name, value]) => {\n    const openaiLimit = /^x-ratelimit-limit-(.+)$/.exec(name)?.[1]\n    if (openaiLimit) return addRateLimitValue(limit, openaiLimit, value)\n\n    const openaiRemaining = /^x-ratelimit-remaining-(.+)$/.exec(name)?.[1]\n    if (openaiRemaining) return addRateLimitValue(remaining, openaiRemaining, value)\n\n    const openaiReset = /^x-ratelimit-reset-(.+)$/.exec(name)?.[1]\n    if (openaiReset) return addRateLimitValue(reset, openaiReset, value)\n\n    const anthropic = /^anthropic-ratelimit-(.+)-(limit|remaining|reset)$/.exec(name)\n    if (!anthropic) return\n    if (anthropic[2] === \"limit\") return addRateLimitValue(limit, anthropic[1], value)\n    if (anthropic[2] === \"remaining\") return addRateLimitValue(remaining, anthropic[1], value)\n    return addRateLimitValue(reset, anthropic[1], value)\n  })\n\n  if (\n    retryAfter === undefined &&\n    Object.keys(limit).length === 0 &&"},{"id":"executor_requestdetails","label":"requestDetails()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L150-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L150"}],"snippet":"requestDetails = (request: HttpClientRequest.HttpClientRequest, redactedNames: ReadonlyArray<string | RegExp>) =>\n  new HttpRequestDetails({\n    method: request.method,\n    url: redactUrl(request.url),\n    headers: redactHeaders(request.headers, redactedNames),\n  })"},{"id":"executor_responsedetails","label":"responseDetails()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L157-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L157"}],"snippet":"responseDetails = (\n  response: HttpClientResponse.HttpClientResponse,\n  redactedNames: ReadonlyArray<string | RegExp>,\n) =>\n  new HttpResponseDetails({\n    status: response.status,\n    headers: redactHeaders(response.headers, redactedNames),\n  })"},{"id":"executor_secretvalues","label":"secretValues()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L166-L186","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L166"}],"snippet":"secretValues = (request: HttpClientRequest.HttpClientRequest) => {\n  const values = new Set<string>()\n  const add = (value: string) => {\n    if (value.length < 4) return\n    values.add(value)\n    values.add(encodeURIComponent(value))\n  }\n\n  Object.entries(request.headers).forEach(([name, value]) => {\n    if (!isSensitiveHeaderName(name)) return\n    add(value)\n    const bearer = /^Bearer\\s+(.+)$/i.exec(value)?.[1]\n    if (bearer) add(bearer)\n  })\n\n  if (!URL.canParse(request.url)) return values\n  new URL(request.url).searchParams.forEach((value, key) => {\n    if (isSensitiveQueryName(key)) add(value)\n  })\n  return values\n}"},{"id":"executor_secretvalues_add","label":"add()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L168-L172","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L168"}],"snippet":"add = (value: string) => {\n    if (value.length < 4) return\n    values.add(value)\n    values.add(encodeURIComponent(value))\n  }"},{"id":"executor_redactbody","label":"redactBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L191-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L191"}],"snippet":"redactBody = (body: string, request: HttpClientRequest.HttpClientRequest) =>\n  Array.from(secretValues(request)).reduce(\n    (text, secret) => text.split(secret).join(REDACTED),\n    body.replace(REDACT_JSON_FIELD, `$1\"${REDACTED}\"`).replace(REDACT_QUERY_FIELD, `$1${REDACTED}`),\n  )"},{"id":"executor_responsebody","label":"responseBody()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L197-L202","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L197"}],"snippet":"responseBody = (body: string | void, request: HttpClientRequest.HttpClientRequest) => {\n  if (body === undefined) return {}\n  const redacted = redactBody(body, request)\n  if (redacted.length <= BODY_LIMIT) return { body: redacted }\n  return { body: redacted.slice(0, BODY_LIMIT), bodyTruncated: true }\n}"},{"id":"executor_providermessage","label":"providerMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L204-L207","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L204"}],"snippet":"providerMessage = (status: number, body: { readonly body?: string }) => {\n  if (body.body && body.body.length <= 500) return `Provider request failed with HTTP ${status}: ${body.body}`\n  return `Provider request failed with HTTP ${status}`\n}"},{"id":"executor_responsehttp","label":"responseHttp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L209-L223","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L209"}],"snippet":"responseHttp = (input: {\n  readonly request: HttpClientRequest.HttpClientRequest\n  readonly response: HttpClientResponse.HttpClientResponse\n  readonly redactedNames: ReadonlyArray<string | RegExp>\n  readonly body: ReturnType<typeof responseBody>\n  readonly requestId?: string | undefined\n  readonly rateLimit?: HttpRateLimitDetails | undefined\n}) =>\n  new HttpContext({\n    request: requestDetails(input.request, input.redactedNames),\n    response: responseDetails(input.response, input.redactedNames),\n    ...input.body,\n    requestId: input.requestId,\n    rateLimit: input.rateLimit,\n  })"},{"id":"executor_statusreason","label":"statusReason()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L225-L275","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L225"}],"snippet":"statusReason = (input: {\n  readonly status: number\n  readonly message: string\n  readonly retryAfterMs?: number | undefined\n  readonly rateLimit?: HttpRateLimitDetails | undefined\n  readonly http: HttpContext\n}) => {\n  const body = input.http.body ?? \"\"\n  if (/content[-_\\s]?policy|content_filter|safety/i.test(body)) {\n    return new ContentPolicyReason({ message: input.message, http: input.http })\n  }\n  if (input.status === 401) {\n    return new AuthenticationReason({ message: input.message, kind: \"invalid\", http: input.http })\n  }\n  if (input.status === 403) {\n    return new AuthenticationReason({ message: input.message, kind: \"insufficient-permissions\", http: input.http })\n  }\n  if (input.status === 429) {\n    if (/insufficient[-_\\s]?quota|quota[-_\\s]?exceeded/i.test(body)) {\n      return new QuotaExceededReason({ message: input.message, http: input.http })\n    }\n    return new RateLimitReason({\n      message: input.message,\n      retryAfterMs: input.retryAfterMs,\n      rateLimit: input.rateLimit,"},{"id":"executor_statuserror","label":"statusError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L277-L305","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L277"}],"snippet":"statusError =\n  (request: HttpClientRequest.HttpClientRequest, redactedNames: ReadonlyArray<string | RegExp>) =>\n  (response: HttpClientResponse.HttpClientResponse) =>\n    Effect.gen(function* () {\n      if (response.status < 400) return response\n      const body = yield* response.text.pipe(Effect.catch(() => Effect.void))\n      const headers = normalizedHeaders(response.headers)\n      const retryAfter = retryAfterMs(headers)\n      const rateLimit = rateLimitDetails(headers, retryAfter)\n      const details = responseBody(body, request)\n      return yield* new LLMError({\n        module: \"RequestExecutor\",\n        method: \"execute\",\n        reason: statusReason({\n          status: response.status,\n          message: providerMessage(response.status, details),\n          retryAfterMs: retryAfter,\n          rateLimit,\n          http: responseHttp({\n            request,\n            response,\n            redactedNames,\n            body: details,\n            requestId: requestId(headers),\n            rateLimit,"},{"id":"executor_tohttperror","label":"toHttpError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L307-L343","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L307"}],"snippet":"toHttpError = (redactedNames: ReadonlyArray<string | RegExp>) => (error: unknown) => {\n  const transportError = (input: {\n    readonly message: string\n    readonly kind?: string | undefined\n    readonly request?: HttpClientRequest.HttpClientRequest | undefined\n  }) =>\n    new LLMError({\n      module: \"RequestExecutor\",\n      method: \"execute\",\n      reason: new TransportReason({\n        message: input.message,\n        kind: input.kind,\n        url: input.request ? redactUrl(input.request.url) : undefined,\n        http: input.request ? new HttpContext({ request: requestDetails(input.request, redactedNames) }) : undefined,\n      }),\n    })\n\n  if (Cause.isTimeoutError(error)) {\n    return transportError({ message: error.message, kind: \"Timeout\" })\n  }\n  if (!HttpClientError.isHttpClientError(error)) {\n    return transportError({ message: \"HTTP transport failed\" })\n  }\n  const request = \"request\" in error ? error.request : undefined\n  if (error.reason._tag === \"TransportError\") {"},{"id":"executor_tohttperror_transporterror","label":"transportError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L308-L322","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L308"}],"snippet":"transportError = (input: {\n    readonly message: string\n    readonly kind?: string | undefined\n    readonly request?: HttpClientRequest.HttpClientRequest | undefined\n  }) =>\n    new LLMError({\n      module: \"RequestExecutor\",\n      method: \"execute\",\n      reason: new TransportReason({\n        message: input.message,\n        kind: input.kind,\n        url: input.request ? redactUrl(input.request.url) : undefined,\n        http: input.request ? new HttpContext({ request: requestDetails(input.request, redactedNames) }) : undefined,\n      }),\n    })"},{"id":"executor_retrydelay","label":"retryDelay()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L345-L351","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L345"}],"snippet":"retryDelay = (error: LLMError, attempt: number) => {\n  if (error.retryAfterMs !== undefined) return Effect.succeed(Math.min(error.retryAfterMs, MAX_DELAY_MS))\n  return Random.nextBetween(\n    Math.min(BASE_DELAY_MS * 2 ** attempt * 0.8, MAX_DELAY_MS),\n    Math.min(BASE_DELAY_MS * 2 ** attempt * 1.2, MAX_DELAY_MS),\n  ).pipe(Effect.map((delay) => Math.round(delay)))\n}"},{"id":"executor_retrystatusfailures","label":"retryStatusFailures()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L353-L364","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/route/executor.ts","source_location":"L353"}],"snippet":"retryStatusFailures = <A, R>(\n  effect: Effect.Effect<A, LLMError, R>,\n  retries = MAX_RETRIES,\n  attempt = 0,\n): Effect.Effect<A, LLMError, R> =>\n  Effect.catchTag(effect, \"LLM.Error\", (error): Effect.Effect<A, LLMError, R> => {\n    if (!error.retryable || retries <= 0) return Effect.fail(error)\n    return retryDelay(error, attempt).pipe(\n   