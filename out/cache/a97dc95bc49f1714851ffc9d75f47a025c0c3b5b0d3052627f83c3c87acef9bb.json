{"__madarTsExtractorVersion":67,"__madarFileStem":"parse","nodes":[{"id":"parse","label":"parse.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/parse.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/parse.ts","source_location":"L1"}]},{"id":"parse_jsonc","label":"jsonc()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/parse.ts","source_location":"L8-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/parse.ts","source_location":"L8"}],"snippet":"export function jsonc(text: string, filepath: string): unknown {\n  const errors: JsoncParseError[] = []\n  const data = parseJsoncImpl(text, errors, { allowTrailingComma: true })\n  if (errors.length) {\n    const lines = text.split(\"\\n\")\n    const issues = errors\n      .map((e) => {\n        const beforeOffset = text.substring(0, e.offset).split(\"\\n\")\n        const line = beforeOffset.length\n        const column = beforeOffset[beforeOffset.length - 1].length + 1\n        const problemLine = lines[line - 1]\n\n        const error = `${printParseErrorCode(e.error)} at line ${line}, column ${column}`\n        if (!problemLine) return error\n\n        return `${error}\\n   Line ${line}: ${problemLine}\\n${\"\".padStart(column + 9)}^`\n      })\n      .join(\"\\n\")\n    throw new JsonError({\n      path: filepath,\n      message: `\\n--- JSONC Input ---\\n${text}\\n--- Errors ---\\n${issues}\\n--- End ---`,\n    })\n  }\n\n  return data"},{"id":"parse_schema","label":"schema()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/parse.ts","source_location":"L35-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/parse.ts","source_location":"L35"}],"snippet":"export function schema<S extends EffectSchema.Decoder<unknown, never>>(\n  schema: S,\n  data: unknown,\n  source: string,\n): DeepMutable<S[\"Type\"]> {\n  const extra = topLevelExtraKeys(schema, data)\n  if (extra.length) {\n    throw new InvalidError({\n      path: source,\n      issues: [\n        {\n          code: \"unrecognized_keys\",\n          keys: extra,\n          path: [],\n          message: `Unrecognized key${extra.length === 1 ? \"\" : \"s\"}: ${extra.join(\", \")}`,\n        },\n      ],\n    })\n  }\n\n  const decoded = EffectSchema.decodeUnknownExit(schema)(data, { errors: \"all\", propertyOrder: \"original\" })\n  if (Exit.isSuccess(decoded)) return decoded.value as DeepMutable<S[\"Type\"]>\n  const error = Cause.squash(decoded.cause)\n\n  throw new InvalidError("},{"id":"parse_toplevelextrakeys","label":"topLevelExtraKeys()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/parse.ts","source_location":"L74-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/config/parse.ts","source_location":"L74"}],"snippet":"function topLevelExtraKeys(schema: EffectSchema.Top, data: unknown) {\n  if (typeof data !== \"object\" || data === null || Array.isArray(data)) return []\n  if (schema.ast._tag !== \"Objects\" || schema.ast.indexSignatures.length > 0) return []\n  const known = new Set(schema.ast.propertySignatures.map((item) => String(item.name)))\n  return Object.keys(data).filter((key) => !known.has(key))\n}"}],"edges":[{"source":"parse","target":"parse","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/