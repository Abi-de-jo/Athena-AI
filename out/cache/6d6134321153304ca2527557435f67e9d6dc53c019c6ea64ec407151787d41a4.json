{"__madarTsExtractorVersion":67,"__madarFileStem":"worktree-endpoint-repro.test","nodes":[{"id":"worktree_endpoint_repro_test","label":"worktree-endpoint-repro.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L1"}]},{"id":"worktree_endpoint_repro_test_serverscoped","label":"serverScoped()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L36-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L36"}],"snippet":"function serverScoped() {\n  return Effect.sync(() => Server.Default().app)\n}"},{"id":"worktree_endpoint_repro_test_request","label":"request()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L40-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L40"}],"snippet":"function request(server: TestServer, input: string, init?: RequestInit) {\n  return Effect.promise(() => Promise.resolve(server.request(input, init)))\n}"},{"id":"worktree_endpoint_repro_test_withrequesttimeout","label":"withRequestTimeout()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L44-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L44"}],"snippet":"function withRequestTimeout(effect: Effect.Effect<Response>, label: string, ms = 5_000) {\n  return effect.pipe(\n    Effect.timeoutOrElse({\n      duration: `${ms} millis`,\n      orElse: () => Effect.fail(new Error(`${label} timed out after ${ms}ms`)),\n    }),\n  )\n}"},{"id":"worktree_endpoint_repro_test_json","label":"json()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L53-L55","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L53"}],"snippet":"function json<T>(response: Response) {\n  return Effect.promise(() => response.json() as Promise<T>)\n}"},{"id":"worktree_endpoint_repro_test_readywatcher","label":"readyWatcher()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L57-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L57"}],"snippet":"function readyWatcher() {\n  return Effect.gen(function* () {\n    const events = yield* Queue.bounded<GlobalEvent>(1)\n    const on = (event: GlobalEvent) => {\n      if (event.payload.type === Worktree.Event.Ready.type) Queue.offerUnsafe(events, event)\n    }\n\n    GlobalBus.on(\"event\", on)\n    yield* Effect.addFinalizer(() => Effect.sync(() => GlobalBus.off(\"event\", on)))\n\n    return (directory: string) =>\n      Effect.gen(function* () {\n        while (true) {\n          const event = yield* Queue.take(events)\n          if (event.directory === directory) return\n        }\n      }).pipe(\n        Effect.timeoutOrElse({\n          duration: \"10 seconds\",\n          orElse: () => Effect.fail(new Error(`timed out waiting for worktree.ready: ${directory}`)),\n        }),\n      )\n  })\n}"},{"id":"worktree_endpoint_repro_test_readywatcher_on","label":"on()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L60-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L60"}],"snippet":"on = (event: GlobalEvent) => {\n      if (event.payload.type === Worktree.Event.Ready.type) Queue.offerUnsafe(events, event)\n    }"},{"id":"worktree_endpoint_repro_test_removecreatedworktree","label":"removeCreatedWorktree()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L82-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L82"}],"snippet":"function removeCreatedWorktree(input: {\n  server: TestServer\n  rootDirectory: string\n  worktreeDirectory: string\n  ready: Effect.Effect<void, Error>\n}) {\n  return Effect.gen(function* () {\n    yield* input.ready.pipe(Effect.timeout(\"1 second\"), Effect.ignore)\n    yield* Effect.promise(() => disposeAllInstances()).pipe(Effect.ignore)\n\n    const removed = yield* request(\n      input.server,\n      `${ExperimentalPaths.worktree}?directory=${encodeURIComponent(input.rootDirectory)}`,\n      {\n        method: \"DELETE\",\n        headers: { \"content-type\": \"application/json\" },\n        body: JSON.stringify({ directory: input.worktreeDirectory }),\n      },\n    )\n    if (removed.status !== 200) {\n      const message = yield* Effect.promise(() => removed.text())\n      throw new Error(`failed to remove worktree: ${removed.status} ${message}`)\n    }\n    const ok = yield* json<boolean>(removed)\n    if (!ok) throw new Error(`failed to remove worktree ${input.worktreeDirectory}`)"},{"id":"worktree_endpoint_repro_test_createworktreescoped","label":"createWorktreeScoped()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L110-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L110"}],"snippet":"function createWorktreeScoped(input: {\n  server: TestServer\n  directory: string\n  path: string\n  init: RequestInit\n  timeoutLabel: string\n  timeoutMs?: number\n}) {\n  return Effect.acquireRelease(\n    Effect.gen(function* () {\n      const waitReady = yield* readyWatcher()\n      const response = yield* withRequestTimeout(\n        request(input.server, input.path, input.init),\n        input.timeoutLabel,\n        input.timeoutMs,\n      )\n      if (response.status !== 200) {\n        const message = yield* Effect.promise(() => response.text())\n        throw new Error(`${input.timeoutLabel} failed: ${response.status} ${message}`)\n      }\n      expect(response.status).toBe(200)\n      const body = yield* json<CreatedWorktree>(response)\n      return { directory: body.directory, body, ready: waitReady(body.directory) } satisfies ScopedWorktree\n    }),\n    (created) =>"},{"id":"worktree_endpoint_repro_test_setprojectstartcommand","label":"setProjectStartCommand()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L144-L160","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L144"}],"snippet":"function setProjectStartCommand(input: { server: TestServer; directory: string; command: string }) {\n  return Effect.gen(function* () {\n    const current = yield* request(input.server, `/project/current?directory=${encodeURIComponent(input.directory)}`)\n    expect(current.status).toBe(200)\n    const project = yield* json<{ id: string }>(current)\n    const updated = yield* request(\n      input.server,\n      `/project/${project.id}?directory=${encodeURIComponent(input.directory)}`,\n      {\n        method: \"PATCH\",\n        headers: { \"content-type\": \"application/json\" },\n        body: JSON.stringify({ commands: { start: input.command } }),\n      },\n    )\n    expect(updated.status).toBe(200)\n  })\n}"}],"edges":[{"source":"worktree_endpoint_repro_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L1"}],"weight":1},{"source":"worktree_endpoint_repro_test","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/worktree-endpoint-repro.test.ts","source_location":"L2","layer":"base","p