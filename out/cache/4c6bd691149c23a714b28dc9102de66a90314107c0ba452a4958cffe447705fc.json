r>\n          <Probe\n            onReady={async (ctx) => {\n              project = ctx.project\n              await project.sync()\n              done()\n            }}\n            seen={seen}\n            workspaces={workspaces}\n          />\n        </ProjectProvider>"},{"id":"use_event_test_probe","label":"Probe()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/use-event.test.tsx","source_location":"L84-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/use-event.test.tsx","source_location":"L84"}],"snippet":"function Probe(props: {\n  seen: Event[]\n  workspaces: Array<string | undefined>\n  onReady: (ctx: { project: ReturnType<typeof useProject> }) => void\n}) {\n  const project = useProject()\n  const event = useEvent()\n\n  onMount(() => {\n    event.subscribe((evt, { workspace }) => {\n      props.seen.push(evt)\n      props.workspaces.push(workspace)\n    })\n    props.onReady({ project })\n  })\n\n  return <box />\n}","node_kind":"component"}],"edges":[{"source":"use_event_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/use-event.test.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/use-event.test.tsx","source_location":"L2"}],"weight":1},{"source":"use_event_test","target":"solid","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/use-event.test.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai