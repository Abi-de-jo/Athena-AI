{"__madarTsExtractorVersion":67,"__madarFileStem":"managed","nodes":[{"id":"managed","label":"managed.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L1"}]},{"id":"managed_systemmanagedconfigdir","label":"systemManagedConfigDir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L20-L29","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L20"}],"snippet":"function systemManagedConfigDir(): string {\n  switch (process.platform) {\n    case \"darwin\":\n      return \"/Library/Application Support/rimuru\"\n    case \"win32\":\n      return path.join(process.env.ProgramData || \"C:\\\\ProgramData\", \"rimuru-ai\")\n    default:\n      return \"/etc/rimuru\"\n  }\n}"},{"id":"managed_managedconfigdir","label":"managedConfigDir()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L31-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L31"}],"snippet":"export function managedConfigDir() {\n  return process.env.OPENCODE_TEST_MANAGED_CONFIG_DIR || systemManagedConfigDir()\n}"},{"id":"managed_parsemanagedplist","label":"parseManagedPlist()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L35-L41","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L35"}],"snippet":"export function parseManagedPlist(json: string): string {\n  const raw = JSON.parse(json)\n  for (const key of Object.keys(raw)) {\n    if (PLIST_META.has(key)) delete raw[key]\n  }\n  return JSON.stringify(raw)\n}"},{"id":"managed_readmanagedpreferences","label":"readManagedPreferences()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L43-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L43"}],"snippet":"export async function readManagedPreferences() {\n  if (process.platform !== \"darwin\") return\n\n  const user = (() => {\n    try {\n      return os.userInfo().username || \"user\"\n    } catch {\n      return \"user\"\n    }\n  })()\n  const paths = [\n    path.join(\"/Library/Managed Preferences\", user, `${MANAGED_PLIST_DOMAIN}.plist`),\n    path.join(\"/Library/Managed Preferences\", `${MANAGED_PLIST_DOMAIN}.plist`),\n  ]\n\n  for (const plist of paths) {\n    if (!existsSync(plist)) continue\n    const result = await Process.run([\"plutil\", \"-convert\", \"json\", \"-o\", \"-\", plist], { nothrow: true })\n    if (result.code !== 0) continue\n    return {\n      source: `mobileconfig:${plist}`,\n      text: parseManagedPlist(result.stdout.toString()),\n    }\n  }"}],"edges":[{"source":"managed","target":"managed","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/config/managed.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdam