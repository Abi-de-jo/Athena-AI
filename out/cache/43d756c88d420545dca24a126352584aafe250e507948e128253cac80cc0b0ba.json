{"__madarTsExtractorVersion":67,"__madarFileStem":"permission.shared","nodes":[{"id":"permission_shared","label":"permission.shared.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L1"}]},{"id":"permission_shared_dict","label":"dict()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L46-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L46"}],"snippet":"function dict(v: unknown): Dict {\n  if (!v || typeof v !== \"object\" || Array.isArray(v)) {\n    return {}\n  }\n\n  return { ...v }\n}"},{"id":"permission_shared_text","label":"text()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L54-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L54"}],"snippet":"function text(v: unknown): string {\n  return typeof v === \"string\" ? v : \"\"\n}"},{"id":"permission_shared_data","label":"data()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L58-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L58"}],"snippet":"function data(request: PermissionRequest): Dict {\n  const meta = dict(request.metadata)\n  return {\n    ...meta,\n    ...dict(meta.input),\n  }\n}"},{"id":"permission_shared_patterns","label":"patterns()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L66-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L66"}],"snippet":"function patterns(request: PermissionRequest): string[] {\n  return request.patterns.filter((item): item is string => typeof item === \"string\")\n}"},{"id":"permission_shared_createpermissionbodystate","label":"createPermissionBodyState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L70-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L70"}],"snippet":"export function createPermissionBodyState(requestID: string): PermissionBodyState {\n  return {\n    requestID,\n    stage: \"permission\",\n    selected: \"once\",\n    message: \"\",\n    submitting: false,\n  }\n}"},{"id":"permission_shared_permissionoptions","label":"permissionOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L80-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L80"}],"snippet":"export function permissionOptions(stage: PermissionStage): PermissionOption[] {\n  if (stage === \"permission\") {\n    return [\"once\", \"always\", \"reject\"]\n  }\n\n  if (stage === \"always\") {\n    return [\"confirm\", \"cancel\"]\n  }\n\n  return []\n}"},{"id":"permission_shared_permissioninfo","label":"permissionInfo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L92-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L92"}],"snippet":"export function permissionInfo(request: PermissionRequest): PermissionInfo {\n  const pats = patterns(request)\n  const input = data(request)\n  const info = toolPermissionInfo(request.permission, input, dict(request.metadata), pats)\n  if (info) {\n    return info\n  }\n\n  if (request.permission === \"external_directory\") {\n    const meta = dict(request.metadata)\n    const raw = text(meta.parentDir) || text(meta.filepath) || pats[0] || \"\"\n    const dir = raw.includes(\"*\") ? raw.slice(0, raw.indexOf(\"*\")).replace(/[\\\\/]+$/, \"\") : raw\n    return {\n      icon: \"←\",\n      title: `Access external directory ${toolPath(dir, { home: true })}`,\n      lines: pats.map((item) => `- ${item}`),\n    }\n  }\n\n  if (request.permission === \"doom_loop\") {\n    return {\n      icon: \"⟳\",\n      title: \"Continue after repeated failures\",\n      lines: [\"This keeps the session running despite repeated failures.\"],\n    }"},{"id":"permission_shared_permissionalwayslines","label":"permissionAlwaysLines()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L126-L135","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L126"}],"snippet":"export function permissionAlwaysLines(request: PermissionRequest): string[] {\n  if (request.always.length === 1 && request.always[0] === \"*\") {\n    return [`This will allow ${request.permission} until OpenCode is restarted.`]\n  }\n\n  return [\n    \"This will allow the following patterns until OpenCode is restarted.\",\n    ...request.always.map((item) => `- ${item}`),\n  ]\n}"},{"id":"permission_shared_permissionlabel","label":"permissionLabel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L137-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L137"}],"snippet":"export function permissionLabel(option: PermissionOption): string {\n  if (option === \"once\") return \"Allow once\"\n  if (option === \"always\") return \"Allow always\"\n  if (option === \"reject\") return \"Reject\"\n  if (option === \"confirm\") return \"Confirm\"\n  return \"Cancel\"\n}"},{"id":"permission_shared_permissionreply","label":"permissionReply()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L145-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L145"}],"snippet":"export function permissionReply(requestID: string, reply: PermissionReply[\"reply\"], message?: string): PermissionReply {\n  return {\n    requestID,\n    reply,\n    ...(message && message.trim() ? { message: message.trim() } : {}),\n  }\n}"},{"id":"permission_shared_permissionshift","label":"permissionShift()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L153-L165","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L153"}],"snippet":"export function permissionShift(state: PermissionBodyState, dir: -1 | 1): PermissionBodyState {\n  const list = permissionOptions(state.stage)\n  if (list.length === 0) {\n    return state\n  }\n\n  const idx = Math.max(0, list.indexOf(state.selected))\n  const selected = list[(idx + dir + list.length) % list.length]\n  return {\n    ...state,\n    selected,\n  }\n}"},{"id":"permission_shared_permissionhover","label":"permissionHover()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L167-L172","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L167"}],"snippet":"export function permissionHover(state: PermissionBodyState, option: PermissionOption): PermissionBodyState {\n  return {\n    ...state,\n    selected: option,\n  }\n}"},{"id":"permission_shared_permissionrun","label":"permissionRun()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L174-L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L174"}],"snippet":"export function permissionRun(state: PermissionBodyState, requestID: string, option: PermissionOption): PermissionStep {\n  if (state.submitting) {\n    return { state }\n  }\n\n  if (state.stage === \"permission\") {\n    if (option === \"always\") {\n      return {\n        state: {\n          ...state,\n          stage: \"always\",\n          selected: \"confirm\",\n        },\n      }\n    }\n\n    if (option === \"reject\") {\n      return {\n        state: {\n          ...state,\n          stage: \"reject\",\n          selected: \"reject\",\n        },\n      }\n    }"},{"id":"permission_shared_permissionreject","label":"permissionReject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L226-L232","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L226"}],"snippet":"export function permissionReject(state: PermissionBodyState, requestID: string): PermissionReply | undefined {\n  if (state.submitting) {\n    return undefined\n  }\n\n  return permissionReply(requestID, \"reject\", state.message)\n}"},{"id":"permission_shared_permissioncancel","label":"permissionCancel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L234-L240","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L234"}],"snippet":"export function permissionCancel(state: PermissionBodyState): PermissionBodyState {\n  return {\n    ...state,\n    stage: \"permission\",\n    selected: \"reject\",\n  }\n}"},{"id":"permission_shared_permissionescape","label":"permissionEscape()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L242-L256","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L242"}],"snippet":"export function permissionEscape(state: PermissionBodyState): PermissionBodyState {\n  if (state.stage === \"always\") {\n    return {\n      ...state,\n      stage: \"permission\",\n      selected: \"always\",\n    }\n  }\n\n  return {\n    ...state,\n    stage: \"reject\",\n    selected: \"reject\",\n  }\n}"}],"edges":[{"source":"permission_shared","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L16","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L16"}],"weight":1},{"source":"permission_shared","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/permission.shared.ts","source_location":"L17"}],"weight":1},{"source":"permission_shared","target":"tool","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run