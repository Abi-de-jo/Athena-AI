{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_tui_src_editor","nodes":[{"id":"packages_tui_src_editor","label":"editor.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L1"}]},{"id":"packages_tui_src_editor_normalizepromptcontent","label":"normalizePromptContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L12-L24","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L12"}],"snippet":"export function normalizePromptContent(content: string) {\n  if (content.endsWith(\"\\r\\n\")) {\n    const body = content.slice(0, -2)\n    return !body.includes(\"\\n\") && !body.includes(\"\\r\") ? body : content\n  }\n\n  if (content.endsWith(\"\\n\")) {\n    const body = content.slice(0, -1)\n    return !body.includes(\"\\n\") && !body.includes(\"\\r\") ? body : content\n  }\n\n  return content\n}"},{"id":"packages_tui_src_editor_openeditor","label":"openEditor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L26-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L26"}],"snippet":"export async function openEditor(input: { value: string; renderer: CliRenderer; cwd?: string; stdin?: EditorStdio }) {\n  const editor = process.env.VISUAL || process.env.EDITOR\n  if (!editor) return\n  const file = path.join(os.tmpdir(), `${Date.now()}.md`)\n  await writeFile(file, input.value)\n  input.renderer.suspend()\n  input.renderer.currentRenderBuffer.clear()\n  try {\n    await new Promise<void>((resolve, reject) => {\n      const parts = editor.split(\" \")\n      const child = spawn(parts[0]!, [...parts.slice(1), file], {\n        cwd: input.cwd && existsSync(input.cwd) ? input.cwd : process.cwd(),\n        stdio: [input.stdin ?? \"inherit\", \"inherit\", \"inherit\"],\n        shell: process.platform === \"win32\",\n      })\n      child.on(\"error\", reject)\n      child.on(\"exit\", (code, signal) => {\n        if (code === 0) return resolve()\n        reject(new Error(`Editor exited with ${signal ? `signal ${signal}` : `code ${code}`}`))\n      })\n    })\n    return (await readFile(file, \"utf8\")) || undefined\n  } finally {\n    await rm(file, { force: true }).catch(() => {})\n    input.renderer.currentRenderBuffer.clear()"},{"id":"packages_tui_src_editor_discovereditorconnection","label":"discoverEditorConnection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L56-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L56"}],"snippet":"export function discoverEditorConnection(directory: string) {\n  const root = path.join(os.homedir(), \".claude\", \"ide\")\n  const contains = (parent: string) => {\n    const resolved = path.resolve(parent)\n    const relative = path.relative(resolved, path.resolve(directory))\n    return relative === \"\" || (!relative.startsWith(\"..\") && !path.isAbsolute(relative)) ? resolved.length : 0\n  }\n  try {\n    return readdirSync(root)\n      .filter((entry) => entry.endsWith(\".lock\"))\n      .flatMap((entry) => {\n        const file = path.join(root, entry)\n        const port = Number.parseInt(path.basename(file, \".lock\"), 10)\n        if (!Number.isInteger(port) || port <= 0 || port > 65535) return []\n        try {\n          const value = JSON.parse(readFileSync(file, \"utf8\")) as Record<string, unknown>\n          if (value.transport !== undefined && value.transport !== \"ws\") return []\n          const folders = Array.isArray(value.workspaceFolders)\n            ? value.workspaceFolders.filter((item): item is string => typeof item === \"string\")\n            : []\n          const score = Math.max(0, ...folders.map(contains))\n          if (!score) return []\n          return [\n            {\n              url: `ws://127.0.0.1:${port}`,"},{"id":"packages_tui_src_editor_discovereditorconnection_contains","label":"contains()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L58-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L58"}],"snippet":"contains = (parent: string) => {\n    const resolved = path.resolve(parent)\n    const relative = path.relative(resolved, path.resolve(directory))\n    return relative === \"\" || (!relative.startsWith(\"..\") && !path.isAbsolute(relative)) ? resolved.length : 0\n  }"}],"edges":[{"source":"packages_tui_src_editor","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L1"}],"weight":1},{"source":"packages_tui_src_editor","target":"fs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/editor.ts","source_location":"L2","layer":"base","provenance":[{"capa