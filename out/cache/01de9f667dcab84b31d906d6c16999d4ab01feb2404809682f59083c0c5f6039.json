Promise<void>>()\n  const sessionMeta = new Map<string, { limit: number }>()\n\n  const sdkFor = (directory: string) => {\n    const key = directoryKey(directory)\n    const cached = sdkCache.get(key)\n    if (cached) return cached\n    const sdk = serverSDK.createClient({\n      directory,\n      throwOnError: true,\n    })\n    sdkCache.set(key, sdk)\n    return sdk\n  }\n\n  const queryOptionsApi = makeQueryOptionsApi(serverSDK.scope, () => serverSDK.client, sdkFor)\n\n  const [configQuery, providerQuery, pathQuery] = useQueries(() => ({"},{"id":"server_sync_createserversynccontextinner_sdkfor","label":"sdkFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L97-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L97"}],"snippet":"sdkFor = (directory: string) => {\n    const key = directoryKey(directory)\n    const cached = sdkCache.get(key)\n    if (cached) return cached\n    const sdk = serverSDK.createClient({\n      directory,\n      throwOnError: true,\n    })\n    sdkCache.set(key, sdk)\n    return sdk\n  }"},{"id":"server_sync_createserversynccontextinner_setprojects","label":"setProjects()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L153-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L153"}],"snippet":"setProjects = (next: Project[] | ((draft: Project[]) => Project[])) => {\n    setGlobalStore(\"project\", next)\n  }"},{"id":"server_sync_createserversynccontextinner_setsessiontodo","label":"setSessionTodo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L190-L202","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L190"}],"snippet":"setSessionTodo = (sessionID: string, todos: Todo[] | undefined) => {\n    if (!sessionID) return\n    if (!todos) {\n      setGlobalStore(\n        \"session_todo\",\n        produce((draft) => {\n          delete draft[sessionID]\n        }),\n      )\n      return\n    }\n    setGlobalStore(\"session_todo\", sessionID, reconcile(todos, { key: \"id\" }))\n  }"},{"id":"server_sync_createserversynccontextinner_paused","label":"paused()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L204","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L204"}],"snippet":"paused = () => untrack(() => globalStore.reload) !== undefined"},{"id":"server_sync_createserversynccontextinner_loadsessions","label":"loadSessions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L250-L329","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L250"}],"snippet":"async function loadSessions(directory: string, options?: { limit?: number }) {\n    const key = directoryKey(directory)\n    const pending = sessionLoads.get(key)\n    if (pending) {\n      await pending\n      return loadSessions(directory, options)\n    }\n\n    children.pin(key)\n    const [store, setStore] = children.child(directory, { bootstrap: false })\n    const meta = sessionMeta.get(key)\n    const retainedLimit = Math.max(store.limit, options?.limit ?? 0, meta?.limit ?? 0)\n    if (meta && meta.limit >= retainedLimit) {\n      const next = trimSessions(store.session, {\n        limit: retainedLimit,\n        permission: store.permission,\n      })\n      if (next.length !== store.session.length) {\n        setStore(\"session\", reconcile(next, { key: \"id\" }))\n        cleanupDroppedSessionCaches(store, setStore, next, setSessionTodo)\n      }\n      children.unpin(key)\n      return\n    }"},{"id":"server_sync_createserversynccontextinner_bootstrapinstance","label":"bootstrapInstance()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L331-L369","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L331"}],"snippet":"async function bootstrapInstance(directory: string) {\n    const key = directoryKey(directory)\n    if (!key) return\n    const pending = booting.get(key)\n    if (pending) return pending\n\n    children.pin(key)\n    const promise = Promise.resolve().then(async () => {\n      const child = children.ensureChild(directory)\n      const cache = children.vcsCache.get(key)\n      if (!cache) return\n      const sdk = sdkFor(directory)\n      await bootstrapDirectory({\n        directory,\n        scope: serverSDK.scope,\n        mcp: children.mcp(key),\n        global: {\n          config: globalStore.config,\n          path: globalStore.path,\n          project: globalStore.project,\n          provider: globalStore.provider,\n        },\n        sdk,\n        store: child[0],\n        setStore: child[1],"},{"id":"server_sync_createserversynccontext","label":"createServerSyncContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L509-L518","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L509"}],"snippet":"export function createServerSyncContext(serverSDK: ServerSDK) {\n  const inner = createServerSyncContextInner(serverSDK)\n  return Object.assign(inner, {\n    createDirSyncContext: createRefCountMap(\n      (dir) => createDirSyncContext(dir, inner, serverSDK),\n      (dir) => inner.disableMcp(dir),\n      directoryKey,\n    ),\n  })\n}"},{"id":"server_sync_usequeryoptions","label":"useQueryOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L539-L542","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L539"}],"snippet":"export function useQueryOptions() {\n  const sync = useServerSync()\n  return createMemo(() => sync().queryOptions)\n}"}],"edges":[{"source":"server_sync","target":"client","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L1"}],"weight":1},{"source":"server_sync","target":"toast","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/server-sync.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extra