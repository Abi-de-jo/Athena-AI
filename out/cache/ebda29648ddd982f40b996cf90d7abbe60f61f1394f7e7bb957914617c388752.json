rce_location":"L75"}],"snippet":"export interface ReplacementBlocked {\n  readonly _tag: \"ReplacementBlocked\"\n}"},{"id":"packages_core_src_system_context_index_initializationblocked","label":"InitializationBlocked","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L82-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L82"}],"snippet":"export class InitializationBlocked extends Schema.TaggedErrorClass<InitializationBlocked>()(\n  \"SystemContext.InitializationBlocked\",\n  { keys: Schema.Array(Key) },\n) {}"},{"id":"packages_core_src_system_context_index_duplicatekeyerror","label":"DuplicateKeyError","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L87-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L87"}],"snippet":"export class DuplicateKeyError extends Schema.TaggedErrorClass<DuplicateKeyError>()(\"SystemContext.DuplicateKeyError\", {\n  key: Key,\n}) {\n  override get message() {\n    return `Duplicate system context key: ${this.key}`\n  }\n}"},{"id":"packages_core_src_system_context_index_taggederrorclass","label":"TaggedErrorClass","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L87","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L87"}]},{"id":"packages_core_src_system_context_index_packedsource","label":"PackedSource","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L95-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L95"}],"snippet":"interface PackedSource {\n  readonly key: Key\n  readonly load: Effect.Effect<Loaded | Unavailable>\n}"},{"id":"packages_core_src_system_context_index_loaded","label":"Loaded","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L100-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L100"}],"snippet":"interface Loaded {\n  readonly baseline: () => Rendered\n  readonly compare: (previous: Schema.Json) => Compared\n}"},{"id":"packages_core_src_system_context_index_rendered","label":"Rendered","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L105-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L105"}],"snippet":"interface Rendered {\n  readonly text: string\n  readonly snapshot: SourceSnapshot\n}"},{"id":"packages_core_src_system_context_index_availableentry","label":"AvailableEntry","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L115-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L115"}],"snippet":"interface AvailableEntry extends Loaded {\n  readonly _tag: \"Available\"\n  readonly key: Key\n}"},{"id":"packages_core_src_system_context_index_unavailableentry","label":"UnavailableEntry","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L120-L123","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L120"}],"snippet":"interface UnavailableEntry {\n  readonly _tag: \"Unavailable\"\n  readonly key: Key\n}"},{"id":"packages_core_src_system_context_index_make","label":"make()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L131-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L131"}],"snippet":"export function make<A>(source: Source<A>): SystemContext {\n  const decode = Schema.decodeUnknownOption(source.codec)\n  const encode = Schema.encodeSync(source.codec)\n  const equivalent = Schema.toEquivalence(source.codec)\n  return context([\n    {\n      key: source.key,\n      load: source.load.pipe(\n        Effect.map((value) => {\n          if (isUnavailable(value)) return value\n          const snapshot = (): SourceSnapshot => ({\n            value: encode(value),\n            ...(source.removed ? { removed: requireText(source.key, \"removal\", source.removed(value)) } : {}),\n          })\n          return {\n            baseline: (): Rendered => ({\n              text: requireText(source.key, \"baseline\", source.baseline(value)),\n              snapshot: snapshot(),\n            }),\n            compare: (previous): Compared =>\n              Option.match(decode(previous), {\n                onNone: (): Compared => ({ _tag: \"Incompatible\" }),\n                onSome: (decoded): Compared =>\n                  equivalent(decoded, value)\n                    ? { _tag: \"Unchanged\" }"},{"id":"packages_core_src_system_context_index_make_snapshot","label":"snapshot()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L141-L144","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L141"}],"snippet":"snapshot = (): SourceSnapshot => ({\n            value: encode(value),\n            ...(source.removed ? { removed: requireText(source.key, \"removal\", source.removed(value)) } : {}),\n          })"},{"id":"packages_core_src_system_context_index_combine","label":"combine()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L172-L176","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L172"}],"snippet":"export function combine(values: ReadonlyArray<SystemContext>): SystemContext {\n  const sources = values.flatMap((value) => value[ContextTypeId])\n  assertUniqueKeys(sources)\n  return context(sources)\n}"},{"id":"packages_core_src_system_context_index_observe","label":"observe()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L178-L191","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L178"}],"snippet":"observe = (value: SystemContext) =>\n  Effect.forEach(\n    value[ContextTypeId],\n    (source) =>\n      source.load.pipe(\n        Effect.map(\n          (result): Entry =>\n            result === unavailable\n              ? { _tag: \"Unavailable\", key: source.key }\n              : { _tag: \"Available\", key: source.key, ...result },\n        ),\n      ),\n    { concurrency: \"unbounded\" },\n  )"},{"id":"packages_core_src_system_context_index_initialize","label":"initialize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L194-L202","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L194"}],"snippet":"export function initialize(value: SystemContext): Effect.Effect<Generation, InitializationBlocked> {\n  return observe(value).pipe(\n    Effect.flatMap((entries) => {\n      const unavailable = entries.flatMap((entry) => (entry._tag === \"Unavailable\" ? [entry.key] : []))\n      if (unavailable.length > 0) return new InitializationBlocked({ keys: unavailable })\n      return Effect.succeed(initializeObservation(entries))\n    }),\n  )\n}"},{"id":"packages_core_src_system_context_index_initializeobservation","label":"initializeObservation()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L204-L211","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L204"}],"snippet":"function initializeObservation(entries: ReadonlyArray<Entry>): Generation {\n  const available = entries.filter((entry): entry is AvailableEntry => entry._tag === \"Available\")\n  const rendered = available.map((entry) => [entry.key, entry.baseline()] as const)\n  return {\n    baseline: render(rendered.map(([, result]) => result.text)),\n    snapshot: Object.fromEntries(rendered.map(([key, result]) => [key, result.snapshot])),\n  }\n}"},{"id":"packages_core_src_system_context_index_reconcile","label":"reconcile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L214-L222","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L214"}],"snippet":"export function reconcile(value: SystemContext, previous: Snapshot): Effect.Effect<ReconcileResult> {\n  return observe(value).pipe(\n    Effect.map((entries): ReconcileResult => {\n      const result = reconcileObservation(entries, previous)\n      if (result._tag === \"Unchanged\" || result._tag === \"Updated\") return result\n      return replaceObservation(entries, previous)\n    }),\n  )\n}"},{"id":"packages_core_src_system_context_index_reconcileobservation","label":"reconcileObservation()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L224-L276","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L224"}],"snippet":"function reconcileObservation(\n  entries: ReadonlyArray<Entry>,\n  previous: Snapshot,\n): { readonly _tag: \"Unchanged\" } | Updated | { readonly _tag: \"Replace\" } {\n  const keys = new Set(entries.map((entry) => entry.key))\n  const comparisons = new Map<Key, Compared>()\n  for (const entry of entries) {\n    if (entry._tag === \"Unavailable\") continue\n    const stored = getSnapshot(previous, entry.key)\n    if (!stored) continue\n    const compared = entry.compare(stored.value)\n    if (compared._tag === \"Incompatible\") return { _tag: \"Replace\" }\n    comparisons.set(entry.key, compared)\n  }\n  for (const key of Object.keys(previous).sort()) {\n    if (keys.has(Key.make(key))) continue\n    if (previous[key].removed === undefined) return { _tag: \"Replace\" }\n  }\n\n  const snapshot: Record<string, SourceSnapshot> = {}\n  const updates: string[] = []\n  for (const entry of entries) {\n    const stored = getSnapshot(previous, entry.key)\n    if (entry._tag === \"Unavailable\") {\n      if (stored) snapshot[entry.key] = stored"},{"id":"packages_core_src_system_context_index_replace","label":"replace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L279-L281","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L279"}],"snippet":"export function replace(value: SystemContext, previous: Snapshot): Effect.Effect<ReplacementResult> {\n  return observe(value).pipe(Effect.map((entries) => replaceObservation(entries, previous)))\n}"},{"id":"packages_core_src_system_context_index_replaceobservation","label":"replaceObservation()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L283-L287","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L283"}],"snippet":"function replaceObservation(entries: ReadonlyArray<Entry>, previous: Snapshot): ReplacementResult {\n  if (entries.some((entry) => entry._tag === \"Unavailable\" && getSnapshot(previous, entry.key) !== undefined))\n    return { _tag: \"ReplacementBlocked\" }\n  return { _tag: \"ReplacementReady\", generation: initializeObservation(entries) }\n}"},{"id":"packages_core_src_system_context_index_context","label":"context()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L289-L291","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L289"}],"snippet":"function context(sources: ReadonlyArray<PackedSource>): SystemContext {\n  return { [ContextTypeId]: sources }\n}"},{"id":"packages_core_src_system_context_index_render","label":"render()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L293-L295","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L293"}],"snippet":"function render(parts: ReadonlyArray<string>) {\n  return parts.join(\"\\n\\n\")\n}"},{"id":"packages_core_src_system_context_index_getsnapshot","label":"getSnapshot()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L297-L299","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L297"}],"snippet":"function getSnapshot(snapshot: Snapshot, key: Key) {\n  return Object.hasOwn(snapshot, key) ? snapshot[key] : undefined\n}"},{"id":"packages_core_src_system_context_index_isunavailable","label":"isUnavailable()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L301-L303","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L301"}],"snippet":"function isUnavailable(value: unknown): value is Unavailable {\n  return value === unavailable\n}"},{"id":"packages_core_src_system_context_index_requiretext","label":"requireText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L305-L308","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L305"}],"snippet":"function requireText(key: Key, kind: string, text: string) {\n  if (text.length === 0) throw new Error(`System context source ${key} rendered an empty ${kind}`)\n  return text\n}"},{"id":"packages_core_src_system_context_index_assertuniquekeys","label":"assertUniqueKeys()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L310-L316","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/system-context/index.ts","source_location":"L310"}],"snippet":"function assertUniqueKeys(sources: ReadonlyArray<PackedSource>) {\n  const keys = new Set<Key>()\n  for (const source of sources) {\n    if (keys.has(source.key)) throw new DuplicateKeyError({ key: source.key })\n    keys.add(source.key)\n  }\n}"}],"edges":[{"source":"packages_core_src_system_context_index","target":"index","relation":"imports_from","confidence":"EXTRA