{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_context_layout","nodes":[{"id":"packages_app_src_context_layout","label":"layout.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L1"}]},{"id":"packages_app_src_context_layout_getavatarcolors","label":"getAvatarColors()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L31-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L31"}],"snippet":"export function getAvatarColors(key?: string) {\n  if (key && AVATAR_COLOR_KEYS.includes(key as AvatarColorKey)) {\n    return {\n      background: `var(--avatar-background-${key})`,\n      foreground: `var(--avatar-text-${key})`,\n    }\n  }\n  return {\n    background: \"var(--surface-info-base)\",\n    foreground: \"var(--text-base)\",\n  }\n}"},{"id":"packages_app_src_context_layout_getprojectavatarvariant","label":"getProjectAvatarVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L44-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L44"}],"snippet":"export function getProjectAvatarVariant(key?: string): ProjectAvatarVariant {\n  if (key === \"orange\") return \"orange\"\n  if (key === \"pink\") return \"pink\"\n  if (key === \"cyan\") return \"cyan\"\n  if (key === \"purple\") return \"purple\"\n  if (key === \"mint\") return \"cyan\"\n  if (key === \"lime\") return \"green\"\n  return \"gray\"\n}"},{"id":"packages_app_src_context_layout_nextsessiontabsforopen","label":"nextSessionTabsForOpen()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L84-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L84"}],"snippet":"function nextSessionTabsForOpen(current: SessionTabs | undefined, tab: string): SessionTabs {\n  const all = current?.all ?? []\n  if (tab === \"review\") return { all: all.filter((x) => x !== \"review\"), active: tab }\n  if (tab === \"context\") return { all: [tab, ...all.filter((x) => x !== tab)], active: tab }\n  if (!all.includes(tab)) return { all: [...all, tab], active: tab }\n  return { all, active: tab }\n}"},{"id":"packages_app_src_context_layout_sessionpath","label":"sessionPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L92-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L92"}],"snippet":"sessionPath = (key: string) => {\n  const dir = SessionStateKey.route(key).split(\"/\")[0]\n  if (!dir) return\n  const root = decode64(dir)\n  if (!root) return\n  return createPathHelpers(() => root)\n}"},{"id":"packages_app_src_context_layout_normalizesessiontab","label":"normalizeSessionTab()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L100-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L100"}],"snippet":"normalizeSessionTab = (path: ReturnType<typeof createPathHelpers> | undefined, tab: string) => {\n  if (!tab.startsWith(\"file://\")) return tab\n  if (!path) return tab\n  return path.tab(tab)\n}"},{"id":"packages_app_src_context_layout_normalizesessiontablist","label":"normalizeSessionTabList()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L106-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L106"}],"snippet":"normalizeSessionTabList = (path: ReturnType<typeof createPathHelpers> | undefined, all: string[]) => {\n  const seen = new Set<string>()\n  return all.flatMap((tab) => {\n    const value = normalizeSessionTab(path, tab)\n    if (seen.has(value)) return []\n    seen.add(value)\n    return [value]\n  })\n}"},{"id":"packages_app_src_context_layout_normalizestoredsessiontabs","label":"normalizeStoredSessionTabs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L116-L122","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L116"}],"snippet":"normalizeStoredSessionTabs = (key: string, tabs: SessionTabs) => {\n  const path = sessionPath(key)\n  return {\n    all: normalizeSessionTabList(path, tabs.all),\n    active: tabs.active ? normalizeSessionTab(path, tabs.active) : tabs.active,\n  }\n}"},{"id":"packages_app_src_context_layout_currentroute","label":"currentRoute()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L124-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L124"}],"snippet":"currentRoute = (pathname: string, search: string): LayoutRoute => {\n  const parts = pathname.split(\"/\").filter(Boolean)\n  if (parts.length === 0) return { type: \"home\" }\n\n  if (parts[0] === \"new-session\") {\n    const draftID = new URLSearchParams(search).get(\"draftId\")\n    if (!draftID) return { type: \"home\" }\n    return { type: \"draft\", draftID }\n  }\n\n  const dirBase64 = parts[0]\n  const dir = decode64(dirBase64)\n  if (!dir) return { type: \"home\" }\n\n  if (parts[1] !== \"session\") return { type: \"home\" }\n\n  const id = parts[2]\n  if (id) return { type: \"session\", dir, dirBase64, sessionId: id }\n  return { type: \"dir-new-sesssion\", dir, dirBase64 }\n}"},{"id":"home_gowdaman_projects_personal_rimuru_ai_packages_nextjs_route_src_context","label":"/src/context","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app","source_location":"L1","layer":"base","node_kind":"route","framework":"nextjs","framework_role":"next_route","route_path":"/src/context"},{"id":"home_gowdaman_projects_personal_rimuru_ai_packages_nextjs_layout_src_context","label":"layout /src/context","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/layout.tsx","source_location":"L1"}],"node_kind":"component","framework":"nextjs","framework_role":"next_layout","route_path":"/src/context"}],"edges":[{"source":"packages_app_src_context_layout","target":"store","relation":"imports_from","confidence":