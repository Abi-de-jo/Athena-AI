{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_components_settings-v2_providers","nodes":[{"id":"packages_app_src_components_settings_v2_providers","label":"providers.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L1"}]},{"id":"packages_app_src_components_settings_v2_providers_settingsprovidersv2","label":"SettingsProvidersV2()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L33-L265","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L33"}],"snippet":"SettingsProvidersV2: Component = () => {\n  const dialog = useDialog()\n  const language = useLanguage()\n  const serverSdk = useServerSDK()\n  const serverSync = useServerSync()\n  const providers = useProviders()\n\n  const connected = createMemo(() => {\n    return providers\n      .connected()\n      .filter((p) => p.id !== \"rimuru-ai\" || Object.values(p.models).find((m) => m.cost?.input))\n  })\n\n  const popular = createMemo(() => {\n    const connectedIDs = new Set(connected().map((p) => p.id))\n    const items = providers\n      .popular()\n      .filter((p) => !connectedIDs.has(p.id))\n      .slice()\n    items.sort((a, b) => popularProviders.indexOf(a.id) - popularProviders.indexOf(b.id))\n    return items\n  })\n\n  const source = (item: ProviderItem): ProviderSource | undefined => {\n    if (!(\"source\" in item)) return","node_kind":"component"},{"id":"packages_app_src_components_settings_v2_providers_settingsprovidersv2_source","label":"source()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L56-L61","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L56"}],"snippet":"source = (item: ProviderItem): ProviderSource | undefined => {\n    if (!(\"source\" in item)) return\n    const value = item.source\n    if (value === \"env\" || value === \"api\" || value === \"config\" || value === \"custom\") return value\n    return\n  }"},{"id":"packages_app_src_components_settings_v2_providers_settingsprovidersv2_type","label":"type()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L63-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L63"}],"snippet":"type = (item: ProviderItem) => {\n    const current = source(item)\n    if (current === \"env\") return language.t(\"settings.providers.tag.environment\")\n    if (current === \"api\") return language.t(\"provider.connect.method.apiKey\")\n    if (current === \"config\") {\n      if (isConfigCustom(item.id)) return language.t(\"settings.providers.tag.custom\")\n      return language.t(\"settings.providers.tag.config\")\n    }\n    if (current === \"custom\") return language.t(\"settings.providers.tag.custom\")\n    return language.t(\"settings.providers.tag.other\")\n  }"},{"id":"packages_app_src_components_settings_v2_providers_settingsprovidersv2_candisconnect","label":"canDisconnect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L75"}],"snippet":"canDisconnect = (item: ProviderItem) => source(item) !== \"env\""},{"id":"packages_app_src_components_settings_v2_providers_settingsprovidersv2_note","label":"note()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L77","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L77"}],"snippet":"note = (id: string) => PROVIDER_NOTES.find((item) => item.match(id))?.key"},{"id":"packages_app_src_components_settings_v2_providers_settingsprovidersv2_isconfigcustom","label":"isConfigCustom()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L79-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L79"}],"snippet":"isConfigCustom = (providerID: string) => {\n    const provider = serverSync().data.config.provider?.[providerID]\n    if (!provider) return false\n    if (provider.npm !== \"@ai-sdk/openai-compatible\") return false\n    if (!provider.models || Object.keys(provider.models).length === 0) return false\n    return true\n  }"},{"id":"packages_app_src_components_settings_v2_providers_settingsprovidersv2_disableprovider","label":"disableProvider()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L87-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L87"}],"snippet":"disableProvider = async (providerID: string, name: string) => {\n    const before = serverSync().data.config.disabled_providers ?? []\n    const next = before.includes(providerID) ? before : [...before, providerID]\n    serverSync().set(\"config\", \"disabled_providers\", next)\n\n    await serverSync()\n      .updateConfig({ disabled_providers: next })\n      .then(() => {\n        showToast({\n          variant: \"success\",\n          icon: \"circle-check\",\n          title: language.t(\"provider.disconnect.toast.disconnected.title\", { provider: name }),\n          description: language.t(\"provider.disconnect.toast.disconnected.description\", { provider: name }),\n        })\n      })\n      .catch((err: unknown) => {\n        serverSync().set(\"config\", \"disabled_providers\", before)\n        const message = err instanceof Error ? err.message : String(err)\n        showToast({ title: language.t(\"common.requestFailed\"), description: message })\n      })\n  }"},{"id":"packages_app_src_components_settings_v2_providers_settingsprovidersv2_disconnect","label":"disconnect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L109-L132","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L109"}],"snippet":"disconnect = async (providerID: string, name: string) => {\n    if (isConfigCustom(providerID)) {\n      await serverSdk()\n        .client.auth.remove({ providerID })\n        .catch(() => undefined)\n      await disableProvider(providerID, name)\n      return\n    }\n    await serverSdk()\n      .client.auth.remove({ providerID })\n      .then(async () => {\n        await serverSdk().client.global.dispose()\n        showToast({\n          variant: \"success\",\n          icon: \"circle-check\",\n          title: language.t(\"provider.disconnect.toast.disconnected.title\", { provider: name }),\n          description: language.t(\"provider.disconnect.toast.disconnected.description\", { provider: name }),\n        })\n      })\n      .catch((err: unknown) => {\n        const message = err instanceof Error ? err.message : String(err)\n        showToast({ title: language.t(\"common.requestFailed\"), description: message })\n      })\n  }"}],"edges":[{"source":"packages_app_src_components_settings_v2_providers","target":"button_v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L1"}],"weight":1},{"source":"packages_app_src_components_settings_v2_providers","target":"badge_v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/settings-v2/providers.tsx","source_location":"L2"}],"weight":1},{"source":"packages_app_src_components_settings_v2_providers","target":"dialog","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdama