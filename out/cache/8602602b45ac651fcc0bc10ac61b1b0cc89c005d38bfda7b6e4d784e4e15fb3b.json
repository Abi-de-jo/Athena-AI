nagedProviders: [], switchableOrgCount: 0 })\n    if (url.pathname === \"/path\") return json({ home: \"\", state: \"\", config: \"\", worktree, directory })\n    if (url.pathname === \"/api/location\") return json({ directory, project: { id: \"proj_test\", directory: worktree } })"}],"edges":[{"source":"packages_tui_test_fixture_tui_sdk","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/fixture/tui-sdk.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/fixture/tui-sdk.ts","source_location":"L1"}],"weight":1},{"source":"packages_tui_test_fixture_tui_sdk","target":"sdk","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/fixture/tui-sdk.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/fixture/tui-sdk.ts","source_location":"L2"}],"weight":1},{"source":"packages_tui_test_fixture_tui_sdk","target":"packages_tui_test_fixture_tui_sdk_json","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/fixture/tui-sdk.ts","source_location":"L7","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/fixture/tui-sdk.ts","source_location":"L7"}],"weight":1},{"source":"packages_tui_test_fixture_tui_sdk","target":"packages_tui_test_fixture_tui_sdk_eventsource","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/fixture/tui-sdk.ts","source_location":"L14","layer":"base","provenance":[{"cap