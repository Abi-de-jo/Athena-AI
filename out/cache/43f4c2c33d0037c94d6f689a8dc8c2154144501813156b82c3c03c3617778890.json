item.version)\n    .catch(() => undefined)\n}"},{"id":"meta_entrycore","label":"entryCore()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L83-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L83"}],"snippet":"async function entryCore(item: Touch): Promise<Core> {\n  const spec = item.spec\n  const target = item.target\n  const source = pluginSource(spec)\n  if (source === \"file\") {\n    const file = fileTarget(spec, target)\n    return {\n      id: item.id,\n      source,\n      spec,\n      target,\n      modified: file ? await modifiedAt(file) : undefined,\n    }\n  }\n\n  return {\n    id: item.id,\n    source,\n    spec,\n    target,\n    requested: parsePluginSpecifier(spec).version,\n    version: await npmVersion(target),\n  }\n}"},{"id":"meta_fingerprint","label":"fingerprint()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L108-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L108"}],"snippet":"function fingerprint(value: Core) {\n  if (value.source === \"file\") return [value.target, value.modified ?? \"\"].join(\"|\")\n  return [value.target, value.requested ?? \"\", value.version ?? \"\"].join(\"|\")\n}"},{"id":"meta_read","label":"read()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L113-L115","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L113"}],"snippet":"async function read(file: string): Promise<Store> {\n  return Filesystem.readJson<Store>(file).catch(() => ({}) as Store)\n}"},{"id":"meta_row","label":"row()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L117-L122","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L117"}],"snippet":"async function row(item: Touch): Promise<Row> {\n  return {\n    ...item,\n    core: await entryCore(item),\n  }\n}"},{"id":"meta_next","label":"next()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L124-L140","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L124"}],"snippet":"function next(prev: Entry | undefined, core: Core, now: number): { state: State; entry: Entry } {\n  const entry: Entry = {\n    ...core,\n    first_time: prev?.first_time ?? now,\n    last_time: now,\n    time_changed: prev?.time_changed ?? now,\n    load_count: (prev?.load_count ?? 0) + 1,\n    fingerprint: fingerprint(core),\n    themes: prev?.themes,\n  }\n  const state: State = !prev ? \"first\" : prev.fingerprint === entry.fingerprint ? \"same\" : \"updated\"\n  if (state === \"updated\") entry.time_changed = now\n  return {\n    state,\n    entry,\n  }\n}"},{"id":"meta_touchmany","label":"touchMany()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L142-L159","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L142"}],"snippet":"export async function touchMany(items: Touch[]): Promise<Array<{ state: State; entry: Entry }>> {\n  if (!items.length) return []\n  const file = storePath()\n  const rows = await Promise.all(items.map((item) => row(item)))\n\n  return Flock.withLock(lock(file), async () => {\n    const store = await read(file)\n    const now = Date.now()\n    const out: Array<{ state: State; entry: Entry }> = []\n    for (const item of rows) {\n      const hit = next(store[item.id], item.core, now)\n      store[item.id] = hit.entry\n      out.push(hit)\n    }\n    await Filesystem.writeJson(file, store)\n    return out\n  })\n}"},{"id":"meta_touch","label":"touch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L161-L167","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L161"}],"snippet":"export async function touch(spec: string, target: string, id: string): Promise<{ state: State; entry: Entry }> {\n  return touchMany([{ spec, target, id }]).then((item) => {\n    const hit = item[0]\n    if (hit) return hit\n    throw new Error(\"Failed to touch plugin metadata.\")\n  })\n}"},{"id":"meta_settheme","label":"setTheme()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L169-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L169"}],"snippet":"export async function setTheme(id: string, name: string, theme: Theme): Promise<void> {\n  const file = storePath()\n  await Flock.withLock(lock(file), async () => {\n    const store = await read(file)\n    const entry = store[id]\n    if (!entry) return\n    entry.themes = {\n      ...entry.themes,\n      [name]: theme,\n    }\n    await Filesystem.writeJson(file, store)\n  })\n}"},{"id":"meta_list","label":"list()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L183-L186","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L183"}],"snippet":"export async function list(): Promise<Store> {\n  const file = storePath()\n  return Flock.withLock(lock(file), async () => read(file))\n}"}],"edges":[{"source":"meta","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L1"}],"weight":1},{"source":"meta","target":"url","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L2"}],"weight":1},{"source":"meta","target":"flag","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/meta.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/o