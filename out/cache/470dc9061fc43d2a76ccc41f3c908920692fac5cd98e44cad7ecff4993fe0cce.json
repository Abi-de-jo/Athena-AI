{"__madarTsExtractorVersion":67,"__madarFileStem":"content-cache","nodes":[{"id":"content_cache","label":"content-cache.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L1"}]},{"id":"content_cache_approxbytes","label":"approxBytes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L9-L16","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L9"}],"snippet":"export function approxBytes(content: FileContent) {\n  const patchBytes =\n    content.patch?.hunks.reduce((sum, hunk) => {\n      return sum + hunk.lines.reduce((lineSum, line) => lineSum + line.length, 0)\n    }, 0) ?? 0\n\n  return (content.content.length + (content.diff?.length ?? 0) + patchBytes) * 2\n}"},{"id":"content_cache_setbytes","label":"setBytes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L18-L24","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L18"}],"snippet":"function setBytes(path: string, nextBytes: number) {\n  const prev = lru.get(path)\n  if (prev !== undefined) total -= prev\n  lru.delete(path)\n  lru.set(path, nextBytes)\n  total += nextBytes\n}"},{"id":"content_cache_touch","label":"touch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L26-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L26"}],"snippet":"function touch(path: string, bytes?: number) {\n  const prev = lru.get(path)\n  if (prev === undefined && bytes === undefined) return\n  setBytes(path, bytes ?? prev ?? 0)\n}"},{"id":"content_cache_remove","label":"remove()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L32-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L32"}],"snippet":"function remove(path: string) {\n  const prev = lru.get(path)\n  if (prev === undefined) return\n  lru.delete(path)\n  total -= prev\n}"},{"id":"content_cache_reset","label":"reset()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L39-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L39"}],"snippet":"function reset() {\n  lru.clear()\n  total = 0\n}"},{"id":"content_cache_evictcontentlru","label":"evictContentLru()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L44-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L44"}],"snippet":"export function evictContentLru(keep: Set<string> | undefined, evict: (path: string) => void) {\n  const set = keep ?? new Set<string>()\n\n  while (lru.size > MAX_FILE_CONTENT_ENTRIES || total > MAX_FILE_CONTENT_BYTES) {\n    const path = lru.keys().next().value\n    if (!path) return\n\n    if (set.has(path)) {\n      touch(path)\n      if (lru.size <= set.size) return\n      continue\n    }\n\n    remove(path)\n    evict(path)\n  }\n}"},{"id":"content_cache_resetfilecontentlru","label":"resetFileContentLru()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L62-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L62"}],"snippet":"export function resetFileContentLru() {\n  reset()\n}"},{"id":"content_cache_setfilecontentbytes","label":"setFileContentBytes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L66-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L66"}],"snippet":"export function setFileContentBytes(path: string, bytes: number) {\n  setBytes(path, bytes)\n}"},{"id":"content_cache_removefilecontentbytes","label":"removeFileContentBytes()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L70-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/file/content-cache.ts","source_location":"L70