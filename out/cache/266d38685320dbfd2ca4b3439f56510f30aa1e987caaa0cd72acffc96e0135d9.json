{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_plugin_xai","nodes":[{"id":"packages_opencode_src_plugin_xai","label":"xai.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L1"}]},{"id":"packages_opencode_src_plugin_xai_xaiauthpluginoptions","label":"XaiAuthPluginOptions","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L45-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L45"}],"snippet":"interface XaiAuthPluginOptions {\n  authorizeUrl?: string\n  tokenUrl?: string\n  deviceAuthorizationUrl?: string\n}"},{"id":"packages_opencode_src_plugin_xai_pkcecodes","label":"PkceCodes","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L51-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L51"}],"snippet":"interface PkceCodes {\n  verifier: string\n  challenge: string\n}"},{"id":"packages_opencode_src_plugin_xai_generatepkce","label":"generatePKCE()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L56-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L56"}],"snippet":"async function generatePKCE(): Promise<PkceCodes> {\n  const verifier = generateRandomString(64)\n  const hash = await crypto.subtle.digest(\"SHA-256\", new TextEncoder().encode(verifier))\n  return { verifier, challenge: base64UrlEncode(hash) }\n}"},{"id":"packages_opencode_src_plugin_xai_generaterandomstring","label":"generateRandomString()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L62-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L62"}],"snippet":"function generateRandomString(length: number): string {\n  const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~\"\n  return Array.from(crypto.getRandomValues(new Uint8Array(length)))\n    .map((b) => chars[b % chars.length])\n    .join(\"\")\n}"},{"id":"packages_opencode_src_plugin_xai_base64urlencode","label":"base64UrlEncode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L69-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L69"}],"snippet":"function base64UrlEncode(buffer: ArrayBuffer): string {\n  const binary = String.fromCharCode(...new Uint8Array(buffer))\n  return btoa(binary).replace(/\\+/g, \"-\").replace(/\\//g, \"_\").replace(/=+$/, \"\")\n}"},{"id":"packages_opencode_src_plugin_xai_generatestate","label":"generateState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L74-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L74"}],"snippet":"function generateState(): string {\n  return base64UrlEncode(crypto.getRandomValues(new Uint8Array(32)).buffer)\n}"},{"id":"packages_opencode_src_plugin_xai_tokenresponse","label":"TokenResponse","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L78-L85","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L78"}],"snippet":"interface TokenResponse {\n  access_token: string\n  refresh_token: string\n  id_token?: string\n  token_type?: string\n  expires_in?: number\n  scope?: string\n}"},{"id":"packages_opencode_src_plugin_xai_authheaders","label":"authHeaders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L87-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L87"}],"snippet":"function authHeaders() {\n  return {\n    \"Content-Type\": \"application/x-www-form-urlencoded\",\n    Accept: \"application/json\",\n    \"User-Agent\": `opencode/${InstallationVersion}`,\n  }\n}"},{"id":"packages_opencode_src_plugin_xai_accesstokenisexpiring","label":"accessTokenIsExpiring()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L100-L116","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L100"}],"snippet":"export function accessTokenIsExpiring(\n  token: string | undefined,\n  skewMs: number = ACCESS_TOKEN_REFRESH_SKEW_MS,\n): boolean {\n  if (!token || typeof token !== \"string\") return false\n  const parts = token.split(\".\")\n  if (parts.length < 2) return false\n  try {\n    let payload = parts[1].replace(/-/g, \"+\").replace(/_/g, \"/\")\n    while (payload.length % 4 !== 0) payload += \"=\"\n    const claims = JSON.parse(Buffer.from(payload, \"base64\").toString(\"utf8\"))\n    if (typeof claims?.exp !== \"number\") return false\n    return claims.exp * 1000 <= Date.now() + Math.max(0, skewMs)\n  } catch {\n    return false\n  }\n}"},{"id":"packages_opencode_src_plugin_xai_buildauthorizeurl","label":"buildAuthorizeUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L118-L142","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L118"}],"snippet":"export function buildAuthorizeUrl(\n  pkce: PkceCodes,\n  state: string,\n  nonce: string,\n  options: XaiAuthPluginOptions = {},\n): string {\n  // `plan=generic` opts the consent screen into xAI's generic OAuth plan tier;\n  // without it, accounts.x.ai rejects loopback OAuth from non-allowlisted\n  // clients. `referrer=opencode` lets xAI attribute opencode-originated\n  // logins in their OAuth server logs (best-effort attribution while we\n  // continue to reuse the Grok-CLI client_id).\n  const params = new URLSearchParams({\n    response_type: \"code\",\n    client_id: CLIENT_ID,\n    redirect_uri: REDIRECT_URI,\n    scope: SCOPE,\n    code_challenge: pkce.challenge,\n    code_challenge_method: \"S256\",\n    state,\n    nonce,\n    plan: \"generic\",\n    referrer: \"rimuru-ai\",\n  })\n  return `${options.authorizeUrl ?? AUTHORIZE_URL}?${params.toString()}`\n}"},{"id":"packages_opencode_src_plugin_xai_exchangecodefortokens","label":"exchangeCodeForTokens()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L144-L165","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L144"}],"snippet":"async function exchangeCodeForTokens(\n  code: string,\n  pkce: PkceCodes,\n  options: XaiAuthPluginOptions = {},\n): Promise<TokenResponse> {\n  const response = await fetch(options.tokenUrl ?? TOKEN_URL, {\n    method: \"POST\",\n    headers: authHeaders(),\n    body: new URLSearchParams({\n      grant_type: \"authorization_code\",\n      code,\n      redirect_uri: REDIRECT_URI,\n      client_id: CLIENT_ID,\n      code_verifier: pkce.verifier,\n    }).toString(),\n  })\n  if (!response.ok) {\n    const detail = await response.text().catch(() => \"\")\n    throw new Error(`xAI token exchange failed (${response.status})${detail ? `: ${detail}` : \"\"}`)\n  }\n  return response.json() as Promise<TokenResponse>\n}"},{"id":"packages_opencode_src_plugin_xai_refreshaccesstoken","label":"refreshAccessToken()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L167-L182","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L167"}],"snippet":"async function refreshAccessToken(refreshToken: string, options: XaiAuthPluginOptions = {}): Promise<TokenResponse> {\n  const response = await fetch(options.tokenUrl ?? TOKEN_URL, {\n    method: \"POST\",\n    headers: authHeaders(),\n    body: new URLSearchParams({\n      grant_type: \"refresh_token\",\n      refresh_token: refreshToken,\n      client_id: CLIENT_ID,\n    }).toString(),\n  })\n  if (!response.ok) {\n    const detail = await response.text().catch(() => \"\")\n    throw new Error(`xAI token refresh failed (${response.status})${detail ? `: ${detail}` : \"\"}`)\n  }\n  return response.json() as Promise<TokenResponse>\n}"},{"id":"packages_opencode_src_plugin_xai_devicecoderesponse","label":"DeviceCodeResponse","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L184-L191","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L184"}],"snippet":"export interface DeviceCodeResponse {\n  device_code: string\n  user_code: string\n  verification_uri: string\n  verification_uri_complete?: string\n  expires_in?: number\n  interval?: number\n}"},{"id":"packages_opencode_src_plugin_xai_devicetokenerrorbody","label":"DeviceTokenErrorBody","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L193-L196","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L193"}],"snippet":"interface DeviceTokenErrorBody {\n  error?: string\n  error_description?: string\n}"},{"id":"packages_opencode_src_plugin_xai_requestdevicecode","label":"requestDeviceCode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L198-L216","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L198"}],"snippet":"export async function requestDeviceCode(options: XaiAuthPluginOptions = {}): Promise<DeviceCodeResponse> {\n  const response = await fetch(options.deviceAuthorizationUrl ?? DEVICE_AUTHORIZATION_URL, {\n    method: \"POST\",\n    headers: authHeaders(),\n    body: new URLSearchParams({\n      client_id: CLIENT_ID,\n      scope: SCOPE,\n    }).toString(),\n  })\n  if (!response.ok) {\n    const detail = await response.text().catch(() => \"\")\n    throw new Error(`xAI device code request failed (${response.status})${detail ? `: ${detail}` : \"\"}`)\n  }\n  const json = (await response.json()) as DeviceCodeResponse\n  if (!json.device_code || !json.user_code || !json.verification_uri) {\n    throw new Error(\"xAI device code response is missing device_code / user_code / verification_uri\")\n  }\n  return json\n}"},{"id":"packages_opencode_src_plugin_xai_defaultsleep","label":"defaultSleep()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L220-L222","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L220"}],"snippet":"async function defaultSleep(ms: number): Promise<void> {\n  await new Promise<void>((resolve) => setTimeout(resolve, ms))\n}"},{"id":"packages_opencode_src_plugin_xai_positivesecondstoms","label":"positiveSecondsToMs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L232-L235","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L232"}],"snippet":"function positiveSecondsToMs(value: unknown, defaultMs: number): number {\n  const seconds = Number(value)\n  return Number.isFinite(seconds) && seconds > 0 ? seconds * 1000 : defaultMs\n}"},{"id":"packages_opencode_src_plugin_xai_polldevicecodetoken","label":"pollDeviceCodeToken()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L237-L286","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L237"}],"snippet":"export async function pollDeviceCodeToken(\n  device: DeviceCodeResponse,\n  options: XaiAuthPluginOptions & { sleep?: (ms: number) => Promise<void>; now?: () => number } = {},\n): Promise<TokenResponse> {\n  const sleep = options.sleep ?? defaultSleep\n  const now = options.now ?? (() => Date.now())\n  const expiresInMs = positiveSecondsToMs(device.expires_in, DEVICE_CODE_DEFAULT_EXPIRES_MS)\n  const deadline = now() + expiresInMs\n  let intervalMs = Math.max(\n    positiveSecondsToMs(device.interval, DEVICE_CODE_DEFAULT_INTERVAL_MS),\n    DEVICE_CODE_MIN_INTERVAL_MS,\n  )\n\n  while (now() < deadline) {\n    const response = await fetch(options.tokenUrl ?? TOKEN_URL, {\n      method: \"POST\",\n      headers: authHeaders(),\n      body: new URLSearchParams({\n        grant_type: DEVICE_CODE_GRANT_TYPE,\n        client_id: CLIENT_ID,\n        device_code: device.device_code,\n      }).toString(),\n    })\n    if (response.ok) return (await response.json()) as TokenResponse"},{"id":"packages_opencode_src_plugin_xai_html_error","label":"HTML_ERROR()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L330-L376","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L330"}],"snippet":"HTML_ERROR = (error: string) => `<!doctype html>\n<html>\n  <head>\n    <title>OpenCode - xAI Authorization Failed</title>\n    <style>\n      body {\n        font-family:\n          system-ui,\n          -apple-system,\n          sans-serif;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        height: 100vh;\n        margin: 0;\n        background: #131010;\n        color: #f1ecec;\n      }\n      .container {\n        text-align: center;\n        padding: 2rem;\n      }\n      h1 {\n        color: #fc533a;\n        margin-bottom: 1rem;"},{"id":"packages_opencode_src_plugin_xai_pendingoauth","label":"PendingOAuth","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L384-L389","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L384"}],"snippet":"interface PendingOAuth {\n  pkce: PkceCodes\n  state: string\n  resolve: (tokens: TokenResponse) => void\n  reject: (error: Error) => void\n}"},{"id":"packages_opencode_src_plugin_xai_startoauthserver","label":"startOAuthServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L394-L498","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L394"}],"snippet":"async function startOAuthServer(): Promise<{ port: number; redirectUri: string }> {\n  if (oauthServer) return { port: OAUTH_PORT, redirectUri: REDIRECT_URI }\n\n  const server = createServer((req, res) => {\n    const reqUrl = req.url || \"/\"\n    const url = new URL(reqUrl, `http://${OAUTH_HOST}:${OAUTH_PORT}`)\n\n    const origin = req.headers[\"origin\"]\n    const allowOrigin = typeof origin === \"string\" && CORS_ALLOWED_ORIGINS.has(origin) ? origin : \"\"\n    if (allowOrigin) {\n      res.setHeader(\"Access-Control-Allow-Origin\", allowOrigin)\n      res.setHeader(\"Access-Control-Allow-Methods\", \"GET, OPTIONS\")\n      res.setHeader(\"Access-Control-Allow-Headers\", \"Content-Type\")\n      res.setHeader(\"Access-Control-Allow-Private-Network\", \"true\")\n      res.setHeader(\"Vary\", \"Origin\")\n    }\n\n    if (req.method === \"OPTIONS\") {\n      res.writeHead(204)\n      res.end()\n      return\n    }\n\n    if (url.pathname === OAUTH_REDIRECT_PATH) {\n      const code = url.searchParams.get(\"code\")"},{"id":"packages_opencode_src_plugin_xai_startoauthserver_onerror","label":"onError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L479-L482","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L479"}],"snippet":"onError = (err: Error) => {\n      oauthServer = undefined\n      reject(err)\n    }"},{"id":"packages_opencode_src_plugin_xai_stopoauthserver","label":"stopOAuthServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L500-L505","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L500"}],"snippet":"function stopOAuthServer() {\n  if (oauthServer) {\n    oauthServer.close()\n    oauthServer = undefined\n  }\n}"},{"id":"packages_opencode_src_plugin_xai_waitforoauthcallback","label":"waitForOAuthCallback()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L507-L540","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L507"}],"snippet":"function waitForOAuthCallback(pkce: PkceCodes, state: string): Promise<TokenResponse> {\n  // A previous in-flight authorize() that the user abandoned (or that is\n  // being superseded by a fresh attempt) still owns `pendingOAuth`. Reject\n  // it eagerly so its caller stops waiting on a state value that can never\n  // match the next callback.\n  if (pendingOAuth) {\n    pendingOAuth.reject(new Error(\"Superseded by a newer xAI authorize request\"))\n    pendingOAuth = undefined\n  }\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(\n      () => {\n        if (pendingOAuth) {\n          pendingOAuth = undefined\n          reject(new Error(\"OAuth callback timeout - authorization took too long\"))\n        }\n      },\n      5 * 60 * 1000,\n    )\n\n    pendingOAuth = {\n      pkce,\n      state,\n      resolve: (tokens) => {\n        clearTimeout(timeout)"},{"id":"packages_opencode_src_plugin_xai_refreshresult","label":"RefreshResult","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L542-L546","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L542"}],"snippet":"interface RefreshResult {\n  access: string\n  refresh: string\n  expires: number\n}"},{"id":"packages_opencode_src_plugin_xai_xaiauthplugin","label":"XaiAuthPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L548-L716","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L548"}],"snippet":"export async function XaiAuthPlugin(input: PluginInput, options: XaiAuthPluginOptions = {}): Promise<Hooks> {\n  return {\n    auth: {\n      provider: \"xai\",\n      async loader(getAuth) {\n        const auth = await getAuth()\n        if (auth.type !== \"oauth\") return {}\n\n        // Single-flight refresh: collapse concurrent fetches from this loaded\n        // provider onto one HTTP call so we don't replay a rotating refresh_token.\n        let refreshPromise: Promise<RefreshResult> | undefined\n\n        return {\n          // Dummy bearer keeps the AI SDK from bailing on \"missing apiKey\"; the\n          // real OAuth token is injected by the fetch override below.\n          // We intentionally do NOT set baseURL — @ai-sdk/xai already defaults\n          // to https://api.x.ai/v1 and overriding here would silently route\n          // around a user-configured gateway.\n          apiKey: OAUTH_DUMMY_KEY,\n          async fetch(requestInput: RequestInfo | URL, init?: RequestInit) {\n            let currentAuth = await getAuth()\n            // Auth can flip from oauth to api mid-session (user re-runs\n            // /connect with a pasted key). When that happens, pass the\n            // request through untouched so the AI SDK's own apiKey-based\n            // Authorization header reaches xAI unmodified."}],"edges":[{"source":"packages_opencode_src_plugin_xai","target":"plugin","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/xai.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_plugin_xai","target":"auth","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/pac