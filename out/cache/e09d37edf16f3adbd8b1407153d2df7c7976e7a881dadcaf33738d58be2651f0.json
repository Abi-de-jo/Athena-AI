ey, entry)\n  }"},{"id":"scoped_cache_createscopedcache_prune","label":"prune()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/scoped-cache.ts","source_location":"L41-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/scoped-cache.ts","source_location":"L41"}],"snippet":"prune = () => {\n    if (options.maxEntries === undefined) return\n    while (store.size > options.maxEntries) {\n      const key = store.keys().next().value\n      if (!key) return\n      const entry = store.get(key)\n      store.delete(key)\n      if (!entry) continue\n      dispose(key, entry)\n    }\n  }"},{"id":"scoped_cache_createscopedcache_remove","label":"remove()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/scoped-cache.ts","source_location":"L53-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/scoped-cache.ts","source_location":"L53"}],"snippet":"remove = (key: string) => {\n    const entry = store.get(key)\n    if (!entry) return\n    store.delete(key)\n    dispose(key, entry)\n    return entry.value\n  }"},{"id":"scoped_cache_createscopedcache_peek","label":"peek()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/scoped-cache.ts","source_location":"L61-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/scoped-cache.ts","source_location":"L61"}],"snippet":"peek = (key: string) => {\n    sweep()\n    const entry = store.get(key)\n    if (!entry) return\n    if (!expired(entry)) return entry.value\n    store.delete(key)\n    dispose(key, entry)\n  }"},