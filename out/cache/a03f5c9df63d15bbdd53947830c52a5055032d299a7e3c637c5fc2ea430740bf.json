ions = createMemo(() => {\n    // Track sync data and loading state to trigger re-render when they change\n    const mcpData = sync.data.mcp\n    const loadingMcp = loading()\n\n    return pipe(\n      mcpData ?? {},\n      entries(),\n      sortBy(([name]) => name),\n      map(([name, status]) => ({\n        value: name,\n        title: name,\n        description: status.status === \"failed\" ? \"failed\" : status.status,\n        footer: <Status enabled={local.mcp.isEnabled(name)} loading={loadingMcp === name} />,\n        category: undefined,\n      })),\n    )\n  })","node_kind":"component"}],"edges":[{"source":"dialog_mcp","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-mcp.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-mcp.tsx","source_location":"L1"}],"weight":1},{"source":"dialog_mcp","target":"local","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-mcp.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-mcp.tsx","source_location":"L2"}],"weight":1},{"source":"dialog_mcp","target":"sync","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-mcp.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/component/dialog-mcp.tsx","source_location":"L3"}],"weight":1},{"source":"dialog_mcp","target":"remeda","relat