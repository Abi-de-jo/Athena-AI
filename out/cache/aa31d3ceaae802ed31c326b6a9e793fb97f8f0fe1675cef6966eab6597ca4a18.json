jects/personal/rimuru-ai/packages/core/src/config/markdown.ts","source_location":"L22"}],"snippet":"export function sanitize(content: string) {\n  const match = content.match(/^---\\r?\\n([\\s\\S]*?)\\r?\\n---/)\n  if (!match) return content\n  const frontmatter = match[1]\n  const result = frontmatter.split(/\\r?\\n/).flatMap((line) => {\n    if (line.trim().startsWith(\"#\") || line.trim() === \"\" || /^\\s+/.test(line)) return [line]\n    const entry = line.match(/^([a-zA-Z_][a-zA-Z0-9_]*)\\s*:\\s*(.*)$/)\n    if (!entry) return [line]\n    const value = entry[2].trim()\n    if (value === \"\" || value === \">\" || value === \"|\" || value.startsWith('\"') || value.startsWith(\"'\")) return [line]\n    if (!value.includes(\":\")) return [line]\n    return [`${entry[1]}: |-`, `  ${value}`]\n  })\n  return content.replace(frontmatter, () => result.join(\"\\n\"))\n}"}],"edges":[{"source":"packages_core_src_config_markdown","target":"markdown","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/config/markdown.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/config/markdown.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_src_config_markdown","target":"gray_matter","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/config/markdown.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/config/markdown.ts","source_location":"L3"}],"weight":1},{"source":"packages_core_src_config_markdown","target":"packages_core_src_config_markdown_parse","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects