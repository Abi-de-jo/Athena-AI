_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L42-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L42"}],"snippet":"textEvent = (direction: \"client\" | \"server\", body: string): WebSocketEvent => ({\n  direction,\n  kind: \"text\",\n  body,\n})"},{"id":"packages_http_recorder_src_websocket_decodeevent","label":"decodeEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L48-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L48"}],"snippet":"decodeEvent = (event: WebSocketEvent) =>\n  event.kind === \"text\" ? event.body : new Uint8Array(Buffer.from(event.body, \"base64\"))"},{"id":"packages_http_recorder_src_websocket_jsonortext","label":"jsonOrText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L51"}],"snippet":"jsonOrText = (value: string) => Option.match(decodeJson(value), { onNone: () => value, onSome: canonicalizeJson })"},{"id":"packages_http_recorder_src_websocket_assertclientevent","label":"assertClientEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L53-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L53"}],"snippet":"assertClientEvent = (actual: string, expected: WebSocketEvent | undefined, index: number, asJson: boolean) =>\n  Effect.sync(() => {\n    const matches =\n      expected?.direction === \"client\" &&\n      expected.kind === \"text\" &&\n      JSON.stringify(asJson ? jsonOrText(actual) : actual) ===\n        JSON.stringify(asJson ? jsonOrText(expected.body) : expected.body)\n    if (matches) return\n    throw new Error(`WebSocket client frame ${index + 1}: expected ${safeText(expected)}, received ${safeText(actual)}`)\n  })"},{"id":"packages_http_recorder_src_websocket_makewebsocketexecutor","label":"makeWebSocketExecutor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L64-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L64"}],"snippet":"makeWebSocketExecutor = <E>(\n  options: WebSocketRecordReplayOptions<E>,\n): Effect.Effect<WebSocketExecutor<E>, never, Scope.Scope> =>\n  Effect.gen(function* () {\n    const mode = options.mode ?? (yield* resolveAutoMode(options.cassette, options.name))\n    const redactor = options.redactor ?? make()\n    const openSnapshot = (request: WebSocketRequest) => {\n      const snapshot = redactor.request({\n        method: \"GET\",\n        url: request.url,\n        headers: headersRecord(request.headers),\n        body: \"\",\n      })\n      return { url: snapshot.url, headers: snapshot.headers }\n    }\n    const redactEvent = (event: WebSocketEvent) => {\n      if (event.kind === \"binary\") return event\n      const body =\n        event.direction === \"client\"\n          ? redactor.request({ method: \"WEBSOCKET\", url: \"\", headers: {}, body: event.body }).body\n          : redactor.response({ status: 101, headers: {}, body: event.body }).body\n      return { ...event, body }\n    }\n\n    if (mode === \"passthrough\") return options.live"},{"id":"packages_http_recorder_src_websocket_makewebsocketexecutor_opensnapshot","label":"openSnapshot()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L70-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L70"}],"snippet":"openSnapshot = (request: WebSocketRequest) => {\n      const snapshot = redactor.request({\n        method: \"GET\",\n        url: request.url,\n        headers: headersRecord(request.headers),\n        body: \"\",\n      })\n      return { url: snapshot.url, headers: snapshot.headers }\n    }"},{"id":"packages_http_recorder_src_websocket_makewebsocketexecutor_redactevent","label":"redactEvent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L79-L86","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/http-recorder/src/websocket.ts","source_location":"L79"}],"snippet":"redactEvent = (event: WebSocketEvent) => {\n      if (event.kind === \"binary\") return event\n      const body =\n        event.direction === \"client\"\n          ? redactor.request({ method: \"WEBSOCKET\", url: \"\", headers: {}, body: event.body }).body\n          : redactor.response({ status: 101, headers: {}, body: event.body }).body\n      return { ...event, body }\n    }"}],"edges":[{"source":"packages_http_recorder_src_websocket","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rim