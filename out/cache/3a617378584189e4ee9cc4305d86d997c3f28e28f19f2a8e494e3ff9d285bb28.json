{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_app_src_utils_prompt","nodes":[{"id":"packages_app_src_utils_prompt","label":"prompt.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L1"}]},{"id":"packages_app_src_utils_prompt_selectionfromfileurl","label":"selectionFromFileUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L26-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L26"}],"snippet":"function selectionFromFileUrl(url: string): Extract<Inline, { type: \"file\" }>[\"selection\"] {\n  const queryIndex = url.indexOf(\"?\")\n  if (queryIndex === -1) return undefined\n  const params = new URLSearchParams(url.slice(queryIndex + 1))\n  const startLine = Number(params.get(\"start\"))\n  const endLine = Number(params.get(\"end\"))\n  if (!Number.isFinite(startLine) || !Number.isFinite(endLine)) return undefined\n  return {\n    startLine,\n    endLine,\n    startChar: 0,\n    endChar: 0,\n  }\n}"},{"id":"packages_app_src_utils_prompt_textpartvalue","label":"textPartValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L41-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L41"}],"snippet":"function textPartValue(parts: Part[]) {\n  const candidates = parts\n    .filter((part): part is TextPart => part.type === \"text\")\n    .filter((part) => !part.synthetic && !part.ignored)\n  return candidates.reduce((best: TextPart | undefined, part) => {\n    if (!best) return part\n    if (part.text.length > best.text.length) return part\n    return best\n  }, undefined)\n}"},{"id":"packages_app_src_utils_prompt_extractpromptfromparts","label":"extractPromptFromParts()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L56-L203","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L56"}],"snippet":"export function extractPromptFromParts(parts: Part[], opts?: { directory?: string; attachmentName?: string }): Prompt {\n  const textPart = textPartValue(parts)\n  const text = textPart?.text ?? \"\"\n  const directory = opts?.directory\n  const attachmentName = opts?.attachmentName ?? \"attachment\"\n\n  const toRelative = (path: string) => {\n    if (!directory) return path\n\n    const prefix = directory.endsWith(\"/\") ? directory : directory + \"/\"\n    if (path.startsWith(prefix)) return path.slice(prefix.length)\n\n    if (path.startsWith(directory)) {\n      const next = path.slice(directory.length)\n      if (next.startsWith(\"/\")) return next.slice(1)\n      return next\n    }\n\n    return path\n  }\n\n  const inline: Inline[] = []\n  const images: ImageAttachmentPart[] = []\n\n  for (const part of parts) {"},{"id":"packages_app_src_utils_prompt_extractpromptfromparts_torelative","label":"toRelative()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L62-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L62"}],"snippet":"toRelative = (path: string) => {\n    if (!directory) return path\n\n    const prefix = directory.endsWith(\"/\") ? directory : directory + \"/\"\n    if (path.startsWith(prefix)) return path.slice(prefix.length)\n\n    if (path.startsWith(directory)) {\n      const next = path.slice(directory.length)\n      if (next.startsWith(\"/\")) return next.slice(1)\n      return next\n    }\n\n    return path\n  }"},{"id":"packages_app_src_utils_prompt_extractpromptfromparts_pushtext","label":"pushText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L138-L147","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L138"}],"snippet":"pushText = (content: string) => {\n    if (!content) return\n    result.push({\n      type: \"text\",\n      content,\n      start: position,\n      end: position + content.length,\n    })\n    position += content.length\n  }"},{"id":"packages_app_src_utils_prompt_extractpromptfromparts_pushfile","label":"pushFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L149-L161","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/prompt.ts","source_location":"L149"}],"snippet":"pushFile = (item: Extract<Inline, { type: \"file\" }>) => {\n    const content = item.value\n    const attachment: FileAttachmentPart = {\n      type: \"file\",\n      path: item.path,\n      content,\n      start: position,\n      end: position + content.length,\n      selection: item.selection,\n    }\n    result.push(attachment)\n    position += content.length\n  }"},{"id":"packages_app_src_utils_prompt_extractpro