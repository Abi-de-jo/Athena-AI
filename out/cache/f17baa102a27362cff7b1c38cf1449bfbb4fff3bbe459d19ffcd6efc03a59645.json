gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/bash.ts","source_location":"L93"}],"snippet":"shellTokens = (command: string) => command.match(/(?:[^\\s\"']+|\"[^\"]*\"|'[^']*')+/g) ?? []"},{"id":"bash_unquote","label":"unquote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/bash.ts","source_location":"L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/bash.ts","source_location":"L94"}],"snippet":"unquote = (value: string) => value.replace(/^(['\"])(.*)\\1$/, \"$2\")"},{"id":"bash_externalcommanddirectories","label":"externalCommandDirectories()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/bash.ts","source_location":"L95-L105","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/bash.ts","source_location":"L95"}],"snippet":"externalCommandDirectories = (command: string, cwd: string) => {\n  const directories = new Set<string>()\n  for (const token of shellTokens(command)) {\n    const value = unquote(token).replace(/[;,|&]+$/, \"\")\n    if (!path.isAbsolute(value)) continue\n    const resolved = FSUtil.resolve(value)\n    if (FSUtil.contains(cwd, resolved)) continue\n    directories.add(FSUtil.resolve(path.dirname(resolved)))\n  }\n  return [...directories]\n}"}],"edges":[{"source":"bash","target":"bash","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/bash.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/bash.ts","source_location":"L1"}],"weight":1},{"source":"bash","t