{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_cli_cmd_run_runtime","nodes":[{"id":"packages_rimuru_src_cli_cmd_run_runtime","label":"runtime.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_cli_cmd_run_runtime_createsessionresolver","label":"createSessionResolver()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L100-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L100"}],"snippet":"function createSessionResolver(fn?: CreateSession) {\n  if (!fn) {\n    return undefined\n  }\n\n  return async (ctx: BootContext, input: CreateSessionInput): Promise<ResolvedSession> => {\n    const created = await fn(ctx.sdk, input)\n    if (!created.id) {\n      throw new Error(\"Failed to create session\")\n    }\n\n    return {\n      sessionID: created.id,\n      sessionTitle: created.title,\n      agent: input.agent,\n    }\n  }\n}"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_hassession","label":"hasSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L139-L141","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L139"}],"snippet":"function hasSession(input: RunRuntimeInput, state: RuntimeState) {\n  return !input.resolveSession || !!state.sessionID\n}"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_eagerstream","label":"eagerStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L143-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L143"}],"snippet":"function eagerStream(input: RunRuntimeInput, ctx: BootContext) {\n  return ctx.resume === true || !input.resolveSession || !!input.demo\n}"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_variantsfor","label":"variantsFor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L147-L153","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L147"}],"snippet":"function variantsFor(providers: RunProvider[], model: RunInput[\"model\"]) {\n  if (!model) {\n    return []\n  }\n\n  return Object.keys(providers.find((item) => item.id === model.providerID)?.models?.[model.modelID]?.variants ?? {})\n}"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_resolveexittitle","label":"resolveExitTitle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L158-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L158"}],"snippet":"async function resolveExitTitle(\n  ctx: BootContext,\n  input: RunRuntimeInput,\n  state: RuntimeState,\n): Promise<string | undefined> {\n  if (!state.shown || !hasSession(input, state)) {\n    return undefined\n  }\n\n  return ctx.sdk.session\n    .get({\n      sessionID: state.sessionID,\n    })\n    .then((x) => x.data?.title)\n    .catch(() => undefined)\n}"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_runinteractiveruntime","label":"runInteractiveRuntime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L181-L731","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L181"}],"snippet":"async function runInteractiveRuntime(input: RunRuntimeInput, deps: RunRuntimeDeps = {}): Promise<void> {\n  const start = performance.now()\n  const log = trace()\n  const tuiConfigTask = resolveRunTuiConfig()\n  const ctx = await input.boot()\n  const modelTask = resolveModelInfo(ctx.sdk, ctx.directory, ctx.model)\n  const sessionTask =\n    ctx.resume === true\n      ? resolveSessionInfo(ctx.sdk, ctx.sessionID, ctx.model)\n      : Promise.resolve({\n          first: true,\n          history: [],\n          variant: undefined,\n        })\n  const savedTask = resolveSavedVariant(ctx.model)\n  const [tuiConfig, session, savedVariant] = await Promise.all([tuiConfigTask, sessionTask, savedTask])\n  const state: RuntimeState = {\n    shown: !session.first,\n    aborting: false,\n    model: ctx.model,\n    providers: [],\n    variants: [],\n    limits: {},\n    activeVariant: resolveVariant(ctx.variant, session.variant, savedVariant, []),\n    sessionID: ctx.sessionID,"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_runinteractiveruntime_ensuresession","label":"ensureSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L211-L226","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L211"}],"snippet":"ensureSession = () => {\n    if (!input.resolveSession || state.sessionID) {\n      return Promise.resolve()\n    }\n\n    if (state.session) {\n      return state.session\n    }\n\n    state.session = input.resolveSession(ctx).then((next) => {\n      state.sessionID = next.sessionID\n      state.sessionTitle = next.sessionTitle ?? state.sessionTitle\n      state.agent = next.agent\n    })\n    return state.session\n  }"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_runinteractiveruntime_rememberlocal","label":"rememberLocal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L367-L369","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L367"}],"snippet":"rememberLocal = (commit: StreamCommit, after?: LocalReplayAnchor) => {\n    state.localRows = [...state.localRows, { commit, after }].slice(-LOCAL_REPLAY_ROW_LIMIT)\n  }"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_runinteractiveruntime_loadcatalog","label":"loadCatalog()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L371-L400","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L371"}],"snippet":"loadCatalog = async (): Promise<void> => {\n    if (footer.isClosed) {\n      return\n    }\n\n    const [agents, resources, commands] = await Promise.all([\n      ctx.sdk.app\n        .agents({ directory: ctx.directory })\n        .then((x) => x.data ?? [])\n        .catch(() => []),\n      ctx.sdk.experimental.resource\n        .list({ directory: ctx.directory })\n        .then((x) => Object.values(x.data ?? {}))\n        .catch(() => []),\n      ctx.sdk.command\n        .list({ directory: ctx.directory })\n        .then((x) => x.data ?? [])\n        .catch(() => []),\n    ])\n    if (footer.isClosed) {\n      return\n    }\n\n    footer.event({\n      type: \"catalog\","},{"id":"packages_rimuru_src_cli_cmd_run_runtime_runinteractiveruntime_ensurestream","label":"ensureStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L457-L502","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L457"}],"snippet":"ensureStream = () => {\n    if (state.stream) {\n      return state.stream\n    }\n\n    // Share eager prewarm and first-turn boot through one in-flight promise,\n    // but clear it if transport creation fails so a later prompt can retry.\n    const next = (async () => {\n      await ensureSession()\n      if (footer.isClosed) {\n        throw new Error(\"runtime closed\")\n      }\n\n      const mod = await streamTask\n      if (footer.isClosed) {\n        throw new Error(\"runtime closed\")\n      }\n\n      const handle = await mod.createSessionTransport({\n        sdk: ctx.sdk,\n        directory: ctx.directory,\n        sessionID: state.sessionID,\n        thinking: input.thinking,\n        replay: input.replay,\n        replayLimit: input.replayLimit,"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_runinteractiveruntime_runqueue","label":"runQueue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L537-L688","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L537"}],"snippet":"runQueue = async () => {\n    let includeFiles = true\n    if (state.demo) {\n      await state.demo.start()\n    }\n\n    const mod = await import(\"./runtime.queue\")\n    const createSession = input.createSession\n    await mod.runPromptQueue({\n      footer,\n      initialInput: input.initialInput,\n      trace: log,\n      onSend: (prompt) => {\n        state.shown = true\n        state.history.push(prompt)\n        if (prompt.mode !== \"shell\") {\n          rememberLocal({\n            kind: \"user\",\n            text: prompt.text,\n            phase: \"start\",\n            source: \"system\",\n            messageID: prompt.messageID,\n          })\n        }\n      },"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_runinteractivelocalmode","label":"runInteractiveLocalMode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L735-L784","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L735"}],"snippet":"export async function runInteractiveLocalMode(input: RunLocalInput): Promise<void> {\n  const sdk = createOpencodeClient({\n    baseUrl: \"http://rimuru.internal\",\n    fetch: input.fetch,\n    directory: input.directory,\n  })\n  let session: Promise<ResolvedSession> | undefined\n\n  return runInteractiveRuntime({\n    files: input.files,\n    initialInput: input.initialInput,\n    thinking: input.thinking,\n    backgroundSubagents: input.backgroundSubagents,\n    replay: input.replay,\n    replayLimit: input.replayLimit,\n    demo: input.demo,\n    resolveSession: () => {\n      if (session) {\n        return session\n      }\n\n      session = Promise.all([input.resolveAgent(), input.session(sdk)]).then(([agent, next]) => {\n        if (!next?.id) {\n          throw new Error(\"Session not found\")\n        }"},{"id":"packages_rimuru_src_cli_cmd_run_runtime_runinteractivemode","label":"runInteractiveMode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L787-L814","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L787"}],"snippet":"export async function runInteractiveMode(\n  input: RunInput & { createSession?: CreateSession },\n  deps?: RunRuntimeDeps,\n): Promise<void> {\n  return runInteractiveRuntime(\n    {\n      files: input.files,\n      initialInput: input.initialInput,\n      thinking: input.thinking,\n      backgroundSubagents: input.backgroundSubagents,\n      replay: input.replay,\n      replayLimit: input.replayLimit,\n      demo: input.demo,\n      boot: async () => ({\n        sdk: input.sdk,\n        directory: input.directory,\n        sessionID: input.sessionID,\n        sessionTitle: input.sessionTitle,\n        resume: input.resume,\n        agent: input.agent,\n        model: input.model,\n        variant: input.variant,\n      }),\n      createSession: createSessionResolver(input.createSession),\n    },"}],"edges":[{"source":"packages_rimuru_src_cli_cmd_run_runtime","target":"v2","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/runtime.ts","source_location":"L15"}],"weight":1},{"source":"p