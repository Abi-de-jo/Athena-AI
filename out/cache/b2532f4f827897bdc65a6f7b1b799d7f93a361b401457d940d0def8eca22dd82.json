{"__madarTsExtractorVersion":67,"__madarFileStem":"attention","nodes":[{"id":"attention","label":"attention.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L1"}]},{"id":"attention_skipped","label":"skipped()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L60-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L60"}],"snippet":"function skipped(reason: TuiAttentionNotifySkipReason): TuiAttentionNotifyResult {\n  return {\n    ok: false,\n    notification: false,\n    sound: false,\n    skipped: reason,\n  }\n}"},{"id":"attention_normalizetext","label":"normalizeText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L69-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L69"}],"snippet":"function normalizeText(input: string | undefined, fallback: string, limit: number) {\n  const text = stripAnsi(input ?? \"\")\n    .replace(/[ \\t]*[\\r\\n]+[ \\t]*/g, \" \")\n    .replace(/[\\u0000-\\u0009\\u000B\\u000C\\u000E-\\u001F\\u007F-\\u009F]/g, \"\")\n    .trim()\n  const normalized = text.length ? text : fallback\n  return Array.from(normalized).slice(0, limit).join(\"\")\n}"},{"id":"attention_clampvolume","label":"clampVolume()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L78-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L78"}],"snippet":"function clampVolume(volume: number) {\n  if (!Number.isFinite(volume)) return 0\n  return Math.min(1, Math.max(0, volume))\n}"},{"id":"attention_soundvolume","label":"soundVolume()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L83-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L83"}],"snippet":"function soundVolume(input: TuiAttentionNotifyInput, config: Pick<TuiConfig.Resolved, \"attention\">) {\n  if (!config.attention.sound) return\n  if (input.sound === false) return\n  if (input.sound === undefined) return clampVolume(config.attention.volume)\n  if (input.sound === true) return clampVolume(config.attention.volume)\n  return clampVolume(input.sound.volume ?? config.attention.volume)\n}"},{"id":"attention_normalizepack","label":"normalizePack()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L91-L105","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L91"}],"snippet":"function normalizePack(pack: TuiAttentionSoundPack): RegisteredSoundPack | undefined {\n  const id = pack.id.trim()\n  if (!id) return\n  return {\n    id,\n    name: pack.name?.trim() || undefined,\n    builtin: false,\n    sounds: Object.fromEntries(\n      Object.entries(pack.sounds).filter(\n        (item): item is [TuiAttentionSoundName, string] =>\n          Schema.is(AttentionSoundName)(item[0]) && typeof item[1] === \"string\" && item[1].trim().length > 0,\n      ),\n    ),\n  }\n}"},{"id":"attention_focusskip","label":"focusSkip()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L107-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L107"}],"snippet":"function focusSkip(when: TuiAttentionWhen, focus: FocusState) {\n  if (when === \"always\") return\n  if (focus === \"unknown\") return \"focus_unknown\"\n  if (when === \"blurred\" && focus === \"focused\") return \"focused\"\n  if (when === \"focused\" && focus === \"blurred\") return \"blurred\"\n}"},{"id":"attention_createtuiattention","label":"createTuiAttention()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L114-L260","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L114"}],"snippet":"export function createTuiAttention(input: {\n  renderer: AttentionRenderer\n  config: Pick<TuiConfig.Resolved, \"attention\">\n  kv?: TuiKV\n  audio?: Pick<typeof TuiAudio, \"loadSoundFile\" | \"play\">\n}): TuiAttentionHost {\n  let focus: FocusState = \"unknown\"\n  let disposed = false\n  let activePackID: string | undefined\n  const packs = new Map<string, RegisteredSoundPack>([[BUILTIN_PACK.id, BUILTIN_PACK]])\n  const audio = input.audio ?? TuiAudio\n\n  const onFocus = () => {\n    focus = \"focused\"\n  }\n  const onBlur = () => {\n    focus = \"blurred\"\n  }\n\n  input.renderer.on(\"focus\", onFocus)\n  input.renderer.on(\"blur\", onBlur)\n\n  function configuredPackID() {\n    const stored = input.kv?.get<string | undefined>(KV_SOUND_PACK, undefined)\n    return activePackID ?? stored ?? input.config.attention.sound_pack"},{"id":"attention_createtuiattention_onfocus","label":"onFocus()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L126-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L126"}],"snippet":"onFocus = () => {\n    focus = \"focused\"\n  }"},{"id":"attention_createtuiattention_onblur","label":"onBlur()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L129-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L129"}],"snippet":"onBlur = () => {\n    focus = \"blurred\"\n  }"},{"id":"attention_createtuiattention_configuredpackid","label":"configuredPackID()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L136-L139","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L136"}],"snippet":"function configuredPackID() {\n    const stored = input.kv?.get<string | undefined>(KV_SOUND_PACK, undefined)\n    return activePackID ?? stored ?? input.config.attention.sound_pack\n  }"},{"id":"attention_createtuiattention_currentpack","label":"currentPack()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L141-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L141"}],"snippet":"function currentPack() {\n    return packs.get(configuredPackID()) ?? BUILTIN_PACK\n  }"},{"id":"attention_createtuiattention_soundcandidates","label":"soundCandidates()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L145-L149","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L145"}],"snippet":"function soundCandidates(name: TuiAttentionSoundName) {\n    return [input.config.attention.sounds[name], currentPack().sounds[name], BUILTIN_PACK.sounds[name]].filter(\n      (item, index, list): item is string => typeof item === \"string\" && list.indexOf(item) === index,\n    )\n  }"},{"id":"attention_createtuiattention_playsound","label":"playSound()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L151-L167","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/attention.ts","source_location":"L151"}],"snippet":"async function playSound(name: TuiAttentionSoundName, volume: number) {\n    try {\n      for (const file of soundCandidates(name)) {\n        const current = await audio.loadSoundFile(file).catch((error) => {\n          console.debug(\"failed to load attention sound\", { file, error })\n          return null\n        })\n        if (disposed) return false\n        if (current == null) continue\n        if (audio.play(current, { volume }) != null) return true\n      }\n      return false\n    } catch (error) {\n      console.debug(\"failed to play attention sound\", { error })\n      return false\n    }\n  }"}],"edges":[{"source":"attention","target":