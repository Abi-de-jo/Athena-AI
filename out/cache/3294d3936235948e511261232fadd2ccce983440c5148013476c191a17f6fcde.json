pter {\n  const assistantIndex = (messageID: SessionMessage.ID) =>\n    state.messages.findLastIndex((message) => message.id === messageID)\n  // A newer turn supersedes stale incomplete rows; never resume an older assistant projection.\n  const latestAssistantIndex = () => state.messages.findLastIndex((message) => message.type === \"assistant\")\n  const activeShellIndex = (callID: string) =>\n    state.messages.findLastIndex((message) => message.type === \"shell\" && message.callID === callID)\n\n  return {\n    getCurrentAssistant() {\n      return Effect.sync(() => {\n        const index = latestAssistantIndex()\n        if (index < 0) return\n        const assistant = state.messages[index]\n        return assistant?.type === \"assistant\" && !assistant.time.completed ? assistant : undefined\n      })\n    },\n    getAssistant(messageID) {\n      return Effect.sync(() => {\n        const index = assistantIndex(messageID)\n        if (index < 0) return\n        const assistant = state.messages[index]\n        return assistant?.type === \"assistant\" ? assistant : undefined\n      })\n    },"},{"id":"message_updater_memory_assistantindex","label":"assistantIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/message-updater.ts","source_location":"L20-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/message-updater.ts","source_location":"L20"}],"snippet":"assistantIndex = (messageID: SessionMessage.ID) =>\n    state.messages.findLastIndex((message) => message.id === messageID)"},{"id":"message_updater_memory_latestassistantindex","label":"latestAssistantIndex()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/message-updater.ts","source_location":"L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescri