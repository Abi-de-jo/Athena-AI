{"__madarTsExtractorVersion":67,"__madarFileStem":"runtime.lifecycle","nodes":[{"id":"runtime_lifecycle","label":"runtime.lifecycle.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L1"}]},{"id":"runtime_lifecycle_shutdown","label":"shutdown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L91-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L91"}],"snippet":"function shutdown(renderer: CliRenderer): void {\n  if (renderer.isDestroyed) {\n    return\n  }\n\n  if (renderer.externalOutputMode === \"capture-stdout\") {\n    renderer.externalOutputMode = \"passthrough\"\n  }\n\n  if (renderer.screenMode === \"split-footer\") {\n    renderer.screenMode = \"main-screen\"\n  }\n\n  if (!renderer.isDestroyed) {\n    renderer.destroy()\n  }\n}"},{"id":"runtime_lifecycle_splashinfo","label":"splashInfo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L109-L122","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L109"}],"snippet":"function splashInfo(title: string | undefined, history: RunPrompt[]) {\n  if (title && !SessionApi.isDefaultTitle(title)) {\n    return {\n      title,\n      showSession: true,\n    }\n  }\n\n  const next = history.find((item) => item.text.trim().length > 0)\n  return {\n    title: next?.text ?? title,\n    showSession: !!next,\n  }\n}"},{"id":"runtime_lifecycle_footerlabels","label":"footerLabels()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L124-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L124"}],"snippet":"function footerLabels(input: Pick<RunInput, \"agent\" | \"model\" | \"variant\">): FooterLabels {\n  const agentLabel = Locale.titlecase(input.agent ?? \"build\")\n\n  if (!input.model) {\n    return {\n      agentLabel,\n      modelLabel: \"Model default\",\n    }\n  }\n\n  return {\n    agentLabel,\n    modelLabel: formatModelLabel(input.model, input.variant),\n  }\n}"},{"id":"runtime_lifecycle_directorylabel","label":"directoryLabel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L140-L149","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L140"}],"snippet":"function directoryLabel(directory: string) {\n  const resolved = path.resolve(directory)\n  const display =\n    resolved === Global.Path.home\n      ? \"~\"\n      : resolved.startsWith(`${Global.Path.home}${path.sep}`)\n        ? resolved.replace(Global.Path.home, \"~\")\n        : resolved\n  return display.replaceAll(\"\\\\\", \"/\")\n}"},{"id":"runtime_lifecycle_queuesplash","label":"queueSplash()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L151-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L151"}],"snippet":"function queueSplash(\n  renderer: Pick<CliRenderer, \"writeToScrollback\" | \"requestRender\">,\n  state: SplashState,\n  phase: keyof SplashState,\n  write: ScrollbackWriter | undefined,\n): boolean {\n  if (state[phase]) {\n    return false\n  }\n\n  if (!write) {\n    return false\n  }\n\n  state[phase] = true\n  renderer.writeToScrollback(write)\n  renderer.requestRender()\n  return true\n}"},{"id":"runtime_lifecycle_createruntimelifecycle","label":"createRuntimeLifecycle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L176-L406","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L176"}],"snippet":"export async function createRuntimeLifecycle(input: LifecycleInput): Promise<Lifecycle> {\n  const source = resolveInteractiveStdin()\n  let unregisterKeymap: (() => void) | undefined\n\n  try {\n    const renderer = await createCliRenderer({\n      stdin: source.stdin,\n      targetFps: 30,\n      maxFps: 60,\n      useMouse: false,\n      autoFocus: false,\n      openConsoleOnError: false,\n      exitOnCtrlC: false,\n      useKittyKeyboard: { events: process.platform === \"win32\" },\n      screenMode: \"split-footer\",\n      footerHeight: FOOTER_HEIGHT,\n      externalOutputMode: \"capture-stdout\",\n      consoleMode: \"disabled\",\n      clearOnShutdown: false,\n    })\n    const theme = await resolveRunTheme(renderer)\n    renderer.setBackgroundColor(theme.background)\n    const keymap = createDefaultOpenTuiKeymap(renderer)\n    unregisterKeymap = registerOpencodeKeymap(keymap, renderer, input.tuiConfig)\n    const state: SplashState = {"},{"id":"runtime_lifecycle_createruntimelifecycle_sigint","label":"sigint()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L281-L283","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L281"}],"snippet":"sigint = () => {\n      footer.requestExit()\n    }"},{"id":"runtime_lifecycle_createruntimelifecycle_attachsigint","label":"attachSigint()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L285-L292","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L285"}],"snippet":"attachSigint = () => {\n      if (closed || sigintRegistered) {\n        return\n      }\n\n      process.on(\"SIGINT\", sigint)\n      sigintRegistered = true\n    }"},{"id":"runtime_lifecycle_createruntimelifecycle_detachsigint","label":"detachSigint()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L294-L301","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/runtime.lifecycle.ts","source_location":"L294"}],"snippet":"detachSigint = () => {\n      if (!sigintRegistered) {\n        return\n      }\n\n      process.off(\"SIGINT\", sigint)\n      sig