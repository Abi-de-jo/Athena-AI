{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_test_acp_permission.test","nodes":[{"id":"packages_rimuru_test_acp_permission_test","label":"permission.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L1"}]},{"id":"packages_rimuru_test_acp_permission_test_polluntil","label":"pollUntil()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L17-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L17"}],"snippet":"pollUntil = async (\n  check: () => boolean | Promise<boolean>,\n  message: string,\n  opts?: { timeoutMs?: number; intervalMs?: number },\n) => {\n  const started = Date.now()\n  while (true) {\n    if (await check()) return\n    if (Date.now() - started > (opts?.timeoutMs ?? 2000)) throw new Error(message)\n    await new Promise((resolve) => setTimeout(resolve, opts?.intervalMs ?? 5))\n  }\n}"},{"id":"packages_rimuru_test_acp_permission_test_makesessionservice","label":"makeSessionService()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L30-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L30"}],"snippet":"function makeSessionService() {\n  return ManagedRuntime.make(ACPSession.defaultLayer).runSync(\n    ACPSession.Service.use((service) => Effect.succeed(service)),\n  )\n}"},{"id":"packages_rimuru_test_acp_permission_test_createharness","label":"createHarness()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L36-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L36"}],"snippet":"function createHarness(\n  requestPermission: (params: RequestPermissionRequest) => Promise<RequestPermissionResponse> = () =>\n    Promise.resolve({ outcome: { outcome: \"selected\", optionId: \"once\" } }),\n) {\n  const replies: PermissionReplyParams[] = []\n  const requests: RequestPermissionRequest[] = []\n  const updates: SessionUpdateParams[] = []\n  const session = makeSessionService()\n  const sdk = {\n    permission: {\n      reply: (params: PermissionReplyParams) => {\n        replies.push(params)\n        return Promise.resolve({ data: true })\n      },\n    },\n    session: {\n      message: () => Promise.resolve({ data: undefined }),\n    },\n  } as unknown as OpencodeClient\n  const connection = {\n    requestPermission: (params: RequestPermissionRequest) => {\n      requests.push(params)\n      return requestPermission(params)\n    },\n    sessionUpdate: (params: SessionUpdateParams) => {"},{"id":"packages_rimuru_test_acp_permission_test_createsession","label":"createSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L70-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L70"}],"snippet":"async function createSession(session: ACPSession.Interface, sessionId: string, cwd = \"/workspace\") {\n  await Effect.runPromise(session.create({ id: sessionId, cwd }))\n}"},{"id":"packages_rimuru_test_acp_permission_test_createknowntextpart","label":"createKnownTextPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L74-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L74"}],"snippet":"async function createKnownTextPart(\n  session: ACPSession.Interface,\n  sessionId: string,\n  messageId: string,\n  partId: string,\n) {\n  await Effect.runPromise(\n    session.recordPartMetadata({\n      sessionId,\n      messageId,\n      partId,\n      partType: \"text\",\n      role: \"assistant\",\n    }),\n  )\n}"},{"id":"packages_rimuru_test_acp_permission_test_permissionasked","label":"permissionAsked()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L91-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L91"}],"snippet":"function permissionAsked(\n  sessionID: string,\n  id: string,\n  input: {\n    permission?: string\n    metadata?: Record<string, unknown>\n    tool?: { messageID: string; callID: string }\n  } = {},\n) {\n  return {\n    id: `evt_${id}`,\n    type: \"permission.asked\",\n    properties: {\n      id,\n      sessionID,\n      permission: input.permission ?? \"bash\",\n      patterns: [\"*\"],\n      metadata: input.metadata ?? { command: \"printf hello\" },\n      always: [],\n      ...(input.tool ? { tool: input.tool } : {}),\n    },\n  } as PermissionEvent\n}"},{"id":"packages_rimuru_test_acp_permission_test_textdelta","label":"textDelta()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L115-L127","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L115"}],"snippet":"function textDelta(sessionID: string, messageID: string, partID: string, delta: string) {\n  return {\n    id: `evt_${sessionID}_${messageID}_${partID}`,\n    type: \"message.part.delta\",\n    properties: {\n      sessionID,\n      messageID,\n      partID,\n      field: \"text\",\n      delta,\n    },\n  } as Event\n}"},{"id":"packages_rimuru_test_acp_permission_test_textfromupdates","label":"textFromUpdates()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L129-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L129"}],"snippet":"function textFromUpdates(updates: SessionUpdateParams[], sessionId: string) {\n  return updates\n    .filter((item) => item.sessionId === sessionId)\n    .map((item) => item.update)\n    .filter((update): update is Extract<SessionUpdate, { sessionUpdate: \"agent_message_chunk\" }> => {\n      return update.sessionUpdate === \"agent_message_chunk\"\n    })\n    .map((update) => (update.content.type === \"text\" ? update.content.text : \"\"))\n    .join(\"\")\n}"}],"edges":[{"source":"packages_rimuru_test_acp_permission_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/acp/permission.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_