ledResponseHandler = createJsonErrorResponseHandler(errorStructure)\n\n    this.supportsStructuredOutputs = config.supportsStructuredOutputs ?? false\n  }\n\n  get provider(): string {\n    return this.config.provider\n  }"},{"id":"openai_compatible_chat_language_model_languagemodelv3","label":"LanguageModelV3","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/github-copilot/chat/openai-compatible-chat-language-model.ts","source_location":"L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/github-copilot/chat/openai-compatible-chat-language-model.ts","source_location":"L53"}]},{"id":"openai_compatible_chat_language_model_openaicompatiblechatlanguagemodel_constructor","label":".constructor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/github-copilot/chat/openai-compatible-chat-language-model.ts","source_location":"L63-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/github-copilot/chat/openai-compatible-chat-language-model.ts","source_location":"L63"}],"snippet":"constructor(modelId: OpenAICompatibleChatModelId, config: OpenAICompatibleChatConfig) {\n    this.modelId = modelId\n    this.config = config\n\n    // initialize error handling:\n    const errorStructure = config.errorStructure ?? defaultOpenAICompatibleErrorStructure\n    this.chunkSchema = createOpenAICompatibleChatChunkSchema(errorStructure.errorSchema)\n    this.failedResponseHandler = createJsonErrorResponseHandler(errorStructure)\n\n    this.supportsStructuredOutputs = config.supportsStructuredOutputs ?? false\n  }"},{"id":"openai_compatible_chat_language_model_openaicompatiblechatlanguagemodel_getargs","label":".getArgs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/github-copilot/chat/openai-compatible-chat-language-model.ts","source_location":"L87-L190","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/github-copilot/chat/openai-compatible-chat-language-model.ts","source_location":"L87"}],"snippet":"private async getArgs({\n    prompt,\n    maxOutputTokens,\n    temperature,\n    topP,\n    topK,\n    frequencyPenalty,\n    presencePenalty,\n    providerOptions,\n    stopSequences,\n    responseFormat,\n    seed,\n    toolChoice,\n    tools,\n  }: LanguageModelV3CallOptions) {\n    const warnings: SharedV3Warning[] = []\n\n    // Parse provider options\n    const compatibleOptions = Object.assign(\n      (await parseProviderOptions({\n        provider: \"copilot\",\n        providerOptions,\n        schema: openaiCompatibleProviderOptions,\n      })) ?? {},\n      (await parseProviderOptions({"},{"id":"openai_compatible_chat_language_model_openaicompatiblechatlanguagemodel_dogenerate","label":".doGenerate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/github-copilot/chat/openai-compatible-chat-language-model.ts","source_location":"L192-L303","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/github-copilot/chat/openai-compatible-chat-language-model.ts","source_location":"L192"}],"snippet":"async doGenerate(options: LanguageModelV3CallOptions) {\n    const { args, warnings } = await this.getArgs({ ...options })\n\n    const body = JSON.stringify(args)\n\n    const {\n      responseHeaders,\n      value: responseBody,\n      rawValue: rawResponse,\n    } = await postJsonToApi({\n      url: this.config.url({\n        path: \"/chat/completions\",\n        modelId: this.modelId,\n      }),\n      headers: combineHeaders(this.config.headers(), options.headers),\n      body: args,\n      failedResponseHandler: this.failedResponseHandler,\n      successfulResponseHandler: createJsonResponseHandler(OpenAICompatibleChatResponseSchema),\n      abortSignal: options.abortSignal,\n      fetch: this.config.fetch,\n    })\n\n    const choice = responseBody.choices[0]\n    const content: Array<LanguageModelV3Content> = []"},{"id":"openai_compatible_chat_language_model_openaicompatiblechatlanguagemodel_dostream","label":".doStream()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/github-copilot/chat/openai-compatible-chat-language-model.ts","source_location":"L305-L723","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/github-copilot/chat/openai-compatible-chat-language-model.ts","source_location":"L305"}],"snippet":"async doStream(options: LanguageModelV3CallOptions) {\n    const { args, warnings } = await this.getArgs({ ...options })\n\n    const body = {\n      ...args,\n      stream: true,\n\n      // only include stream_options when in strict compatibility mode:\n      stream_options: this.config.includeUsage ? { include_usage: true } : undefined,\n    }\n\n    const metadataExtractor = this.config.metadataExtractor?.createStreamExtractor()\n\n    const { responseHeaders, value: response } = await postJsonToApi({\n      url: this.config.url({\n        path: \"/chat/completions\",\n        modelId: this.modelId,\n      }),\n      headers: combineHeaders(this.config.headers(), options.headers),\n      body,\n      failedResponseHandler: this.failedResponseHandler,\n      successfulResponseHandler: createEventSourceResponseHandler(this.chunkSchema),\n      abortSignal: options.abortSignal,\n      fetch: this.config.fetch,\n    })"},{"id":"openai_compatible_chat_language_model_createopenaicompatiblecha