{"__madarTsExtractorVersion":67,"__madarFileStem":"workspace-proxy.test","nodes":[{"id":"workspace_proxy_test","label":"workspace-proxy.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L1"}]},{"id":"workspace_proxy_test_serverurl","label":"serverUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L10-L12","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L10"}],"snippet":"function serverUrl() {\n  return HttpServer.HttpServer.use((server) => Effect.succeed(HttpServer.formatAddress(server.address)))\n}"},{"id":"workspace_proxy_test_listenserver","label":"listenServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L26-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L26"}],"snippet":"function listenServer<E, R>(handler: TestHandler<E, R>) {\n  return Effect.gen(function* () {\n    yield* HttpServer.serveEffect()(HttpServerRequest.HttpServerRequest.use(handler))\n    return yield* serverUrl()\n  })\n}"},{"id":"workspace_proxy_test_listentestserver","label":"listenTestServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L33-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L33"}],"snippet":"function listenTestServer<E, R>(handler: TestHandler<E, R>) {\n  return Effect.gen(function* () {\n    // Build into the current test scope so the listener stays alive until the\n    // test finishes. Using Effect.provide here would release it immediately.\n    const context = yield* Layer.build(NodeHttpServer.layer(Http.createServer, { host: \"127.0.0.1\", port: 0 }))\n    const server = Context.get(context, HttpServer.HttpServer)\n    yield* server.serve(HttpServerRequest.HttpServerRequest.use(handler))\n    return HttpServer.formatAddress(server.address)\n  })\n}"},{"id":"workspace_proxy_test_echowebsocket","label":"echoWebSocket()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L44-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L44"}],"snippet":"function echoWebSocket(request: HttpServerRequest.HttpServerRequest) {\n  return Effect.gen(function* () {\n    const socket = yield* Effect.orDie(request.upgrade)\n    const write = yield* socket.writer\n    // The upstream announces the negotiated protocol, then echoes every\n    // received frame. The assertions use those messages to prove proxy flow.\n    yield* socket\n      .runRaw((message) => write(`echo:${String(message)}`), {\n        onOpen: write(`protocol:${request.headers[\"sec-websocket-protocol\"] ?? \"none\"}`).pipe(\n          Effect.catch(() => Effect.void),\n        ),\n      })\n      .pipe(Effect.catch(() => Effect.void))\n    return HttpServerResponse.empty()\n  })\n}"}],"edges":[{"source":"workspace_proxy_test","target":"platform_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L1"}],"weight":1},{"source":"workspace_proxy_test","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L2"}],"weight":1},{"source":"workspace_proxy_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L3"}],"weight":1},{"source":"workspace_proxy_test","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/workspace-proxy.test.ts","source_location":"L4"}],"weight":1},{"source":"workspace_proxy_test","target":"so