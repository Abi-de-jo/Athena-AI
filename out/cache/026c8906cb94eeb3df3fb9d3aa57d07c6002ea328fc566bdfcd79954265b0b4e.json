{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_ui_src_context_dialog","nodes":[{"id":"packages_ui_src_context_dialog","label":"dialog.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L1"}]},{"id":"packages_ui_src_context_dialog_init","label":"init()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L32-L156","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L32"}],"snippet":"function init() {\n  const [stack, setStack] = createSignal<Active[]>([])\n  const timer = { current: undefined as ReturnType<typeof setTimeout> | undefined }\n  const lock = { value: false }\n\n  onCleanup(() => {\n    if (timer.current === undefined) return\n    clearTimeout(timer.current)\n    timer.current = undefined\n  })\n\n  const close = (id?: string) => {\n    const items = stack()\n    const current = id ? items.find((item) => item.id === id) : items.at(-1)\n    if (!current || lock.value) return\n    lock.value = true\n    current.onClose?.()\n    current.setClosing(true)\n\n    const closed = current.id\n    if (timer.current !== undefined) {\n      clearTimeout(timer.current)\n      timer.current = undefined\n    }"},{"id":"packages_ui_src_context_dialog_init_close","label":"close()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L43-L63","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L43"}],"snippet":"close = (id?: string) => {\n    const items = stack()\n    const current = id ? items.find((item) => item.id === id) : items.at(-1)\n    if (!current || lock.value) return\n    lock.value = true\n    current.onClose?.()\n    current.setClosing(true)\n\n    const closed = current.id\n    if (timer.current !== undefined) {\n      clearTimeout(timer.current)\n      timer.current = undefined\n    }\n\n    timer.current = setTimeout(() => {\n      timer.current = undefined\n      current.dispose()\n      setStack((items) => items.filter((item) => item.id !== closed))\n      lock.value = false\n    }, 100)\n  }"},{"id":"packages_ui_src_context_dialog_init_onkeydown","label":"onKeyDown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L68-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L68"}],"snippet":"onKeyDown = (event: KeyboardEvent) => {\n      if (event.key !== \"Escape\") return\n      close()\n      event.preventDefault()\n      event.stopPropagation()\n    }"},{"id":"packages_ui_src_context_dialog_init_mount","label":"mount()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L78-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L78"}],"snippet":"mount = (element: DialogElement, owner: Owner, onClose: (() => void) | undefined, layer: number) => {\n    const id = Math.random().toString(36).slice(2)\n    const zIndex = 50 + layer * 10\n    let dispose: (() => void) | undefined\n    let setClosing: ((closing: boolean) => void) | undefined\n\n    const node = runWithOwner(owner, () =>\n      createRoot((d: () => void) => {\n        dispose = d\n        const [closing, setClosingSignal] = createSignal(false)\n        setClosing = setClosingSignal\n        return (\n          <Kobalte\n            modal\n            open={!closing()}\n            onOpenChange={(open: boolean) => {\n              if (open) return\n              close(id)\n            }}\n          >\n            <Kobalte.Portal>\n              <Kobalte.Overlay\n                data-component=\"dialog-overlay\"\n                style={{ \"z-index\": String(zIndex) }}\n                onClick={() => close(id)}"},{"id":"packages_ui_src_context_dialog_init_push","label":"push()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L130-L137","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L130"}],"snippet":"push = (element: DialogElement, owner: Owner, onClose?: () => void) => {\n    if (timer.current !== undefined) {\n      clearTimeout(timer.current)\n      timer.current = undefined\n    }\n    lock.value = false\n    mount(element, owner, onClose, stack().length)\n  }"},{"id":"packages_ui_src_context_dialog_init_show","label":"show()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L139-L148","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L139"}],"snippet":"show = (element: DialogElement, owner: Owner, onClose?: () => void) => {\n    for (const item of stack()) item.dispose()\n    setStack([])\n    if (timer.current !== undefined) {\n      clearTimeout(timer.current)\n      timer.current = undefined\n    }\n    lock.value = false\n    mount(element, owner, onClose, 0)\n  }"},{"id":"packages_ui_src_context_dialog_dialogprovider","label":"DialogProvider()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L158-L168","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L158"}],"snippet":"export function DialogProvider(props: ParentProps) {\n  const ctx = init()\n  return (\n    <Context.Provider value={ctx}>\n      {props.children}\n      <div data-component=\"dialog-stack\">\n        <For each={ctx.stack()}>{(item) => item.node}</For>\n      </div>\n    </Context.Provider>\n  )\n}","node_kind":"component"},{"id":"packages_ui_src_context_dialog_usedialog","label":"useDialog()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L170-L197","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/context/dialog.tsx","source_location":"L170"}],"snippet":"export function useDialog() {\n  const ctx = useContext(Context)\n  const owner = getOwner()\n\n  if (!owner) {\n    throw new Error(\"useDialog must be used within a DialogProvider\")\n  }\n  if (!ctx) {\n    throw new Error(\"useDialog must be used within a DialogProvider\")\n  }\n\n  return {\n    get active() {\n      return ctx.stack().at(-1)\n    },\n    show(element: DialogElement, onClose?: () => void) {\n      const base = ctx.stack().at(-1)?.owner ?? owner\n      return startTransition(() => ctx.show(element, base, onClose))\n    },\n    push(element: DialogElement, onClose?: () => void) {\n      const 