r-file-tree.tsx","source_location":"L78","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L78"}],"snippet":"status = () => fileTreeRowStatus(row, props.files, reviewed())"},{"id":"diff_viewer_file_tree_diffviewerfiletree_name","label":"name()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L79-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L79"}],"snippet":"name = () =>\n                  Locale.truncate(row.name, Math.max(1, props.width - FILE_TREE_STATUS_WIDTH - prefix().length))"},{"id":"diff_viewer_file_tree_scrollfiletreerowintoview","label":"scrollFileTreeRowIntoView()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L125-L134","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L125"}],"snippet":"function scrollFileTreeRowIntoView(scroll: ScrollBoxRenderable | undefined, index: number) {\n  if (!scroll) return\n  if (index < scroll.scrollTop) {\n    scroll.scrollTo(index)\n    return\n  }\n  if (index >= scroll.scrollTop + scroll.viewport.height) {\n    scroll.scrollTo(index - scroll.viewport.height + 1)\n  }\n}"},{"id":"diff_viewer_file_tree_filetreerowprefix","label":"fileTreeRowPrefix()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L136-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L136"}],"snippet":"function fileTreeRowPrefix(\n  rows: readonly FileTreeRow[],\n  index: number,\n  row: FileTreeRow,\n  expandedNodes: ReadonlySet<number> | undefined,\n) {\n  const indentation = Array.from({ length: row.depth }, (_, depth) => {\n    if (depth === 0 && !hasLaterSibling(rows, 0, 0)) return \" \"\n    return hasLaterSibling(rows, index, depth) ? \"│  \" : \"   \"\n  }).join(\"\")\n  const topRoot = index === 0 && row.depth === 0\n  const branch = topRoot ? \" \" : hasLaterSibling(rows, index, row.depth) ? \"├─ \" : \"└─ \"\n  const marker = row.kind === \"directory\" ? (expandedNodes && !expandedNodes.has(row.id) ? \"▸ \" : \"▾ \") : \"\"\n\n  return `${indentation}${branch}${marker}`\n}"},{"id":"diff_viewer_file_tree_haslatersibling","label":"hasLaterSibling()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L153-L155","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L153"}],"snippet":"function hasLaterSibling(rows: readonly FileTreeRow[], index: number, depth: number) {\n  return rows.slice(index + 1).find((row) => row.depth <= depth)?.depth === depth\n}"},{"id":"diff_viewer_file_tree_filetreerowstatus","label":"fileTreeRowStatus()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L157-L162","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L157"}],"snippet":"function fileTreeRowStatus(row: FileTreeRow, files: readonly FileTreeItem[], reviewed: boolean) {\n  if (row.fileIndex === undefined) return \"\"\n  const status = files[row.fileIndex]?.status\n  const marker = status === \"modified\" ? \"M\" : status === \"added\" ? \"A\" : status === \"deleted\" ? \"D\" : \"?\"\n  return `${reviewed ? \"✓\" : \" \"}${marker}`.padStart(FILE_TREE_STATUS_WIDTH)\n}"}],"edges":[{"source":"diff_viewer_file_tree","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L2"}],"weight":1},{"source":"diff_viewer_file_tree","target":"locale","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L3"}],"weight":1},{"source":"diff_viewer_file_tree","target":"theme","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/feature-plugins/system/diff-viewer-file-tree.tsx","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source