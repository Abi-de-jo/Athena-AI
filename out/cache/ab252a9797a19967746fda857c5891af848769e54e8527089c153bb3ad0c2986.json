 ms)\n  }"},{"id":"packages_tui_src_util_signal_createfadein","label":"createFadeIn()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/signal.ts","source_location":"L19-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/signal.ts","source_location":"L19"}],"snippet":"export function createFadeIn(show: Accessor<boolean>, enabled: Accessor<boolean>) {\n  const [alpha, setAlpha] = createSignal(show() ? 1 : 0)\n  let revealed = show()\n\n  createEffect(\n    on([show, enabled], ([visible, animate]) => {\n      if (!visible) {\n        setAlpha(0)\n        return\n      }\n\n      if (!animate || revealed) {\n        revealed = true\n        setAlpha(1)\n        return\n      }\n\n      const start = performance.now()\n      revealed = true\n      setAlpha(0)\n\n      const timer = setInterval(() => {\n        const progress = Math.min((performance.now() - start) / 160, 1)\n        setAlpha(progress * progress * (3 - 2 * progress))\n        if (progress >= 1) clearInterval(timer)"}],"edges":[{"source":"packages_tui_src_util_signal","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/signal.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/signal.ts","source_location":"L1"}],"weight":1},{"source":"packages_tui_src_util_signal","target":"packages_tui_src_util_signal_createdebouncedsignal","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/signal.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/