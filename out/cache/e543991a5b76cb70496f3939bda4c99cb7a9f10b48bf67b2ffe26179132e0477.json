rce_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model-normalization.ts","source_location":"L30-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model-normalization.ts","source_location":"L30"}],"snippet":"export function statModel(model: string | undefined, providerModel: string | undefined) {\n  const normalized = normalizeInferenceModel(model)\n  if (RETIRED_STAT_MODELS.includes(normalized.toLowerCase())) return normalizeInferenceModel(providerModel)\n  return normalized\n}"},{"id":"model_normalization_statprovider","label":"statProvider()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model-normalization.ts","source_location":"L36-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model-normalization.ts","source_location":"L36"}],"snippet":"export function statProvider(\n  model: string | undefined,\n  providerModel: string | undefined,\n  provider: string | undefined,\n) {\n  const modelAuthorValue = modelAuthor(statModel(model, providerModel))\n  if (!modelAuthorValue) return undefined\n\n  const providerModelAuthor = modelAuthor(providerModel)\n  if (providerModelAuthor && providerModelAuthor !== \"unknown\") return providerModelAuthor\n  if (modelAuthorValue !== \"unknown\") return modelAuthorValue\n  if (provider && !RETIRED_STAT_PROVIDERS.includes(provider.toLowerCase())) return provider\n  return modelAuthorValue\n}"}],"edges":[{"source":"model_normalization","target":"model_normalization_normalizeinferencemodel","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/core/src/domain/model-normalization.ts","source_location":"L