{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_ui_src_theme_loader","nodes":[{"id":"packages_ui_src_theme_loader","label":"loader.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L1"}]},{"id":"packages_ui_src_theme_loader_ensureloaderstyleelement","label":"ensureLoaderStyleElement()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L8-L17","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L8"}],"snippet":"function ensureLoaderStyleElement(): HTMLStyleElement {\n  const existing = document.getElementById(THEME_STYLE_ID) as HTMLStyleElement | null\n  if (existing) {\n    return existing\n  }\n  const element = document.createElement(\"style\")\n  element.id = THEME_STYLE_ID\n  document.head.appendChild(element)\n  return element\n}"},{"id":"packages_ui_src_theme_loader_applytheme","label":"applyTheme()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L19-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L19"}],"snippet":"export function applyTheme(theme: DesktopTheme, themeId?: string): void {\n  activeTheme = theme\n  const lightTokens = resolveThemeVariant(theme.light, false)\n  const darkTokens = resolveThemeVariant(theme.dark, true)\n  const lightV2Tokens = resolveThemeVariantV2(theme.light, false)\n  const darkV2Tokens = resolveThemeVariantV2(theme.dark, true)\n  const targetThemeId = themeId ?? theme.id\n  const css = buildThemeCss(lightTokens, darkTokens, lightV2Tokens, darkV2Tokens, targetThemeId)\n  const themeStyleElement = ensureLoaderStyleElement()\n  themeStyleElement.textContent = css\n  document.documentElement.setAttribute(\"data-theme\", targetThemeId)\n}"},{"id":"packages_ui_src_theme_loader_buildthemecss","label":"buildThemeCss()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L32-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L32"}],"snippet":"function buildThemeCss(\n  light: ResolvedTheme,\n  dark: ResolvedTheme,\n  lightV2: ResolvedV2Theme,\n  darkV2: ResolvedV2Theme,\n  themeId: string,\n): string {\n  const isDefaultTheme = themeId === \"oc-2\"\n  const lightCss = `${themeToCss(light)}\\n  ${themeV2ToCss(lightV2)}`\n  const darkCss = `${themeToCss(dark)}\\n  ${themeV2ToCss(darkV2)}`\n\n  if (isDefaultTheme) {\n    return `\n:root {\n  color-scheme: light;\n  --text-mix-blend-mode: multiply;\n\n  ${lightCss}\n\n  @media (prefers-color-scheme: dark) {\n    color-scheme: dark;\n    --text-mix-blend-mode: plus-lighter;\n\n    ${darkCss}\n  }"},{"id":"packages_ui_src_theme_loader_loadthemefromurl","label":"loadThemeFromUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L78-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L78"}],"snippet":"export async function loadThemeFromUrl(url: string): Promise<DesktopTheme> {\n  const response = await fetch(url)\n  if (!response.ok) {\n    throw new Error(`Failed to load theme from ${url}: ${response.statusText}`)\n  }\n  return response.json()\n}"},{"id":"packages_ui_src_theme_loader_getactivetheme","label":"getActiveTheme()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L86-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L86"}],"snippet":"export function getActiveTheme(): DesktopTheme | null {\n  const activeId = document.documentElement.getAttribute(\"data-theme\")\n  if (!activeId) {\n    return null\n  }\n  if (activeTheme?.id === activeId) {\n    return activeTheme\n  }\n  return null\n}"},{"id":"packages_ui_src_theme_loader_removetheme","label":"removeTheme()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L97-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L97"}],"snippet":"export function removeTheme(): void {\n  activeTheme = null\n  const existingElement = document.getElementById(THEME_STYLE_ID)\n  if (existingElement) {\n    existingElement.remove()\n  }\n  document.documentElement.removeAttribute(\"data-theme\")\n}"},{"id":"packages_ui_src_theme_loader_setcolorscheme","label":"setColorScheme()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L106-L112","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L106"}],"snippet":"export function setColorScheme(scheme: \"light\" | \"dark\" | \"auto\"): void {\n  if (scheme === \"auto\") {\n    document.documentElement.style.removeProperty(\"color-scheme\")\n  } else {\n    document.documentElement.style.setProperty(\"color-scheme\", scheme)\n  }\n}"}],"edges":[{"source":"packages_ui_src_theme_loader","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L1"}],"weight":1},{"source":"packages_ui_src_theme_loader","target":"resolve","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L2"}],"weight":1},{"source":"packages_ui_src_theme_loader","target":"packages_ui_src_theme_loader_ensureloaderstyleelement","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L8","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L8"}],"weight":1},{"source":"packages_ui_src_theme_loader","target":"packages_ui_src_theme_loader_applytheme","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/theme/loader.ts","source_location":"L19","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/person