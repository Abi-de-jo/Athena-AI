{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_tool_edit","nodes":[{"id":"packages_rimuru_src_tool_edit","label":"edit.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_tool_edit_normalizelineendings","label":"normalizeLineEndings()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L22-L24","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L22"}],"snippet":"function normalizeLineEndings(text: string): string {\n  return text.replaceAll(\"\\r\\n\", \"\\n\")\n}"},{"id":"packages_rimuru_src_tool_edit_detectlineending","label":"detectLineEnding()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L26-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L26"}],"snippet":"function detectLineEnding(text: string): \"\\n\" | \"\\r\\n\" {\n  return text.includes(\"\\r\\n\") ? \"\\r\\n\" : \"\\n\"\n}"},{"id":"packages_rimuru_src_tool_edit_converttolineending","label":"convertToLineEnding()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L30-L33","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L30"}],"snippet":"function convertToLineEnding(text: string, ending: \"\\n\" | \"\\r\\n\"): string {\n  if (ending === \"\\n\") return text\n  return text.replaceAll(\"\\n\", \"\\r\\n\")\n}"},{"id":"packages_rimuru_src_tool_edit_lock","label":"lock()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L37-L45","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L37"}],"snippet":"function lock(filePath: string) {\n  const resolvedFilePath = FSUtil.resolve(filePath)\n  const hit = locks.get(resolvedFilePath)\n  if (hit) return hit\n\n  const next = Semaphore.makeUnsafe(1)\n  locks.set(resolvedFilePath, next)\n  return next\n}"},{"id":"packages_rimuru_src_tool_edit_levenshtein","label":"levenshtein()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L226-L242","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L226"}],"snippet":"function levenshtein(a: string, b: string): number {\n  // Handle empty strings\n  if (a === \"\" || b === \"\") {\n    return Math.max(a.length, b.length)\n  }\n  const matrix = Array.from({ length: a.length + 1 }, (_, i) =>\n    Array.from({ length: b.length + 1 }, (_, j) => (i === 0 ? j : j === 0 ? i : 0)),\n  )\n\n  for (let i = 1; i <= a.length; i++) {\n    for (let j = 1; j <= b.length; j++) {\n      const cost = a[i - 1] === b[j - 1] ? 0 : 1\n      matrix[i][j] = Math.min(matrix[i - 1][j] + 1, matrix[i][j - 1] + 1, matrix[i - 1][j - 1] + cost)\n    }\n  }\n  return matrix[a.length][b.length]\n}"},{"id":"packages_rimuru_src_tool_edit_simplereplacer","label":"SimpleReplacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L244-L246","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L244"}],"snippet":"SimpleReplacer: Replacer = function* (_content, find) {\n  yield find\n}"},{"id":"packages_rimuru_src_tool_edit_linetrimmedreplacer","label":"LineTrimmedReplacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L248-L286","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L248"}],"snippet":"LineTrimmedReplacer: Replacer = function* (content, find) {\n  const originalLines = content.split(\"\\n\")\n  const searchLines = find.split(\"\\n\")\n\n  if (searchLines[searchLines.length - 1] === \"\") {\n    searchLines.pop()\n  }\n\n  for (let i = 0; i <= originalLines.length - searchLines.length; i++) {\n    let matches = true\n\n    for (let j = 0; j < searchLines.length; j++) {\n      const originalTrimmed = originalLines[i + j].trim()\n      const searchTrimmed = searchLines[j].trim()\n\n      if (originalTrimmed !== searchTrimmed) {\n        matches = false\n        break\n      }\n    }\n\n    if (matches) {\n      let matchStartIndex = 0\n      for (let k = 0; k < i; k++) {\n        matchStartIndex += originalLines[k].length + 1"},{"id":"packages_rimuru_src_tool_edit_blockanchorreplacer","label":"BlockAnchorReplacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L288-L425","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L288"}],"snippet":"BlockAnchorReplacer: Replacer = function* (content, find) {\n  const originalLines = content.split(\"\\n\")\n  const searchLines = find.split(\"\\n\")\n\n  if (searchLines.length < 3) {\n    return\n  }\n\n  if (searchLines[searchLines.length - 1] === \"\") {\n    searchLines.pop()\n  }\n\n  const firstLineSearch = searchLines[0].trim()\n  const lastLineSearch = searchLines[searchLines.length - 1].trim()\n  const searchBlockSize = searchLines.length\n  const maxLineDelta = Math.max(1, Math.floor(searchBlockSize * 0.25))\n\n  // Collect all candidate positions where both anchors match\n  const candidates: Array<{ startLine: number; endLine: number }> = []\n  for (let i = 0; i < originalLines.length; i++) {\n    if (originalLines[i].trim() !== firstLineSearch) {\n      continue\n    }\n\n    // Look for the matching last line after this first line"},{"id":"packages_rimuru_src_tool_edit_whitespacenormalizedreplacer","label":"WhitespaceNormalizedReplacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L427-L469","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L427"}],"snippet":"WhitespaceNormalizedReplacer: Replacer = function* (content, find) {\n  const normalizeWhitespace = (text: string) => text.replace(/\\s+/g, \" \").trim()\n  const normalizedFind = normalizeWhitespace(find)\n\n  // Handle single line matches\n  const lines = content.split(\"\\n\")\n  for (let i = 0; i < lines.length; i++) {\n    const line = lines[i]\n    if (normalizeWhitespace(line) === normalizedFind) {\n      yield line\n    } else {\n      // Only check for substring matches if the full line doesn't match\n      const normalizedLine = normalizeWhitespace(line)\n      if (normalizedLine.includes(normalizedFind)) {\n        // Find the actual substring in the original line that matches\n        const words = find.trim().split(/\\s+/)\n        if (words.length > 0) {\n          const pattern = words.map((word) => word.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$&\")).join(\"\\\\s+\")\n          try {\n            const regex = new RegExp(pattern)\n            const match = line.match(regex)\n            if (match) {\n              yield match[0]\n            }\n          } catch {"},{"id":"packages_rimuru_src_tool_edit_whitespacenormalizedreplacer_normalizewhitespace","label":"normalizeWhitespace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L428","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L428"}],"snippet":"normalizeWhitespace = (text: string) => text.replace(/\\s+/g, \" \").trim()"},{"id":"packages_rimuru_src_tool_edit_indentationflexiblereplacer","label":"IndentationFlexibleReplacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L471-L497","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L471"}],"snippet":"IndentationFlexibleReplacer: Replacer = function* (content, find) {\n  const removeIndentation = (text: string) => {\n    const lines = text.split(\"\\n\")\n    const nonEmptyLines = lines.filter((line) => line.trim().length > 0)\n    if (nonEmptyLines.length === 0) return text\n\n    const minIndent = Math.min(\n      ...nonEmptyLines.map((line) => {\n        const match = line.match(/^(\\s*)/)\n        return match ? match[1].length : 0\n      }),\n    )\n\n    return lines.map((line) => (line.trim().length === 0 ? line : line.slice(minIndent))).join(\"\\n\")\n  }\n\n  const normalizedFind = removeIndentation(find)\n  const contentLines = content.split(\"\\n\")\n  const findLines = find.split(\"\\n\")\n\n  for (let i = 0; i <= contentLines.length - findLines.length; i++) {\n    const block = contentLines.slice(i, i + findLines.length).join(\"\\n\")\n    if (removeIndentation(block) === normalizedFind) {\n      yield block\n    }"},{"id":"packages_rimuru_src_tool_edit_indentationflexiblereplacer_removeindentation","label":"removeIndentation()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L472-L485","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L472"}],"snippet":"removeIndentation = (text: string) => {\n    const lines = text.split(\"\\n\")\n    const nonEmptyLines = lines.filter((line) => line.trim().length > 0)\n    if (nonEmptyLines.length === 0) return text\n\n    const minIndent = Math.min(\n      ...nonEmptyLines.map((line) => {\n        const match = line.match(/^(\\s*)/)\n        return match ? match[1].length : 0\n      }),\n    )\n\n    return lines.map((line) => (line.trim().length === 0 ? line : line.slice(minIndent))).join(\"\\n\")\n  }"},{"id":"packages_rimuru_src_tool_edit_escapenormalizedreplacer","label":"EscapeNormalizedReplacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L499-L546","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L499"}],"snippet":"EscapeNormalizedReplacer: Replacer = function* (content, find) {\n  const unescapeString = (str: string): string => {\n    return str.replace(/\\\\(n|t|r|'|\"|`|\\\\|\\n|\\$)/g, (match, capturedChar) => {\n      switch (capturedChar) {\n        case \"n\":\n          return \"\\n\"\n        case \"t\":\n          return \"\\t\"\n        case \"r\":\n          return \"\\r\"\n        case \"'\":\n          return \"'\"\n        case '\"':\n          return '\"'\n        case \"`\":\n          return \"`\"\n        case \"\\\\\":\n          return \"\\\\\"\n        case \"\\n\":\n          return \"\\n\"\n        case \"$\":\n          return \"$\"\n        default:\n          return match\n      }"},{"id":"packages_rimuru_src_tool_edit_escapenormalizedreplacer_unescapestring","label":"unescapeString()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L500-L525","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L500"}],"snippet":"unescapeString = (str: string): string => {\n    return str.replace(/\\\\(n|t|r|'|\"|`|\\\\|\\n|\\$)/g, (match, capturedChar) => {\n      switch (capturedChar) {\n        case \"n\":\n          return \"\\n\"\n        case \"t\":\n          return \"\\t\"\n        case \"r\":\n          return \"\\r\"\n        case \"'\":\n          return \"'\"\n        case '\"':\n          return '\"'\n        case \"`\":\n          return \"`\"\n        case \"\\\\\":\n          return \"\\\\\"\n        case \"\\n\":\n          return \"\\n\"\n        case \"$\":\n          return \"$\"\n        default:\n          return match\n      }\n    })"},{"id":"packages_rimuru_src_tool_edit_multioccurrencereplacer","label":"MultiOccurrenceReplacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L548-L560","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L548"}],"snippet":"MultiOccurrenceReplacer: Replacer = function* (content, find) {\n  // This replacer yields all exact matches, allowing the replace function\n  // to handle multiple occurrences based on replaceAll parameter\n  let startIndex = 0\n\n  while (true) {\n    const index = content.indexOf(find, startIndex)\n    if (index === -1) break\n\n    yield find\n    startIndex = index + find.length\n  }\n}"},{"id":"packages_rimuru_src_tool_edit_trimmedboundaryreplacer","label":"TrimmedBoundaryReplacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L562-L586","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L562"}],"snippet":"TrimmedBoundaryReplacer: Replacer = function* (content, find) {\n  const trimmedFind = find.trim()\n\n  if (trimmedFind === find) {\n    // Already trimmed, no point in trying\n    return\n  }\n\n  // Try to find the trimmed version\n  if (content.includes(trimmedFind)) {\n    yield trimmedFind\n  }\n\n  // Also try finding blocks where trimmed content matches\n  const lines = content.split(\"\\n\")\n  const findLines = find.split(\"\\n\")\n\n  for (let i = 0; i <= lines.length - findLines.length; i++) {\n    const block = lines.slice(i, i + findLines.length).join(\"\\n\")\n\n    if (block.trim() === trimmedFind) {\n      yield block\n    }\n  }\n}"},{"id":"packages_rimuru_src_tool_edit_contextawarereplacer","label":"ContextAwareReplacer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L588-L644","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L588"}],"snippet":"ContextAwareReplacer: Replacer = function* (content, find) {\n  const findLines = find.split(\"\\n\")\n  if (findLines.length < 3) {\n    // Need at least 3 lines to have meaningful context\n    return\n  }\n\n  // Remove trailing empty line if present\n  if (findLines[findLines.length - 1] === \"\") {\n    findLines.pop()\n  }\n\n  const contentLines = content.split(\"\\n\")\n\n  // Extract first and last lines as context anchors\n  const firstLine = findLines[0].trim()\n  const lastLine = findLines[findLines.length - 1].trim()\n\n  // Find blocks that start and end with the context anchors\n  for (let i = 0; i < contentLines.length; i++) {\n    if (contentLines[i].trim() !== firstLine) continue\n\n    // Look for the matching last line\n    for (let j = i + 2; j < contentLines.length; j++) {\n      if (contentLines[j].trim() === lastLine) {"},{"id":"packages_rimuru_src_tool_edit_trimdiff","label":"trimDiff()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L646-L680","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L646"}],"snippet":"export function trimDiff(diff: string): string {\n  const lines = diff.split(\"\\n\")\n  const contentLines = lines.filter(\n    (line) =>\n      (line.startsWith(\"+\") || line.startsWith(\"-\") || line.startsWith(\" \")) &&\n      !line.startsWith(\"---\") &&\n      !line.startsWith(\"+++\"),\n  )\n\n  if (contentLines.length === 0) return diff\n\n  let min = Infinity\n  for (const line of contentLines) {\n    const content = line.slice(1)\n    if (content.trim().length > 0) {\n      const match = content.match(/^(\\s*)/)\n      if (match) min = Math.min(min, match[1].length)\n    }\n  }\n  if (min === Infinity || min === 0) return diff\n  const trimmedLines = lines.map((line) => {\n    if (\n      (line.startsWith(\"+\") || line.startsWith(\"-\") || line.startsWith(\" \")) &&\n      !line.startsWith(\"---\") &&\n      !line.startsWith(\"+++\")"},{"id":"packages_rimuru_src_tool_edit_replace","label":"replace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L682-L729","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L682"}],"snippet":"export function replace(content: string, oldString: string, newString: string, replaceAll = false): string {\n  if (oldString === newString) {\n    throw new Error(\"No changes to apply: oldString and newString are identical.\")\n  }\n  if (oldString === \"\") {\n    throw new Error(\n      \"oldString cannot be empty when editing an existing file. Provide the exact text to replace, or use write for an intentional full-file replacement.\",\n    )\n  }\n\n  let notFound = true\n\n  for (const replacer of [\n    SimpleReplacer,\n    LineTrimmedReplacer,\n    BlockAnchorReplacer,\n    WhitespaceNormalizedReplacer,\n    IndentationFlexibleReplacer,\n    EscapeNormalizedReplacer,\n    TrimmedBoundaryReplacer,\n    ContextAwareReplacer,\n    MultiOccurrenceReplacer,\n  ]) {\n    for (const search of replacer(content, oldString)) {\n      const index = content.indexOf(search)"},{"id":"packages_rimuru_src_tool_edit_isdisproportionatematch","label":"isDisproportionateMatch()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/tool/edit.ts","source_location":"L731-L737","layer":"base","provenance":[{"capability_id":"