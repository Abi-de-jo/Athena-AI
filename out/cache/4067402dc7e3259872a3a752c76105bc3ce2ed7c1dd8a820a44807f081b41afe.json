{"__madarTsExtractorVersion":67,"__madarFileStem":"prompt.shared","nodes":[{"id":"prompt_shared","label":"prompt.shared.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L1"}]},{"id":"prompt_shared_promptcopy","label":"promptCopy()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L28-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L28"}],"snippet":"export function promptCopy(prompt: RunPrompt): RunPrompt {\n  return {\n    text: prompt.text,\n    parts: structuredClone(prompt.parts),\n    ...(prompt.mode ? { mode: prompt.mode } : {}),\n    ...(prompt.command ? { command: prompt.command } : {}),\n  }\n}"},{"id":"prompt_shared_promptsame","label":"promptSame()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L37-L44","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L37"}],"snippet":"export function promptSame(a: RunPrompt, b: RunPrompt): boolean {\n  return (\n    a.mode === b.mode &&\n    a.text === b.text &&\n    JSON.stringify(a.parts) === JSON.stringify(b.parts) &&\n    JSON.stringify(a.command) === JSON.stringify(b.command)\n  )\n}"},{"id":"prompt_shared_isexitcommand","label":"isExitCommand()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L46-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L46"}],"snippet":"export function isExitCommand(input: string): boolean {\n  const text = input.trim().toLowerCase()\n  return text === \"/exit\" || text === \"/quit\" || text === \":q\"\n}"},{"id":"prompt_shared_isnewcommand","label":"isNewCommand()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L51-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L51"}],"snippet":"export function isNewCommand(input: string): boolean {\n  return input.trim().toLowerCase() === \"/new\"\n}"},{"id":"prompt_shared_createprompthistory","label":"createPromptHistory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L55-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L55"}],"snippet":"export function createPromptHistory(items?: RunPrompt[]): PromptHistoryState {\n  const list = (items ?? []).filter((item) => item.text.trim().length > 0).map(promptCopy)\n  const next: RunPrompt[] = []\n  for (const item of list) {\n    if (next.length > 0 && promptSame(next[next.length - 1], item)) {\n      continue\n    }\n\n    next.push(item)\n  }\n\n  return {\n    items: next.slice(-HISTORY_LIMIT),\n    index: null,\n    draft: \"\",\n  }\n}"},{"id":"prompt_shared_pushprompthistory","label":"pushPromptHistory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L73-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L73"}],"snippet":"export function pushPromptHistory(state: PromptHistoryState, prompt: RunPrompt): PromptHistoryState {\n  if (!prompt.text.trim()) {\n    return state\n  }\n\n  const next = promptCopy(prompt)\n  if (state.items[state.items.length - 1] && promptSame(state.items[state.items.length - 1], next)) {\n    return {\n      ...state,\n      index: null,\n      draft: \"\",\n    }\n  }\n\n  const items = [...state.items, next].slice(-HISTORY_LIMIT)\n  return {\n    ...state,\n    items,\n    index: null,\n    draft: \"\",\n  }\n}"},{"id":"prompt_shared_moveprompthistory","label":"movePromptHistory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L96-L153","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/prompt.shared.ts","source_location":"L96"}],"snippet":"export function movePromptHistory(state: PromptHistoryState, dir: -1 | 1, text: string, cursor: number): PromptMove {\n  if (state.items.length === 0) {\n    return { state, apply: false }\n  }\n\n  if (dir === -1 && cursor !== 0) {\n    return { state, apply: false }\n  }\n\n  if (dir === 1 && cursor !== Bun.stringWidth(text)) {\n    return { state, apply: false }\n  }\n\n  if (state.index === null) {\n    if (dir === 1) {\n      return { state, apply: false }\n    }\n\n    const idx = state.items.length 