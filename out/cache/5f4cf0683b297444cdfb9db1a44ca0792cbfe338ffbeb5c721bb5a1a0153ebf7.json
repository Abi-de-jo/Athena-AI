{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_desktop_src_main_updater","nodes":[{"id":"packages_desktop_src_main_updater","label":"updater.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/updater.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/updater.ts","source_location":"L1"}]},{"id":"packages_desktop_src_main_updater_setupautoupdater","label":"setupAutoUpdater()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/updater.ts","source_location":"L11-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/updater.ts","source_location":"L11"}],"snippet":"export function setupAutoUpdater(stop: () => Promise<void>) {\n  const logger = getLogger()\n  autoUpdater.logger = logger\n  autoUpdater.channel = \"latest\"\n  autoUpdater.allowPrerelease = false\n  autoUpdater.allowDowngrade = true\n  autoUpdater.autoDownload = false\n  autoUpdater.autoInstallOnAppQuit = false\n  logger.log(\"auto updater configured\", {\n    channel: autoUpdater.channel,\n    allowPrerelease: autoUpdater.allowPrerelease,\n    allowDowngrade: autoUpdater.allowDowngrade,\n    currentVersion: app.getVersion(),\n  })\n\n  const store = getStore(\"opencode.updater\")\n  return createUpdaterController({\n    enabled: UPDATER_ENABLED,\n    currentVersion: app.getVersion(),\n    backend: autoUpdater,\n    persistence: {\n      get() {\n        const value = store.get(key)\n        if (!value || typeof value !== \"object\" || !(\"version\" in value) || typeof value.version !== \"string\") return\n        return { version: value.version } satisfies UpdaterReadyRecord"},{"id":"packages_desktop_src_main_updater_showupdaterdialog","label":"showUpdaterDialog()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/updater.ts","source_location":"L45-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/updater.ts","source_location":"L45"}],"snippet":"export async function showUpdaterDialog(controller: ReturnType<typeof setupAutoUpdater>, alertOnFail: boolean) {\n  const state = await controller.check()\n  if (state.status === \"error\") {\n    if (!alertOnFail) return\n    await dialog.showMessageBox({ type: \"error\", message: \"Update check failed.\", title: \"Update Error\" })\n    return\n  }\n  if (state.status === \"up-to-date\") {\n    if (!alertOnFail) return\n    await dialog.showMessageBox({ type: \"info\", message: \"You're up to date.\", title: \"No Updates\" })\n    return\n  }\n  if (state.status !== \"ready\") return\n\n  const response = await dialog.showMessageBox({\n    type: \"info\",\n    message: `Update ${state.version} downloaded. Restart now?`,\n    title: \"Update Ready\",\n    buttons: [\"Restart\", \"Later\"],\n    defaultId: 0,\n    cancelId: 1,\n  })\n  if (response.response === 0) await controller.install()\n}"}],"edges":[{"source":"packages_desktop_src_main_updater","target":"electron","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/updater.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/src/main/updater.ts","source_location":"L1"}],"weight":1},{"source":"packages_desktop_src_main_updater","target":"electron_updater","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/deskt