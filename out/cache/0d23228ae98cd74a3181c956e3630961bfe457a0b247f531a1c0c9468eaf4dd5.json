= questions().length)\n  const options = createMemo(() => question()?.options ?? [])\n  const custom = createMemo(() => question()?.custom !== false)","node_kind":"component"},{"id":"packages_tui_src_routes_session_question_questionprompt_submit","label":"submit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L48-L55","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L48"}],"snippet":"function submit() {\n    const answers = questions().map((_, i) => store.answers[i] ?? [])\n    void sdk.client.question.reply({\n      requestID: props.request.id,\n      directory: props.directory,\n      answers,\n    })\n  }"},{"id":"packages_tui_src_routes_session_question_questionprompt_reject","label":"reject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L57-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L57"}],"snippet":"function reject() {\n    void sdk.client.question.reject({\n      requestID: props.request.id,\n      directory: props.directory,\n    })\n  }"},{"id":"packages_tui_src_routes_session_question_questionprompt_pick","label":"pick()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L64-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L64"}],"snippet":"function pick(answer: string, custom: boolean = false) {\n    const answers = [...store.answers]\n    answers[store.tab] = [answer]\n    setStore(\"answers\", answers)\n    if (custom) {\n      const inputs = [...store.custom]\n      inputs[store.tab] = answer\n      setStore(\"custom\", inputs)\n    }\n    if (single()) {\n      void sdk.client.question.reply({\n        requestID: props.request.id,\n        directory: props.directory,\n        answers: [[answer]],\n      })\n      return\n    }\n    setStore(\"tab\", store.tab + 1)\n    setStore(\"selected\", 0)\n  }"},{"id":"packages_tui_src_routes_session_question_questionprompt_toggle","label":"toggle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L85-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L85"}],"snippet":"function toggle(answer: string) {\n    const existing = store.answers[store.tab] ?? []\n    const next = [...existing]\n    const index = next.indexOf(answer)\n    if (index === -1) next.push(answer)\n    if (index !== -1) next.splice(index, 1)\n    const answers = [...store.answers]\n    answers[store.tab] = next\n    setStore(\"answers\", answers)\n  }"},{"id":"packages_tui_src_routes_session_question_questionprompt_moveto","label":"moveTo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L96-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L96"}],"snippet":"function moveTo(index: number) {\n    setStore(\"selected\", index)\n  }"},{"id":"packages_tui_src_routes_session_question_questionprompt_selecttab","label":"selectTab()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L100-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L100"}],"snippet":"function selectTab(index: number) {\n    setStore(\"tab\", index)\n    setStore(\"selected\", 0)\n  }"},{"id":"packages_tui_src_routes_session_question_questionprompt_selectoption","label":"selectOption()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L105-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L105"}],"snippet":"function selectOption() {\n    if (other()) {\n      if (!multi()) {\n        setStore(\"editing\", true)\n        return\n      }\n      const value = input()\n      if (value && customPicked()) {\n        toggle(value)\n        return\n      }\n      setStore(\"editing\", true)\n      return\n    }\n    const opt = options()[store.selected]\n    if (!opt) return\n    if (multi()) {\n      toggle(opt.label)\n      return\n    }\n    pick(opt.label)\n  }"},{"id":"packages_tui_src_routes_session_question_questionprompt_isactive","label":"isActive()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L300","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/routes/session/question.tsx","source_location":"L300"}],"snippet":"isActive = () => index() === store.tab"},{"id":"pa