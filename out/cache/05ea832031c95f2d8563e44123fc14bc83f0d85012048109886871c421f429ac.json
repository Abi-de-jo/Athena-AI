{"__madarTsExtractorVersion":67,"__madarFileStem":"server-health","nodes":[{"id":"server_health","label":"server-health.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L1"}]},{"id":"server_health_checkserverhealthoptions","label":"CheckServerHealthOptions","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L9-L14","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L9"}],"snippet":"interface CheckServerHealthOptions {\n  timeoutMs?: number\n  signal?: AbortSignal\n  retryCount?: number\n  retryDelayMs?: number\n}"},{"id":"server_health_cachekey","label":"cacheKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L25-L27","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L25"}],"snippet":"function cacheKey(server: ServerConnection.HttpBase) {\n  return `${server.url}\\n${server.username ?? \"\"}\\n${server.password ?? \"\"}`\n}"},{"id":"server_health_timeoutsignal","label":"timeoutSignal()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L29-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L29"}],"snippet":"function timeoutSignal(timeoutMs: number) {\n  const timeout = (AbortSignal as unknown as { timeout?: (ms: number) => AbortSignal }).timeout\n  if (timeout) {\n    try {\n      return {\n        signal: timeout.call(AbortSignal, timeoutMs),\n        clear: undefined as (() => void) | undefined,\n      }\n    } catch {}\n  }\n  const controller = new AbortController()\n  const timer = setTimeout(() => controller.abort(), timeoutMs)\n  return { signal: controller.signal, clear: () => clearTimeout(timer) }\n}"},{"id":"server_health_wait","label":"wait()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L44-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L44"}],"snippet":"function wait(ms: number, signal?: AbortSignal) {\n  return new Promise<void>((resolve, reject) => {\n    if (signal?.aborted) {\n      reject(new DOMException(\"Aborted\", \"AbortError\"))\n      return\n    }\n    const timer = setTimeout(() => {\n      signal?.removeEventListener(\"abort\", onAbort)\n      resolve()\n    }, ms)\n    const onAbort = () => {\n      clearTimeout(timer)\n      reject(new DOMException(\"Aborted\", \"AbortError\"))\n    }\n    signal?.addEventListener(\"abort\", onAbort, { once: true })\n  })\n}"},{"id":"server_health_wait_onabort","label":"onAbort()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L54-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L54"}],"snippet":"onAbort = () => {\n      clearTimeout(timer)\n      reject(new DOMException(\"Aborted\", \"AbortError\"))\n    }"},{"id":"server_health_retryable","label":"retryable()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L62-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L62"}],"snippet":"function retryable(error: unknown, signal?: AbortSignal) {\n  if (signal?.aborted) return false\n  if (!(error instanceof Error)) return false\n  if (error.name === \"AbortError\" || error.name === \"TimeoutError\") return false\n  if (error instanceof TypeError) return true\n  return /network|fetch|econnreset|econnrefused|enotfound|timedout/i.test(error.message)\n}"},{"id":"server_health_checkserverhealth","label":"checkServerHealth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L70-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L70"}],"snippet":"export async function checkServerHealth(\n  server: ServerConnection.HttpBase,\n  fetch: typeof globalThis.fetch,\n  opts?: CheckServerHealthOptions,\n): Promise<ServerHealth> {\n  const timeout = opts?.signal ? undefined : timeoutSignal(opts?.timeoutMs ?? defaultTimeoutMs)\n  const signal = opts?.signal ?? timeout?.signal\n  const retryCount = opts?.retryCount ?? defaultRetryCount\n  const retryDelayMs = opts?.retryDelayMs ?? defaultRetryDelayMs\n  const next = (count: number, error: unknown) => {\n    if (count >= retryCount || !retryable(error, signal)) return Promise.resolve({ healthy: false } as const)\n    return wait(retryDelayMs * (count + 1), signal)\n      .then(() => attempt(count + 1))\n      .catch(() => ({ healthy: false }))\n  }\n  const attempt = (count: number): Promise<ServerHealth> =>\n    createSdkForServer({\n      server,\n      fetch,\n      signal,\n    })\n      .global.health()\n      .then((x) => (x.error ? next(count, x.error) : { healthy: x.data?.healthy === true, version: x.data?.version }))\n      .catch((error) => next(count, error))\n  return attempt(0).finally(() => timeout?.clear?.())"},{"id":"server_health_checkserverhealth_next","label":"next()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L79-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L79"}],"snippet":"next = (count: number, error: unknown) => {\n    if (count >= retryCount || !retryable(error, signal)) return Promise.resolve({ healthy: false } as const)\n    return wait(retryDelayMs * (count + 1), signal)\n      .then(() => attempt(count + 1))\n      .catch(() => ({ healthy: false }))\n  }"},{"id":"server_health_checkserverhealth_attempt","label":"attempt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L85-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L85"}],"snippet":"attempt = (count: number): Promise<ServerHealth> =>\n    createSdkForServer({\n      server,\n      fetch,\n      signal,\n    })\n      .global.health()\n      .then((x) => (x.error ? next(count, x.error) : { healthy: x.data?.healthy === true, version: x.data?.version }))\n      .catch((error) => next(count, error))"},{"id":"server_health_usecheckserverhealth","label":"useCheckServerHealth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L99-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L99"}],"snippet":"export function useCheckServerHealth() {\n  const platform = usePlatform()\n  const fetcher = platform.fetch ?? globalThis.fetch\n\n  return (http: ServerConnection.HttpBase) => {\n    const key = cacheKey(http)\n    const hit = healthCache.get(key)\n    const now = Date.now()\n    if (hit && hit.fetch === fetcher && (!hit.done || now - hit.at < cacheMs)) return hit.promise\n    const promise = checkServerHealth(http, fetcher).finally(() => {\n      const next = healthCache.get(key)\n      if (!next || next.promise !== promise) return\n      next.done = true\n      next.at = Date.now()\n    })\n    healthCache.set(key, { at: now, done: false, fetch: fetcher, promise })\n    return promise\n  }\n}"},{"id":"server_health_useserverhealth","label":"useServerHealth()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L119-L154","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L119"}],"snippet":"useServerHealth = (servers: Accessor<ServerConnection.Any[]>, enabled: Accessor<boolean>) => {\n  const checkServerHealth = useCheckServerHealth()\n  const [status, setStatus] = createStore({} as Record<ServerConnection.Key, ServerHealth | undefined>)\n\n  createEffect(() => {\n    if (!enabled()) {\n      setStatus(reconcile({}))\n      return\n    }\n    const list = servers()\n    let dead = false\n\n    const refresh = async () => {\n      const results: Record<string, ServerHealth> = {}\n      await Promise.all(\n        list.map(async (conn) => {\n          const key = ServerConnection.key(conn)\n          const result = await checkServerHealth(conn.http)\n          results[key] = result\n          if (!dead) setStatus(key, result)\n        }),\n      )\n      if (dead) return\n      setStatus(reconcile(results))\n    }"},{"id":"server_health_useserverhealth_refresh","label":"refresh()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L131-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L131"}],"snippet":"refresh = async () => {\n      const results: Record<string, ServerHealth> = {}\n      await Promise.all(\n        list.map(async (conn) => {\n          const key = ServerConnection.key(conn)\n          const result = await checkServerHealth(conn.http)\n          results[key] = result\n          if (!dead) setStatus(key, result)\n        }),\n      )\n      if (dead) return\n      setStatus(reconcile(results))\n    }"}],"edges":[{"source":"server_health","target":"platform","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L1"}],"weight":1},{"source":"server_health","target":"server","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/utils/server-health.ts","source_location":"L2","layer":"base","provenance":[{"capabili