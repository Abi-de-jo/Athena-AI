r(commit: StreamCommit, theme: RunTheme): ColorInput {\n  if (commit.kind === \"assistant\") {\n    return theme.entry.assistant.body\n  }\n\n  if (commit.kind === \"reasoning\") {\n    return theme.entry.reasoning.body\n  }\n\n  if (entryFailed(commit)) {\n    return theme.entry.error.body\n  }\n\n  if (commit.kind === \"tool\") {\n    return theme.block.text\n  }\n\n  return entryLook(commit, theme.entry).fg\n}"}],"edges":[{"source":"scrollback_shared","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.shared.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.shared.ts","source_location":"L1"}],"weight":1},{"source":"scrollback_shared","target":"theme","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.shared.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.shared.ts","source_location":"L2"}],"weight":1},{"source":"scrollback_shared","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.shared.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/cli/cmd/run/scrollback.shared.ts","source_location":"L3"}],"weight":1},{"source":"scrollback_shared","target":"scrollback_shared_syntax","relation":"contains","confidence":"EXTRACTED","source_file":"/home/g