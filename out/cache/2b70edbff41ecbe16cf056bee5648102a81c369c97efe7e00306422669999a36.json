{"__madarTsExtractorVersion":67,"__madarFileStem":"normalize-bun-binaries","nodes":[{"id":"normalize_bun_binaries","label":"normalize-bun-binaries.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L1"}]},{"id":"normalize_bun_binaries_collectpackages","label":"collectPackages()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L50-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L50"}],"snippet":"async function collectPackages(modulesRoot: string) {\n  const found: string[] = []\n  const topLevel = (await readdir(modulesRoot)).sort()\n  for (const name of topLevel) {\n    if (name === \".bin\" || name === \".bun\") {\n      continue\n    }\n    const full = join(modulesRoot, name)\n    if (!(await isDirectory(full))) {\n      continue\n    }\n    if (name.startsWith(\"@\")) {\n      const scoped = (await readdir(full)).sort()\n      for (const child of scoped) {\n        const scopedDir = join(full, child)\n        if (await isDirectory(scopedDir)) {\n          found.push(scopedDir)\n        }\n      }\n      continue\n    }\n    found.push(full)\n  }\n  return found.sort()\n}"},{"id":"normalize_bun_binaries_readmanifest","label":"readManifest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L76-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L76"}],"snippet":"async function readManifest(dir: string) {\n  const file = Bun.file(join(dir, \"package.json\"))\n  if (!(await file.exists())) {\n    return null\n  }\n  const data = (await file.json()) as PackageManifest\n  return data\n}"},{"id":"normalize_bun_binaries_linkbinary","label":"linkBinary()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L85-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L85"}],"snippet":"async function linkBinary(binRoot: string, name: string, packageDir: string, target: string, seen: Set<string>) {\n  if (!name || !target) {\n    return\n  }\n  const normalizedName = normalizeBinName(name)\n  if (seen.has(normalizedName)) {\n    return\n  }\n  const resolved = join(packageDir, target)\n  const script = Bun.file(resolved)\n  if (!(await script.exists())) {\n    return\n  }\n  seen.add(normalizedName)\n  const destination = join(binRoot, normalizedName)\n  const relativeTarget = relative(binRoot, resolved) || \".\"\n  await rm(destination, { force: true })\n  await symlink(relativeTarget, destination)\n  rewritten++\n}"},{"id":"normalize_bun_binaries_exists","label":"exists()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L106-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L106"}],"snippet":"async function exists(path: string) {\n  try {\n    await lstat(path)\n    return true\n  } catch {\n    return false\n  }\n}"},{"id":"normalize_bun_binaries_isdirectory","label":"isDirectory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L115-L122","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L115"}],"snippet":"async function isDirectory(path: string) {\n  try {\n    const info = await lstat(path)\n    return info.isDirectory()\n  } catch {\n    return false\n  }\n}"},{"id":"normalize_bun_binaries_normalizebinname","label":"normalizeBinName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L124-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L124"}],"snippet":"function normalizeBinName(name: string) {\n  const slash = name.lastIndexOf(\"/\")\n  if (slash >= 0) {\n    return name.slice(slash + 1)\n  }\n  return name\n}"}],"edges":[{"source":"normalize_bun_binaries","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L1"}],"weight":1},{"source":"normalize_bun_binaries","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/nix/scripts/normalize-bun-binaries.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rim