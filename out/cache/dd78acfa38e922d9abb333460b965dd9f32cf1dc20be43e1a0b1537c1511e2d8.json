i/src/components/animated-number.tsx","source_location":"L17"}],"snippet":"function Digit(props: { value: number; direction: 1 | -1 }) {\n  const [state, setState] = createStore({\n    step: props.value + 10,\n    animating: false,\n  })\n  const step = () => state.step\n  const animating = () => state.animating\n  let last = props.value\n\n  createEffect(\n    on(\n      () => props.value,\n      (next) => {\n        const delta = spin(last, next, props.direction)\n        last = next\n        if (!delta) {\n          setState(\"animating\", false)\n          setState(\"step\", next + 10)\n          return\n        }\n\n        setState(\"animating\", true)\n        setState(\"step\", (value) => value + delta)\n      },\n      { defer: true },","node_kind":"component"},{"id":"animated_number_digit_step","label":"step()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/animated-number.tsx","source_location":"L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/animated-number.tsx","source_location":"L22"}],"snippet":"step = () => state.step"},{"id":"animated_number_digit_animating","label":"animating()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/animated-number.tsx","source_location":"L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/animated-number.tsx","source_location":"L23"}],"snippet":"animating = () => state.animating"},{"id":"animated_number_animatednumber","label":"AnimatedNumber()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/animated-number.tsx","source_location":"L65-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/animated-number.tsx","source_location":"L65"}],"snippet":"export function AnimatedNumber(props: { value: number; class?: string }) {\n  const target = createMemo(() => {\n    if (!Number.isFinite(props.value)) return 0\n    return Math.max(0, Math.round(props.value))\n  })\n\n  const [state, setState] = createStore({\n    value: target(),\n    direction: 1 as 1 | -1,\n  })\n  const value = () => state.value\n  const direction = () => state.direction\n\n  createEffect(\n    on(\n      target,\n      (next) => {\n        const current = value()\n        if (next === current) return\n\n        setState(\"direction\", next > current ? 1 : -1)\n        setState(\"value\", next)\n      },\n      { defer: true },\n    ),","node_kind":"component"},{"id":"animated_number_animatednumber_value","label":"value()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/animated-number.tsx","source_location":"L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/animated-number.tsx","source_location":"L75"}],"snippet":"value = () => state.value"},{"id":"animated_number_animatednumber_direction","label":"direction()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/animated-number.tsx","source_location":"L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/animated-number.tsx","source_location":"L76"}],"snippet":"direction = () => state.direction"}],"edges":[{"source":"animated_number","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/