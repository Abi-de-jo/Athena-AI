{"__madarTsExtractorVersion":67,"__madarFileStem":"titlebar-history","nodes":[{"id":"titlebar_history","label":"titlebar-history.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L1"}]},{"id":"titlebar_history_applypath","label":"applyPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L11-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L11"}],"snippet":"export function applyPath(state: TitlebarHistory, current: string, max = MAX_TITLEBAR_HISTORY): TitlebarHistory {\n  if (!state.stack.length) {\n    const stack = current === \"/\" ? [\"/\"] : [\"/\", current]\n    return { stack, index: stack.length - 1, action: undefined }\n  }\n\n  const active = state.stack[state.index]\n  if (current === active) {\n    if (!state.action) return state\n    return { ...state, action: undefined }\n  }\n\n  if (state.action) return { ...state, action: undefined }\n\n  return pushPath(state, current, max)\n}"},{"id":"titlebar_history_pushpath","label":"pushPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L28-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L28"}],"snippet":"export function pushPath(state: TitlebarHistory, path: string, max = MAX_TITLEBAR_HISTORY): TitlebarHistory {\n  const stack = state.stack.slice(0, state.index + 1).concat(path)\n  const next = trimHistory(stack, stack.length - 1, max)\n  return { ...state, ...next, action: undefined }\n}"},{"id":"titlebar_history_trimhistory","label":"trimHistory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L34-L41","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L34"}],"snippet":"export function trimHistory(stack: string[], index: number, max = MAX_TITLEBAR_HISTORY) {\n  if (stack.length <= max) return { stack, index }\n  const cut = stack.length - max\n  return {\n    stack: stack.slice(cut),\n    index: Math.max(0, index - cut),\n  }\n}"},{"id":"titlebar_history_backpath","label":"backPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L43-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L43"}],"snippet":"export function backPath(state: TitlebarHistory) {\n  if (state.index <= 0) return\n  const index = state.index - 1\n  const to = state.stack[index]\n  if (!to) return\n  return { state: { ...state, index, action: \"back\" as const }, to }\n}"},{"id":"titlebar_history_forwardpath","label":"forwardPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L51-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L51"}],"snippet":"export function forwardPath(state: TitlebarHistory) {\n  if (state.index >= state.stack.length - 1) return\n  const index = state.index + 1\n  const to = state.stack[index]\n  if (!to) return\n  return { state: { ...state, index, action: \"forward\" as const }, to }\n}"}],"edges":[{"source":"titlebar_history","target":"titlebar_history_applypath","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L11","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L11"}],"weight":1},{"source":"titlebar_history","target":"titlebar_history_pushpath","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L28"}],"weight":1},{"source":"titlebar_history","target":"titlebar_history_trimhistory","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/titlebar-history.ts","source_location":"L34"}],"weight":1},{"source":"titlebar_history","target":"titlebar_history_backpath","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/ri