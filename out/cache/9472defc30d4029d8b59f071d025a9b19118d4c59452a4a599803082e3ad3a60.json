ages/session/message-timeline.data.ts","source_location":"L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L68"}],"snippet":"export class BottomSpacer extends Data.TaggedClass(\"BottomSpacer\")<{}> {}"},{"id":"message_timeline_data_key","label":"key()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L81-L102","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L81"}],"snippet":"key = (row: TimelineRow) => {\n    switch (row._tag) {\n      case \"CommentStrip\":\n        return `comment-strip:${row.userMessageID}`\n      case \"UserMessage\":\n        return `user-message:${row.userMessageID}`\n      case \"TurnDivider\":\n        return `turn-divider:${row.userMessageID}:${row.label}`\n      case \"AssistantPart\":\n        return `assistant-part:${row.userMessageID}:${row.group.key}`\n      case \"Thinking\":\n        return `thinking:${row.userMessageID}`\n      case \"DiffSummary\":\n        return `diff-summary:${row.userMessageID}`\n      case \"Error\":\n        return `error:${row.userMessageID}`\n      case \"Retry\":\n        return `retry:${row.userMessageID}`\n      case \"BottomSpacer\":\n        return \"bottom-spacer\"\n    }\n  }"},{"id":"message_timeline_data_equals","label":"equals()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L104-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L104"}],"snippet":"export function equals(a: TimelineRow, b: TimelineRow) {\n    return Equal.equals(a, b)\n  }"},{"id":"message_timeline_data_constructmessagerows","label":"constructMessageRows()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L110-L245","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L110"}],"snippet":"export function constructMessageRows(\n    userMessage: UserMessage,\n    getMessageParts: (messageID: string) => Part[],\n    assistantMessages: AssistantMessage[],\n    index: number,\n    showReasoning: boolean,\n    status: SessionStatus[\"type\"],\n    isActive: boolean,\n  ) {\n    const rows: TimelineRow.TimelineRow[] = []\n\n    const previousUserMessage = index > 0\n    const userParts = getMessageParts(userMessage.id)\n    const comments = userParts.flatMap((p) => MessageComment.fromPart(p) ?? [])\n    const compaction = userParts.some((p) => p.type === \"compaction\")\n    const interruptedMessageIndex = assistantMessages.findIndex((m) => m.error?.name === \"MessageAbortedError\")\n    const interrupted = interruptedMessageIndex !== -1\n    const error = assistantMessages.find((m) => m.error && m.error.name !== \"MessageAbortedError\")?.error\n\n    const assistantPartRefs = assistantMessages.flatMap((message, messageIndex) =>\n      getMessageParts(message.id)\n        .filter((part) => renderable(part, showReasoning))\n        .map((part) => ({ messageID: message.id, messageIndex, part })),\n    )\n    const assistantItems ="},{"id":"message_timeline_data_issummarydiff","label":"isSummaryDiff()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L247-L249","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L247"}],"snippet":"function isSummaryDiff(value: SnapshotFileDiff): value is SummaryDiff {\n    return typeof value.file === \"string\"\n  }"},{"id":"message_timeline_data_reasoningheading","label":"reasoningHeading()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L251-L276","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L251"}],"snippet":"function reasoningHeading(text: string) {\n    const markdown = text.replace(/\\r\\n?/g, \"\\n\")\n    const html = markdown.match(/<h[1-6][^>]*>([\\s\\S]*?)<\\/h[1-6]>/i)\n    if (html?.[1]) {\n      const value = cleanHeading(html[1].replace(/<[^>]+>/g, \" \"))\n      if (value) return value\n    }\n\n    const atx = markdown.match(/^\\s{0,3}#{1,6}[ \\t]+(.+?)(?:[ \\t]+#+[ \\t]*)?$/m)\n    if (atx?.[1]) {\n      const value = cleanHeading(atx[1])\n      if (value) return value\n    }\n\n    const setext = markdown.match(/^([^\\n]+)\\n(?:=+|-+)\\s*$/m)\n    if (setext?.[1]) {\n      const value = cleanHeading(setext[1])\n      if (value) return value\n    }\n\n    const strong = markdown.match(/^\\s*(?:\\*\\*|__)(.+?)(?:\\*\\*|__)\\s*$/m)\n    if (strong?.[1]) {\n      const value = cleanHeading(strong[1])\n      if (value) return value\n    }"},{"id":"message_timeline_data_cleanheading","label":"cleanHeading()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L278-L284","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L278"}],"snippet":"function cleanHeading(value: string) {\n    return value\n      .replace(/`([^`]+)`/g, \"$1\")\n      .replace(/\\[([^\\]]+)\\]\\([^)]+\\)/g, \"$1\")\n      .replace(/[*_~]+/g, \"\")\n      .trim()\n  }"},{"id":"message_timeline_data_unwraperrormessage","label":"unwrapErrorMessage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L286-L331","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L286"}],"snippet":"function unwrapErrorMessage(message: string) {\n    const text = message.replace(/^Error:\\s*/, \"\").trim()\n\n    const parse = (value: string) => {\n      try {\n        return JSON.parse(value) as unknown\n      } catch {\n        return undefined\n      }\n    }\n\n    const read = (value: string) => {\n      const first = parse(value)\n      if (typeof first !== \"string\") return first\n      return parse(first.trim())\n    }\n\n    let json = read(text)\n\n    if (json === undefined) {\n      const start = text.indexOf(\"{\")\n      const end = text.lastIndexOf(\"}\")\n      if (start !== -1 && end > start) json = read(text.slice(start, end + 1))\n    }"},{"id":"message_timeline_data_unwraperrormessage_parse","label":"parse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L289-L295","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L289"}],"snippet":"parse = (value: string) => {\n      try {\n        return JSON.parse(value) as unknown\n      } catch {\n        return undefined\n      }\n    }"},{"id":"message_timeline_data_unwraperrormessage_read","label":"read()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L297-L301","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L297"}],"snippet":"read = (value: string) => {\n      const first = parse(value)\n      if (typeof first !== \"string\") return first\n      return parse(first.trim())\n    }"},{"id":"message_timeline_data_record","label":"record()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L333-L335","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L333"}],"snippet":"function record(value: unknown): value is Record<string, unknown> {\n    return !!value && typeof value === \"object\" && !Array.isArray(value)\n  }"},{"id":"message_timeline_data_frompart","label":"fromPart()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L348-L362","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/message-timeline.data.ts","source_location":"L348"}],"snippet":"fromPart