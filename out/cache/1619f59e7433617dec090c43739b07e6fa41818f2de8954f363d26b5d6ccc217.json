{"__madarTsExtractorVersion":67,"__madarFileStem":"session-composer-state","nodes":[{"id":"session_composer_state","label":"session-composer-state.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L1"}]},{"id":"session_composer_state_todostate","label":"todoState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L13-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L13"}],"snippet":"todoState = (input: {\n  count: number\n  done: boolean\n  live: boolean\n}): \"hide\" | \"clear\" | \"open\" | \"close\" => {\n  if (input.count === 0) return \"hide\"\n  if (!input.live) return \"clear\"\n  if (!input.done) return \"open\"\n  return \"close\"\n}"},{"id":"session_composer_state_createsessioncomposerstate","label":"createSessionComposerState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L26-L189","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L26"}],"snippet":"export function createSessionComposerState(options?: { closeMs?: number | (() => number) }) {\n  const params = useParams()\n  const sdk = useSDK()\n  const sync = useSync()\n  const serverSync = useServerSync()\n  const language = useLanguage()\n  const permission = usePermission()\n\n  const questionRequest = createMemo((): QuestionRequest | undefined => {\n    return sessionQuestionRequest(sync().data.session, sync().data.question, params.id)\n  })\n\n  const permissionRequest = createMemo((): PermissionRequest | undefined => {\n    return sessionPermissionRequest(sync().data.session, sync().data.permission, params.id, (item) => {\n      return !permission.autoResponds(item, sdk().directory)\n    })\n  })\n\n  const blocked = createMemo(() => {\n    const id = params.id\n    if (!id) return false\n    return !!permissionRequest() || !!questionRequest()\n  })\n\n  const todos = createMemo((): Todo[] => {"},{"id":"session_composer_state_createsessioncomposerstate_decide","label":"decide()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L75-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L75"}],"snippet":"decide = (response: \"once\" | \"always\" | \"reject\") => {\n    const perm = permissionRequest()\n    if (!perm) return\n    if (store.responding === perm.id) return\n\n    setStore(\"responding\", perm.id)\n    sdk()\n      .client.permission.respond({ sessionID: perm.sessionID, permissionID: perm.id, response })\n      .catch((err: unknown) => {\n        const description = err instanceof Error ? err.message : String(err)\n        showToast({ title: language.t(\"common.requestFailed\"), description })\n      })\n      .finally(() => {\n        setStore(\"responding\", (id) => (id === perm.id ? undefined : id))\n      })\n  }"},{"id":"session_composer_state_createsessioncomposerstate_closems","label":"closeMs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L95-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L95"}],"snippet":"closeMs = () => {\n    const value = options?.closeMs\n    if (typeof value === \"function\") return Math.max(0, value())\n    if (typeof value === \"number\") return Math.max(0, value)\n    return 400\n  }"},{"id":"session_composer_state_createsessioncomposerstate_scheduleclose","label":"scheduleClose()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L102-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L102"}],"snippet":"scheduleClose = () => {\n    if (timer) window.clearTimeout(timer)\n    timer = window.setTimeout(() => {\n      setStore({ dock: false, closing: false })\n      timer = undefined\n    }, closeMs())\n  }"},{"id":"session_composer_state_createsessioncomposerstate_clear","label":"clear()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L111-L116","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-composer-state.ts","source_location":"L111"}],"snippet":"clear = () => {\n    const id = params.id\n    if (!id) return\n    serverSync().todo.set(id, [])\n    sync().set(\