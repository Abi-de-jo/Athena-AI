{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_stats_app_src_routes_[lab]_index","nodes":[{"id":"packages_stats_app_src_routes_lab_index","label":"index.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L1"}]},{"id":"packages_stats_app_src_routes_lab_index_statslab","label":"StatsLab()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L52-L136","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L52"}],"snippet":"export default function StatsLab() {\n  const event = getRequestEvent()\n  event?.response.headers.set(\"Cache-Control\", \"public, max-age=60, s-maxage=300, stale-while-revalidate=86400\")\n  const params = useParams()\n  const labParam = createMemo(() => params.lab ?? \"\")\n  const catalog = createAsync(() => getModelCatalog())\n  const lab = createMemo(() => {\n    const data = catalog()\n    if (!data) return undefined\n    return findModelCatalogLab(data, labParam()) ?? null\n  })\n  const stats = createAsync(() => {\n    const entry = lab()\n    if (catalog() === undefined || entry === undefined) return Promise.resolve(undefined)\n    if (!entry) return Promise.resolve(null)\n    return getLabData(entry.id)\n  })\n  const githubStars = createAsync(() => getGitHubStars())\n  const [themePreference, setThemePreference] = createSignal<ThemePreference>(\"system\")\n  const labName = createMemo(() => lab()?.name ?? formatCatalogLabName(labParam()))\n  const labTitle = createMemo(() => `${labName()} Models`)\n  const labDescription = createMemo(\n    () =>\n      `Explore ${labName()} models used in OpenCode, with recent token usage, context windows, release dates, and model-specific data.`,\n  )","node_kind":"component"},{"id":"packages_stats_app_src_routes_lab_index_statslab_updatethemepreference","label":"updateThemePreference()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L78-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L78"}],"snippet":"updateThemePreference = (preference: ThemePreference) => {\n    applyThemePreference(preference)\n    setThemePreference(preference)\n    if (typeof window === \"undefined\") return\n    window.localStorage.setItem(themeStorageKey, preference)\n  }"},{"id":"packages_stats_app_src_routes_lab_index_labloading","label":"LabLoading()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L138-L152","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L138"}],"snippet":"function LabLoading() {\n  return (\n    <section id=\"overview\" data-section=\"lab-hero\">\n      <div data-slot=\"model-hero-grid\">\n        <div data-slot=\"model-hero-copy\">\n          <a data-slot=\"model-back-link\" href={import.meta.env.BASE_URL}>\n            Data\n          </a>\n          <h1>Model Lab</h1>\n          <p>Reading model availability and recent OpenCode usage.</p>\n        </div>\n      </div>\n    </section>\n  )\n}","node_kind":"component"},{"id":"packages_stats_app_src_routes_lab_index_labnotfound","label":"LabNotFound()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L154-L168","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L154"}],"snippet":"function LabNotFound(props: { lab: string }) {\n  return (\n    <section id=\"overview\" data-section=\"lab-hero\">\n      <div data-slot=\"model-hero-grid\">\n        <div data-slot=\"model-hero-copy\">\n          <a data-slot=\"model-back-link\" href={import.meta.env.BASE_URL}>\n            Data\n          </a>\n          <h1>{formatCatalogLabName(props.lab)}</h1>\n          <p>No models matched this lab.</p>\n        </div>\n      </div>\n    </section>\n  )\n}","node_kind":"component"},{"id":"packages_stats_app_src_routes_lab_index_labhero","label":"LabHero()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L170-L209","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L170"}],"snippet":"function LabHero(props: { lab: ModelCatalogLab; stats: StatsLabData | null }) {\n  const latest = createMemo(\n    () =>\n      props.lab.models\n        .map((model) => model.releaseDate)\n        .filter((value): value is string => value !== undefined)\n        .toSorted((a, b) => new Date(b).getTime() - new Date(a).getTime())[0],\n  )\n  const featuredModels = createMemo(() => props.lab.models.slice(0, 3).map((model) => model.name))\n\n  return (\n    <section id=\"overview\" data-section=\"lab-hero\">\n      <a data-slot=\"model-back-link\" href={import.meta.env.BASE_URL}>\n        Data\n      </a>\n      <div data-slot=\"model-hero-grid\">\n        <div data-slot=\"model-hero-copy\">\n          <h1>{props.lab.name}</h1>\n          <div data-slot=\"model-hero-pattern\" aria-hidden=\"true\" />\n          <p>\n            Explore {props.lab.models.length} {props.lab.name} models used in OpenCode\n            <Show when={featuredModels().length > 0}> including {formatList(featuredModels())}</Show>. Compare recent\n            token usage, context windows, release dates, and model-specific data.\n          </p>\n        </div>","node_kind":"component"},{"id":"packages_stats_app_src_routes_lab_index_labusagesection","label":"LabUsageSection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L211-L320","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L211"}],"snippet":"function LabUsageSection(props: { lab: ModelCatalogLab; data: StatsLabData | null }) {\n  const [activeIndex, setActiveIndex] = createSignal<number>()\n  const usage = createMemo(() => props.data?.usage ?? [])\n  const max = createMemo(() => Math.max(0, ...usage().map((item) => item.tokens)) || 1)\n  const activePoint = createMemo(() => {\n    const index = activeIndex()\n    if (index === undefined) return undefined\n    return usage()[index]\n  })\n\n  return (\n    <section id=\"usage\" data-section=\"model-panel\">\n      <p data-slot=\"section-title\">\n        <strong>{props.lab.name} token usage.</strong>{\" \"}\n        <span>Daily OpenCode token volume over the last two months.</span>\n      </p>\n      <Show\n        when={usage().some((item) => item.tokens > 0)}\n        fallback={\n          <LabEmptyState\n            title=\"No usage yet\"\n            description=\"Recent token usage appears here once this lab has activity.\"\n          />\n        }\n      >","node_kind":"component"},{"id":"packages_stats_app_src_routes_lab_index_labmodelssection","label":"LabModelsSection()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L322-L336","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L322"}],"snippet":"function LabModelsSection(props: { lab: ModelCatalogLab; usage: LabUsageModelEntry[] }) {\n  const usageBySlug = createMemo(() => new Map(props.usage.map((item) => [item.slug, item])))\n  return (\n    <section id=\"models\" data-section=\"model-panel\">\n      <p data-slot=\"section-title\">\n        <strong>{props.lab.name} models.</strong> <span>Recent usage and limits.</span>\n      </p>\n      <div data-component=\"lab-model-grid\">\n        <For each={props.lab.models}>\n          {(model) => <LabModelCard model={model} usage={usageBySlug().get(model.slug)} />}\n        </For>\n      </div>\n    </section>\n  )\n}","node_kind":"component"},{"id":"packages_stats_app_src_routes_lab_index_labmodelcard","label":"LabModelCard()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L338-L366","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L338"}],"snippet":"function LabModelCard(props: { model: ModelCatalogEntry; usage: LabUsageModelEntry | undefined }) {\n  return (\n    <a data-component=\"lab-model-card\" href={`${import.meta.env.BASE_URL}${props.model.id}`}>\n      <strong>{props.model.name}</strong>\n      <div data-slot=\"lab-model-card-meta\">\n        <p>\n          <b>Usage</b>\n          <em>{props.usage ? formatTokens(props.usage.tokens) : \"—\"}</em>\n        </p>\n        <p>\n          <b>Share</b>\n          <em>{props.usage ? formatPercent(props.usage.share) : \"—\"}</em>\n        </p>\n        <p>\n          <b>Context</b>\n          <em>{formatCatalogLimit(props.model.limit?.context)}</em>\n        </p>\n        <p>\n          <b>Output</b>\n          <em>{formatCatalogLimit(props.model.limit?.output)}</em>\n        </p>\n        <p>\n          <b>Release</b>\n          <em>{formatCatalogDate(props.model.releaseDate)}</em>\n        </p>","node_kind":"component"},{"id":"packages_stats_app_src_routes_lab_index_labemptystate","label":"LabEmptyState()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L368-L375","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L368"}],"snippet":"function LabEmptyState(props: { title: string; description: string }) {\n  return (\n    <div data-component=\"empty-state\" data-compact=\"true\">\n      <strong>{props.title}</strong>\n      <p>{props.description}</p>\n    </div>\n  )\n}","node_kind":"component"},{"id":"packages_stats_app_src_routes_lab_index_formatcataloglimit","label":"formatCatalogLimit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L377-L379","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L377"}],"snippet":"function formatCatalogLimit(value: number | undefined) {\n  return value === undefined ? \"Unknown\" : formatTokens(value)\n}"},{"id":"packages_stats_app_src_routes_lab_index_formatcatalogdate","label":"formatCatalogDate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L381-L394","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L381"}],"snippet":"function formatCatalogDate(value: string | undefined) {\n  if (!value) return \"Unknown\"\n  const match = /^(\\d{4})(?:-(\\d{2}))?(?:-(\\d{2}))?$/.exec(value)\n  if (!match) return value\n  const year = Number(match[1])\n  const month = match[2] ? Number(match[2]) - 1 : 0\n  const day = match[3] ? Number(match[3]) : 1\n  return new Intl.DateTimeFormat(\"en\", {\n    month: match[2] ? \"short\" : undefined,\n    day: match[3] ? \"numeric\" : undefined,\n    year: \"numeric\",\n    timeZone: \"UTC\",\n  }).format(new Date(Date.UTC(year, month, day)))\n}"},{"id":"packages_stats_app_src_routes_lab_index_formatlist","label":"formatList()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L396-L400","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L396"}],"snippet":"function formatList(values: string[]) {\n  if (values.length <= 1) return values[0] ?? \"\"\n  if (values.length === 2) return `${values[0]} and ${values[1]}`\n  return `${values.slice(0, -1).join(\", \")}, and ${values[values.length - 1]}`\n}"},{"id":"packages_stats_app_src_routes_lab_index_formatpercent","label":"formatPercent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L402-L404","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L402"}],"snippet":"function formatPercent(value: number) {\n  return `${trimNumber(value, value >= 10 ? 1 : 2)}%`\n}"},{"id":"packages_stats_app_src_routes_lab_index_formattokens","label":"formatTokens()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L406-L413","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L406"}],"snippet":"function formatTokens(value: number) {\n  if (value >= 1_000_000_000_000)\n    return `${trimNumber(value / 1_000_000_000_000, value >= 10_000_000_000_000 ? 0 : 1)}T`\n  if (value >= 1_000_000_000) return `${trimNumber(value / 1_000_000_000, value >= 10_000_000_000 ? 0 : 1)}B`\n  if (value >= 1_000_000) return `${trimNumber(value / 1_000_000, value >= 10_000_000 ? 0 : 1)}M`\n  if (value >= 1_000) return `${trimNumber(value / 1_000, value >= 10_000 ? 0 : 1)}K`\n  return String(Math.round(value))\n}"},{"id":"packages_stats_app_src_routes_lab_index_trimnumber","label":"trimNumber()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L415-L417","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L415"}],"snippet":"function trimNumber(value: number, digits: number) {\n  return Number(value.toFixed(digits)).toLocaleString(\"en\")\n}"},{"id":"packages_stats_app_src_routes_lab_index_usageheight","label":"usageHeight()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L419-L422","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L419"}],"snippet":"function usageHeight(value: number, max: number) {\n  if (value <= 0 || max <= 0) return 0\n  return Math.max(4, (value / max) * 100)\n}"},{"id":"packages_stats_app_src_routes_lab_index_islabusagedense","label":"isLabUsageDense()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L424-L426","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L424"}],"snippet":"function isLabUsageDense(count: number) {\n  return count > 20\n}"},{"id":"packages_stats_app_src_routes_lab_index_islabusagelabelhidden","label":"isLabUsageLabelHidden()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L428-L432","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_location":"L428"}],"snippet":"function isLabUsageLabelHidden(index: number, count: number) {\n  if (count <= 14) return false\n  const cadence = count > 45 ? 7 : count > 28 ? 4 : 2\n  return index % cadence !== 0 && index !== count - 1\n}"}],"edges":[{"source":"packages_stats_app_src_routes_lab_index","target":"index","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/stats/app/src/routes/[lab]/index.tsx","source_locati