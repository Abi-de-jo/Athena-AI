{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_core_src_observability_logging","nodes":[{"id":"packages_core_src_observability_logging","label":"logging.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L1"}]},{"id":"packages_core_src_observability_logging_formatter","label":"formatter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L6-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L6"}],"snippet":"function formatter(id: string = runID) {\n  return Logger.map(Logger.formatStructured, (output) => {\n    const messages = Array.isArray(output.message) ? output.message : [output.message]\n    return [\n      [\"timestamp\", output.timestamp],\n      [\"level\", output.level],\n      [\"run\", id],\n      ...messages.flatMap((value) => (plain(value) ? flatten(value) : [[\"message\", value] as const])),\n      ...(output.cause === undefined ? [] : [[\"cause\", output.cause] as const]),\n      ...flatten(output.spans),\n      ...flatten(output.annotations),\n    ]\n      .map(([key, value]) => `${key}=${format(value)}`)\n      .join(\" \")\n  })\n}"},{"id":"packages_core_src_observability_logging_flatten","label":"flatten()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L23-L36","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L23"}],"snippet":"function flatten(\n  input: Record<string, unknown>,\n  prefix = \"\",\n  seen = new WeakSet<object>(),\n): Array<readonly [string, unknown]> {\n  if (seen.has(input)) return [[prefix, \"[Circular]\"]]\n  seen.add(input)\n  const entries = Object.entries(input)\n  if (entries.length === 0 && prefix) return [[prefix, input]]\n  return entries.flatMap(([key, value]) => {\n    const path = prefix ? `${prefix}.${key}` : key\n    return plain(value) ? flatten(value, path, seen) : [[path, value] as const]\n  })\n}"},{"id":"packages_core_src_observability_logging_plain","label":"plain()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L38-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L38"}],"snippet":"function plain(input: unknown): input is Record<string, unknown> {\n  if (input === null || typeof input !== \"object\" || Array.isArray(input)) return false\n  const prototype = Object.getPrototypeOf(input)\n  return prototype === Object.prototype || prototype === null\n}"},{"id":"packages_core_src_observability_logging_format","label":"format()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L44-L47","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L44"}],"snippet":"function format(input: unknown) {\n  const value = typeof input === \"string\" ? input : Formatter.format(input)\n  return /^[^\\s=\"\\\\]+$/.test(value) ? value : JSON.stringify(value)\n}"},{"id":"packages_core_src_observability_logging_filelogger","label":"fileLogger()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L49-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L49"}],"snippet":"export function fileLogger(file = path.join(Global.Path.log, \"rimuru.log\"), id: string = runID) {\n  // Do not set batchWindow to 0; it causes high idle CPU usage.\n  return Logger.toFile(formatter(id), file, { flag: \"a\" })\n}"},{"id":"packages_core_src_observability_logging_minimumloglevel","label":"minimumLogLevel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L56-L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L56"}],"snippet":"export function minimumLogLevel() {\n  const value = process.env.OPENCODE_LOG_LEVEL?.toUpperCase()\n  const levels = {\n    DEBUG: \"Debug\",\n    INFO: \"Info\",\n    WARN: \"Warn\",\n    ERROR: \"Error\",\n  } as const satisfies Record<string, LogLevel.LogLevel>\n  return value && value in levels ? levels[value as keyof typeof levels] : levels.INFO\n}"},{"id":"packages_core_src_observability_logging_loggers","label":"loggers()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L67-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/observability/logging.ts","source_location":"L67"}],"snippet":"export function 