outh-2\",\n    ].some((item) => resolvedRegion.includes(item))\n    const modelRequiresPrefix = [\"claude\", \"nova-lite\", \"nova-micro\", \"llama3\", \"pixtral\"].some((item) =>\n      modelID.includes(item),"},{"id":"packages_core_src_plugin_provider_amazon_bedrock_selectmantlemodel","label":"selectMantleModel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/amazon-bedrock.ts","source_location":"L56-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/amazon-bedrock.ts","source_location":"L56"}],"snippet":"function selectMantleModel(sdk: MantleSDK, modelID: string) {\n  if (modelID === \"openai.gpt-oss-safeguard-20b\" || modelID === \"openai.gpt-oss-safeguard-120b\")\n    return sdk.chat(modelID)\n  return sdk.responses(modelID)\n}"}],"edges":[{"source":"packages_core_src_plugin_provider_amazon_bedrock","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/amazon-bedrock.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/amazon-bedrock.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_src_plugin_provider_amazon_bedrock","target":"provider","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/amazon-bedrock.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/plugin/provider/amazon-bedrock.ts","source_location":"L2"}],"weight":1},{"source":"packages_core_src_