nvalid tool input: ${error.message}` })),\n        Effect.flatMap((input) =>\n          config.execute(input, context).pipe(\n            Effect.flatMap((output) =>\n              Schema.encodeEffect(config.output)(output).pipe("},{"id":"packages_core_src_tool_tool_validatename","label":"validateName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/tool.ts","source_location":"L116-L119","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/tool.ts","source_location":"L116"}],"snippet":"validateName = (name: string) =>\n  /^[A-Za-z][A-Za-z0-9_-]{0,63}$/.test(name)\n    ? Effect.void\n    : Effect.fail(new RegistrationError({ name, message: `Invalid tool name: ${name}` }))"},{"id":"packages_core_src_tool_tool_withpermission","label":"withPermission()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/tool.ts","source_location":"L121-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/tool.ts","source_location":"L121"}],"snippet":"withPermission = <Input extends SchemaType<any>, Output extends SchemaType<any>>(\n  tool: Definition<Input, Output>,\n  permission: string,\n) => {\n  const decorated = Object.freeze({}) as Definition<Input, Output>\n  runtimes.set(decorated, { ...runtimeOf(tool), permission })\n  return decorated\n}"},{"id":"packages_core_src_tool_tool_permission","label":"permission()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/tool.ts","source_location":"L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool/tool.ts","source_locati