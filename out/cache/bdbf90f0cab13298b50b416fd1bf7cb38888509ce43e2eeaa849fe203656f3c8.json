{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_plugin_openai_codex","nodes":[{"id":"packages_opencode_src_plugin_openai_codex","label":"codex.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L1"}]},{"id":"packages_opencode_src_plugin_openai_codex_pkcecodes","label":"PkceCodes","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L17-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L17"}],"snippet":"interface PkceCodes {\n  verifier: string\n  challenge: string\n}"},{"id":"packages_opencode_src_plugin_openai_codex_generatepkce","label":"generatePKCE()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L22-L29","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L22"}],"snippet":"async function generatePKCE(): Promise<PkceCodes> {\n  const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~\"\n  const verifier = Array.from(crypto.getRandomValues(new Uint8Array(43)))\n    .map((b) => chars[b % chars.length])\n    .join(\"\")\n  const challenge = base64UrlEncode(await crypto.subtle.digest(\"SHA-256\", new TextEncoder().encode(verifier)))\n  return { verifier, challenge }\n}"},{"id":"packages_opencode_src_plugin_openai_codex_base64urlencode","label":"base64UrlEncode()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L31-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L31"}],"snippet":"function base64UrlEncode(buffer: ArrayBuffer): string {\n  const bytes = new Uint8Array(buffer)\n  const binary = String.fromCharCode(...bytes)\n  return btoa(binary).replace(/\\+/g, \"-\").replace(/\\//g, \"_\").replace(/=+$/, \"\")\n}"},{"id":"packages_opencode_src_plugin_openai_codex_idtokenclaims","label":"IdTokenClaims","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L37-L44","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L37"}],"snippet":"export interface IdTokenClaims {\n  chatgpt_account_id?: string\n  organizations?: Array<{ id: string }>\n  email?: string\n  \"https://api.openai.com/auth\"?: {\n    chatgpt_account_id?: string\n  }\n}"},{"id":"packages_opencode_src_plugin_openai_codex_parsejwtclaims","label":"parseJwtClaims()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L46-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L46"}],"snippet":"export function parseJwtClaims(token: string): IdTokenClaims | undefined {\n  const parts = token.split(\".\")\n  if (parts.length !== 3) return undefined\n  try {\n    return JSON.parse(Buffer.from(parts[1], \"base64url\").toString())\n  } catch {\n    return undefined\n  }\n}"},{"id":"packages_opencode_src_plugin_openai_codex_extractaccountidfromclaims","label":"extractAccountIdFromClaims()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L56-L62","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L56"}],"snippet":"export function extractAccountIdFromClaims(claims: IdTokenClaims): string | undefined {\n  return (\n    claims.chatgpt_account_id ||\n    claims[\"https://api.openai.com/auth\"]?.chatgpt_account_id ||\n    claims.organizations?.[0]?.id\n  )\n}"},{"id":"packages_opencode_src_plugin_openai_codex_extractaccountid","label":"extractAccountId()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L64-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L64"}],"snippet":"export function extractAccountId(tokens: TokenResponse): string | undefined {\n  if (tokens.id_token) {\n    const claims = parseJwtClaims(tokens.id_token)\n    const accountId = claims && extractAccountIdFromClaims(claims)\n    if (accountId) return accountId\n  }\n  if (tokens.access_token) {\n    const claims = parseJwtClaims(tokens.access_token)\n    return claims ? extractAccountIdFromClaims(claims) : undefined\n  }\n  return undefined\n}"},{"id":"packages_opencode_src_plugin_openai_codex_buildauthorizeurl","label":"buildAuthorizeUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L77-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L77"}],"snippet":"function buildAuthorizeUrl(redirectUri: string, pkce: PkceCodes, state: string): string {\n  const params = new URLSearchParams({\n    response_type: \"code\",\n    client_id: CLIENT_ID,\n    redirect_uri: redirectUri,\n    scope: \"openid profile email offline_access\",\n    code_challenge: pkce.challenge,\n    code_challenge_method: \"S256\",\n    id_token_add_organizations: \"true\",\n    codex_cli_simplified_flow: \"true\",\n    state,\n    originator: \"rimuru-ai\",\n  })\n  return `${ISSUER}/oauth/authorize?${params.toString()}`\n}"},{"id":"packages_opencode_src_plugin_openai_codex_tokenresponse","label":"TokenResponse","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L93-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L93"}],"snippet":"interface TokenResponse {\n  id_token: string\n  access_token: string\n  refresh_token: string\n  expires_in?: number\n}"},{"id":"packages_opencode_src_plugin_openai_codex_codexauthpluginoptions","label":"CodexAuthPluginOptions","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L100-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L100"}],"snippet":"interface CodexAuthPluginOptions {\n  issuer?: string\n  codexApiEndpoint?: string\n  experimentalWebSockets?: boolean\n}"},{"id":"packages_opencode_src_plugin_openai_codex_exchangecodefortokens","label":"exchangeCodeForTokens()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L106-L122","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L106"}],"snippet":"async function exchangeCodeForTokens(code: string, redirectUri: string, pkce: PkceCodes): Promise<TokenResponse> {\n  const response = await fetch(`${ISSUER}/oauth/token`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/x-www-form-urlencoded\" },\n    body: new URLSearchParams({\n      grant_type: \"authorization_code\",\n      code,\n      redirect_uri: redirectUri,\n      client_id: CLIENT_ID,\n      code_verifier: pkce.verifier,\n    }).toString(),\n  })\n  if (!response.ok) {\n    throw new Error(`Token exchange failed: ${response.status}`)\n  }\n  return response.json()\n}"},{"id":"packages_opencode_src_plugin_openai_codex_refreshaccesstoken","label":"refreshAccessToken()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L124-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L124"}],"snippet":"async function refreshAccessToken(refreshToken: string, issuer = ISSUER): Promise<TokenResponse> {\n  const response = await fetch(`${issuer}/oauth/token`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/x-www-form-urlencoded\" },\n    body: new URLSearchParams({\n      grant_type: \"refresh_token\",\n      refresh_token: refreshToken,\n      client_id: CLIENT_ID,\n    }).toString(),\n  })\n  if (!response.ok) {\n    throw new Error(`Token refresh failed: ${response.status}`)\n  }\n  return response.json()\n}"},{"id":"packages_opencode_src_plugin_openai_codex_renderoautherror","label":"renderOAuthError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L182-L228","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L182"}],"snippet":"renderOAuthError = (error: string) => `<!doctype html>\n<html>\n  <head>\n    <title>OpenCode - Codex Authorization Failed</title>\n    <style>\n      body {\n        font-family:\n          system-ui,\n          -apple-system,\n          sans-serif;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        height: 100vh;\n        margin: 0;\n        background: #131010;\n        color: #f1ecec;\n      }\n      .container {\n        text-align: center;\n        padding: 2rem;\n      }\n      h1 {\n        color: #fc533a;\n        margin-bottom: 1rem;"},{"id":"packages_opencode_src_plugin_openai_codex_pendingoauth","label":"PendingOAuth","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L230-L235","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L230"}],"snippet":"interface PendingOAuth {\n  pkce: PkceCodes\n  state: string\n  resolve: (tokens: TokenResponse) => void\n  reject: (error: Error) => void\n}"},{"id":"packages_opencode_src_plugin_openai_codex_startoauthserver","label":"startOAuthServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L240-L313","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L240"}],"snippet":"async function startOAuthServer(): Promise<{ port: number; redirectUri: string }> {\n  if (oauthServer) {\n    return { port: OAUTH_PORT, redirectUri: `http://localhost:${OAUTH_PORT}/auth/callback` }\n  }\n\n  oauthServer = createServer((req, res) => {\n    const url = new URL(req.url || \"/\", `http://localhost:${OAUTH_PORT}`)\n\n    if (url.pathname === \"/auth/callback\") {\n      const code = url.searchParams.get(\"code\")\n      const state = url.searchParams.get(\"state\")\n      const error = url.searchParams.get(\"error\")\n      const errorDescription = url.searchParams.get(\"error_description\")\n\n      if (error) {\n        const errorMsg = errorDescription || error\n        pendingOAuth?.reject(new Error(errorMsg))\n        pendingOAuth = undefined\n        res.writeHead(200, { \"Content-Type\": \"text/html; charset=utf-8\" })\n        res.end(renderOAuthError(errorMsg))\n        return\n      }\n\n      if (!code) {\n        const errorMsg = \"Missing authorization code\""},{"id":"packages_opencode_src_plugin_openai_codex_stopoauthserver","label":"stopOAuthServer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L315-L320","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L315"}],"snippet":"function stopOAuthServer() {\n  if (oauthServer) {\n    oauthServer.close(() => {})\n    oauthServer = undefined\n  }\n}"},{"id":"packages_opencode_src_plugin_openai_codex_waitforoauthcallback","label":"waitForOAuthCallback()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L322-L347","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L322"}],"snippet":"function waitForOAuthCallback(pkce: PkceCodes, state: string): Promise<TokenResponse> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(\n      () => {\n        if (pendingOAuth) {\n          pendingOAuth = undefined\n          reject(new Error(\"OAuth callback timeout - authorization took too long\"))\n        }\n      },\n      5 * 60 * 1000,\n    ) // 5 minute timeout\n\n    pendingOAuth = {\n      pkce,\n      state,\n      resolve: (tokens) => {\n        clearTimeout(timeout)\n        resolve(tokens)\n      },\n      reject: (error) => {\n        clearTimeout(timeout)\n        reject(error)\n      },\n    }\n  })"},{"id":"packages_opencode_src_plugin_openai_codex_codexauthplugin","label":"CodexAuthPlugin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L349-L641","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L349"}],"snippet":"export async function CodexAuthPlugin(input: PluginInput, options: CodexAuthPluginOptions = {}): Promise<Hooks> {\n  const issuer = options.issuer ?? ISSUER\n  const codexApiEndpoint = options.codexApiEndpoint ?? CODEX_API_ENDPOINT\n  let websocketFetchInstalled = false\n  const websocketFetches: Array<ReturnType<typeof OpenAIWebSocketPool.createWebSocketFetch>> = []\n\n  return {\n    async dispose() {\n      for (const websocketFetch of websocketFetches) websocketFetch.close()\n      websocketFetches.length = 0\n    },\n    async event(input) {\n      if (input.event.type !== \"session.deleted\") return\n      for (const websocketFetch of websocketFetches) websocketFetch.remove(input.event.properties.info.id)\n    },\n    provider: {\n      id: \"openai\",\n      async models(provider, ctx) {\n        if (ctx.auth?.type !== \"oauth\") return provider.models\n\n        return Object.fromEntries(\n          Object.entries(provider.models)\n            .filter(([, model]) => {\n              if (ALLOWED_MODELS.has(model.api.id)) return true\n              const match = model.api.id.match(/^gpt-(\\d+\\.\\d+)/)"}],"edges":[{"source":"packages_opencode_src_plugin_openai_codex","target":"plugin","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_plugin_openai_codex","target":"version","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L2"}],"weight":1},{"source":"packages_opencode_src_plugin_openai_codex","target":"auth","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L3"}],"weight":1},{"source":"packages_opencode_src_plugin_openai_codex","target":"os","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L4"}],"weight":1},{"source":"packages_opencode_src_plugin_openai_codex","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L5","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L5"}],"weight":1},{"source":"packages_opencode_src_plugin_openai_codex","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L6","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L6"}],"weight":1},{"source":"packages_opencode_src_plugin_openai_codex","target":"ws_pool","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/plugin/openai/codex.ts","source_location":"L7","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_fi