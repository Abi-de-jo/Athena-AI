 of input) {\n    const size = Buffer.byteLength(char, \"utf-8\")\n    if (bytes + size > maximumBytes) break\n    content += char\n    bytes += size\n  }\n  return content\n}"},{"id":"tool_output_store_takesuffix","label":"takeSuffix()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool-output-store.ts","source_location":"L56-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool-output-store.ts","source_location":"L56"}],"snippet":"takeSuffix = (input: string, maximumBytes: number) => {\n  let bytes = 0\n  const content: string[] = []\n  for (const char of Array.from(input).toReversed()) {\n    const size = Buffer.byteLength(char, \"utf-8\")\n    if (bytes + size > maximumBytes) break\n    content.unshift(char)\n    bytes += size\n  }\n  return content.join(\"\")\n}"},{"id":"tool_output_store_preview","label":"preview()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool-output-store.ts","source_location":"L68-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool-output-store.ts","source_location":"L68"}],"snippet":"preview = (text: string, maxLines: number, maxBytes: number) => {\n  const lines = text.split(\"\\n\")\n  const headLines = Math.ceil(maxLines / 2)\n  const tailLines = Math.floor(maxLines / 2)\n  const sampled =\n    lines.length <= maxLines\n      ? text\n      : [\n          lines.slice(0, headLines).join(\"\\n\"),\n          ...(tailLines > 0 ? [lines.slice(lines.length - tailLines).join(\"\\n\")] : []),\n        ].join(\"\\n\")\n  if (Buffer.byteLength(sampled, \"utf-8\") <= maxBytes) {\n    return lines.length <= maxLines\n      ? { head: sampled, tail: \"\" }\n      : {\n          head: lines.slice(0, headLines).join(\"\\n\"),\n          tail: tailLines > 0 ? lines.slice(lines.length - tailLines).join(\"\\n\") : \"\",\n        }\n  }\n  const headBytes = Math.ceil(maxBytes / 2)\n  const tailBytes = Math.floor(maxBytes / 2)\n  return { head: takePrefix(sampled, headBytes), tail: takeSuffix(sampled, tailBytes) }\n}"},{"id":"tool_output_store_boundedpreview","label":"boundedPreview()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool-output-store.ts","source_location":"L92-L98","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool-output-store.ts","source_location":"L92"}],"snippet":"boundedPreview = (text: string, marker: string, maxLines: number, maxBytes: number) => {\n  const markerOnly = takePrefix(marker, maxBytes).split(\"\\n\").slice(0, maxLines).join(\"\\n\")\n  const markerBytes = Buffer.byteLength(marker, \"utf-8\")\n  if (maxLines <= 4 || maxBytes <= markerBytes + 4) return markerOnly\n  const bounded = preview(text, maxLines - 4, maxBytes - markerBytes - 4)\n  return bounded.tail ? `${bounded.head}\\n\\n${marker}\\n\\n${bounded.tail}` : `${bounded.head}\\n\\n${marker}`\n}"},{"id":"tool_output_store_linecount","label":"lineCount()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool-output-store.ts","source_location":"L100-L104","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/tool-output-store.ts","source_location":"L100"}],"snippet":"lineCount = (text: string) => {\n  let count = 1\n  for (const char of text) if (char === \"\\n\") count++\n  return count\n}"}],"edges":[{"source":"tool_output_store","target":"tool_output_store","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal