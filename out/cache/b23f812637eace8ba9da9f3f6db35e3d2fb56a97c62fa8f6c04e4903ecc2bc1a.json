g>()\n  const mcpToggles = new Map<string, (enabled: boolean) => void>()"},{"id":"child_store_createchildstoremanager_markkey","label":"markKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L49-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L49"}],"snippet":"markKey = (key: DirectoryKey) => {\n    if (!key) return\n    lifecycle.set(key, { lastAccessAt: Date.now() })\n    runEviction(key)\n  }"},{"id":"child_store_createchildstoremanager_mark","label":"mark()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L55-L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L55"}],"snippet":"mark = (directory: string) => {\n    const key = directoryKey(directory)\n    markKey(key)\n  }"},{"id":"child_store_createchildstoremanager_pin","label":"pin()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L60-L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L60"}],"snippet":"pin = (directory: string) => {\n    const key = directoryKey(directory)\n    if (!key) return\n    pins.set(key, (pins.get(key) ?? 0) + 1)\n    markKey(key)\n  }"},{"id":"child_store_createchildstoremanager_unpin","label":"unpin()","file_type":"code","source_file":"/home/gowdaman/Project