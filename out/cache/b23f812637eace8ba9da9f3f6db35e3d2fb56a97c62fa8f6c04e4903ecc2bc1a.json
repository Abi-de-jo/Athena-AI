n      const set = ownerPins.get(key)\n      if (set) {\n        set.delete(directory)\n        if (set.size === 0) ownerPins.delete(key)\n      }\n      unpin(directory)\n    })\n  }"},{"id":"child_store_createchildstoremanager_disposedirectory","label":"disposeDirectory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L101-L129","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L101"}],"snippet":"function disposeDirectory(directory: DirectoryKey) {\n    const key = directory\n    if (\n      !canDisposeDirectory({\n        directory: key,\n        hasStore: !!children[key],\n        pinned: pinned(key),\n        booting: input.isBooting(key),\n        loadingSessions: input.isLoadingSessions(key),\n      })\n    ) {\n      return false\n    }\n\n    vcsCache.delete(key)\n    metaCache.delete(key)\n    iconCache.delete(key)\n    lifecycle.delete(key)\n    mcpDirectories.delete(key)\n    mcpToggles.delete(key)\n    const dispose = disposers.get(key)\n    if (dispose) {\n      dispose()\n      disposers.delete(key)\n    }"},{"id":"child_store_createchildstoremanager_runeviction","label":"runEviction()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L131-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L131"}],"snippet":"function runEviction(skip?: string) {\n    const stores = Object.keys(children)\n    if (stores.length === 0) return\n    const list = pickDirectoriesToEvict({\n      stores,\n      state: lifecycle,\n      pins: new Set(stores.filter(pinned)),\n      max: MAX_DIR_STORES,\n      ttl: DIR_IDLE_TTL_MS,\n      now: Date.now(),\n    }).filter((directory) => directory !== skip)\n    if (list.length === 0) return\n    for (const directory of list) {\n      if (!disposeDirectory(directoryKey(directory))) continue\n    }\n  }"},{"id":"child_store_createchildstoremanager_ensurechild","label":"ensureChild()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L148-L277","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L148"}],"snippet":"function ensureChild(directory: string) {\n    const key = directoryKey(directory)\n    if (!key) console.error(\"No directory provided\")\n    if (!children[key]) {\n      const vcs = runWithOwner(input.owner, () =>\n        input.persist(\n          Persist.serverWorkspace(input.scope, directory, \"vcs\", [\"vcs.v1\"]),\n          createStore({ value: undefined as VcsInfo | undefined }),\n        ),\n      )\n      if (!vcs) throw new Error(input.translate(\"error.childStore.persistedCacheCreateFailed\"))\n      const vcsStore = vcs[0]\n      vcsCache.set(key, { store: vcsStore, setStore: vcs[1], ready: vcs[3] })\n\n      const meta = runWithOwner(input.owner, () =>\n        input.persist(\n          Persist.serverWorkspace(input.scope, directory, \"project\", [\"project.v1\"]),\n          createStore({ value: undefined as ProjectMeta | undefined }),\n        ),\n      )\n      if (!meta) throw new Error(input.translate(\"error.childStore.persistedProjectMetadataCreateFailed\"))\n      metaCache.set(key, { store: meta[0], setStore: meta[1], ready: meta[3] })\n\n      const icon = runWithOwner(input.owner, () =>\n        input.persist("},{"id":"child_store_createchildstoremanager_ensurechild_init","label":"init()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L180-L269","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L180"}],"snippet":"init = () =>\n        createRoot((dispose) => {\n          const initialMeta = meta[0].value\n          const initialIcon = icon[0].value\n          const [mcpEnabled, setMcpEnabled] = createSignal(false)\n\n          const pathQuery = useQuery(() => input.queryOptions.path(key))\n          const mcpQuery = useQuery(() => ({ ...input.queryOptions.mcp(key), enabled: mcpEnabled() }))\n          const lspQuery = useQuery(() => input.queryOptions.lsp(key))\n          const providerQuery = useQuery(() => input.queryOptions.providers(key))\n\n          const child = createStore<State>({\n            project: \"\",\n            projectMeta: initialMeta,\n            icon: initialIcon,\n            get provider_ready() {\n              return !providerQuery.isLoading\n            },\n            get provider() {\n              const EMPTY = { all: new Map(), connected: [], default: {} }\n              if (providerQuery.isLoading) return EMPTY\n              if (providerQuery.data?.all.size === 0 && input.global.provider.all.size > 0) return input.global.provider\n              return providerQuery.data ?? EMPTY\n            },\n            config: {},"},{"id":"child_store_createchildstoremanager_ensurechild_init_onpersistedinit","label":"onPersistedInit()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L246-L252","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projec