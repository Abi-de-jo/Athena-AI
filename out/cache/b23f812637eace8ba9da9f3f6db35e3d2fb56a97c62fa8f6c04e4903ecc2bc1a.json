bootstrap ?? true\n    if (shouldBootstrap && childStore[0].status === \"loading\") {\n      input.onBootstrap(directory)\n    }\n    return childStore\n  }"},{"id":"child_store_createchildstoremanager_enablemcp","label":"enableMcp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L302-L307","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L302"}],"snippet":"function enableMcp(directory: string, key: DirectoryKey, childStore: [Store<State>, SetStoreFunction<State>]) {\n    if (mcpDirectories.has(key)) return\n    mcpDirectories.add(key)\n    mcpToggles.get(key)?.(true)\n    if (childStore[0].status !== \"loading\") input.onMcp(directory, childStore[1])\n  }"},{"id":"child_store_createchildstoremanager_disablemcp","label":"disableMcp()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L309-L313","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L309"}],"snippet":"function disableMcp(directory: string) {\n    const key = directoryKey(directory)\n    if (!mcpDirectories.delete(key)) return\n    mcpToggles.get(key)?.(false)\n  }"},{"id":"child_store_createchildstoremanager_projectmeta","label":"projectMeta()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/context/global-sync/child-store.ts","source_location":"L315-L331","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/