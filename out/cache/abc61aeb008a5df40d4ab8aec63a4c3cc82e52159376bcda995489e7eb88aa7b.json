,"source_location":"L116"}],"snippet":"function ensureSprite() {\n  if (spriteInserted) return\n  if (typeof document === \"undefined\") return\n  if (document.getElementById(spriteID)) {\n    spriteInserted = true\n    return\n  }\n  const body = document.body as HTMLElement | null\n  if (!body) return\n\n  const svg = document.createElementNS(\"http://www.w3.org/2000/svg\", \"svg\")\n  svg.id = spriteID\n  svg.setAttribute(\"aria-hidden\", \"true\")\n  svg.setAttribute(\"width\", \"0\")\n  svg.setAttribute(\"height\", \"0\")\n  svg.style.position = \"absolute\"\n  svg.style.overflow = \"hidden\"\n  svg.innerHTML = Object.entries(icons)\n    .map(([name, path]) => {\n      const key = name as keyof typeof icons\n      return `<symbol id=\"${symbol(key)}\" viewBox=\"${viewBox(key)}\">${path}</symbol>`\n    })\n    .join(\"\")\n  body.insertBefore(svg, body.firstChild)\n  spriteInserted = true"},{"id":"packages_ui_src_components_icon_iconprops","label":"IconProps","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/icon.tsx","source_location":"L143-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/icon.tsx","source_location":"L143"}],"snippet":"export interface IconProps extends ComponentProps<\"svg\"> {\n  name: keyof typeof icons\n  size?: \"small\" | \"normal\" | \"medium\" | \"large\"\n}"},{"id":"packages_ui_src_components_icon_componentprops","label":"ComponentProps","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/icon.tsx","source_location":"L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/icon.tsx","source_location":"L143"}]},{"id":"packages_ui_src_components_icon_icon","label":"Icon()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/icon.tsx","source_location":"L148-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/icon.tsx","source_location":"L148"}],"snippet":"export function Icon(props: IconProps) {\n  const [local, others] = splitProps(props, [\"name\", \"size\", \"class\", \"classList\"])\n  onMount(ensureSprite)\n\n  return (\n    <div data-component=\"icon\" data-size={local.size || \"normal\"}>\n      <svg\n        data-slot=\"icon-svg\"\n        classList={{\n          ...local.classList,\n          [local.class ?? \"\"]: !!local.class,\n        }}\n        fill=\"none\"\n        viewBox={viewBox(local.name)}\n        aria-hidden=\"true\"\n        {...others}\n      >\n        <use href={`#${symbol(local.name)}`} />\n      </svg>\n    </div>\n  )\n}","node_kind":"component"}],"edges":[{"source":"packages_ui_src_components_icon","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/icon.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/icon.tsx","source_location":"L1"}],"weight":1},{"source":"packages_ui_src_components_icon","target":"packages_ui_src_components_icon_symbol","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/icon.tsx","source_location":"L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/ui/src/components/icon.tsx","source_location":"L109"}],"weight":1},{"source":"packages_ui_src_components_icon"