{"__madarTsExtractorVersion":67,"__madarFileStem":"setup-recording-env","nodes":[{"id":"setup_recording_env","label":"setup-recording-env.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L1"}]},{"id":"setup_recording_env_hasflag","label":"hasFlag()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L224","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L224"}],"snippet":"hasFlag = (name: string) => args.includes(name)"},{"id":"setup_recording_env_option","label":"option()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L225-L229","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L225"}],"snippet":"option = (name: string) => {\n  const index = args.indexOf(name)\n  if (index === -1) return undefined\n  return args[index + 1]\n}"},{"id":"setup_recording_env_providersforoption","label":"providersForOption()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L238-L250","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L238"}],"snippet":"providersForOption = (value: string | undefined) => {\n  if (!value || value === \"recommended\")\n    return PROVIDERS.filter((provider) => provider.tier === \"core\" || provider.tier === \"canary\")\n  if (value === \"recorded\") return PROVIDERS.filter((provider) => provider.tier !== \"optional\")\n  if (value === \"all\") return PROVIDERS\n  const ids = new Set(\n    value\n      .split(\",\")\n      .map((item) => item.trim())\n      .filter(Boolean),\n  )\n  return PROVIDERS.filter((provider) => ids.has(provider.id))\n}"},{"id":"setup_recording_env_chooseproviders","label":"chooseProviders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L252-L255","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L252"}],"snippet":"chooseProviders = async () => {\n  if (providerOption) return providersForOption(providerOption)\n  return providersForOption(\"recommended\")\n}"},{"id":"setup_recording_env_catchmissingfile","label":"catchMissingFile()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L257-L260","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L257"}],"snippet":"catchMissingFile = (error: PlatformError.PlatformError) => {\n  if (error.reason._tag === \"NotFound\") return Effect.succeed(\"\")\n  return Effect.fail(error)\n}"},{"id":"setup_recording_env_readconfigstring","label":"readConfigString()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L267-L275","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L267"}],"snippet":"readConfigString = (provider: ConfigProvider.ConfigProvider, name: string) =>\n  Config.string(name)\n    .parse(provider)\n    .pipe(\n      Effect.match({\n        onFailure: () => undefined,\n        onSuccess: (value) => value,\n      }),\n    )"},{"id":"setup_recording_env_quote","label":"quote()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L286","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L286"}],"snippet":"quote = (value: string) => JSON.stringify(value)"},{"id":"setup_recording_env_status","label":"status()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L288-L292","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L288"}],"snippet":"status = (name: string, fileEnv: Env) => {\n  if (fileEnv[name]) return \"file\"\n  if (process.env[name]) return \"shell\"\n  return \"missing\"\n}"},{"id":"setup_recording_env_statusline","label":"statusLine()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L294-L303","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L294"}],"snippet":"statusLine = (provider: Provider, fileEnv: Env) =>\n  [\n    `${provider.label} (${provider.tier})`,\n    provider.note,\n    ...provider.vars.map((item) => {\n      const value = status(item.name, fileEnv)\n      const suffix = item.optional ? \" optional\" : \"\"\n      return `  ${value === \"missing\" ? \"missing\" : \"set\"} ${item.name}${suffix}${value === \"shell\" ? \" (shell only)\" : \"\"}`\n    }),\n  ].join(\"\\n\")"},{"id":"setup_recording_env_printstatus","label":"printStatus()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L305-L307","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L305"}],"snippet":"printStatus = (providers: ReadonlyArray<Provider>, fileEnv: Env) => {\n  prompts.note(providers.map((provider) => statusLine(provider, fileEnv)).join(\"\\n\\n\"), `Recording env: ${envPath}`)\n}"},{"id":"setup_recording_env_exitifcancel","label":"exitIfCancel()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L309-L313","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L309"}],"snippet":"exitIfCancel = <A>(value: A | symbol): A => {\n  if (!prompts.isCancel(value)) return value as A\n  prompts.cancel(\"Cancelled\")\n  process.exit(130)\n}"},{"id":"setup_recording_env_upsertenv","label":"upsertEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L315-L333","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L315"}],"snippet":"upsertEnv = (contents: string, values: Env) => {\n  const names = Object.keys(values)\n  const seen = new Set<string>()\n  const lines = contents.split(/\\r?\\n/).map((line) => {\n    const match = line.match(/^\\s*(?:export\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\s*=/)\n    if (!match || !names.includes(match[1])) return line\n    seen.add(match[1])\n    return `${match[1]}=${quote(values[match[1]])}`\n  })\n  const missing = names.filter((name) => !seen.has(name))\n  if (missing.length === 0) return lines.join(\"\\n\").replace(/\\n*$/, \"\\n\")\n  const prefix = lines.join(\"\\n\").trimEnd()\n  const block = [\n    \"\",\n    \"# Added by bun run setup:recording-env\",\n    ...missing.map((name) => `${name}=${quote(values[name])}`),\n  ].join(\"\\n\")\n  return `${prefix}${block}\\n`\n}"},{"id":"setup_recording_env_providerrequiredstatus","label":"providerRequiredStatus()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L335-L340","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L335"}],"snippet":"providerRequiredStatus = (provider: Provider, fileEnv: Env) => {\n  const required = requiredVars(provider)\n  if (required.some((item) => status(item.name, fileEnv) === \"missing\")) return \"missing\"\n  if (required.some((item) => status(item.name, fileEnv) === \"shell\")) return \"set in shell\"\n  return \"already added\"\n}"},{"id":"setup_recording_env_requiredvars","label":"requiredVars()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L342","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L342"}],"snippet":"requiredVars = (provider: Provider) => provider.vars.filter((item) => !item.optional)"},{"id":"setup_recording_env_promptvars","label":"promptVars()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L344","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L344"}],"snippet":"promptVars = (provider: Provider) => provider.vars.filter((item) => !item.optional || item.secret === false)"},{"id":"setup_recording_env_processenv","label":"processEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L346-L347","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L346"}],"snippet":"processEnv = (): Env =>\n  Object.fromEntries(Object.entries(process.env).filter((entry): entry is [string, string] => entry[1] !== undefined))"},{"id":"setup_recording_env_envvalue","label":"envValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L349","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L349"}],"snippet":"envValue = (env: Env, names: ReadonlyArray<string>) => names.map((name) => env[name]).find(Boolean) ?? \"\""},{"id":"setup_recording_env_envwithvalues","label":"envWithValues()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L351-L355","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L351"}],"snippet":"envWithValues = (fileEnv: Env, values: Env): Env => ({\n  ...processEnv(),\n  ...fileEnv,\n  ...values,\n})"},{"id":"setup_recording_env_validatebearer","label":"validateBearer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L372-L376","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L372"}],"snippet":"validateBearer = (url: string, token: Redacted.Redacted<string>, headers: Record<string, string> = {}) =>\n  HttpClientRequest.get(url).pipe(\n    HttpClientRequest.setHeaders({ ...headers, authorization: `Bearer ${Redacted.value(token)}` }),\n    executeRequest,\n  )"},{"id":"setup_recording_env_validatechat","label":"validateChat()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L378-L394","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L378"}],"snippet":"validateChat = (input: {\n  readonly url: string\n  readonly token: Redacted.Redacted<string>\n  readonly tokenHeader?: string\n  readonly model: string\n  readonly headers?: Record<string, string>\n}) =>\n  ProviderShared.jsonPost({\n    url: input.url,\n    headers: { ...input.headers, [input.tokenHeader ?? \"authorization\"]: `Bearer ${Redacted.value(input.token)}` },\n    body: ProviderShared.encodeJson({\n      model: input.model,\n      messages: [{ role: \"user\", content: \"Reply with exactly: ok\" }],\n      max_tokens: 3,\n      temperature: 0,\n    }),\n  }).pipe(executeRequest)"},{"id":"setup_recording_env_validatebedrock","label":"validateBedrock()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L396-L413","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L396"}],"snippet":"validateBedrock = (env: Env) =>\n  Effect.gen(function* () {\n    const request = yield* Effect.promise(() =>\n      new AwsV4Signer({\n        url: `https://bedrock.${env.BEDROCK_RECORDING_REGION || \"us-east-1\"}.amazonaws.com/foundation-models`,\n        method: \"GET\",\n        service: \"bedrock\",\n        region: env.BEDROCK_RECORDING_REGION || \"us-east-1\",\n        accessKeyId: env.AWS_ACCESS_KEY_ID,\n        secretAccessKey: env.AWS_SECRET_ACCESS_KEY,\n        sessionToken: env.AWS_SESSION_TOKEN || undefined,\n      }).sign(),\n    )\n    return yield* HttpClientRequest.get(request.url.toString()).pipe(\n      HttpClientRequest.setHeaders(Object.fromEntries(request.headers.entries())),\n      executeRequest,\n    )\n  })"},{"id":"setup_recording_env_prompt","label":"prompt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L453","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L453"}],"snippet":"prompt = <A>(run: () => Promise<A | symbol>) => Effect.promise(run).pipe(Effect.map(exitIfCancel))"},{"id":"setup_recording_env_promptenvvar","label":"promptEnvVar()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L478-L488","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L478"}],"snippet":"promptEnvVar = (item: Provider[\"vars\"][number]) =>\n  prompt<string>(() => {\n    const input = {\n      message: item.label ?? item.name,\n      validate: (input: string | undefined) => {\n        if (item.optional) return undefined\n        return !input || input.length === 0 ? \"Leave blank by pressing Esc/cancel, or paste a value\" : undefined\n      },\n    }\n    return item.secret === false ? prompts.text(input) : prompts.password(input)\n  })"}],"edges":[{"source":"setup_recording_env","target":"platform_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L3"}],"weight":1},{"source":"setup_recording_env","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/script/setup-recording-env.ts","source_location":"L4"}],"weight":1},{"source":"setup_recording_env","target":"prompts","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/g