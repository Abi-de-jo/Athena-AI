{"__madarTsExtractorVersion":67,"__madarFileStem":"session.shared","nodes":[{"id":"session_shared","label":"session.shared.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L1"}]},{"id":"session_shared_filename","label":"fileName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L25-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L25"}],"snippet":"function fileName(url: string, filename?: string) {\n  if (filename) {\n    return filename\n  }\n\n  try {\n    const next = new URL(url)\n    if (next.protocol !== \"file:\") {\n      return url\n    }\n\n    const name = next.pathname.split(\"/\").at(-1)\n    if (name) {\n      return decodeURIComponent(name)\n    }\n  } catch {}\n\n  return url\n}"},{"id":"session_shared_filesource","label":"fileSource()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L45-L61","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L45"}],"snippet":"function fileSource(\n  part: Extract<SessionMessages[number][\"parts\"][number], { type: \"file\" }>,\n  text: { start: number; end: number; value: string },\n) {\n  if (part.source) {\n    return {\n      ...structuredClone(part.source),\n      text,\n    }\n  }\n\n  return {\n    type: \"file\" as const,\n    path: part.filename ?? part.url,\n    text,\n  }\n}"},{"id":"session_shared_messageprompt","label":"messagePrompt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L63-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L63"}],"snippet":"export function messagePrompt(msg: SessionMessages[number]): RunPrompt {\n  const parts: RunPrompt[\"parts\"] = []\n  let text = msg.parts\n    .filter((part): part is Extract<SessionMessages[number][\"parts\"][number], { type: \"text\" }> => {\n      return part.type === \"text\" && !part.synthetic\n    })\n    .map((part) => part.text)\n    .join(\"\")\n  let cursor = Bun.stringWidth(text)\n  const used: Array<{ start: number; end: number }> = []\n\n  const take = (value: string): { start: number; end: number; value: string } | undefined => {\n    let from = 0\n    while (true) {\n      const idx = text.indexOf(value, from)\n      if (idx === -1) {\n        return undefined\n      }\n\n      const start = Bun.stringWidth(text.slice(0, idx))\n      const end = start + Bun.stringWidth(value)\n      if (!used.some((item) => item.start < end && start < item.end)) {\n        return { start, end, value }\n      }"},{"id":"session_shared_messageprompt_take","label":"take()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L74-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L74"}],"snippet":"take = (value: string): { start: number; end: number; value: string } | undefined => {\n    let from = 0\n    while (true) {\n      const idx = text.indexOf(value, from)\n      if (idx === -1) {\n        return undefined\n      }\n\n      const start = Bun.stringWidth(text.slice(0, idx))\n      const end = start + Bun.stringWidth(value)\n      if (!used.some((item) => item.start < end && start < item.end)) {\n        return { start, end, value }\n      }\n\n      from = idx + value.length\n    }\n  }"},{"id":"session_shared_messageprompt_add","label":"add()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L92-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L92"}],"snippet":"add = (value: string) => {\n    const gap = text ? \" \" : \"\"\n    const start = cursor + Bun.stringWidth(gap)\n    text += gap + value\n    const end = start + Bun.stringWidth(value)\n    cursor = end\n    return { start, end, value }\n  }"},{"id":"session_shared_turn","label":"turn()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L132-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L132"}],"snippet":"function turn(msg: SessionMessages[number]): Turn | undefined {\n  if (msg.info.role !== \"user\") {\n    return undefined\n  }\n\n  return {\n    prompt: messagePrompt(msg),\n    provider: msg.info.model.providerID,\n    model: msg.info.model.modelID,\n    variant: msg.info.model.variant,\n  }\n}"},{"id":"session_shared_createsession","label":"createSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L145-L153","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L145"}],"snippet":"export function createSession(messages: SessionMessages): RunSession {\n  return {\n    first: messages.length === 0,\n    turns: messages.flatMap((msg) => {\n      const item = turn(msg)\n      return item ? [item] : []\n    }),\n  }\n}"},{"id":"session_shared_resolvesession","label":"resolveSession()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L155-L161","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L155"}],"snippet":"export async function resolveSession(sdk: RunInput[\"sdk\"], sessionID: string, limit = LIMIT): Promise<RunSession> {\n  const response = await sdk.session.messages({\n    sessionID,\n    limit,\n  })\n  return createSession(response.data ?? [])\n}"},{"id":"session_shared_sessionhistory","label":"sessionHistory()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L163-L179","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L163"}],"snippet":"export function sessionHistory(session: RunSession, limit = LIMIT): RunPrompt[] {\n  const out: RunPrompt[] = []\n\n  for (const turn of session.turns) {\n    if (!turn.prompt.text.trim()) {\n      continue\n    }\n\n    if (out[out.length - 1] && promptSame(out[out.length - 1], turn.prompt)) {\n      continue\n    }\n\n    out.push(promptCopy(turn.prompt))\n  }\n\n  return out.slice(-limit)\n}"},{"id":"session_shared_sessionvariant","label":"sessionVariant()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L181-L196","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L181"}],"snippet":"export function sessionVariant(session: RunSession, model: RunInput[\"model\"]): string | undefined {\n  if (!model) {\n    return undefined\n  }\n\n  for (let idx = session.turns.length - 1; idx >= 0; idx -= 1) {\n    const turn = session.turns[idx]\n    if (turn.provider !== model.providerID || turn.model !== model.modelID) {\n      continue\n    }\n\n    return turn.variant\n  }\n\n  return undefined\n}"}],"edges":[{"source":"session_shared","target":"prompt","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L6","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L6"}],"weight":1},{"source":"session_shared","target":"types","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L7","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/session.shared.ts","source_location":"L7"}]