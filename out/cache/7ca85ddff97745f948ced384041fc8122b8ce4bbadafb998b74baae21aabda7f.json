{"__madarTsExtractorVersion":67,"__madarFileStem":"options","nodes":[{"id":"options","label":"options.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/schema/options.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/schema/options.ts","source_location":"L1"}]},{"id":"options_mergejsonrecords","label":"mergeJsonRecords()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/schema/options.ts","source_location":"L6-L20","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/schema/options.ts","source_location":"L6"}],"snippet":"mergeJsonRecords = (\n  ...items: ReadonlyArray<Record<string, unknown> | undefined>\n): Record<string, unknown> | undefined => {\n  const defined = items.filter((item): item is Record<string, unknown> => item !== undefined)\n  if (defined.length === 0) return undefined\n  if (defined.length === 1 && Object.values(defined[0]).every((value) => value !== undefined)) return defined[0]\n  const result: Record<string, unknown> = {}\n  for (const item of defined) {\n    for (const [key, value] of Object.entries(item)) {\n      if (value === undefined) continue\n      result[key] = isRecord(result[key]) && isRecord(value) ? mergeJsonRecords(result[key], value) : value\n    }\n  }\n  return Object.keys(result).length === 0 ? undefined : result\n}"},{"id":"options_mergestringrecords","label":"mergeStringRecords()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/schema/options.ts","source_location":"L22-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/schema/options.ts","source_location":"L22"}],"snippet":"mergeStringRecords = (\n  ...items: ReadonlyArray<Record<string, string> | undefined>\n): Record<string, string> | undefined => {\n  const defined = items.filter((item): item is Record<string, string> => item !== undefined)\n  if (defined.length === 0) return undefined\n  if (defined.length === 1) return defined[0]\n  const result = Object.fromEntries(\n    defined.flatMap((item) =>\n      Object.entries(item).filter((entry): entry is [string, string] => entry[1] !== undefined),\n    ),\n  )\n  return Object.keys(result).length === 0 ? undefined : result\n}"},{"id":"options_mergeprovideroptions","label":"mergeProviderOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/schema/options.ts","source_location":"L39-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/schema/options.ts","source_location":"L39"}],"snippet":"mergeProviderOptions = (\n  ...items: ReadonlyArray<ProviderOptions | undefined>\n): ProviderOptions | undefined => {\n  const result: Record<string, Record<string, unknown>> = {}\n  for (const item of items) {\n    if (!item) continue\n    for (const [provider, options] of Object.entries(item)) {\n      const merged = mergeJsonRecords(result[provider], options)\n      if (merged) result[provider] = merged\n    }\n  }\n  return Object.keys(result).length === 0 ? undefined : result\n}"},{"id":"options_httpoptions","label":"HttpOptions","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/schema/options.ts","source_location":"L53-L57","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/schema/options.ts","source_location":"L53"}],"snippet":"export class HttpOptions extend