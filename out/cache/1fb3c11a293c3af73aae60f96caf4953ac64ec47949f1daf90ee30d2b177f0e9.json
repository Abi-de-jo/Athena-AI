{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_src_util_queue","nodes":[{"id":"packages_rimuru_src_util_queue","label":"queue.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/queue.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/queue.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_util_queue_asyncqueue","label":"AsyncQueue","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/queue.ts","source_location":"L1-L19","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/queue.ts","source_location":"L1"}],"snippet":"export class AsyncQueue<T> implements AsyncIterable<T> {\n  private queue: T[] = []\n  private resolvers: ((value: T) => void)[] = []\n\n  push(item: T) {\n    const resolve = this.resolvers.shift()\n    if (resolve) resolve(item)\n    else this.queue.push(item)\n  }\n\n  async next(): Promise<T> {\n    if (this.queue.length > 0) return this.queue.shift()!\n    return new Promise((resolve) => this.resolvers.push(resolve))\n  }\n\n  async *[Symbol.asyncIterator]() {\n    while (true) yield await this.next()\n  }\n}"},{"id":"packages_rimuru_src_util_queue_asynciterable","label":"AsyncIterable","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/queue.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/util/queue.ts","source_location":"L1"}]},{"id":"packages_rimuru_src_util_queue_asyncqueue_push","label":".push()","file_type":"code","source_file":"/home/gowdaman/Pro