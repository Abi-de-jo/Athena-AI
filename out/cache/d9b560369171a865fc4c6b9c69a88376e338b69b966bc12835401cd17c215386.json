{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_tui_src_util_locale","nodes":[{"id":"packages_tui_src_util_locale","label":"locale.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L1"}]},{"id":"packages_tui_src_util_locale_titlecase","label":"titlecase()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L1-L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L1"}],"snippet":"export function titlecase(str: string) {\n  return str.replace(/\\b\\w/g, (c) => c.toUpperCase())\n}"},{"id":"packages_tui_src_util_locale_time","label":"time()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L5-L8","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L5"}],"snippet":"export function time(input: number): string {\n  const date = new Date(input)\n  return date.toLocaleTimeString(undefined, { timeStyle: \"short\" })\n}"},{"id":"packages_tui_src_util_locale_datetime","label":"datetime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L10-L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L10"}],"snippet":"export function datetime(input: number): string {\n  const date = new Date(input)\n  const localTime = time(input)\n  const localDate = date.toLocaleDateString()\n  return `${localTime} · ${localDate}`\n}"},{"id":"packages_tui_src_util_locale_todaytimeordatetime","label":"todayTimeOrDateTime()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L17-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L17"}],"snippet":"export function todayTimeOrDateTime(input: number): string {\n  const date = new Date(input)\n  const now = new Date()\n  const isToday =\n    date.getFullYear() === now.getFullYear() && date.getMonth() === now.getMonth() && date.getDate() === now.getDate()\n\n  if (isToday) {\n    return time(input)\n  } else {\n    return datetime(input)\n  }\n}"},{"id":"packages_tui_src_util_locale_number","label":"number()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L30-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L30"}],"snippet":"export function number(num: number): string {\n  if (num >= 1000000) {\n    return (num / 1000000).toFixed(1) + \"M\"\n  } else if (num >= 1000) {\n    return (num / 1000).toFixed(1) + \"K\"\n  }\n  return num.toString()\n}"},{"id":"packages_tui_src_util_locale_duration","label":"duration()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L39-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L39"}],"snippet":"export function duration(input: number) {\n  if (input < 1000) {\n    return `${input}ms`\n  }\n  if (input < 60000) {\n    return `${(input / 1000).toFixed(1)}s`\n  }\n  if (input < 3600000) {\n    const minutes = Math.floor(input / 60000)\n    const seconds = Math.floor((input % 60000) / 1000)\n    return `${minutes}m ${seconds}s`\n  }\n  if (input < 86400000) {\n    const hours = Math.floor(input / 3600000)\n    const minutes = Math.floor((input % 3600000) / 60000)\n    return `${hours}h ${minutes}m`\n  }\n  const hours = Math.floor(input / 3600000)\n  const days = Math.floor((input % 3600000) / 86400000)\n  return `${days}d ${hours}h`\n}"},{"id":"packages_tui_src_util_locale_truncate","label":"truncate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L61-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L61"}],"snippet":"export function truncate(str: string, len: number): string {\n  if (str.length <= len) return str\n  return str.slice(0, len - 1) + \"…\"\n}"},{"id":"packages_tui_src_util_locale_truncateleft","label":"truncateLeft()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L66-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L66"}],"snippet":"export function truncateLeft(str: string, len: number): string {\n  if (str.length <= len) return str\n  return \"…\" + str.slice(-(len - 1))\n}"},{"id":"packages_tui_src_util_locale_truncatemiddle","label":"truncateMiddle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L71-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L71"}],"snippet":"export function truncateMiddle(str: string, maxLength: number = 35): string {\n  if (str.length <= maxLength) return str\n\n  const ellipsis = \"…\"\n  const keepStart = Math.ceil((maxLength - ellipsis.length) / 2)\n  const keepEnd = Math.floor((maxLength - ellipsis.length) / 2)\n\n  return str.slice(0, keepStart) + ellipsis + str.slice(-keepEnd)\n}"},{"id":"packages_tui_src_util_locale_pluralize","label":"pluralize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L81-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L81"}],"snippet":"export function pluralize(count: number, singular: string, plural: string): string {\n  const template = count === 1 ? singular : plural\n  return template.replace(\"{}\", count.toString())\n}"}],"edges":[{"source":"packages_tui_src_util_locale","target":"packages_tui_src_util_locale_titlecase","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/src/util/locale.ts","source_location":"L1"}],"weight":1},{"source":"packages_tui_src_util_locale","target":"packages_tui_src_util_locale_time","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/sr