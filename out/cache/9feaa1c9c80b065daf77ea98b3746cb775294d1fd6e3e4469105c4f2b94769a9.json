{"__madarTsExtractorVersion":67,"__madarFileStem":"session-context-usage","nodes":[{"id":"session_context_usage","label":"session-context-usage.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L1"}]},{"id":"session_context_usage_sessioncontextusageprops","label":"SessionContextUsageProps","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L15-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L15"}],"snippet":"interface SessionContextUsageProps {\n  variant?: \"button\" | \"indicator\"\n  placement?: TooltipProps[\"placement\"]\n}"},{"id":"session_context_usage_opensessioncontext","label":"openSessionContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L20-L29","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L20"}],"snippet":"function openSessionContext(args: {\n  view: ReturnType<ReturnType<typeof useLayout>[\"view\"]>\n  layout: ReturnType<typeof useLayout>\n  tabs: ReturnType<ReturnType<typeof useLayout>[\"tabs\"]>\n}) {\n  if (!args.view.reviewPanel.opened()) args.view.reviewPanel.open()\n  if (args.layout.fileTree.opened() && args.layout.fileTree.tab() !== \"all\") args.layout.fileTree.setTab(\"all\")\n  void args.tabs.open(\"context\")\n  args.tabs.setActive(\"context\")\n}"},{"id":"session_context_usage_sessioncontextusage","label":"SessionContextUsage()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L31-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L31"}],"snippet":"export function SessionContextUsage(props: SessionContextUsageProps) {\n  const sync = useSync()\n  const file = useFile()\n  const layout = useLayout()\n  const language = useLanguage()\n  const providers = useProviders()\n  const { params, tabs, view } = useSessionLayout()\n\n  const variant = createMemo(() => props.variant ?? \"button\")\n  const tabState = createSessionTabs({\n    tabs,\n    pathFromTab: file.pathFromTab,\n    normalizeTab: (tab) => (tab.startsWith(\"file://\") ? file.tab(tab) : tab),\n  })\n  const messages = createMemo(() => (params.id ? (sync().data.message[params.id] ?? []) : []))\n\n  const usd = createMemo(\n    () =>\n      new Intl.NumberFormat(language.intl(), {\n        style: \"currency\",\n        currency: \"USD\",\n      }),\n  )\n\n  const metrics = createMemo(() => getSessionContextMetrics(messages(), [...providers.all().values()]))","node_kind":"component"},{"id":"session_context_usage_sessioncontextusage_opencontext","label":"openContext()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L61-L73","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L61"}],"snippet":"openContext = () => {\n    if (!params.id) return\n\n    if (tabState.activeTab() === \"context\") {\n      tabs().close(\"context\")\n      return\n    }\n    openSessionContext({\n      view: view(),\n      layout,\n      tabs: tabs(),\n    })\n  }"},{"id":"session_context_usage_sessioncontextusage_circle","label":"circle()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L75-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L75"}],"snippet":"circle = () => (\n    <div class=\"flex items-center justify-center\">\n      <ProgressCircle size={16} strokeWidth={2} percentage={context()?.usage ?? 0} />\n    </div>\n  )"},{"id":"session_context_usage_sessioncontextusage_tooltipvalue","label":"tooltipValue()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L81-L102","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/components/session-context-usage.tsx","source_location":"L81"}],"snippet":"tooltipValue = () => (\n    <div>\n      <Show when={context()}>\n        {(ctx) => (\n          <>\n            <div class=\"flex items-center gap-2\">\n              <span class=\"text-text-invert-strong\">{ctx().total.toLocaleString(language.intl())}</span>\n              <span class=\"text-text-invert-base\">{language.t(\"context.usage.tokens\")}</span>\n            </div>\n            <div class=\"flex items-center gap-2\">\n              <span class=\"text-text-invert-strong\">{ctx().usage ?? 0}%</span>\n              <span class=\"text-text-invert-base\">{language.t(\"context.usage.usage\")}</span>\n