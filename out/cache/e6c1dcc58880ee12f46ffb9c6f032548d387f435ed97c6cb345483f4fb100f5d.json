{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_opencode_src_server_server","nodes":[{"id":"packages_opencode_src_server_server","label":"server.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L1"}]},{"id":"packages_opencode_src_server_server_listenerserver","label":"ListenerServer","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L47-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L47"}],"snippet":"interface ListenerServer {\n  readonly closeAll: Effect.Effect<void>\n}"},{"id":"packages_opencode_src_server_server_listenerserverservice","label":"ListenerServerService","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L51-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L51"}],"snippet":"class ListenerServerService extends Context.Service<ListenerServerService, ListenerServer>()(\n  \"@opencode/ListenerServer\",\n) {}"},{"id":"packages_opencode_src_server_server_service","label":"Service","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L51","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L51"}]},{"id":"packages_opencode_src_server_server_openapi","label":"openapi()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L66-L68","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L66"}],"snippet":"export async function openapi() {\n  return OpenApi.fromApi(PublicApi)\n}"},{"id":"packages_opencode_src_server_server_listen","label":"listen()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L72-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L72"}],"snippet":"export async function listen(opts: ListenOptions): Promise<Listener> {\n  const listener = await Effect.runPromise(listenEffect(opts))\n  return {\n    hostname: listener.hostname,\n    port: listener.port,\n    url: listener.url,\n    stop: (close?: boolean) => Effect.runPromiseExit(listener.stop(close)).then(() => undefined),\n  }\n}"},{"id":"packages_opencode_src_server_server_listenerlayer","label":"listenerLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L99-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L99"}],"snippet":"function listenerLayer(opts: ListenOptions, port: number) {\n  return HttpRouter.serve(HttpApiApp.createRoutes(opts), {\n    middleware: disposeMiddleware,\n    disableLogger: true,\n    disableListenLog: true,\n  }).pipe(\n    Layer.provideMerge(WebSocketTracker.layer),\n    Layer.provideMerge(serverLayer({ port, hostname: opts.hostname })),\n    // Install a fresh `ConfigProvider` per listener so `Config.string(...)`\n    // reads reflect the current `process.env`. Effect's default\n    // `ConfigProvider` snapshots `process.env` on first read and caches the\n    // result on a module-singleton Reference; without overriding it here,\n    // every later `Server.listen()` keeps observing that initial snapshot.\n    Layer.provide(ConfigProvider.layer(ConfigProvider.fromEnv())),\n  )\n}"},{"id":"packages_opencode_src_server_server_startwithportfallback","label":"startWithPortFallback()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L116-L121","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L116"}],"snippet":"function startWithPortFallback(opts: ListenOptions) {\n  if (opts.port !== 0) return startListener(opts, opts.port)\n  // Match the legacy listener port-resolution behavior: explicit `0` prefers\n  // 4096 first, then any free port.\n  return startListener(opts, 4096).pipe(Effect.catch(() => startListener(opts, 0)))\n}"},{"id":"packages_opencode_src_server_server_startlistener","label":"startListener()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L123-L137","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L123"}],"snippet":"function startListener(opts: ListenOptions, port: number) {\n  const scope = Scope.makeUnsafe()\n  return Layer.buildWithMemoMap(listenerLayer(opts, port), Layer.makeMemoMapUnsafe(), scope).pipe(\n    Effect.provide(HttpApiApp.context),\n    Effect.onError(() => Scope.close(scope, Exit.void).pipe(Effect.ignore)),\n    Effect.map(\n      (ctx): ListenerState => ({\n        scope,\n        server: Context.get(ctx, HttpServer.HttpServer),\n        http: Context.get(ctx, ListenerServerService),\n        websockets: Context.get(ctx, WebSocketTracker.Service),\n      }),\n    ),\n  )\n}"},{"id":"packages_opencode_src_server_server_tcpaddress","label":"tcpAddress()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L139-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L139"}],"snippet":"function tcpAddress(state: ListenerState) {\n  return Effect.gen(function* () {\n    if (state.server.address._tag === \"TcpAddress\") return state.server.address\n    yield* Scope.close(state.scope, Exit.void).pipe(Effect.ignore)\n    return yield* Effect.die(new Error(`Unexpected HttpServer address tag: ${state.server.address._tag}`))\n  })\n}"},{"id":"packages_opencode_src_server_server_makeurl","label":"makeURL()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L147-L152","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L147"}],"snippet":"function makeURL(hostname: string, port: number) {\n  const result = new URL(\"http://localhost\")\n  result.hostname = hostname\n  result.port = String(port)\n  return result\n}"},{"id":"packages_opencode_src_server_server_setupmdns","label":"setupMdns()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L154-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L154"}],"snippet":"function setupMdns(opts: ListenOptions, port: number, scope: Scope.Scope) {\n  return Effect.gen(function* () {\n    const publish =\n      opts.mdns && port && opts.hostname !== \"127.0.0.1\" && opts.hostname !== \"localhost\" && opts.hostname !== \"::1\"\n    if (publish) {\n      const unpublish = yield* Effect.cached(Effect.sync(() => MDNS.unpublish()))\n      yield* Effect.sync(() => MDNS.publish(port, opts.mdnsDomain))\n      yield* Scope.addFinalizer(scope, unpublish)\n      return unpublish\n    }\n    if (opts.mdns) {\n      yield* Effect.logWarning(\"mDNS enabled but hostname is loopback; skipping mDNS publish\")\n    }\n    return Effect.void\n  })\n}"},{"id":"packages_opencode_src_server_server_makestop","label":"makeStop()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L171-L192","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L171"}],"snippet":"function makeStop(state: ListenerState, unpublishMdns: Effect.Effect<void>, listenerUrl: URL) {\n  return Effect.gen(function* () {\n    const forceCloseOnce = yield* Effect.cached(forceClose(state).pipe(Effect.ignore))\n    const closeScopeOnce = yield* Effect.cached(\n      Scope.close(state.scope, Exit.void).pipe(\n        Effect.ignore,\n        Effect.ensuring(\n          Effect.sync(() => {\n            if (url === listenerUrl) url = undefined\n          }),\n        ),\n      ),\n    )\n\n    return (close?: boolean) =>\n      Effect.gen(function* () {\n        yield* unpublishMdns\n        if (close) yield* forceCloseOnce\n        yield* closeScopeOnce\n      })\n  })\n}"},{"id":"packages_opencode_src_server_server_forceclose","label":"forceClose()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L194-L196","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L194"}],"snippet":"function forceClose(state: ListenerState) {\n  return Effect.all([state.http.closeAll, state.websockets.closeAll], { concurrency: \"unbounded\", discard: true })\n}"},{"id":"packages_opencode_src_server_server_serverlayer","label":"serverLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L198-L223","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L198"}],"snippet":"function serverLayer(opts: { port: number; hostname: string }) {\n  const server = createServer()\n  const serverRef = { closeStarted: false, forceStop: false }\n  const close = server.close.bind(server)\n  // Keep shutdown owned by NodeHttpServer, but honor listener.stop(true) by\n  // force-closing active HTTP sockets when its finalizer calls server.close().\n  // oxlint-disable-next-line typescript-eslint/no-unsafe-type-assertion -- Node's overloads don't preserve a monkey-patched method assignment.\n  server.close = ((callback?: Parameters<typeof server.close>[0]) => {\n    serverRef.closeStarted = true\n    const result = close(callback)\n    if (serverRef.forceStop) server.closeAllConnections()\n    return result\n  }) as typeof server.close\n\n  return Layer.mergeAll(\n    NodeHttpServer.layer(() => server, { port: opts.port, host: opts.hostname, gracefulShutdownTimeout: \"1 second\" }),\n    Layer.succeed(ListenerServerService)(\n      ListenerServerService.of({\n        closeAll: Effect.sync(() => {\n          serverRef.forceStop = true\n          if (serverRef.closeStarted) server.closeAllConnections()\n        }),\n      }),\n    ),\n  )"}],"edges":[{"source":"packages_opencode_src_server_server","target":"init_projectors","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L1"}],"weight":1},{"source":"packages_opencode_src_server_server","target":"platform_node","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L3"}],"weight":1},{"source":"packages_opencode_src_server_server","target":"effect","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/server/server.ts","source_location":"L4"}],"weight":1},{"source":"packages_opencode_src_server_server","target":"http","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gow