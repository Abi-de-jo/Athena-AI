{"__madarTsExtractorVersion":67,"__madarFileStem":"diff-viewer-file-tree.test","nodes":[{"id":"diff_viewer_file_tree_test","label":"diff-viewer-file-tree.test.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L1"}]},{"id":"diff_viewer_file_tree_test_renderframe","label":"renderFrame()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L155-L163","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L155"}],"snippet":"async function renderFrame(component: () => JSX.Element) {\n  const app = await testRender(() => withTheme(component), { width: 40, height: 10 })\n  try {\n    await renderOnceSettled(app)\n    return await captureSettledFrame(app)\n  } finally {\n    app.renderer.destroy()\n  }\n}"},{"id":"diff_viewer_file_tree_test_renderoncesettled","label":"renderOnceSettled()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L165-L169","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L165"}],"snippet":"async function renderOnceSettled(app: Awaited<ReturnType<typeof testRender>>) {\n  await app.renderOnce()\n  await new Promise((resolve) => setTimeout(resolve, 25))\n  await app.renderOnce()\n}"},{"id":"diff_viewer_file_tree_test_capturesettledframe","label":"captureSettledFrame()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L171-L179","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L171"}],"snippet":"async function captureSettledFrame(app: Awaited<ReturnType<typeof testRender>>) {\n  for (let attempt = 0; attempt < 5; attempt++) {\n    const frame = app.captureCharFrame()\n    if (frame.trim().length > 0) return frame\n    await new Promise((resolve) => setTimeout(resolve, 25))\n    await app.renderOnce()\n  }\n  return app.captureCharFrame()\n}"},{"id":"diff_viewer_file_tree_test_withtheme","label":"withTheme()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L181-L191","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L181"}],"snippet":"function withTheme(component: () => JSX.Element) {\n  return (\n    <TestTuiContexts>\n      <TuiConfigProvider config={createTuiResolvedConfig()}>\n        <KVProvider>\n          <ThemeProvider mode=\"dark\">{component()}</ThemeProvider>\n        </KVProvider>\n      </TuiConfigProvider>\n    </TestTuiContexts>\n  )\n}"},{"id":"diff_viewer_file_tree_test_visiblelines","label":"visibleLines()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L193-L200","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L193"}],"snippet":"function visibleLines(frame: string) {\n  return frame\n    .split(\"\\n\")\n    .map((line) => line.trimEnd())\n    .map((line) => line.replace(/^ ?│ ?/, \"\").replace(/[ │]*$/, \"\"))\n    .map((line) => (line.startsWith(\" \") ? line.slice(1) : line))\n    .filter((line) => line.length > 0 && !/^┌|^└|^─+$/.test(line))\n}"}],"edges":[{"source":"diff_viewer_file_tree_test","target":"bun_test","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L2"}],"weight":1},{"source":"diff_viewer_file_tree_test","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L3"}],"weight":1},{"source":"diff_viewer_file_tree_test","target":"solid","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/tui/test/cli/tui/diff-viewer-file-tree.test.tsx","source_location":"L4"}],"weight":1},{"source":"diff_viewer_fil