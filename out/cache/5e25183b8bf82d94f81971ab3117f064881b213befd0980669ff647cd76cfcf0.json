rable, selectedIndex: number) {\n  expect(list.backgroundColor.toInts()).toEqual((RUN_THEME_FALLBACK.footer.shade as RGBA).toInts())\n  expect((list.getChildren()[selectedIndex] as BoxRenderable).backgroundColor.toInts()).toEqual(\n    (RUN_THEME_FALLBACK.footer.selected as RGBA).toInts(),\n  )\n}"},{"id":"footer_view_test_child","label":"child()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/footer.view.test.tsx","source_location":"L251-L253","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/footer.view.test.tsx","source_location":"L251"}],"snippet":"function child(root: BoxRenderable | RootRenderable, index: number) {\n  return root.getChildren()[index] as BoxRenderable\n}"},{"id":"footer_view_test_boxpath","label":"boxPath()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/footer.view.test.tsx","source_location":"L255-L262","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/footer.view.test.tsx","source_location":"L255"}],"snippet":"function boxPath(root: BoxRenderable | RootRenderable, name: string): BoxRenderable[] | undefined {\n  for (const item of root.getChildren()) {\n    if (item.constructor.name === name) return root instanceof BoxRenderable ? [root] : []\n    if (!(item instanceof BoxRenderable)) continue\n    const path = boxPath(item, name)\n    if (path) return root instanceof BoxRenderable ? [root, ...path] : path\n  }\n}"},{"id":"footer_view_test_footercomposerframe","label":"footerComposerFrame()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/footer.view.test.tsx","source_location":"L264-L266","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/footer.view.test.tsx","source_location":"L264"}],"snippet":"function footerComposerFrame(root: BoxRenderable | RootRenderable) {\n  return boxPath(root, \"TextareaRenderable\")!.at(-5)!\n}"},{"id":"footer_view_test_footerstatusline","label":"footerStatusline()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/footer.view.test.tsx","source_location":"L268-L282","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/footer.view.test.tsx","source_location":"L268"}],"snippet":"function footerStatusline(root: BoxRenderable | RootRenderable) {\n  const status = (RUN_THEME_FALLBACK.footer.status as RGBA).toInts()\n  const accent = (RUN_THEME_FALLBACK.footer.statusAccent as RGBA).toInts()\n  const boxes = root.getChildren().filter((item): item is BoxRenderable => item instanceof BoxRenderable)\n  for (const box of boxes) {\n    const first = box.getChildren().find((item): item is BoxRenderable => item instanceof BoxRenderable)\n    if (\n      box.backgroundColor?.toInts().every((value, index) => value === status[index]) &&\n      first?.backgroundColor?.toInts().every((value, index) => value === accent[index])\n    )\n      return box\n    boxes.push(...box.getChildren().filter((item): item is BoxRenderable => item instanceof BoxRenderable))\n  }\n  throw new Error(\"Footer statusline not found\")\n}"},{"id":"footer_view_test_panelmenu","label":"panelMenu()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/cli/run/footer.view.test.tsx","source_location":"L284-L288","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects