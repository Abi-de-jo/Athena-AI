te()\n    return new Date(Date.UTC(year, month, Math.min(day, max), hh, mm, ss, ms))\n  }\n\n  function shift(year: number, month: number, delta: number) {\n    const total = year * 12 + month + delta\n    return [Math.floor(total / 12), ((total % 12) + 12) % 12] as const\n  }\n\n  let y = now.getUTCFullYear()\n  let m = now.getUTCMonth()\n  let start = anchor(y, m)\n  if (start > now) {\n    ;[y, m] = shift(y, m, -1)\n    start = anchor(y, m)\n  }\n  const [ny, nm] = shift(y, m, 1)"},{"id":"date_getmonthlybounds_anchor","label":"anchor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/src/util/date.ts","source_location":"L18-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/src/util/date.ts","source_location":"L18"}],"snippet":"function anchor(year: number, month: number) {\n    const max = new Date(Date.UTC(year, month + 1, 0)).getUTCDate()\n    return new Date(Date.UTC(year, month, Math.min(day, max), hh, mm, ss, ms))\n  }"},{"id":"date_getmonthlybounds_shift","label":"shift()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/src/util/date.ts","source_location":"L23-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/src/util/date.ts","source_location":"L23"}],"snippet":"function shift(year: number, month: number, delta: number) {\n    const total = year * 12 + month + delta\n    return [Math.floor(total / 12), ((total % 12) + 12) % 12] as const\n  }"}],"edges":[{"source":"date","target":"date_getweekbounds","relation":"contains","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/core/src/util/date.ts","source_location":"L1","layer":"base","provenance":[{"capability