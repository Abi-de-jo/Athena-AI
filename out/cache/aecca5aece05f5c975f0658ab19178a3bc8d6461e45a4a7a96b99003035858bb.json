n/Projects/personal/rimuru-ai/packages/app/src/pages/layout/inline-editor.tsx","source_location":"L20-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/inline-editor.tsx","source_location":"L20"}],"snippet":"saveEditor = (callback: (next: string) => void) => {\n    const next = editor.value.trim()\n    if (!next) {\n      closeEditor()\n      return\n    }\n    closeEditor()\n    callback(next)\n  }"},{"id":"inline_editor_createinlineeditorcontroller_editorkeydown","label":"editorKeyDown()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/inline-editor.tsx","source_location":"L30-L39","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/inline-editor.tsx","source_location":"L30"}],"snippet":"editorKeyDown = (event: KeyboardEvent, callback: (next: string) => void) => {\n    if (event.key === \"Enter\") {\n      event.preventDefault()\n      saveEditor(callback)\n      return\n    }\n    if (event.key !== \"Escape\") return\n    event.preventDefault()\n    closeEditor()\n  }"},{"id":"inline_editor_createinlineeditorcontroller_inlineeditor","label":"InlineEditor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/inline-editor.tsx","source_location":"L41-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/layout/inline-editor.tsx","source_location":"L41"}],"snippet":"InlineEditor = (props: {\n    id: string\n    value: Accessor<string>\n    onSave: (next: string) => void\n    class?: string\n    displayClass?: string\n    editing?: boolean\n    stopPropagation?: boolean\