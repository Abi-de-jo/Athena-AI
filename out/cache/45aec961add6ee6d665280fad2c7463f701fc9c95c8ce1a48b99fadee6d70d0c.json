{"__madarTsExtractorVersion":67,"__madarFileStem":"session-request-tree","nodes":[{"id":"session_request_tree","label":"session-request-tree.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-request-tree.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-request-tree.ts","source_location":"L1"}]},{"id":"session_request_tree_sessiontreerequest","label":"sessionTreeRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-request-tree.ts","source_location":"L3-L34","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-request-tree.ts","source_location":"L3"}],"snippet":"function sessionTreeRequest<T>(\n  session: Session[],\n  request: Record<string, T[] | undefined>,\n  sessionID?: string,\n  include: (item: T) => boolean = () => true,\n) {\n  if (!sessionID) return\n\n  const map = session.reduce((acc, item) => {\n    if (!item.parentID) return acc\n    const list = acc.get(item.parentID)\n    if (list) list.push(item.id)\n    if (!list) acc.set(item.parentID, [item.id])\n    return acc\n  }, new Map<string, string[]>())\n\n  const seen = new Set([sessionID])\n  const ids = [sessionID]\n  for (const id of ids) {\n    const list = map.get(id)\n    if (!list) continue\n    for (const child of list) {\n      if (seen.has(child)) continue\n      seen.add(child)\n      ids.push(child)"},{"id":"session_request_tree_sessionpermissionrequest","label":"sessionPermissionRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-request-tree.ts","source_location":"L36-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-request-tree.ts","source_location":"L36"}],"snippet":"export function sessionPermissionRequest(\n  session: Session[],\n  request: Record<string, PermissionRequest[] | undefined>,\n  sessionID?: string,\n  include?: (item: PermissionRequest) => boolean,\n) {\n  return sessionTreeRequest(session, request, sessionID, include)\n}"},{"id":"session_request_tree_sessionquestionrequest","label":"sessionQuestionRequest()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-request-tree.ts","source_location":"L45-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-request-tree.ts","source_location":"L45"}],"snippet":"export function sessionQuestionRequest(\n  session: Session[],\n  request: Record<string, QuestionRequest[] | undefined>,\n  sessionID?: string,\n  include?: (item: QuestionRequest) => boolean,\n) {\n  return sessionTreeRequest(session, request, sessionID, include)\n}"}],"edges":[{"source":"session_request_tree","target":"client","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-request-tree.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/app/src/pages/session/composer/session-request-tree.ts","source_location":"L1"}],"weight":1},{"source":"session_request_tree","target":"session_request_tree_sessiontreerequest","relation":"contains","confidence":"EXTRACTED","sourc