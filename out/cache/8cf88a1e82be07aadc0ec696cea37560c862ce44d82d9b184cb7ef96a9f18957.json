{"__madarTsExtractorVersion":67,"__madarFileStem":"json-schema","nodes":[{"id":"json_schema","label":"json-schema.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L1"}]},{"id":"json_schema_fromschema","label":"fromSchema()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L8-L22","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L8"}],"snippet":"export function fromSchema(schema: Schema.Top): JSONSchema7 {\n  const cached = cache.get(schema)\n  if (cached) return cached\n\n  const document = Schema.toJsonSchemaDocument(schema, { additionalProperties: true })\n  const result = normalize({\n    $schema: JsonSchema.META_SCHEMA_URI_DRAFT_2020_12,\n    ...document.schema,\n    ...(Object.keys(document.definitions).length > 0 ? { $defs: document.definitions } : {}),\n  })\n  const inlined = dropDefinitionsIfResolved(inlineLocalReferences(result))\n  if (!isJsonSchema(inlined)) throw new Error(\"tool JSON Schema helper produced a non-schema value\")\n  cache.set(schema, inlined)\n  return inlined\n}"},{"id":"json_schema_fromtool","label":"fromTool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L24-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L24"}],"snippet":"export function fromTool(tool: Tool.Def): JSONSchema7 {\n  return tool.jsonSchema ?? fromSchema(tool.parameters as Schema.Top)\n}"},{"id":"json_schema_normalize","label":"normalize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L28-L88","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L28"}],"snippet":"function normalize(value: unknown, options: { stripNull?: boolean } = {}): unknown {\n  if (Array.isArray(value)) return value.map((item) => normalize(item))\n  if (!isRecord(value)) return value\n\n  const required = Array.isArray(value.required)\n    ? new Set(value.required.filter((item) => typeof item === \"string\"))\n    : undefined\n  const schema = Object.fromEntries(\n    Object.entries(value).map(([key, item]) => [\n      key,\n      key === \"properties\" && isRecord(item)\n        ? Object.fromEntries(\n            Object.entries(item).map(([name, property]) => [\n              name,\n              normalize(property, { stripNull: !required?.has(name) }),\n            ]),\n          )\n        : normalize(item),\n    ]),\n  )\n\n  if (schema.additionalProperties === true) delete schema.additionalProperties\n\n  if (options.stripNull && Array.isArray(schema.anyOf)) {\n    const withoutNull = schema.anyOf.filter((item) => !isRecord(item) || item.type !== \"null\")"},{"id":"json_schema_isrecord","label":"isRecord()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L90-L92","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L90"}],"snippet":"function isRecord(value: unknown): value is JsonObject {\n  return typeof value === \"object\" && value !== null && !Array.isArray(value)\n}"},{"id":"json_schema_isjsonschema","label":"isJsonSchema()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L94-L96","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L94"}],"snippet":"function isJsonSchema(value: unknown): value is JSONSchema7 {\n  return typeof value === \"boolean\" || isRecord(value)\n}"},{"id":"json_schema_isnonfinitenumber","label":"isNonFiniteNumber()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L98-L100","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L98"}],"snippet":"function isNonFiniteNumber(value: unknown) {\n  return value === \"NaN\" || value === \"Infinity\" || value === \"-Infinity\"\n}"},{"id":"json_schema_isemptystructunion","label":"isEmptyStructUnion()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L102-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L102"}],"snippet":"function isEmptyStructUnion(items: unknown[]) {\n  return (\n    items.length === 2 &&\n    items.some((item) => isRecord(item) && item.type === \"object\" && item.properties === undefined) &&\n    items.some((item) => isRecord(item) && item.type === \"array\" && item.items === undefined)\n  )\n}"},{"id":"json_schema_canflattenallof","label":"canFlattenAllOf()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L110-L119","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L110"}],"snippet":"function canFlattenAllOf(allOf: JsonObject[], parent: JsonObject) {\n  const keys = new Set(Object.keys(parent).filter((key) => key !== \"allOf\"))\n  return allOf.every((item) =>\n    Object.keys(item).every((key) => {\n      if (keys.has(key)) return false\n      keys.add(key)\n      return true\n    }),\n  )\n}"},{"id":"json_schema_inlinelocalreferences","label":"inlineLocalReferences()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L121-L144","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L121"}],"snippet":"function inlineLocalReferences(value: unknown, definitions?: JsonObject, seen = new Set<string>()): unknown {\n  if (Array.isArray(value)) return value.map((item) => inlineLocalReferences(item, definitions, seen))\n  if (!isRecord(value)) return value\n\n  const localDefinitions = definitions ?? (isRecord(value.$defs) ? value.$defs : undefined)\n  if (typeof value.$ref === \"string\" && localDefinitions) {\n    const name = value.$ref.match(/^#\\/\\$defs\\/(.+)$/)?.[1] ?? value.$ref.match(/^#\\/definitions\\/(.+)$/)?.[1]\n    if (name && !seen.has(name)) {\n      const target = localDefinitions[name]\n      if (target) {\n        const { $ref: _, ...rest } = value\n        return inlineLocalReferences(\n          { ...(isRecord(target) ? target : {}), ...rest },\n          localDefinitions,\n          new Set(seen).add(name),\n        )\n      }\n    }\n  }\n\n  return Object.fromEntries(\n    Object.entries(value).map(([key, item]) => [key, inlineLocalReferences(item, localDefinitions, seen)]),\n  )\n}"},{"id":"json_schema_dropdefinitionsifresolved","label":"dropDefinitionsIfResolved()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L146-L150","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L146"}],"snippet":"function dropDefinitionsIfResolved(value: unknown): unknown {\n  if (!isRecord(value) || hasLocalReference(value)) return value\n  const { $defs: _, definitions: __, ...rest } = value\n  return rest\n}"},{"id":"json_schema_haslocalreference","label":"hasLocalReference()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L152-L162","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L152"}],"snippet":"function hasLocalReference(value: unknown): boolean {\n  if (Array.isArray(value)) return value.some(hasLocalReference)\n  if (!isRecord(value)) return false\n  if (\n    typeof value.$ref === \"string\" &&\n    (value.$ref.startsWith(\"#/$defs/\") || value.$ref.startsWith(\"#/definitions/\"))\n  ) {\n    return true\n  }\n  return Object.values(value).some(hasLocalReference)\n}"}],"edges":[{"source":"json_schema","target":"provider","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/opencode/src/tool/json-schema.ts","source_location":"L1","l