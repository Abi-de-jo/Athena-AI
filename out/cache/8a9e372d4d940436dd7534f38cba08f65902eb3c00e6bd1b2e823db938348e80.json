{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_test_server_httpapi-exercise_routing","nodes":[{"id":"packages_rimuru_test_server_httpapi_exercise_routing","label":"routing.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L1"}]},{"id":"packages_rimuru_test_server_httpapi_exercise_routing_routekeys","label":"routeKeys()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L25-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L25"}],"snippet":"export function routeKeys(spec: OpenApiSpec) {\n  return Object.entries(spec.paths ?? {})\n    .flatMap(([path, item]) =>\n      OpenApiMethods.filter((method) => item[method]).map((method) => `${method.toUpperCase()} ${path}`),\n    )\n    .sort()\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_routing_routekey","label":"routeKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L33-L35","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L33"}],"snippet":"export function routeKey(scenario: Scenario) {\n  return `${scenario.method} ${scenario.path}`\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_routing_coverageresult","label":"coverageResult()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L37-L40","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L37"}],"snippet":"export function coverageResult(scenario: Scenario): Result {\n  if (scenario.kind === \"todo\") return { status: \"skip\", scenario }\n  return { status: \"pass\", scenario }\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_routing_parseoptions","label":"parseOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L42-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L42"}],"snippet":"export function parseOptions(args: string[]): Options {\n  const mode = option(args, \"--mode\") ?? \"effect\"\n  if (mode !== \"effect\" && mode !== \"coverage\" && mode !== \"auth\") throw new Error(`invalid --mode ${mode}`)\n  return {\n    mode,\n    include: option(args, \"--include\"),\n    startAt: option(args, \"--start-at\"),\n    stopAt: option(args, \"--stop-at\"),\n    failOnMissing: args.includes(\"--fail-on-missing\"),\n    failOnSkip: args.includes(\"--fail-on-skip\"),\n    scenarioTimeout: parseScenarioTimeout(option(args, \"--scenario-timeout\") ?? \"30 seconds\"),\n    progress: args.includes(\"--progress\"),\n    trace: args.includes(\"--trace\"),\n  }\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_routing_matches","label":"matches()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L58-L65","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L58"}],"snippet":"export function matches(options: Options, scenario: Scenario) {\n  if (!options.include) return true\n  return (\n    scenario.name.includes(options.include) ||\n    scenario.path.includes(options.include) ||\n    scenario.method.includes(options.include.toUpperCase())\n  )\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_routing_selectedscenarios","label":"selectedScenarios()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L67-L76","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L67"}],"snippet":"export function selectedScenarios(options: Options, scenarios: Scenario[]) {\n  const included = scenarios.filter((scenario) => matches(options, scenario))\n  const start = options.startAt ? included.findIndex((scenario) => matchesName(options.startAt!, scenario)) : 0\n  const end = options.stopAt\n    ? included.findIndex((scenario) => matchesName(options.stopAt!, scenario))\n    : included.length - 1\n  if (start === -1) throw new Error(`--start-at matched no scenario: ${options.startAt}`)\n  if (end === -1) throw new Error(`--stop-at matched no scenario: ${options.stopAt}`)\n  return included.slice(start, end + 1)\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_routing_matchesname","label":"matchesName()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L78-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L78"}],"snippet":"function matchesName(value: string, scenario: Scenario) {\n  return scenario.name.includes(value) || scenario.path.includes(value) || scenario.method.includes(value.toUpperCase())\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_routing_option","label":"option()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L82-L86","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L82"}],"snippet":"function option(args: string[], name: string) {\n  const index = args.indexOf(name)\n  if (index === -1) return undefined\n  return args[index + 1]\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_routing_parsescenariotimeout","label":"parseScenarioTimeout()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L88-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/httpapi-exercise/routing.ts","source_location":"L88"}],"snippet":"function parseScenarioTimeout(input: string) {\n  if (!isScenarioTimeout(input)) throw new Error(`invalid --scenario-timeout ${input}`)\n  return Duration.fromInputUnsafe(input)\n}"},{"id":"packages_rimuru_test_server_httpapi_exercise_routing_isscenariotimeout","label":"isScenarioTimeout()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/server/htt