{"__madarTsExtractorVersion":67,"__madarFileStem":"workspace.test","nodes":[{"id":"workspace_test","label":"workspace.test.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L1"}]},{"id":"workspace_test_workspacelayer","label":"workspaceLayer()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L46-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L46"}],"snippet":"workspaceLayer = (experimentalWorkspaces: boolean) =>\n  Workspace.layer.pipe(\n    Layer.provide(Auth.defaultLayer),\n    Layer.provide(SessionNs.defaultLayer),\n    Layer.provide(SessionPrompt.defaultLayer),\n    Layer.provide(Project.defaultLayer),\n    Layer.provide(Vcs.defaultLayer),\n    Layer.provide(Database.defaultLayer),\n    Layer.provide(EventV2Bridge.defaultLayer),\n    Layer.provide(FetchHttpClient.layer),\n    Layer.provide(FSUtil.defaultLayer),\n    Layer.provide(RuntimeFlags.layer({ experimentalWorkspaces })),\n    Layer.provide(Ripgrep.defaultLayer),\n    Layer.provide(InstanceStore.defaultLayer.pipe(Layer.provide(InstanceBootstrap.defaultLayer))),\n  )"},{"id":"workspace_test_unique","label":"unique()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L95-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L95"}],"snippet":"function unique(prefix: string) {\n  return `${prefix}-${Math.random().toString(36).slice(2)}`\n}"},{"id":"workspace_test_restoreenv","label":"restoreEnv()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L99-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L99"}],"snippet":"function restoreEnv() {\n  Object.entries(originalEnv).forEach(([key, value]) => {\n    if (value === undefined) {\n      delete process.env[key]\n      return\n    }\n    process.env[key] = value\n  })\n}"},{"id":"workspace_test_initgitrepo","label":"initGitRepo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L121-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L121"}],"snippet":"async function initGitRepo(dir: string) {\n  await fs.mkdir(dir, { recursive: true })\n  await $`git init`.cwd(dir).quiet()\n  await $`git config core.fsmonitor false`.cwd(dir).quiet()\n  await $`git config commit.gpgsign false`.cwd(dir).quiet()\n  await $`git config user.email \"test@opencode.test\"`.cwd(dir).quiet()\n  await $`git config user.name \"Test\"`.cwd(dir).quiet()\n  await fs.writeFile(path.join(dir, \"tracked.txt\"), \"base\\n\")\n  await $`git add tracked.txt`.cwd(dir).quiet()\n  await $`git commit -m \"base\"`.cwd(dir).quiet()\n}"},{"id":"workspace_test_startworkspacesyncingwithflag","label":"startWorkspaceSyncingWithFlag()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L133-L136","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L133"}],"snippet":"startWorkspaceSyncingWithFlag = (projectID: ProjectV2.ID, experimentalWorkspaces: boolean) =>\n  Effect.runPromise(\n    Workspace.use.startWorkspaceSyncing(projectID).pipe(Effect.provide(workspaceLayer(experimentalWorkspaces))),\n  )"},{"id":"workspace_test_captureglobalevents","label":"captureGlobalEvents()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L138-L148","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L138"}],"snippet":"function captureGlobalEvents() {\n  const events: GlobalEvent[] = []\n  const handler = (event: GlobalEvent) => events.push(event)\n  GlobalBus.on(\"event\", handler)\n  return {\n    events,\n    dispose() {\n      GlobalBus.off(\"event\", handler)\n    },\n  }\n}"},{"id":"workspace_test_captureglobalevents_handler","label":"handler()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L140","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L140"}],"snippet":"handler = (event: GlobalEvent) => events.push(event)"},{"id":"workspace_test_expectexitcontains","label":"expectExitContains()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L150-L154","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L150"}],"snippet":"function expectExitContains(exit: Exit.Exit<unknown, unknown>, ...messages: string[]) {\n  expect(Exit.isFailure(exit)).toBe(true)\n  if (!Exit.isFailure(exit)) return\n  for (const message of messages) expect(String(exit.cause)).toContain(message)\n}"},{"id":"workspace_test_eventuallyeffect","label":"eventuallyEffect()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L156-L168","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L156"}],"snippet":"function eventuallyEffect(effect: Effect.Effect<void>, timeout = 1500) {\n  return Effect.gen(function* () {\n    const started = Date.now()\n    let last: unknown\n    while (Date.now() - started < timeout) {\n      const exit = yield* Effect.exit(effect)\n      if (exit._tag === \"Success\") return\n      last = exit.cause\n      yield* Effect.sleep(\"10 millis\")\n    }\n    throw last ?? new Error(\"Timed out waiting for condition\")\n  })\n}"},{"id":"workspace_test_recordedadapter","label":"recordedAdapter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L170-L220","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L170"}],"snippet":"function recordedAdapter(input: {\n  target: (info: WorkspaceInfo) => Target | Promise<Target>\n  configure?: (info: WorkspaceInfo) => WorkspaceInfo | Promise<WorkspaceInfo>\n  create?: (info: WorkspaceInfo, env: Record<string, string | undefined>, from?: WorkspaceInfo) => Promise<void>\n  list?: () => Omit<WorkspaceInfo, \"id\">[] | Promise<Omit<WorkspaceInfo, \"id\">[]>\n  remove?: (info: WorkspaceInfo) => Promise<void>\n}): RecordedAdapter {\n  const calls: RecordedAdapter[\"calls\"] = {\n    configure: [],\n    create: [],\n    list: 0,\n    remove: [],\n    target: [],\n  }\n\n  return {\n    calls,\n    adapter: {\n      name: \"recorded\",\n      description: \"recorded\",\n      configure(info) {\n        calls.configure.push(structuredClone(info))\n        return input.configure?.(info) ?? info\n      },\n      async create(info, env, from) {"},{"id":"workspace_test_localadapter","label":"localAdapter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L222-L236","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L222"}],"snippet":"function localAdapter(dir: string, input?: { createDir?: boolean; remove?: (info: WorkspaceInfo) => Promise<void> }) {\n  return recordedAdapter({\n    configure(info) {\n      return { ...info, directory: dir }\n    },\n    async create() {\n      if (input?.createDir === false) return\n      await fs.mkdir(dir, { recursive: true })\n    },\n    remove: input?.remove,\n    target() {\n      return { type: \"local\", directory: dir }\n    },\n  })\n}"},{"id":"workspace_test_remoteadapter","label":"remoteAdapter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L238-L247","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L238"}],"snippet":"function remoteAdapter(url: string, input?: { directory?: string | null; headers?: HeadersInit }) {\n  return recordedAdapter({\n    configure(info) {\n      return { ...info, directory: input?.directory ?? info.directory }\n    },\n    target() {\n      return { type: \"remote\", url, headers: input?.headers }\n    },\n  })\n}"},{"id":"workspace_test_eventstreamresponse","label":"eventStreamResponse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L249-L261","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L249"}],"snippet":"function eventStreamResponse(events: unknown[] = [], keepOpen = true) {\n  const encoder = new TextEncoder()\n  return new Response(\n    new ReadableStream<Uint8Array>({\n      start(controller) {\n        if (keepOpen) controller.enqueue(encoder.encode(\":\\n\\n\"))\n        events.forEach((event) => controller.enqueue(encoder.encode(`data: ${JSON.stringify(event)}\\n\\n`)))\n        if (!keepOpen) controller.close()\n      },\n    }),\n    { status: 200, headers: { \"content-type\": \"text/event-stream\" } },\n  )\n}"},{"id":"workspace_test_serverurl","label":"serverUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L263-L267","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L263"}],"snippet":"function serverUrl() {\n  return Effect.gen(function* () {\n    return HttpServer.formatAddress((yield* HttpServer.HttpServer).address)\n  })\n}"},{"id":"workspace_test_workspaceinfo","label":"workspaceInfo()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L269-L280","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L269"}],"snippet":"function workspaceInfo(projectID: ProjectV2.ID, type: string, input?: Partial<Workspace.Info>): Workspace.Info {\n  return {\n    id: input?.id ?? WorkspaceV2.ID.ascending(),\n    type,\n    name: input?.name ?? unique(\"workspace\"),\n    branch: input?.branch ?? null,\n    directory: input?.directory ?? null,\n    extra: input?.extra ?? null,\n    projectID,\n    timeUsed: input?.timeUsed ?? Date.now(),\n  }\n}"},{"id":"workspace_test_insertworkspace","label":"insertWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L282-L299","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L282"}],"snippet":"function insertWorkspace(info: Workspace.Info) {\n  return Database.Service.use(({ db }) =>\n    db\n      .insert(WorkspaceTable)\n      .values({\n        id: info.id,\n        type: info.type,\n        branch: info.branch,\n        name: info.name,\n        directory: info.directory,\n        extra: info.extra,\n        project_id: info.projectID,\n        time_used: info.timeUsed,\n      })\n      .run()\n      .pipe(Effect.orDie),\n  )\n}"},{"id":"workspace_test_insertproject","label":"insertProject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L301-L317","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L301"}],"snippet":"function insertProject(id: ProjectV2.ID, worktree: string) {\n  return Database.Service.use(({ db }) =>\n    db\n      .insert(ProjectTable)\n      .values({\n        id,\n        worktree: AbsolutePath.make(worktree),\n        vcs: null,\n        name: null,\n        time_created: Date.now(),\n        time_updated: Date.now(),\n        sandboxes: [],\n      })\n      .run()\n      .pipe(Effect.orDie),\n  )\n}"},{"id":"workspace_test_attachsessiontoworkspace","label":"attachSessionToWorkspace()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L319-L328","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L319"}],"snippet":"function attachSessionToWorkspace(sessionID: SessionID, workspaceID: WorkspaceV2.ID) {\n  return Database.Service.use(({ db }) =>\n    db\n      .update(SessionTable)\n      .set({ workspace_id: workspaceID })\n      .where(eq(SessionTable.id, sessionID))\n      .run()\n      .pipe(Effect.orDie),\n  )\n}"},{"id":"workspace_test_sessionsequence","label":"sessionSequence()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/control-plane/workspace.test.ts","source_location":"L330-L342","layer":"base","provenance":[{"capability_id":"builtin:e