{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_core_src_session_compaction","nodes":[{"id":"packages_core_src_session_compaction","label":"compaction.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L1"}]},{"id":"packages_core_src_session_compaction_estimate","label":"estimate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L79"}],"snippet":"estimate = (value: unknown) => Token.estimate(JSON.stringify(value))"},{"id":"packages_core_src_session_compaction_truncate","label":"truncate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L81-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L81"}],"snippet":"truncate = (value: string) =>\n  value.length <= TOOL_OUTPUT_MAX_CHARS ? value : `${value.slice(0, TOOL_OUTPUT_MAX_CHARS)}\\n[truncated]`"},{"id":"packages_core_src_session_compaction_serializetoolcontent","label":"serializeToolContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L84-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L84"}],"snippet":"serializeToolContent = (content: SessionMessage.ToolStateCompleted[\"content\"]) =>\n  content\n    .map((item) =>\n      item.type === \"text\" ? item.text : `[Attached ${item.mime}${item.name === undefined ? \"\" : `: ${item.name}`}]`,\n    )\n    .join(\"\\n\")"},{"id":"packages_core_src_session_compaction_serialize","label":"serialize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L91-L117","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L91"}],"snippet":"serialize = (message: SessionMessage.Message) => {\n  if (message.type === \"user\") {\n    const files = message.files?.map((file) => `[Attached ${file.mime}: ${file.name ?? file.uri}]`) ?? []\n    return [`[User]: ${message.text}`, ...files].join(\"\\n\")\n  }\n  if (message.type === \"assistant\") {\n    return message.content\n      .flatMap((part) => {\n        if (part.type === \"text\") return [`[Assistant]: ${part.text}`]\n        if (part.type === \"reasoning\") return part.text ? [`[Assistant reasoning]: ${part.text}`] : []\n        const input = typeof part.state.input === \"string\" ? part.state.input : JSON.stringify(part.state.input)\n        if (part.state.status === \"completed\")\n          return [\n            `[Assistant tool call]: ${part.name}(${input})`,\n            `[Tool result]: ${truncate(serializeToolContent(part.state.content))}`,\n          ]\n        if (part.state.status === \"error\")\n          return [`[Assistant tool call]: ${part.name}(${input})`, `[Tool error]: ${part.state.error.message}`]\n        return [`[Assistant tool call]: ${part.name}(${input})`]\n      })\n      .join(\"\\n\")\n  }\n  if (message.type === \"system\") return `[System update]: ${message.text}`\n  if (message.type === \"synthetic\") return `[Synthetic context]: ${message.text}`\n  if (message.type === \"shell\") return `[Shell]: ${message.command}\\n${truncate(message.output)}`"},{"id":"packages_core_src_session_compaction_settings","label":"settings()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L119-L131","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L119"}],"snippet":"settings = (documents: readonly Config.Entry[]) => {\n  const configured = documents\n    .filter((entry): entry is Config.Document => entry.type === \"document\")\n    .flatMap((entry) => (entry.info.compaction ? [entry.info.compaction] : []))\n  return configured.reduce<Settings>(\n    (result, current) => ({\n      auto: current.auto ?? result.auto,\n      buffer: current.buffer ?? result.buffer,\n      tokens: current.keep?.tokens ?? result.tokens,\n    }),\n    { auto: true, buffer: DEFAULT_BUFFER, tokens: DEFAULT_KEEP_TOKENS },\n  )\n}"},{"id":"packages_core_src_session_compaction_select","label":"select()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L133-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L133"}],"snippet":"select = (\n  entries: readonly Entry[],\n  tokens: number,\n): { readonly head: string; readonly recent: string } | undefined => {\n  const conversation = entries\n    .filter((entry) => entry.message.type !== \"compaction\")\n    .map((entry) => serialize(entry.message))\n    .filter(Boolean)\n  if (conversation.length === 0) return\n  let total = 0\n  let split = conversation.length\n  let splitPrefix = \"\"\n  let splitSuffix = \"\"\n  for (let index = conversation.length - 1; index >= 0; index--) {\n    const next = total + Token.estimate(conversation[index])\n    if (next > tokens) {\n      const remaining = Math.max(0, tokens - total) * 4\n      if (remaining > 0) {\n        splitPrefix = conversation[index].slice(0, -remaining)\n        splitSuffix = conversation[index].slice(-remaining)\n        split = index + 1\n      }\n      break\n    }\n    total = next"},{"id":"packages_core_src_session_compaction_buildprompt","label":"buildPrompt()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L166-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L166"}],"snippet":"buildPrompt = (input: { readonly previousSummary?: string; readonly context: readonly string[] }) =>\n  [\n    input.previousSummary\n      ? `Update the anchored summary below using the conversation history above.\\nPreserve still-true details, remove stale details, and merge in the new facts.\\n<previous-summary>\\n${input.previousSummary}\\n</previous-summary>`\n      : \"Create a new anchored summary from the conversation history.\",\n    SUMMARY_TEMPLATE,\n    ...input.context,\n  ].join(\"\\n\\n\")"},{"id":"packages_core_src_session_compaction_make","label":"make()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L175-L246","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L175"}],"snippet":"make = (dependencies: Dependencies) => {\n  const config = settings(dependencies.config)\n  const compactAfterOverflow = Effect.fn(\"SessionCompaction.compactAfterOverflow\")(function* (input: Input) {\n    const context = input.model.route.defaults.limits?.context\n    if (context === undefined || context <= 0) return false\n    const output = input.request.generation?.maxTokens ?? input.model.route.defaults.limits?.output ?? 0\n    const selected = select(input.entries, config.tokens)\n    const previousSummary = input.entries.find((entry) => entry.message.type === \"compaction\")?.message\n    if (!selected || (selected.head.length === 0 && previousSummary?.type !== \"compaction\")) return false\n    const summaryPrompt = buildPrompt({\n      previousSummary: previousSummary?.type === \"compaction\" ? previousSummary.summary : undefined,\n      context: [previousSummary?.type === \"compaction\" ? previousSummary.recent : \"\", selected.head].filter(Boolean),\n    })\n    const summaryOutput = Math.min(output || SUMMARY_OUTPUT_TOKENS, SUMMARY_OUTPUT_TOKENS)\n    if (Token.estimate(summaryPrompt) > context - summaryOutput) return false\n    const messageID = SessionMessage.ID.create()\n    yield* dependencies.events.publish(SessionEvent.Compaction.Started, {\n      sessionID: input.sessionID,\n      messageID,\n      timestamp: yield* DateTime.now,\n      reason: \"auto\",\n    })\n\n    const chunks: string[] = []\n    let failed = false"}],"edges":[{"source":"packages_core_src_session_compaction","target":"compaction","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/session/compaction.ts","source_location":"L1"}],"weight":1},{"source":"packages_core_src_session_compaction","target":