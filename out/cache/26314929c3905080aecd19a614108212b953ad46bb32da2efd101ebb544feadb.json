an/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L69"}],"snippet":"function inline(info: Inline) {\n  const suffix = info.description ? UI.Style.TEXT_DIM + ` ${info.description}` + UI.Style.TEXT_NORMAL : \"\"\n  UI.println(UI.Style.TEXT_NORMAL + info.icon, UI.Style.TEXT_NORMAL + info.title + suffix)\n}"},{"id":"run_block","label":"block()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L74-L80","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L74"}],"snippet":"function block(info: Inline, output?: string) {\n  UI.empty()\n  inline(info)\n  if (!output?.trim()) return\n  UI.println(output)\n  UI.empty()\n}"},{"id":"run_formatrunerror","label":"formatRunError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L82-L84","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L82"}],"snippet":"function formatRunError(error: unknown) {\n  return FormatError(error) ?? FormatUnknownError(error)\n}"},{"id":"run_tool","label":"tool()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L86-L102","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L86"}],"snippet":"async function tool(part: ToolPart) {\n  try {\n    const { toolInlineInfo } = await import(\"./run/tool\")\n    const next = toolInlineInfo(part)\n    if (next.mode === \"block\") {\n      block(next, next.body)\n      return\n    }\n\n    inline(next)\n  } catch {\n    inline({\n      icon: \"\\u2699\",\n      title: part.tool,\n    })\n  }\n}"},{"id":"run_toolerror","label":"toolError()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L104-L120","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L104"}],"snippet":"async function toolError(part: ToolPart) {\n  try {\n    const { toolInlineInfo } = await import(\"./run/tool\")\n    const next = toolInlineInfo(part)\n    inline({\n      icon: \"✗\",\n      title: `${next.title} failed`,\n      ...(next.description && { description: next.description }),\n    })\n    return\n  } catch {\n    inline({\n      icon: \"✗\",\n      title: `${part.tool} failed`,\n    })\n  }\n}"}],"edges":[{"source":"run","target":"permission","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L1"}],"weight":1},{"source":"run","target":"yargs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L15","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run.ts","source_location":"L15"}],"weight":1},{"source":"run","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai