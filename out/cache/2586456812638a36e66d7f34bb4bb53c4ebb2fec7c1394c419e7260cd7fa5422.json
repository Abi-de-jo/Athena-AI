{"__madarTsExtractorVersion":67,"__madarFileStem":"scrollback.writer","nodes":[{"id":"scrollback_writer","label":"scrollback.writer.tsx","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L1"}]},{"id":"scrollback_writer_todotext","label":"todoText()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L10-L24","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L10"}],"snippet":"function todoText(item: { status: string; content: string }): string {\n  if (item.status === \"completed\") {\n    return `[✓] ${item.content}`\n  }\n\n  if (item.status === \"cancelled\") {\n    return `~[ ] ${item.content}~`\n  }\n\n  if (item.status === \"in_progress\") {\n    return `[•] ${item.content}`\n  }\n\n  return `[ ] ${item.content}`\n}"},{"id":"scrollback_writer_todocolor","label":"todoColor()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L26-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L26"}],"snippet":"function todoColor(theme: RunTheme, status: string) {\n  return status === \"in_progress\" ? theme.block.warning : theme.block.muted\n}"},{"id":"scrollback_writer_entrygroupkey","label":"entryGroupKey()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L30-L40","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L30"}],"snippet":"export function entryGroupKey(commit: StreamCommit): string | undefined {\n  if (!commit.partID) {\n    return undefined\n  }\n\n  if (toolStructuredFinal(commit)) {\n    return `tool:${commit.partID}:final`\n  }\n\n  return `${commit.kind}:${commit.partID}`\n}"},{"id":"scrollback_writer_sameentrygroup","label":"sameEntryGroup()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L42-L50","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L42"}],"snippet":"export function sameEntryGroup(left: StreamCommit | undefined, right: StreamCommit): boolean {\n  if (!left) {\n    return false\n  }\n\n  const current = entryGroupKey(left)\n  const next = entryGroupKey(right)\n  return Boolean(current && next && current === next)\n}"},{"id":"scrollback_writer_entrylayout","label":"entryLayout()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L52-L79","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L52"}],"snippet":"export function entryLayout(commit: StreamCommit, body: RunEntryBody = entryBody(commit)): EntryLayout {\n  if (commit.kind === \"tool\") {\n    if (body.type === \"structured\" || body.type === \"markdown\") {\n      return \"block\"\n    }\n\n    if (\n      commit.phase === \"progress\" &&\n      commit.toolState === \"completed\" &&\n      body.type === \"text\" &&\n      body.content.includes(\"\\n\")\n    ) {\n      return \"block\"\n    }\n\n    return \"inline\"\n  }\n\n  if (commit.kind === \"reasoning\") {\n    return \"block\"\n  }\n\n  if (commit.kind === \"error\") {\n    return \"block\"\n  }"},{"id":"scrollback_writer_separatorrows","label":"separatorRows()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L81-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L81"}],"snippet":"export function separatorRows(\n  prev: StreamCommit | undefined,\n  next: StreamCommit,\n  body: RunEntryBody = entryBody(next),\n): number {\n  if (!prev || sameEntryGroup(prev, next)) {\n    return 0\n  }\n\n  if (entryLayout(prev) === \"inline\" && entryLayout(next, body) === \"inline\") {\n    return 0\n  }\n\n  return 1\n}"},{"id":"scrollback_writer_runentrycontent","label":"RunEntryContent()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L97-L300","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L97"}],"snippet":"export function RunEntryContent(props: {\n  commit: StreamCommit\n  body?: RunEntryBody\n  theme?: RunTheme\n  opts?: ScrollbackOptions\n  width?: number\n}) {\n  const theme = createMemo(() => props.theme ?? RUN_THEME_FALLBACK)\n  const body = createMemo(() => props.body ?? entryBody(props.commit))\n  const style = createMemo(() => entryLook(props.commit, theme().entry))\n  const syntax = createMemo(() => entrySyntax(props.commit, theme()))\n  const color = createMemo(() => entryColor(props.commit, theme()))\n  const suppressBackgrounds = createMemo(() => props.opts?.suppressBackgrounds === true)\n  const diffBg = (color: ColorInput) => (suppressBackgrounds() ? transparent : color)\n  const streaming = createMemo(() => props.commit.phase === \"progress\")\n  const text = createMemo(() => {\n    const next = body()\n    return next.type === \"text\" ? next : undefined\n  })\n  const code = createMemo(() => {\n    const next = body()\n    return next.type === \"code\" ? next : undefined\n  })\n  const structured = createMemo(() => {\n    const next = body()","node_kind":"component"},{"id":"scrollback_writer_runentrycontent_diffbg","label":"diffBg()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L110","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L110"}],"snippet":"diffBg = (color: ColorInput) => (suppressBackgrounds() ? transparent : color)"},{"id":"scrollback_writer_entrywriter","label":"entryWriter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L302-L320","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L302"}],"snippet":"export function entryWriter(input: {\n  commit: StreamCommit\n  body?: RunEntryBody\n  theme?: RunTheme\n  opts?: ScrollbackOptions\n}): ScrollbackWriter {\n  return createScrollbackWriter(\n    (ctx) => (\n      <RunEntryContent\n        commit={input.commit}\n        body={input.body}\n        theme={input.theme}\n        opts={{ ...input.opts, suppressBackgrounds: true }}\n        width={ctx.width}\n      />\n    ),\n    entryFlags(input.commit),\n  )\n}"},{"id":"scrollback_writer_spacerwriter","label":"spacerWriter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L322-L334","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L322"}],"snippet":"export function spacerWriter(): ScrollbackWriter {\n  return (ctx: ScrollbackRenderContext) => ({\n    root: new TextRenderable(ctx.renderContext, {\n      width: Math.max(1, Math.trunc(ctx.width)),\n      height: 1,\n      content: \"\",\n    }),\n    width: Math.max(1, Math.trunc(ctx.width)),\n    height: 1,\n    startOnNewLine: true,\n    trailingNewline: true,\n  })\n}"},{"id":"scrollback_writer_turnsummarywriter","label":"turnSummaryWriter()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L336-L352","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L336"}],"snippet":"export function turnSummaryWriter(input: { agent: string; model: string; duration: string; theme: RunTheme }) {\n  return createScrollbackWriter(\n    () => (\n      <box width=\"100%\" height={1}>\n        <text wrapMode=\"none\" truncate>\n          <span style={{ fg: input.theme.block.highlight }}>▣ </span>\n          <span style={{ fg: input.theme.block.text }}>{input.agent}</span>\n          <span style={{ fg: input.theme.block.muted }}>\n            {\" \"}\n            · {input.model} · {input.duration}\n          </span>\n        </text>\n      </box>\n    ),\n    { startOnNewLine: true, trailingNewline: false },\n  )\n}"}],"edges":[{"source":"scrollback_writer","target":"solid","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L1"}],"weight":1},{"source":"scrollback_writer","target":"core","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L2"}],"weight":1},{"source":"scrollback_writer","target":"solid_js","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L3"}],"weight":1},{"source":"scrollback_writer","target":"entry","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/src/cli/cmd/run/scrollback.writer.tsx","source_location":"L4","layer