ed\n}"},{"id":"packages_llm_src_protocols_gemini_lowertoolcall","label":"lowerToolCall()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/gemini.ts","source_location":"L198-L201","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/gemini.ts","source_location":"L198"}],"snippet":"lowerToolCall = (part: ToolCallPart) => ({\n  functionCall: { name: part.name, args: part.input },\n  thoughtSignature: thoughtSignature(part.providerMetadata),\n})"},{"id":"packages_llm_src_protocols_gemini_geminioptions","label":"geminiOptions()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/gemini.ts","source_location":"L288","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/gemini.ts","source_location":"L288"}],"snippet":"geminiOptions = (request: LLMRequest) => request.providerOptions?.gemini"},{"id":"packages_llm_src_protocols_gemini_thinkingconfig","label":"thinkingConfig()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/gemini.ts","source_location":"L290-L298","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/llm/src/protocols/gemini.ts","source_location":"L290"}],"snippet":"thinkingConfig = (request: LLMRequest) => {\n  const value = geminiOptions(request)?.thinkingConfig\n  if (!ProviderShared.isRecord(value)) return undefined\n  const result = {\n    thinkingBudget: typeof value.thinkingBudget === \"number\" ? value.thinkingBudget : undefined,\n    includeThoughts: typeof value.includeThoughts === \"boolean\" ? value.includeThoughts : undefined,\n  }\n  re