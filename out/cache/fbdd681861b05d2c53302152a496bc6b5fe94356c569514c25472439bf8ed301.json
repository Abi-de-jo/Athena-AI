{"__madarTsExtractorVersion":67,"__madarFileStem":"finalize-latest-json","nodes":[{"id":"finalize_latest_json","label":"finalize-latest-json.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L1"}]},{"id":"finalize_latest_json_parse","label":"parse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L64-L93","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L64"}],"snippet":"function parse(text: string): Yml {\n  const lines = text.split(\"\\n\")\n  let version = \"\"\n  const files: Item[] = []\n  let url = \"\"\n\n  const flush = () => {\n    if (!url) return\n    files.push({ url })\n    url = \"\"\n  }\n\n  for (const line of lines) {\n    const trim = line.trim()\n    if (line.startsWith(\"version:\")) {\n      version = line.slice(\"version:\".length).trim()\n      continue\n    }\n    if (trim.startsWith(\"- url:\")) {\n      flush()\n      url = trim.slice(\"- url:\".length).trim()\n      continue\n    }\n    const indented = line.startsWith(\"  \") || line.startsWith(\"\\t\")\n    if (!indented) flush()"},{"id":"finalize_latest_json_parse_flush","label":"flush()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L70-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L70"}],"snippet":"flush = () => {\n    if (!url) return\n    files.push({ url })\n    url = \"\"\n  }"},{"id":"finalize_latest_json_read","label":"read()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L95-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L95"}],"snippet":"async function read(sub: string, file: string) {\n  const item = Bun.file(path.join(root, sub, file))\n  if (!(await item.exists())) return undefined\n  return parse(await item.text())\n}"},{"id":"finalize_latest_json_pick","label":"pick()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L101-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L101"}],"snippet":"function pick(list: Item[], exts: string[]) {\n  for (const ext of exts) {\n    const found = list.find((item) => item.url.split(\"?\")[0]?.toLowerCase().endsWith(ext))\n    if (found) return found.url\n  }\n}"},{"id":"finalize_latest_json_link","label":"link()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L108-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L108"}],"snippet":"function link(raw: string) {\n  if (raw.startsWith(\"https://\") || raw.startsWith(\"http://\")) return raw\n  return `https://github.com/${repo}/releases/download/v${version}/${raw}`\n}"},{"id":"finalize_latest_json_sign","label":"sign()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L113-L133","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L113"}],"snippet":"async function sign(url: string, key: string) {\n  const name = decodeURIComponent(new URL(url).pathname.split(\"/\").pop() ?? key)\n  const asset = amap.get(name)\n  const res = await fetch(asset?.url ?? url, {\n    headers: {\n      Authorization: `token ${token}`,\n      ...(asset ? { Accept: \"application/octet-stream\" } : {}),\n    },\n  })\n  if (!res.ok) {\n    throw new Error(`Failed to fetch file ${name}: ${res.status} ${res.statusText} (${asset?.url ?? url})`)\n  }\n\n  const tmp = process.env.RUNNER_TEMP ?? \"/tmp\"\n  const file = path.join(tmp, name)\n  await Bun.write(file, await res.arrayBuffer())\n  await $`bunx @tauri-apps/cli signer sign ${file}`\n  const sigFile = Bun.file(`${file}.sig`)\n  if (!(await sigFile.exists())) throw new Error(`Signature file not found for ${name}`)\n  return (await sigFile.text()).trim()\n}"},{"id":"finalize_latest_json_add","label":"add()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L135-L140","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L135"}],"snippet":"add = async (data: Record<string, { url: string; signature: string }>, key: string, raw: string | undefined) => {\n  if (!raw) return\n  if (data[key]) return\n  const url = link(raw)\n  data[key] = { url, signature: await sign(url, key) }\n}"},{"id":"finalize_latest_json_alias","label":"alias()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L142-L146","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L142"}],"snippet":"alias = (data: Record<string, { url: string; signature: string }>, key: string, src: string) => {\n  if (data[key]) return\n  if (!data[src]) return\n  data[key] = data[src]\n}"}],"edges":[{"source":"finalize_latest_json","target":"bun","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L3"}],"weight":1},{"source":"finalize_latest_json","target":"path","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L4"}],"weight":1},{"source":"finalize_latest_json","target":"util","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/desktop/scripts/finalize-latest-json.ts","source_location":"L5","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowd