Pick<RequestOptions, \"auth\" | \"query\"> & {\n    headers: Headers\n  }) => {\n  for (const auth of security) {\n    if (checkForExistence(options, auth.name)) {\n      continue\n    }\n\n    const token = await getAuthToken(auth, options.auth)\n\n    if (!token) {\n      continue\n    }\n\n    const name = auth.name ?? \"Authorization\"\n\n    switch (auth.in) {\n      case \"query\":\n        if (!options.query) {\n          options.query = {}\n        }"},{"id":"packages_sdk_js_src_v2_gen_client_utils_gen_buildurl","label":"buildUrl()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L146-L156","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L146"}],"snippet":"buildUrl: Client[\"buildUrl\"] = (options) =>\n  getUrl({\n    baseUrl: options.baseUrl as string,\n    path: options.path,\n    query: options.query,\n    querySerializer:\n      typeof options.querySerializer === \"function\"\n        ? options.querySerializer\n        : createQuerySerializer(options.querySerializer),\n    url: options.url,\n  })"},{"id":"packages_sdk_js_src_v2_gen_client_utils_gen_mergeconfigs","label":"mergeConfigs()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L158-L165","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L158"}],"snippet":"mergeConfigs = (a: Config, b: Config): Config => {\n  const config = { ...a, ...b }\n  if (config.baseUrl?.endsWith(\"/\")) {\n    config.baseUrl = config.baseUrl.substring(0, config.baseUrl.length - 1)\n  }\n  config.headers = mergeHeaders(a.headers, b.headers)\n  return config\n}"},{"id":"packages_sdk_js_src_v2_gen_client_utils_gen_headersentries","label":"headersEntries()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L167-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L167"}],"snippet":"headersEntries = (headers: Headers): Array<[string, string]> => {\n  const entries: Array<[string, string]> = []\n  headers.forEach((value, key) => {\n    entries.push([key, value])\n  })\n  return entries\n}"},{"id":"packages_sdk_js_src_v2_gen_client_utils_gen_mergeheaders","label":"mergeHeaders()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L175-L199","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L175"}],"snippet":"mergeHeaders = (...headers: Array<Required<Config>[\"headers\"] | undefined>): Headers => {\n  const mergedHeaders = new Headers()\n  for (const header of headers) {\n    if (!header) {\n      continue\n    }\n\n    const iterator = header instanceof Headers ? headersEntries(header) : Object.entries(header)\n\n    for (const [key, value] of iterator) {\n      if (value === null) {\n        mergedHeaders.delete(key)\n      } else if (Array.isArray(value)) {\n        for (const v of value) {\n          mergedHeaders.append(key, v as string)\n        }\n      } else if (value !== undefined) {\n        // assume object headers are meant to be JSON stringified, i.e. their\n        // content value in OpenAPI specification is 'application/json'\n        mergedHeaders.set(key, typeof value === \"object\" ? JSON.stringify(value) : (value as string))\n      }\n    }\n  }\n  return mergedHeaders\n}"},{"id":"packages_sdk_js_src_v2_gen_client_utils_gen_interceptors","label":"Interceptors","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L212-L251","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L212"}],"snippet":"class Interceptors<Interceptor> {\n  fns: Array<Interceptor | null> = []\n\n  clear(): void {\n    this.fns = []\n  }\n\n  eject(id: number | Interceptor): void {\n    const index = this.getInterceptorIndex(id)\n    if (this.fns[index]) {\n      this.fns[index] = null\n    }\n  }\n\n  exists(id: number | Interceptor): boolean {\n    const index = this.getInterceptorIndex(id)\n    return Boolean(this.fns[index])\n  }\n\n  getInterceptorIndex(id: number | Interceptor): number {\n    if (typeof id === \"number\") {\n      return this.fns[id] ? id : -1\n    }\n    return this.fns.indexOf(id)\n  }"},{"id":"packages_sdk_js_src_v2_gen_client_utils_gen_interceptors_clear","label":".clear()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L215-L217","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L215"}],"snippet":"clear(): void {\n    this.fns = []\n  }"},{"id":"packages_sdk_js_src_v2_gen_client_utils_gen_interceptors_eject","label":".eject()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/sdk/js/src/v2/gen/client/utils.gen.ts","source_location":"L219-L224","layer"