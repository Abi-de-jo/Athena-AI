{"__madarTsExtractorVersion":67,"__madarFileStem":"packages_rimuru_test_fixture_flock-worker","nodes":[{"id":"packages_rimuru_test_fixture_flock_worker","label":"flock-worker.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L1"}]},{"id":"packages_rimuru_test_fixture_flock_worker_sleep","label":"sleep()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L17-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L17"}],"snippet":"function sleep(ms: number) {\n  return new Promise<void>((resolve) => {\n    setTimeout(resolve, ms)\n  })\n}"},{"id":"packages_rimuru_test_fixture_flock_worker_input","label":"input()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L23-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L23"}],"snippet":"function input() {\n  const raw = process.argv[2]\n  if (!raw) {\n    throw new Error(\"Missing flock worker input\")\n  }\n\n  return JSON.parse(raw) as Msg\n}"},{"id":"packages_rimuru_test_fixture_flock_worker_job","label":"job()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L32-L54","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L32"}],"snippet":"async function job(input: Msg) {\n  if (input.ready) {\n    await fs.writeFile(input.ready, String(process.pid))\n  }\n\n  if (input.active) {\n    await fs.writeFile(input.active, String(process.pid), { flag: \"wx\" })\n  }\n\n  try {\n    if (input.holdMs && input.holdMs > 0) {\n      await sleep(input.holdMs)\n    }\n\n    if (input.done) {\n      await fs.appendFile(input.done, \"1\\n\")\n    }\n  } finally {\n    if (input.active) {\n      await fs.rm(input.active, { force: true })\n    }\n  }\n}"},{"id":"packages_rimuru_test_fixture_flock_worker_main","label":"main()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L56-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L56"}],"snippet":"async function main() {\n  const msg = input()\n\n  await Flock.withLock(msg.key, () => job(msg), {\n    dir: msg.dir,\n    staleMs: msg.staleMs,\n    timeoutMs: msg.timeoutMs,\n    baseDelayMs: msg.baseDelayMs,\n    maxDelayMs: msg.maxDelayMs,\n  })\n}"}],"edges":[{"source":"packages_rimuru_test_fixture_flock_worker","target":"promises","relation":"imports_from","confidence":"EXTRACTED","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/rimuru/test/fixture/flock-worker.ts","source_location":"L1"}],"weight":1},{"source":"packages_rimuru_test_fixture_flock_worker","target":"flock","relation":"imp