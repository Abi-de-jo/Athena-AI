Error.alreadySubscribed }\n    }"},{"id":"packages_console_app_src_routes_black_subscribe_plan_booksubscription","label":"bookSubscription()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/black/subscribe/[plan].tsx","source_location":"L121-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/black/subscribe/[plan].tsx","source_location":"L121"}],"snippet":"bookSubscription = async (input: {\n  workspaceID: string\n  plan: PlanID\n  paymentMethodID: string\n  paymentMethodType: string\n  paymentMethodLast4?: string\n}) => {\n  \"use server\"\n  return withActor(\n    () =>\n      Database.use((tx) =>\n        tx\n          .update(BillingTable)\n          .set({\n            paymentMethodID: input.paymentMethodID,\n            paymentMethodType: input.paymentMethodType,\n            paymentMethodLast4: input.paymentMethodLast4,\n            subscriptionPlan: input.plan,\n            timeSubscriptionBooked: new Date(),\n          })\n          .where(eq(BillingTable.workspaceID, input.workspaceID)),\n      ),\n    input.workspaceID,\n  )\n}"},{"id":"packages_console_app_src_routes_black_subscribe_plan_successdata","label":"SuccessData","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/black/subscribe/[plan].tsx","source_location":"L147-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/console/app/src/routes/black/subscribe/[plan].tsx","source_location":"L147"}],"snippet":"interface SuccessData {\n  plan: string\n  paymentMethodType: string\n  paymentMethodLast4?: string\n}"},{"id":"packages_console_app_src_routes_black_subscribe_plan_failure","label":"Failure()","file_type":"code","source_file":"/home