{"__madarTsExtractorVersion":67,"__madarFileStem":"patch","nodes":[{"id":"patch","label":"patch.ts","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L1"}]},{"id":"patch_updatefilechunk","label":"UpdateFileChunk","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L13-L18","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L13"}],"snippet":"export interface UpdateFileChunk {\n  readonly oldLines: ReadonlyArray<string>\n  readonly newLines: ReadonlyArray<string>\n  readonly changeContext?: string\n  readonly endOfFile?: boolean\n}"},{"id":"patch_fileupdate","label":"FileUpdate","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L20-L23","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L20"}],"snippet":"export interface FileUpdate {\n  readonly content: string\n  readonly bom: boolean\n}"},{"id":"patch_parse","label":"parse()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L25-L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L25"}],"snippet":"export function parse(patchText: string): ReadonlyArray<Hunk> {\n  const lines = stripHeredoc(patchText.trim()).split(\"\\n\")\n  const begin = lines.findIndex((line) => line.trim() === \"*** Begin Patch\")\n  const end = lines.findIndex((line) => line.trim() === \"*** End Patch\")\n  if (begin === -1 || end === -1 || begin >= end) throw new Error(\"Invalid patch format: missing Begin/End markers\")\n\n  const hunks: Hunk[] = []\n  let index = begin + 1\n  while (index < end) {\n    const line = lines[index]!\n    if (line.startsWith(\"*** Add File:\")) {\n      const path = line.slice(\"*** Add File:\".length).trim()\n      if (!path) throw new Error(\"Invalid add file path\")\n      const parsed = parseAdd(lines, index + 1)\n      hunks.push({ type: \"add\", path, contents: parsed.content })\n      index = parsed.next\n      continue\n    }\n    if (line.startsWith(\"*** Delete File:\")) {\n      const path = line.slice(\"*** Delete File:\".length).trim()\n      if (!path) throw new Error(\"Invalid delete file path\")\n      hunks.push({ type: \"delete\", path })\n      index++\n      continue\n    }"},{"id":"patch_derive","label":"derive()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L71-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L71"}],"snippet":"export function derive(path: string, chunks: ReadonlyArray<UpdateFileChunk>, original: string): FileUpdate {\n  const source = splitBom(original)\n  const lines = source.text.split(\"\\n\")\n  if (lines.at(-1) === \"\") lines.pop()\n  const replacements = computeReplacements(lines, path, chunks)\n  const updated = [...lines]\n  for (const [start, remove, insert] of replacements.toReversed()) updated.splice(start, remove, ...insert)\n  if (updated.at(-1) !== \"\") updated.push(\"\")\n  const next = splitBom(updated.join(\"\\n\"))\n  return { content: next.text, bom: source.bom || next.bom }\n}"},{"id":"patch_joinbom","label":"joinBom()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L83-L86","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L83"}],"snippet":"export function joinBom(text: string, bom: boolean) {\n  const stripped = splitBom(text).text\n  return bom ? `\\uFEFF${stripped}` : stripped\n}"},{"id":"patch_parseadd","label":"parseAdd()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L88-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L88"}],"snippet":"function parseAdd(lines: ReadonlyArray<string>, start: number) {\n  const content: string[] = []\n  let index = start\n  while (index < lines.length && !lines[index]!.startsWith(\"***\")) {\n    if (!lines[index]!.startsWith(\"+\")) throw new Error(`Invalid add file line: ${lines[index]}`)\n    content.push(lines[index]!.slice(1))\n    index++\n  }\n  return { content: content.join(\"\\n\"), next: index }\n}"},{"id":"patch_parseupdate","label":"parseUpdate()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L99-L130","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L99"}],"snippet":"function parseUpdate(lines: ReadonlyArray<string>, start: number) {\n  const chunks: UpdateFileChunk[] = []\n  let index = start\n  while (index < lines.length && !lines[index]!.startsWith(\"***\")) {\n    if (!lines[index]!.startsWith(\"@@\")) {\n      throw new Error(`Invalid update file line: ${lines[index]}`)\n    }\n    const changeContext = lines[index]!.slice(2).trim() || undefined\n    const oldLines: string[] = []\n    const newLines: string[] = []\n    let endOfFile = false\n    index++\n    while (index < lines.length && !lines[index]!.startsWith(\"@@\")) {\n      const line = lines[index]!\n      if (line === \"*** End of File\") {\n        endOfFile = true\n        index++\n        break\n      }\n      if (line.startsWith(\"***\")) break\n      if (line.startsWith(\" \")) {\n        oldLines.push(line.slice(1))\n        newLines.push(line.slice(1))\n      } else if (line.startsWith(\"-\")) oldLines.push(line.slice(1))\n      else if (line.startsWith(\"+\")) newLines.push(line.slice(1))"},{"id":"patch_computereplacements","label":"computeReplacements()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L132-L158","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L132"}],"snippet":"function computeReplacements(lines: ReadonlyArray<string>, path: string, chunks: ReadonlyArray<UpdateFileChunk>) {\n  const replacements: Array<readonly [start: number, remove: number, insert: ReadonlyArray<string>]> = []\n  let lineIndex = 0\n  for (const chunk of chunks) {\n    if (chunk.changeContext) {\n      const context = seek(lines, [chunk.changeContext], lineIndex)\n      if (context === -1) throw new Error(`Failed to find context '${chunk.changeContext}' in ${path}`)\n      lineIndex = context + 1\n    }\n    if (chunk.oldLines.length === 0) {\n      replacements.push([lines.length, 0, chunk.newLines])\n      continue\n    }\n    let oldLines = chunk.oldLines\n    let newLines = chunk.newLines\n    let found = seek(lines, oldLines, lineIndex, chunk.endOfFile)\n    if (found === -1 && oldLines.at(-1) === \"\") {\n      oldLines = oldLines.slice(0, -1)\n      if (newLines.at(-1) === \"\") newLines = newLines.slice(0, -1)\n      found = seek(lines, oldLines, lineIndex, chunk.endOfFile)\n    }\n    if (found === -1) throw new Error(`Failed to find expected lines in ${path}:\\n${chunk.oldLines.join(\"\\n\")}`)\n    replacements.push([found, oldLines.length, newLines])\n    lineIndex = found + oldLines.length\n  }"},{"id":"patch_seek","label":"seek()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L160-L172","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L160"}],"snippet":"function seek(lines: ReadonlyArray<string>, pattern: ReadonlyArray<string>, start: number, eof = false) {\n  if (pattern.length === 0) return -1\n  for (const compare of [exact, rstrip, trim, normalized]) {\n    if (eof) {\n      const offset = lines.length - pattern.length\n      if (offset >= start && matches(lines, pattern, offset, compare)) return offset\n    }\n    for (let offset = start; offset <= lines.length - pattern.length; offset++) {\n      if (matches(lines, pattern, offset, compare)) return offset\n    }\n  }\n  return -1\n}"},{"id":"patch_matches","label":"matches()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L174-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L174"}],"snippet":"function matches(\n  lines: ReadonlyArray<string>,\n  pattern: ReadonlyArray<string>,\n  offset: number,\n  compare: (left: string, right: string) => boolean,\n) {\n  return pattern.every((line, index) => compare(lines[offset + index]!, line))\n}"},{"id":"patch_exact","label":"exact()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L183","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L183"}],"snippet":"exact = (left: string, right: string) => left === right"},{"id":"patch_rstrip","label":"rstrip()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L184","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L184"}],"snippet":"rstrip = (left: string, right: string) => left.trimEnd() === right.trimEnd()"},{"id":"patch_trim","label":"trim()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L185","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L185"}],"snippet":"trim = (left: string, right: string) => left.trim() === right.trim()"},{"id":"patch_normalized","label":"normalized()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L186","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packages/core/src/patch.ts","source_location":"L186"}],"snippet":"normalized = (left: string, right: string) => normalize(left.trim()) === normalize(right.trim())"},{"id":"patch_normalize","label":"normalize()","file_type":"code","source_file":"/home/gowdaman/Projects/personal/rimuru-ai/packa