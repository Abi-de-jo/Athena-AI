{
  "$schema": "https://opencode.ai/config.json",

  "provider": {},

  "permission": {},

  "references": {
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
      "description": "Use for Effect v4 and effect-smol implementation details"
    },
    "athena-local": {
      "path": "~/.local/share/opencode",
      "description": "Contains opencode logs and data"
    },
    "athena-docs": {
      "path": "./packages/docs",
      "description": "Athena documentation site built with Astro"
    },
    "athena-core": {
      "path": "./packages/core",
      "description": "Core shared library for athena-ai"
    }
  },

  "mcp": {
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "@nexus2520/figma-mcp-server"],
      "enabled": true,
      "environment": {
        "FIGMA_ACCESS_TOKEN": "${ATHENA_FIGMA_TOKEN}"
      }
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/home/gowdaman"],
      "enabled": true
    },
    "postman": {
      "type": "local",
      "command": ["npx", "-y", "@postman/postman-mcp-server@latest", "--region", "us", "--full"],
      "enabled": true,
      "environment": {
        "POSTMAN_API_KEY": "${ATHENA_POSTMAN_KEY}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "browser-use": {
      "type": "local",
      "command": ["npx", "-y", "browser-use", "--mcp"],
      "enabled": true
    },
  },

  "tools": {
    "github-triage": false,
    "github-pr-search": false
  },

  "agent": {
    "athena-build": {
      "mode": "primary",
      "permission": {
        "task": { "*": "allow" },
        "tool": { "*": "allow" }
      }
    },
    "athena-docs": {
      "mode": "primary",
      "permission": {
        "task": { "*": "allow" },
        "tool": { "*": "allow" }
      }
    },
    "athena-codebase": {
      "mode": "primary",
      "permission": {
        "task": { "*": "allow" },
        "tool": { "*": "allow" }
      }
    }
  },

  "plugin": [
    "opencode-optimal-model-temps",
    "opencode-codebase-index",
    "opencode-helicone-session",
    "opencode-goal-plugin"
  ],

  "command": {
    "goal": {
      "description": "Set a session-scoped goal and auto-continue until complete.",
      "template": "$ARGUMENTS",
      "agent": "build"
    },
    "build-package": {
      "description": "Build a specific package with turbo",
      "template": "bun turbo build --filter=$ARGUMENTS",
      "agent": "build"
    },
    "typecheck": {
      "description": "Run typecheck across the project",
      "template": "bun turbo typecheck",
      "agent": "build"
    },
    "lint": {
      "description": "Run linter",
      "template": "oxlint",
      "agent": "build"
    }
  }
}
