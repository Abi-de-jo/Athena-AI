#!/usr/bin/env sh
# Rimuru AI - Install Script
# Usage: curl -fsSL https://rimurucode.vercel.app/install | sh

set -eu

REPO="gowdaman-dev/rimuru-ai"
INSTALL_DIR="${INSTALL_DIR:-$HOME/.rimuru/bin}"
VERSION="${VERSION:-latest}"

# ─── helpers ────────────────────────────────────────────────────────────
info()  { printf "\033[1;34m➜\033[0m %s\n" "$*" >&2; }
ok()    { printf "\033[1;32m✔\033[0m %s\n" "$*" >&2; }
err()   { printf "\033[1;31m✘\033[0m %s\n" "$*" >&2; }
header(){ printf "\n\033[1;36m━━━ %s ━━━\033[0m\n\n" "$*" >&2; }

detect_platform() {
  local os arch
  os="$(uname -s | tr '[:upper:]' '[:lower:]')"
  arch="$(uname -m)"

  case "$os" in
    linux)   os="linux" ;;
    darwin)  os="darwin" ;;
    mingw*|msys*|cygwin*) os="windows" ;;
    *)       err "Unsupported OS: $os"; exit 1 ;;
  esac

  case "$arch" in
    x86_64|amd64) arch="x64" ;;
    aarch64|arm64) arch="arm64" ;;
    *)             err "Unsupported architecture: $arch"; exit 1 ;;
  esac

  printf "%s-%s" "$os" "$arch"
}

get_latest_release() {
  if command -v curl >/dev/null 2>&1; then
    curl -fsS "https://api.github.com/repos/$REPO/releases/latest" 2>/dev/null |
      grep -o '"tag_name": *"[^"]*"' | cut -d'"' -f4 || true
  elif command -v wget >/dev/null 2>&1; then
    wget -qO- "https://api.github.com/repos/$REPO/releases/latest" 2>/dev/null |
      grep -o '"tag_name": *"[^"]*"' | cut -d'"' -f4 || true
  fi
}

download_release() {
  local tag="$1" platform="$2" url
  url="https://github.com/$REPO/releases/download/$tag/rimuru-$platform.tar.gz"

  info "Downloading Rimuru AI $tag ($platform)..."
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o /tmp/rimuru.tar.gz
  elif command -v wget >/dev/null 2>&1; then
    wget -qO /tmp/rimuru.tar.gz "$url"
  else
    err "Neither curl nor wget found. Please install one of them."
    exit 1
  fi
}

# ─── main ────────────────────────────────────────────────────────────────

header "Rimuru AI Installer"

platform="$(detect_platform)"
info "Detected platform: $platform"

# Check if the repo has any releases yet
tag="$(get_latest_release || true)"

if [ -n "$tag" ]; then
  # ── Release exists: download binary ──
  header "Downloading Release"

  download_release "$tag" "$platform"

  mkdir -p "$INSTALL_DIR"
  tar xzf /tmp/rimuru.tar.gz -C "$INSTALL_DIR"
  rm -f /tmp/rimuru.tar.gz

  BIN="$INSTALL_DIR/rimuru"
  chmod +x "$BIN"

  ok "Installed to: $BIN"
  info "Run: $BIN"
  info ""
  info "Add to your shell profile to make 'rimuru' available everywhere:"
  info "  export PATH=\"\$PATH:$INSTALL_DIR\""
else
  # ── No release yet: guide to source build ──
  header "No Pre-built Release Found"

  cat >&2 <<'SOURCE'
Rimuru AI is not yet available as a pre-built binary.
To run it from source:

  git clone https://github.com/gowdaman-dev/rimuru-ai.git
  cd rimuru-ai
  bun install
  bun run dev

Requirements:
  • Node.js 22+  (https://nodejs.org)
  • Bun 1.3+     (https://bun.sh)

Once built, you can run:
  bun run dev           # Start the TUI
  bun run dev:web       # Start the web dashboard

Stay tuned — pre-built binaries are coming soon!
SOURCE
  exit 0
fi
