{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "*": "allow",
    "external_directory": "allow"
  },

  "references": {
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
      "description": "Use for Effect v4 and effect-smol implementation details"
    },
    "athena-local": {
      "path": "~/.local/share/athena",
      "description": "Contains athena/opencode logs and data"
    },
    "athena-docs": {
      "path": "./packages/docs",
      "description": "Athena documentation site built with Astro"
    },
    "athena-core": {
      "path": "./packages/core",
      "description": "Core shared library for the Athena monorepo"
    },
    "athena-system": {
      "path": "./.athena/SYSTEM.md",
      "description": "Auto-generated comprehensive host + project + integrations context (read once at session start)"
    },
    "user-skills": {
      "path": "~/.config/opencode/skills",
      "description": "User-global skill library (Athena, backend, frontend, general, hermes, testing, explore)"
    },
    "user-config": {
      "path": "~/.config/opencode/opencode.json",
      "description": "User-global Athena/opencode config (providers, MCPs, plugins)"
    }
  },

  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "C:\\Users\\narea", "D:\\"],
      "enabled": true
    }
  },

  "tools": {
    "github-triage": true,
    "github-pr-search": true
  },

  "agent": {
    "athena-god": {
      "mode": "primary",
      "prompt": "{file:./.athena/agents/athena-god.md}",
      "temperature": 0.2,
      "permission": {
        "task": { "*": "allow" },
        "tool": { "*": "allow" }
      }
    },
    "athena": {
      "mode": "primary",
      "permission": {
        "task": { "*": "allow" },
        "tool": { "*": "allow" }
      }
    },
    "athena-max": {
      "mode": "primary",
      "permission": {
        "task": { "*": "allow" },
        "tool": { "*": "allow" }
      }
    },
    "athena-build": {
      "mode": "primary",
      "permission": {
        "task": { "*": "allow" },
        "tool": { "*": "allow" }
      }
    },
    "athena-doc": {
      "mode": "primary",
      "permission": {
        "task": { "*": "allow" },
        "tool": { "*": "allow" }
      }
    },
    "athena-codebase": {
      "mode": "primary",
      "permission": {
        "task": { "*": "allow" },
        "tool": { "*": "allow" }
      }
    }
  },

  "plugin": [
    "opencode-optimal-model-temps",
    "opencode-codebase-index",
    "opencode-helicone-session",
    "opencode-goal-plugin"
  ],

  "command": {
    "goal": {
      "description": "Set a session-scoped goal and auto-continue until complete.",
      "template": "$ARGUMENTS",
      "agent": "athena-god"
    },
    "build-package": {
      "description": "Build a specific package with turbo",
      "template": "bun turbo build --filter=$ARGUMENTS",
      "agent": "athena-god"
    },
    "typecheck": {
      "description": "Run typecheck across the project",
      "template": "bun turbo typecheck",
      "agent": "athena-god"
    },
    "lint": {
      "description": "Run linter",
      "template": "oxlint",
      "agent": "athena-god"
    },
    "system-info": {
      "description": "Print the current SYSTEM.md summary (host, runtimes, MCPs, agents).",
      "template": "cat .athena/SYSTEM.md",
      "agent": "athena-god"
    }
  }
}

