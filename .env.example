# =====================================================================
# Athena / rimuru-ai environment template
# COPY this file to `.env` and fill in real values.
# `.env` is git-ignored; this template is committed.
# =====================================================================

# --- GitHub MCP ---
# Optional. The github MCP can also use `gh` CLI auth (Windows keyring)
# when GITHUB_TOKEN is empty. Set a PAT for non-CLI / headless use.
# Scopes needed: repo, read:org, workflow
GITHUB_TOKEN=

# --- LinkedIn MCP (Local node server at linkedin-mcp-image/server.js) ---
ATHENA_LINKEDIN_CLIENT_ID=
ATHENA_LINKEDIN_CLIENT_SECRET=

# --- Gmail MCP ---
# Path to OAuth credentials JSON (NOT a token value).
# Get from: https://console.cloud.google.com/apis/credentials
# Then run the OAuth flow once to generate the token at this path.
ATHENA_GMAIL_OAUTH_PATH=

# --- Vercel MCP ---
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=

# --- Firecrawl (hosted MCP + REST API — same key for both) ---
# Get from: https://www.firecrawl.dev/app
# Used as: hosted MCP URL https://mcp.firecrawl.dev/{key}/v2/mcp
#      and: REST API "Authorization: Bearer <key>"
FIRECRAWL_API_KEY=

# --- Figma MCP (local @nexus2520/figma-mcp-server) ---
# Get from: https://www.figma.com/developers/api#access-tokens
ATHENA_FIGMA_TOKEN=

# --- Postman MCP (local @postman/postman-mcp-server) ---
# Get from: https://go.postman.co/settings/me/api-keys
ATHENA_POSTMAN_KEY=
